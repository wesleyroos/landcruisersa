---
import Base from './Base.astro';
import { SITE } from '@/data/site';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const {
  title, excerpt, publishedAt, updatedAt,
  featuredImage, featuredImageAlt,
  category, tags,
  metaTitle, metaDescription,
} = post.data;

// Sidebar: recent posts excluding current
const allPosts = await getCollection('posts', p => !p.data.draft && p.slug !== post.slug);
const recentPosts = allPosts
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 6);

const formattedDate = publishedAt.toLocaleDateString('en-ZA', {
  day: 'numeric', month: 'long', year: 'numeric',
});

const categoryLabel: Record<string, string> = {
  'useful-info': 'Useful Info',
  'partners': 'Partners',
  'gear': 'Gear',
  'routes': 'Routes',
  'builds': 'Builds',
};

const categories = ['useful-info', 'gear', 'routes', 'builds'];

// Estimated reading time (avg 220 wpm)
const wordCount = excerpt.split(' ').length * 20; // rough proxy; MDX slot text not available server-side
const readTime = Math.max(3, Math.ceil(wordCount / 220));

const canonicalUrl = `${SITE.url}/useful-info/${post.slug}/`;

// Structured data
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": metaDescription ?? excerpt,
  "image": new URL(featuredImage, SITE.url).href,
  "datePublished": publishedAt.toISOString(),
  "dateModified": (updatedAt ?? publishedAt).toISOString(),
  "author": {
    "@type": "Organization",
    "name": SITE.name,
    "url": SITE.url,
  },
  "publisher": {
    "@type": "Organization",
    "name": SITE.name,
    "logo": { "@type": "ImageObject", "url": "https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/logo-dark.png" },
  },
  "mainEntityOfPage": canonicalUrl,
  "keywords": tags?.join(', '),
  "articleSection": categoryLabel[category] ?? category,
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE.url },
    { "@type": "ListItem", "position": 2, "name": "Useful Info", "item": `${SITE.url}/useful-info/` },
    { "@type": "ListItem", "position": 3, "name": title, "item": canonicalUrl },
  ],
};

// FAQ structured data — only when the post declares Q&A pairs
const faqSchema = post.data.faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": post.data.faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
} : null;

const shareUrl = encodeURIComponent(canonicalUrl);
const shareTitle = encodeURIComponent(title);
---

<Base
  title={metaTitle ?? `${title} — ${SITE.name}`}
  description={metaDescription ?? excerpt}
  image={featuredImage}
  ogType="article"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbSchema)} />
  {faqSchema && <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />}

  <div class="bg-[#F5F3EE] min-h-screen">
    <div class="max-w-7xl mx-auto px-4 py-10 lg:py-14">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-12 items-start">

        <!-- ═══ MAIN ARTICLE ═══ -->
        <article itemscope itemtype="https://schema.org/Article">

          <!-- Breadcrumb -->
          <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-xs text-[#6B7280] mb-6 flex-wrap">
            <a href="/" class="hover:text-[#F5A623] transition-colors">Home</a>
            <span aria-hidden="true">›</span>
            <a href="/useful-info/" class="hover:text-[#F5A623] transition-colors">Useful Info</a>
            <span aria-hidden="true">›</span>
            <span class="text-[#1A1A1A] font-medium line-clamp-1">{title}</span>
          </nav>

          <!-- Category + read time -->
          <div class="flex items-center gap-3 mb-4">
            <a
              href={`/useful-info/?category=${category}`}
              class="inline-flex items-center bg-[#F5A623] text-[#111111] text-xs font-heading font-bold uppercase tracking-widest px-3 py-1 rounded-full hover:bg-[#D4881A] transition-colors"
            >
              {categoryLabel[category] ?? category}
            </a>
            <span class="text-xs text-[#6B7280]">{readTime} min read</span>
          </div>

          <!-- Title -->
          <h1
            itemprop="headline"
            class="font-heading font-bold uppercase text-4xl md:text-5xl leading-tight text-[#111111] mb-5"
          >
            {title}
          </h1>

          <!-- Meta row -->
          <div class="flex items-center gap-4 pb-6 mb-6 border-b border-[#DDD9D3]">
            <div class="flex items-center gap-2">
              <div class="w-7 h-7 rounded-full bg-[#111111] flex items-center justify-center flex-shrink-0">
                <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/logo.png" alt="" class="w-5 h-5 object-contain" aria-hidden="true" />
              </div>
              <span class="text-sm font-medium text-[#1A1A1A]">Land Cruiser SA</span>
            </div>
            <span class="text-[#DDD9D3]">·</span>
            <time
              itemprop="datePublished"
              datetime={publishedAt.toISOString()}
              class="text-sm text-[#6B7280]"
            >
              {formattedDate}
            </time>
          </div>

          <!-- Featured image -->
          <div class="rounded-2xl overflow-hidden mb-8 shadow-lg">
            <img
              itemprop="image"
              src={featuredImage}
              alt={featuredImageAlt ?? title}
              class="w-full aspect-video object-cover"
              loading="eager"
              fetchpriority="high"
            />
          </div>

          <!-- Excerpt lead -->
          <p class="text-lg text-[#4A4A4A] leading-relaxed mb-8 font-medium border-l-4 border-[#F5A623] pl-4">
            {excerpt}
          </p>

          <!-- Article content -->
          <div class="article-body" itemprop="articleBody">
            <slot />
          </div>

          <!-- Tags -->
          {tags && tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-10 pt-8 border-t border-[#DDD9D3]">
              <span class="text-xs font-bold uppercase tracking-widest text-[#6B7280] mr-2 self-center">Tags:</span>
              {tags.map(tag => (
                <span class="px-3 py-1 bg-[#EAE8E3] rounded-full text-xs text-[#4A4A4A] font-medium">{tag}</span>
              ))}
            </div>
          )}

          <!-- Share row -->
          <div class="mt-8 pt-8 border-t border-[#DDD9D3] flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <span class="text-sm font-bold uppercase tracking-widest text-[#6B7280]">Share:</span>
            <div class="flex gap-3">
              <a
                href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`}
                target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-2 bg-[#1877F2] text-white text-sm font-semibold px-4 py-2 rounded-lg hover:opacity-90 transition-opacity"
                aria-label="Share on Facebook"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                Facebook
              </a>
              <a
                href={`https://wa.me/?text=${shareTitle}%20${shareUrl}`}
                target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-2 bg-[#25D366] text-white text-sm font-semibold px-4 py-2 rounded-lg hover:opacity-90 transition-opacity"
                aria-label="Share on WhatsApp"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                WhatsApp
              </a>
            </div>
          </div>

          <!-- Training CTA -->
          <div class="mt-12 rounded-2xl overflow-hidden bg-[#111111] text-white flex flex-col md:flex-row">
            <div class="p-8 flex-1">
              <p class="text-[#F5A623] font-heading font-bold uppercase tracking-widest text-xs mb-2">4x4 Training</p>
              <h2 class="font-heading font-bold uppercase text-3xl leading-tight mb-3">
                Take it off-road. For real.
              </h2>
              <p class="text-white/70 text-sm leading-relaxed mb-6">
                Our Advanced 4x4 Driving & Recovery Course covers everything from sand, mud and water crossings to vehicle recovery and winching — in a safe, structured environment. R4,250 per person, VAT included.
              </p>
              <a
                href="/training/"
                class="inline-flex items-center gap-2 bg-[#F5A623] text-[#111111] font-heading font-bold uppercase tracking-wide px-6 py-3 rounded-xl hover:bg-[#D4881A] transition-colors text-sm"
              >
                View Course & Book
                <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
              </a>
            </div>
            <div class="hidden md:block w-56 flex-shrink-0 overflow-hidden">
              <img
                src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/training/training-bg.jpg"
                alt="4x4 training course"
                class="w-full h-full object-cover opacity-60"
                loading="lazy"
              />
            </div>
          </div>

          <!-- Related posts -->
          {recentPosts.length > 0 && (
            <div class="mt-14">
              <div class="flex items-center gap-3 mb-6">
                <span class="w-1 h-6 bg-[#F5A623] rounded flex-shrink-0"></span>
                <h2 class="font-heading font-bold uppercase text-2xl tracking-wide text-[#111111]">More Articles</h2>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                {recentPosts.slice(0, 4).map(p => (
                  <a
                    href={`/useful-info/${p.slug}/`}
                    class="group flex gap-4 bg-white rounded-xl border border-[#DDD9D3] p-4 hover:border-[#F5A623] hover:shadow-md transition-all duration-200"
                  >
                    <div class="w-20 h-20 rounded-lg overflow-hidden flex-shrink-0">
                      <img
                        src={p.data.featuredImage}
                        alt={p.data.featuredImageAlt ?? p.data.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        loading="lazy"
                      />
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-xs font-bold uppercase tracking-wider text-[#F5A623] mb-1">
                        {categoryLabel[p.data.category] ?? p.data.category}
                      </p>
                      <p class="font-heading font-bold uppercase text-sm leading-tight text-[#111111] group-hover:text-[#F5A623] transition-colors line-clamp-2">
                        {p.data.title}
                      </p>
                      <p class="text-xs text-[#6B7280] mt-1">
                        {p.data.publishedAt.toLocaleDateString('en-ZA', { day: 'numeric', month: 'short', year: 'numeric' })}
                      </p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}

        </article>

        <!-- ═══ STICKY SIDEBAR ═══ -->
        <aside class="hidden lg:block">
          <div class="sticky top-24 space-y-6">

            <!-- Recent Posts -->
            <div class="bg-white rounded-2xl border border-[#DDD9D3] overflow-hidden">
              <div class="flex items-center gap-2 px-5 py-4 border-b border-[#DDD9D3]">
                <span class="w-1 h-5 bg-[#F5A623] rounded flex-shrink-0"></span>
                <h3 class="font-heading font-bold uppercase text-sm tracking-widest text-[#111111]">Recent Posts</h3>
              </div>
              <ul class="divide-y divide-[#EAE8E3]">
                {recentPosts.map(p => (
                  <li>
                    <a
                      href={`/useful-info/${p.slug}/`}
                      class="flex gap-3 p-4 hover:bg-[#F5F3EE] transition-colors group"
                    >
                      <div class="w-14 h-14 rounded-lg overflow-hidden flex-shrink-0 bg-[#EAE8E3]">
                        <img
                          src={p.data.featuredImage}
                          alt=""
                          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                          loading="lazy"
                        />
                      </div>
                      <div class="flex-1 min-w-0">
                        <p class="text-xs font-semibold leading-snug text-[#1A1A1A] group-hover:text-[#F5A623] transition-colors line-clamp-2 mb-1">
                          {p.data.title}
                        </p>
                        <p class="text-xs text-[#6B7280]">
                          {p.data.publishedAt.toLocaleDateString('en-ZA', { day: 'numeric', month: 'short' })}
                        </p>
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
              <div class="p-4 border-t border-[#EAE8E3]">
                <a href="/useful-info/" class="text-xs font-bold uppercase tracking-widest text-[#F5A623] hover:text-[#D4881A] transition-colors">
                  All Articles →
                </a>
              </div>
            </div>

            <!-- Browse by Category -->
            <div class="bg-white rounded-2xl border border-[#DDD9D3] p-5">
              <div class="flex items-center gap-2 mb-4">
                <span class="w-1 h-5 bg-[#F5A623] rounded flex-shrink-0"></span>
                <h3 class="font-heading font-bold uppercase text-sm tracking-widest text-[#111111]">Browse by Category</h3>
              </div>
              <ul class="space-y-2">
                {categories.map(cat => (
                  <li>
                    <a
                      href={`/useful-info/?category=${cat}`}
                      class={`flex items-center justify-between px-3 py-2 rounded-lg text-sm font-medium transition-colors ${cat === category ? 'bg-[#F5A623] text-[#111111]' : 'hover:bg-[#F5F3EE] text-[#1A1A1A]'}`}
                    >
                      {categoryLabel[cat]}
                      {cat === category && <span class="text-xs">Current</span>}
                    </a>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Training CTA (compact) -->
            <div class="bg-[#111111] rounded-2xl p-5 text-white">
              <p class="text-[#F5A623] font-heading font-bold uppercase tracking-widest text-xs mb-2">4x4 Training</p>
              <p class="font-heading font-bold uppercase text-xl leading-tight mb-2">Advanced Course</p>
              <p class="text-white/60 text-xs leading-relaxed mb-4">R4,250 per person · VAT incl. · Zwartkops & De Wildt</p>
              <a
                href="/training/"
                class="block text-center bg-[#F5A623] text-[#111111] text-sm font-heading font-bold uppercase tracking-wide py-2.5 rounded-lg hover:bg-[#D4881A] transition-colors"
              >
                Book a Spot
              </a>
            </div>

            <!-- Vehicle Listings CTA -->
            <div class="bg-white rounded-2xl border border-[#DDD9D3] p-5 text-center">
              <p class="font-heading font-bold uppercase text-base text-[#111111] mb-1">Vehicle Listings</p>
              <p class="text-xs text-[#6B7280] mb-4">Land Cruiser classifieds for South Africa</p>
              <a href="/listings/" class="block w-full bg-[#F5A623] text-[#111111] text-sm font-heading font-bold uppercase tracking-wide py-2.5 rounded-lg hover:bg-[#D4881A] transition-colors mb-2">
                Browse Listings
              </a>
              <a href="/listings/submit/" class="block w-full text-sm font-medium text-[#6B7280] py-2 hover:text-[#F5A623] transition-colors">
                List Your Vehicle
              </a>
            </div>

          </div>
        </aside>

      </div>
    </div>
  </div>
</Base>
