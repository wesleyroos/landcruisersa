---
import '../styles/global.css';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import ChatWidget from '@/components/ChatWidget.astro';
import { SITE } from '@/data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  ogType?: string;
  schema?: Record<string, unknown>;
}

const {
  title = SITE.defaultMeta.title,
  description = SITE.defaultMeta.description,
  image = SITE.defaultMeta.image,
  noindex = false,
  ogType = 'website',
  schema,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, SITE.url).href;
const ogImage = new URL(image, SITE.url).href;
---

<!doctype html>
<html lang="en-ZA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/favicon.png" />
    <link rel="preconnect" href="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev" />
    <link rel="preconnect" href="https://overlandsupply.co.za" />
    <link rel="canonical" href={canonicalUrl} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={SITE.name} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Schema: Organisation -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Land Cruiser SA",
      "url": SITE.url,
      "logo": "https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/logo.png",
      "slogan": "South Africa's Land Cruiser market & price data",
      "description": "South Africa's authoritative source for Toyota Land Cruiser market data — live asking prices, supply, and mileage tracked daily across every model, aggregated from listings nationwide. Also home to SA's largest Land Cruiser community, with model guides, classifieds, and 4x4 training.",
      "knowsAbout": [
        "Toyota Land Cruiser prices in South Africa",
        "Used Land Cruiser market data",
        "Land Cruiser asking prices and supply",
        "Land Cruiser Prado pricing",
        "Land Cruiser mileage and depreciation"
      ],
      "sameAs": [SITE.socials.instagram, SITE.socials.facebook],
      "contactPoint": {
        "@type": "ContactPoint",
        "email": SITE.email,
        "contactType": "customer service"
      }
    })} />
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
    <slot name="head" />

    <!-- Plausible Analytics -->
    <script async src="https://plausible.io/js/pa-bSen3CffnpNLVOa4tRJMO.js"></script>
    <script>
      window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
      plausible.init()
    </script>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-BSFMBFSSLN"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-BSFMBFSSLN');
    </script>

    <!-- Persist UTM source for session-level attribution (e.g. link-in-bio → listing view),
         and log the campaign link click itself — once per session -->
    <script>
      try {
        const utm = new URLSearchParams(location.search).get('utm_source');
        if (utm) {
          const v = utm.toLowerCase().slice(0, 32);
          sessionStorage.setItem('lcsa_utm', v);
          if (!sessionStorage.getItem('lcsa_visit_sent')) {
            sessionStorage.setItem('lcsa_visit_sent', '1');
            navigator.sendBeacon('/api/track-visit', JSON.stringify({
              utm_source: v,
              landing_path: location.pathname,
            }));
          }
        }
      } catch {}
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <ChatWidget />
  </body>
</html>
