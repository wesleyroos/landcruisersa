---
import '../styles/global.css';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import ChatWidget from '@/components/ChatWidget.astro';
import SigninModal from '@/components/SigninModal.astro';
import { SITE } from '@/data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  ogType?: string;
  schema?: Record<string, unknown>;
}

const {
  title = SITE.defaultMeta.title,
  description = SITE.defaultMeta.description,
  image = SITE.defaultMeta.image,
  noindex = false,
  ogType = 'website',
  schema,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, SITE.url).href;
const ogImage = new URL(image, SITE.url).href;
---

<!doctype html>
<html lang="en-ZA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/favicon.png" />
    <link rel="preconnect" href="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev" />
    <link rel="preconnect" href="https://overlandsupply.co.za" />
    <link rel="canonical" href={canonicalUrl} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={SITE.name} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Schema: Organisation -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Land Cruiser SA",
      "alternateName": ["LandCruiserSA", "Landcruiser SA", "LC SA"],
      "url": SITE.url,
      "logo": "https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/logo.png",
      "slogan": "South Africa's Land Cruiser market & price data",
      "description": "South Africa's authoritative source for Toyota Land Cruiser market data — live asking prices, supply, and mileage tracked daily across every model, aggregated from listings nationwide. Also home to SA's largest Land Cruiser community, with model guides, classifieds, and 4x4 training.",
      "knowsAbout": [
        "Toyota Land Cruiser prices in South Africa",
        "Used Land Cruiser market data",
        "Land Cruiser asking prices and supply",
        "Land Cruiser Prado pricing",
        "Land Cruiser mileage and depreciation"
      ],
      "sameAs": [SITE.socials.instagram, SITE.socials.facebook],
      "contactPoint": {
        "@type": "ContactPoint",
        "email": SITE.email,
        "contactType": "customer service"
      }
    })} />
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
    <slot name="head" />

    <!-- Ahrefs Web Analytics -->
    <script src="https://analytics.ahrefs.com/analytics.js" data-key="zoDhL7MjOrrE9so8xxoSMA" async></script>

    <!-- Plausible Analytics -->
    <script async src="https://plausible.io/js/pa-bSen3CffnpNLVOa4tRJMO.js"></script>
    <script>
      window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
      plausible.init()
    </script>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-BSFMBFSSLN"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-BSFMBFSSLN');
    </script>

    <!-- Hotjar (session recordings + heatmaps). Skipped for admin sessions and
         /admin routes so our own browsing doesn't pollute recordings or burn
         the free-tier session quota. lcsa_is_admin is a JS-readable flag set at
         login (the real auth cookie is httpOnly). -->
    <script>
      try {
        var isAdmin = /(^|;\s*)lcsa_is_admin=1(;|$)/.test(document.cookie)
          || location.pathname.indexOf('/admin') === 0;
        if (!isAdmin) {
          (function(h,o,t,j,a,r){
            h.hj=h.hj||function(){(h.hj.q=h.hj.q||[]).push(arguments)};
            h._hjSettings={hjid:3686369,hjsv:6};
            a=o.getElementsByTagName('head')[0];
            r=o.createElement('script');r.async=1;
            r.src=t+h._hjSettings.hjid+j+h._hjSettings.hjsv;
            a.appendChild(r);
          })(window,document,'https://static.hotjar.com/c/hotjar-','.js?sv=');
        }
      } catch {}
    </script>

    <!-- Persist UTM source for session-level attribution (e.g. link-in-bio → listing view),
         and log the campaign link click itself — once per session -->
    <script>
      try {
        const utm = new URLSearchParams(location.search).get('utm_source');
        if (utm) {
          const v = utm.toLowerCase().slice(0, 32);
          sessionStorage.setItem('lcsa_utm', v);
          if (!sessionStorage.getItem('lcsa_visit_sent')) {
            sessionStorage.setItem('lcsa_visit_sent', '1');
            navigator.sendBeacon('/api/track-visit', JSON.stringify({
              utm_source: v,
              landing_path: location.pathname,
            }));
          }
        }
      } catch {}
    </script>

    <!-- Anonymous per-browser id (persisted). Shared across the AI-referral
         beacon, valuation tool and listing contact/finance beacons so a citation
         can be joined to a later conversion. Same key the valuation tool uses. -->
    <script>
      try {
        var c = localStorage.getItem('lcsa_vcid');
        if (!c) {
          c = (self.crypto && crypto.randomUUID) ? crypto.randomUUID()
              : (Date.now().toString(36) + Math.random().toString(36).slice(2));
          localStorage.setItem('lcsa_vcid', c);
        }
        window.__lcsaCid = c;
      } catch {}
    </script>

    <!-- LLM-citation capture: when the visit was referred by an AI assistant
         (plain link, no utm param), log the source + landing page once per
         session. Server re-classifies the host; this just pre-filters.
         NOTE: reads/creates lcsa_vcid itself — Astro emits these inline scripts
         in an order that differs from source, so window.__lcsaCid may not be
         set yet when this runs (that bug nulled client_id on every referral). -->
    <script>
      try {
        const ref = document.referrer;
        if (ref && !sessionStorage.getItem('lcsa_ref_sent')) {
          const h = new URL(ref).hostname.toLowerCase().replace(/^www\./, '');
          const isAi = /(^|\.)(chatgpt\.com|openai\.com|gemini\.google\.com|bard\.google\.com|perplexity\.ai|copilot\.microsoft\.com|claude\.ai|deepseek\.com|grok\.com|x\.ai|mistral\.ai|you\.com|poe\.com|phind\.com)$/.test(h);
          if (isAi) {
            let cid = null;
            try {
              cid = localStorage.getItem('lcsa_vcid');
              if (!cid) {
                cid = (self.crypto && crypto.randomUUID) ? crypto.randomUUID()
                    : (Date.now().toString(36) + Math.random().toString(36).slice(2));
                localStorage.setItem('lcsa_vcid', cid);
              }
            } catch {}
            sessionStorage.setItem('lcsa_ref_sent', '1');
            navigator.sendBeacon('/api/track-referral', JSON.stringify({
              referrer: ref,
              landing_path: location.pathname,
              client_id: cid,
            }));
          }
        }
      } catch {}
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <ChatWidget />
    <SigninModal />
  </body>
</html>
