---
import { NAV_LINKS } from '@/data/navigation';
import { getCurrentUser } from '@/lib/auth-user';

const user = getCurrentUser(Astro.cookies);
const accountHref = user ? '/account/' : '/signin/';
const accountLabel = user ? 'Account' : 'Sign in';
---

<header class="sticky top-0 z-50 bg-[#111111] backdrop-blur-sm border-b border-white/10">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex-shrink-0">
        <img
          src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/logo.png"
          alt="Land Cruiser SA"
          class="h-10 w-auto max-w-[220px]"
          loading="eager"
        />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {NAV_LINKS.map(link => (
          <div class="relative group">
            <a
              href={link.href}
              class="px-3 py-2 text-sm font-heading font-bold uppercase tracking-wide text-white/80 hover:text-[#F5A623] transition-colors rounded"
            >
              {link.label}
              {link.children && (
                <span class="ml-1 text-[#6B7280] text-xs">▾</span>
              )}
            </a>
            {link.children && (
              <div class="absolute top-full left-0 mt-1 w-64 bg-[#F5F3EE] border border-[#DDD9D3] rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 max-h-[80vh] overflow-y-auto">
                {link.children.map(child => (
                  child.label.startsWith('—') ? (
                    <p class="px-4 pt-3 pb-1 text-[10px] font-heading font-bold uppercase tracking-widest text-[#9CA3AF]">
                      {child.label.replace(/—/g, '').trim()}
                    </p>
                  ) : (
                    <a
                      href={child.href}
                      class="block px-4 py-2 text-sm text-[#1A1A1A] hover:text-[#F5A623] hover:bg-white first:rounded-t-lg last:rounded-b-lg transition-colors"
                    >
                      {child.label}
                    </a>
                  )
                ))}
              </div>
            )}
          </div>
        ))}
      </nav>

      <!-- CTA + Mobile toggle -->
      <div class="flex items-center gap-3">
        <a
          href={accountHref}
          class="hidden md:inline-flex items-center gap-1.5 text-sm font-heading font-bold uppercase tracking-wide text-white/80 hover:text-[#F5A623] transition-colors"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          {accountLabel}
        </a>
        <a
          href="/listings/submit/"
          class="hidden md:inline-flex items-center bg-[#F5A623] text-[#111111] text-sm font-heading font-bold uppercase tracking-wide px-4 py-2 rounded hover:bg-[#D4881A] transition-colors"
        >
          List Your Vehicle
        </a>
        <button
          id="mobile-menu-toggle"
          class="lg:hidden p-2 text-white/80 hover:text-[#F5A623]"
          aria-label="Toggle menu"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <rect y="3" width="20" height="2" rx="1"/>
            <rect y="9" width="20" height="2" rx="1"/>
            <rect y="15" width="20" height="2" rx="1"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-white/10">
    <nav class="max-w-7xl mx-auto px-4 py-4 flex flex-col gap-1">
      {NAV_LINKS.map(link => (
        link.children ? (
          <div>
            <a
              href={link.href}
              class="px-3 py-2.5 text-sm font-heading font-bold uppercase tracking-wide text-white/80 hover:text-[#F5A623] hover:bg-white/10 rounded transition-colors block"
            >
              {link.label}
            </a>
            <div class="pl-4 flex flex-col gap-0.5 mt-0.5 mb-1">
              {link.children.filter(c => !c.label.startsWith('—')).map(child => (
                <a
                  href={child.href}
                  class="px-3 py-2 text-xs font-heading font-bold uppercase tracking-wide text-white/50 hover:text-[#F5A623] hover:bg-white/10 rounded transition-colors"
                >
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class="px-3 py-2.5 text-sm font-heading font-bold uppercase tracking-wide text-white/80 hover:text-[#F5A623] hover:bg-white/10 rounded transition-colors"
          >
            {link.label}
          </a>
        )
      ))}
      <a
        href={accountHref}
        class="px-3 py-2.5 text-sm font-heading font-bold uppercase tracking-wide text-white/80 hover:text-[#F5A623] hover:bg-white/10 rounded transition-colors flex items-center gap-2"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        {accountLabel}
      </a>
      <a
        href="/listings/submit/"
        class="mt-2 text-center bg-[#F5A623] text-[#111111] text-sm font-heading font-bold uppercase tracking-wide px-4 py-2.5 rounded hover:bg-[#D4881A] transition-colors"
      >
        List Your Vehicle
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
