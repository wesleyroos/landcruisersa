---
// Floating "chat-style" enquiry widget, site-wide (rendered in Base.astro).
// Brand-orange. Posts a short form to /api/message → DB + email both addresses.
// Not real WhatsApp — a familiar chat UX for a general enquiry.
---

<div class="cw">
  <button class="cw-toggle" id="cw-toggle" aria-label="Ask a question" aria-expanded="false" aria-controls="cw-panel">
    <svg class="cw-i-chat" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
    <svg class="cw-i-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>

  <div class="cw-panel" id="cw-panel" hidden>
    <div class="cw-head">
      <span>Quick question?</span>
      <button class="cw-x" id="cw-x" aria-label="Close" type="button">&times;</button>
    </div>
    <div class="cw-body">
      <div class="cw-bubble">Hi 👋 Ask us anything about a Land Cruiser and we'll get back to you.</div>
      <form class="cw-form" id="cw-form" method="POST" action="/api/message" novalidate>
        <input class="cw-in" name="name" placeholder="Your name" maxlength="120" autocomplete="name" />
        <input class="cw-in" name="phone" placeholder="Phone / WhatsApp" maxlength="40" inputmode="tel" autocomplete="tel" />
        <input class="cw-in" name="email" type="email" placeholder="Email (optional)" maxlength="160" autocomplete="email" />
        <textarea class="cw-in" name="message" placeholder="Your message…" rows="3" maxlength="2000"></textarea>
        <div class="cw-hp" aria-hidden="true"><input name="lcsa_hp" tabindex="-1" autocomplete="off" /></div>
        <p class="cw-err" id="cw-err" hidden></p>
        <button type="submit" class="cw-send" id="cw-send">Send message</button>
      </form>
      <div class="cw-done" id="cw-done" hidden>Thanks! 🙌 We'll be in touch soon.</div>
    </div>
  </div>
</div>

<script>
  (function () {
    const toggle = document.getElementById('cw-toggle');
    const panel = document.getElementById('cw-panel');
    const form = document.getElementById('cw-form');
    if (!toggle || !panel || !form) return;
    const x = document.getElementById('cw-x');
    const err = document.getElementById('cw-err');
    const done = document.getElementById('cw-done');
    const send = document.getElementById('cw-send');

    function open() { panel.hidden = false; requestAnimationFrame(() => panel.classList.add('cw-open')); toggle.classList.add('cw-active'); toggle.setAttribute('aria-expanded', 'true'); }
    function close() { panel.classList.remove('cw-open'); toggle.classList.remove('cw-active'); toggle.setAttribute('aria-expanded', 'false'); setTimeout(() => { panel.hidden = true; }, 200); }
    toggle.addEventListener('click', () => (toggle.classList.contains('cw-active') ? close() : open()));
    if (x) x.addEventListener('click', close);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && toggle.classList.contains('cw-active')) close(); });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const f = new FormData(form);
      const payload = {
        name: (f.get('name') || '').toString().trim(),
        phone: (f.get('phone') || '').toString().trim(),
        email: (f.get('email') || '').toString().trim(),
        message: (f.get('message') || '').toString().trim(),
        lcsa_hp: (f.get('lcsa_hp') || '').toString(),
        source_path: location.pathname,
      };
      function showErr(m) { if (err) { err.textContent = m; err.hidden = false; } }
      if (!payload.name || !payload.message) return showErr('Please add your name and a message.');
      if (!payload.phone && !payload.email) return showErr('Add a phone number or email so we can reply.');
      if (err) err.hidden = true;
      send.disabled = true; const label = send.textContent; send.textContent = 'Sending…';
      try {
        const res = await fetch('/api/message', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
        const data = await res.json();
        if (!res.ok) { showErr(data.error || 'Something went wrong. Please try again.'); return; }
        form.hidden = true; if (done) done.hidden = false;
        try { window.plausible && window.plausible('enquiry_sent'); } catch {}
      } catch {
        // fetch was blocked/failed (e.g. a browser extension or network). Fall
        // back to a classic form POST, which content blockers don't intercept.
        try { form.submit(); return; } catch { showErr('Could not send. Please email wesley@landcruisersa.co.za.'); }
      }
      finally { send.disabled = false; send.textContent = label; }
    });
  })();
</script>

<style>
  .cw { position: fixed; right: 1.1rem; bottom: 1.1rem; z-index: 60; }
  .cw-toggle {
    width: 56px; height: 56px; border-radius: 50%; border: 0; cursor: pointer;
    background: #F5A623; color: #111; box-shadow: 0 6px 20px rgba(0,0,0,0.25);
    display: flex; align-items: center; justify-content: center; transition: background 0.15s, transform 0.15s;
  }
  .cw-toggle:hover { background: #D4881A; }
  .cw-toggle:active { transform: scale(0.94); }
  .cw-i-close { display: none; }
  .cw-toggle.cw-active .cw-i-chat { display: none; }
  .cw-toggle.cw-active .cw-i-close { display: block; }

  .cw-panel {
    position: absolute; right: 0; bottom: 70px; width: 330px; max-width: calc(100vw - 2.2rem);
    background: #fff; border-radius: 0.9rem; overflow: hidden;
    box-shadow: 0 12px 40px rgba(0,0,0,0.28); border: 1px solid #E6E2DB;
    opacity: 0; transform: translateY(10px); transition: opacity 0.2s, transform 0.2s;
  }
  .cw-panel.cw-open { opacity: 1; transform: translateY(0); }
  .cw-head {
    background: #111; color: #fff; padding: 0.85rem 1rem; display: flex; align-items: center; justify-content: space-between;
    font-family: var(--font-heading); font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; font-size: 0.95rem;
  }
  .cw-x { background: none; border: 0; color: rgba(255,255,255,0.7); font-size: 1.5rem; line-height: 1; cursor: pointer; padding: 0 0.2rem; }
  .cw-x:hover { color: #fff; }
  .cw-body { padding: 1rem; }
  .cw-bubble { background: #F5F3EE; border-radius: 0.6rem; padding: 0.7rem 0.85rem; font-size: 0.875rem; color: #374151; line-height: 1.5; margin-bottom: 0.85rem; }
  .cw-form { display: flex; flex-direction: column; gap: 0.55rem; }
  .cw-in { width: 100%; padding: 0.6rem 0.7rem; border: 1px solid #DDD9D3; border-radius: 0.5rem; font: inherit; font-size: 0.9rem; color: #111; }
  .cw-in:focus { outline: 2px solid #F5A623; border-color: #F5A623; }
  textarea.cw-in { resize: vertical; min-height: 64px; }
  .cw-hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
  .cw-err { color: #991B1B; font-size: 0.8rem; margin: 0; }
  .cw-send {
    margin-top: 0.15rem; background: #F5A623; color: #111; border: 0; border-radius: 0.5rem; padding: 0.7rem;
    font-family: var(--font-heading); font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; font-size: 0.9rem; cursor: pointer;
  }
  .cw-send:hover { background: #D4881A; }
  .cw-send:disabled { opacity: 0.7; cursor: wait; }
  .cw-done { padding: 0.5rem 0.2rem; font-size: 0.95rem; color: #166534; font-weight: 600; }

  @media (max-width: 420px) {
    .cw { right: 0.8rem; bottom: 0.8rem; }
    .cw-panel { bottom: 66px; }
  }
</style>
