---
// Click-to-open image gallery + lightbox for article bodies.
// Renders a thumbnail grid; clicking a thumb opens a full-screen lightbox with
// prev/next + keyboard nav. Self-contained (scoped styles + inline script per
// instance, keyed by a deterministic gallery id so multiple galleries coexist).
interface Img { src: string; alt?: string }
interface Props { images: Img[]; caption?: string }
const { images, caption } = Astro.props;
const galleryId = 'gal-' + (images[0]?.src.split('/').pop()?.replace(/[^a-z0-9]/gi, '') ?? 'x');
---

<figure class="not-prose my-8" data-gallery={galleryId}>
  <div class="pg-grid">
    {images.map((img, i) => (
      <button type="button" class="pg-thumb" data-index={i} aria-label={`Open image ${i + 1} of ${images.length}`}>
        <img src={img.src} alt={img.alt ?? ''} loading="lazy" />
        {i === 0 && images.length > 1 && (
          <span class="pg-badge">{images.length} photos · tap to view</span>
        )}
      </button>
    ))}
  </div>
  {caption && <figcaption class="pg-caption">{caption}</figcaption>}

  <div class="pg-lb" id={`${galleryId}-lb`} aria-hidden="true" role="dialog" aria-modal="true" aria-label="Image viewer">
    <button class="pg-close" type="button" aria-label="Close">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <button class="pg-arrow pg-prev" type="button" aria-label="Previous image">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <figure class="pg-stage">
      <img class="pg-lb-img" src="" alt="" />
      <figcaption class="pg-counter"></figcaption>
    </figure>
    <button class="pg-arrow pg-next" type="button" aria-label="Next image">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
  </div>
</figure>

<style>
  .pg-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
  }
  @media (min-width: 640px) {
    .pg-grid { grid-template-columns: repeat(4, 1fr); }
  }
  .pg-thumb {
    position: relative; padding: 0; border: none; cursor: pointer;
    border-radius: 0.75rem; overflow: hidden; background: #E5E2DC;
    aspect-ratio: 1 / 1; display: block;
  }
  .pg-thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; display: block; }
  .pg-thumb:hover img { transform: scale(1.05); }
  .pg-badge {
    position: absolute; bottom: 0.5rem; left: 0.5rem;
    background: rgba(0,0,0,0.65); color: #fff; backdrop-filter: blur(4px);
    font-size: 0.65rem; font-weight: 600; letter-spacing: 0.02em;
    padding: 0.3rem 0.6rem; border-radius: 9999px; pointer-events: none;
  }
  .pg-caption { margin-top: 0.75rem; font-size: 0.8rem; color: #6B7280; font-style: italic; text-align: center; }

  .pg-lb {
    position: fixed; inset: 0; z-index: 1000;
    background: rgba(0,0,0,0.94); backdrop-filter: blur(8px);
    display: flex; align-items: center; justify-content: center; gap: 0.5rem;
    opacity: 0; pointer-events: none; transition: opacity 0.2s;
  }
  .pg-lb.open { opacity: 1; pointer-events: auto; }
  .pg-stage { max-width: 88vw; max-height: 90vh; display: flex; flex-direction: column; align-items: center; gap: 0.75rem; margin: 0; }
  .pg-lb-img { max-width: 88vw; max-height: 84vh; object-fit: contain; border-radius: 0.5rem; user-select: none; }
  .pg-counter { color: rgba(255,255,255,0.6); font-size: 0.8rem; }
  .pg-close { position: absolute; top: 1rem; right: 1rem; background: rgba(255,255,255,0.12); border: none; border-radius: 9999px; width: 2.6rem; height: 2.6rem; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: background 0.15s; }
  .pg-close:hover { background: rgba(255,255,255,0.25); }
  .pg-arrow { background: rgba(255,255,255,0.12); border: none; border-radius: 9999px; width: 3rem; height: 3rem; flex-shrink: 0; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: background 0.15s; }
  .pg-arrow:hover { background: rgba(255,255,255,0.25); }
</style>

<script define:vars={{ galleryId, images }}>
  (function () {
    const root = document.querySelector(`[data-gallery="${galleryId}"]`);
    if (!root) return;
    const lb = document.getElementById(`${galleryId}-lb`);
    const lbImg = lb.querySelector('.pg-lb-img');
    const counter = lb.querySelector('.pg-counter');
    let idx = 0;

    function show(i) {
      idx = (i + images.length) % images.length;
      lbImg.src = images[idx].src;
      lbImg.alt = images[idx].alt || '';
      counter.textContent = `${idx + 1} / ${images.length}`;
    }
    function open(i) { show(i); lb.classList.add('open'); lb.setAttribute('aria-hidden', 'false'); document.body.style.overflow = 'hidden'; }
    function close() { lb.classList.remove('open'); lb.setAttribute('aria-hidden', 'true'); document.body.style.overflow = ''; }

    root.querySelectorAll('.pg-thumb').forEach((b) => b.addEventListener('click', () => open(Number(b.dataset.index))));
    lb.querySelector('.pg-close').addEventListener('click', close);
    lb.querySelector('.pg-prev').addEventListener('click', (e) => { e.stopPropagation(); show(idx - 1); });
    lb.querySelector('.pg-next').addEventListener('click', (e) => { e.stopPropagation(); show(idx + 1); });
    lb.addEventListener('click', (e) => { if (e.target === lb || e.target.classList.contains('pg-stage')) close(); });
    document.addEventListener('keydown', (e) => {
      if (!lb.classList.contains('open')) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') show(idx - 1);
      else if (e.key === 'ArrowRight') show(idx + 1);
    });
  })();
</script>
