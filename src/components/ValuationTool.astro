---
import { LC_MODEL_SLUGS, MODEL_YEAR_RANGE, modelLabel } from '@/lib/sources/normalize';
import { SPEC_OPTIONS } from '@/lib/spec';
import { getSpecYearRanges } from '@/lib/spec-years';

interface Props {
  model?: string;     // preselect a model (per-model pages)
  heading?: string;
}
const { model = '', heading = "What's your Land Cruiser worth?" } = Astro.props;

// Body-style / era hints so the 70-family and Prado/FJ pairs are unambiguous.
const HINTS: Record<string, string> = {
  '76-series': 'Station Wagon', '78-series': 'Troopcarrier', '79-series': 'Pickup / Bakkie', '100-series': 'incl. 105',
  'prado-90': '1996–2002', 'prado-120': '2003–2009', 'prado-150': '2009–2024', 'prado-250': '2024 on', 'fj-cruiser': '2011–2023', 'land-cruiser-fj': '2026 on',
};
const MODELS = LC_MODEL_SLUGS.map(s => ({ slug: s, label: modelLabel(s) + (HINTS[s] ? ` — ${HINTS[s]}` : '') }));
const PROVINCES = ['Gauteng', 'Western Cape', 'KwaZulu-Natal', 'Eastern Cape', 'Limpopo', 'Mpumalanga', 'North West', 'Free State', 'Northern Cape'];
const CONDITIONS = [
  { v: 'excellent', l: 'Showroom' },
  { v: 'good', l: 'Good' },
  { v: 'fair', l: 'Average' },
  { v: 'rough', l: 'Needs work' },
];
const years: number[] = [];
for (let y = new Date().getFullYear(); y >= 1990; y--) years.push(y);
const yearRangesJson = JSON.stringify(MODEL_YEAR_RANGE);

// Client-safe spec map (value+label only — the RegExp matchers stay server-side).
const specPicker = Object.fromEntries(
  Object.entries(SPEC_OPTIONS).map(([m, axes]) => [
    m, Object.fromEntries(Object.entries(axes).map(([ax, opts]) => [ax, opts!.map(o => ({ value: o.value, label: o.label }))])),
  ]),
);
const specPickerJson = JSON.stringify(specPicker);
const specYearsJson = JSON.stringify(getSpecYearRanges());
---

<div class="vt" data-preset-model={model} data-year-ranges={yearRangesJson} data-spec={specPickerJson} data-spec-years={specYearsJson}>
  <form class="vt-form" id="vt-form" method="POST" action="/valuation/" novalidate>
    <h2 class="vt-h">{heading}</h2>

    <div class="vt-grid">
      <label class="vt-field">
        <span>Model</span>
        <select name="model" required>
          <option value="" disabled selected={!model}>Choose model…</option>
          {MODELS.map(m => <option value={m.slug} selected={m.slug === model}>{m.label}</option>)}
        </select>
      </label>

      <label class="vt-field">
        <span>Year</span>
        <select name="year" required>
          <option value="" disabled selected>Year…</option>
          {years.map(y => <option value={y}>{y}</option>)}
        </select>
      </label>

      <label class="vt-field">
        <span>Mileage (km)</span>
        <input type="number" name="mileage" min="0" max="600000" step="1000" inputmode="numeric" placeholder="e.g. 120000" required />
      </label>

      <label class="vt-field">
        <span>Province <em>(optional)</em></span>
        <select name="province">
          <option value="">Anywhere in SA</option>
          {PROVINCES.map(p => <option value={p}>{p}</option>)}
        </select>
      </label>
    </div>

    <div class="vt-spec" id="vt-spec"></div>

    <fieldset class="vt-cond">
      <legend>Condition</legend>
      <div class="vt-pills" role="radiogroup" aria-label="Condition">
        {CONDITIONS.map((c, i) => (
          <label class="vt-pill">
            <input type="radio" name="condition" value={c.v} checked={i === 1} />
            <span>{c.l}</span>
          </label>
        ))}
      </div>
    </fieldset>

    {/* honeypot — visually hidden, off the tab order */}
    <div class="vt-hp" aria-hidden="true">
      <label>Leave this empty<input type="text" name="lcsa_hp" tabindex="-1" autocomplete="off" /></label>
    </div>

    <button type="submit" class="vt-submit">SEE MY ESTIMATE →</button>
    <p class="vt-mini">Free · instant · no sign-up. Estimates from live market asking prices.</p>
  </form>

  <div id="vt-result" class="vt-result" aria-live="polite" hidden></div>
</div>

<script>
  document.querySelectorAll('.vt').forEach(function (root) {
    const form = root.querySelector('#vt-form');
    const out = root.querySelector('#vt-result');
    if (!form || !out) return;

    // Constrain the year dropdown to the selected model's production years, so
    // you can't value a 2015 Prado 250 (launched 2024) or a pre-2026 FJ.
    const yearRanges = (() => { try { return JSON.parse(root.dataset.yearRanges || '{}'); } catch { return {}; } })();
    const specMap = (() => { try { return JSON.parse(root.dataset.spec || '{}'); } catch { return {}; } })();
    const specYears = (() => { try { return JSON.parse(root.dataset.specYears || '{}'); } catch { return {}; } })();
    const mSel = form.querySelector('select[name="model"]');
    const ySel = form.querySelector('select[name="year"]');
    const specBox = root.querySelector('#vt-spec');
    const NOW = new Date().getFullYear();
    const AXIS_LABEL = { grade: 'Variant', engine: 'Engine', body: 'Body' };
    const AXIS_ORDER = ['grade', 'engine', 'body'];

    function rebuildYears() {
      if (!ySel) return;
      const r = yearRanges[mSel.value];
      const lo = r ? r[0] : 1990;
      const hi = r ? Math.min(r[1], NOW + 1) : NOW;
      const cur = ySel.value;
      let html = '<option value="" disabled' + (cur ? '' : ' selected') + '>Year…</option>';
      for (let y = hi; y >= lo; y--) html += '<option value="' + y + '"' + (String(y) === cur ? ' selected' : '') + '>' + y + '</option>';
      ySel.innerHTML = html;
    }

    function rebuildSpec() {
      if (!specBox) return;
      // preserve current selections across a rebuild
      const cur = {};
      specBox.querySelectorAll('select[data-axis]').forEach(s => { cur[s.dataset.axis] = s.value; });
      const axes = specMap[mSel.value] || {};
      const keys = AXIS_ORDER.filter(a => axes[a]);
      const yr = ySel ? parseInt(ySel.value, 10) : NaN;
      const ranges = specYears[mSel.value] || {};
      specBox.innerHTML = keys.map(a => {
        // data-driven year-gate: once a year is chosen, only show spec values
        // observed in that year's listings (a 2.8 GD-6 79 won't show for 2009).
        let opts = axes[a];
        if (yr) opts = opts.filter(o => { const r = ranges[a] && ranges[a][o.value]; return r && yr >= r[0] && yr <= r[1]; });
        const prev = cur[a] || '';
        const keep = opts.some(o => o.value === prev);
        const optHtml = ['<option value="">Any / not sure</option>']
          .concat(opts.map(o => '<option value="' + o.value + '"' + (o.value === prev && keep ? ' selected' : '') + '>' + o.label + '</option>')).join('');
        return '<label class="vt-field"><span>' + AXIS_LABEL[a] + '</span><select data-axis="' + a + '">' + optHtml + '</select></label>';
      }).join('');
    }

    function onModelChange() { rebuildYears(); rebuildSpec(); }
    if (mSel) {
      mSel.addEventListener('change', onModelChange);
      if (mSel.value) onModelChange(); // preset model on per-model pages
    }
    if (ySel) ySel.addEventListener('change', rebuildSpec); // spec availability depends on year

    const R = (n) => 'R' + Math.round(Number(n)).toLocaleString('en-ZA');
    const esc = (s) => String(s).replace(/[&<>]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]));
    const utm = (() => { try { return sessionStorage.getItem('lcsa_utm') || ''; } catch { return ''; } })();

    function track(name) { try { window.plausible && window.plausible(name); } catch {} }

    // ── Valuation feedback (calibration signal → DB + email) ──
    let lastResult = null, lastVerdict = '';
    // email=true only on the final "Send" (with detail). The bare verdict click
    // still records to DB + Plausible, but stays silent — no duplicate email.
    function sendFeedback(verdict, note, userEstimate, email) {
      if (!lastResult) return;
      track('valuation_feedback_' + verdict);
      try {
        fetch('/api/valuation-feedback', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ...lastResult, verdict, note: note || '', userEstimate: userEstimate || null, email: email === true, lcsa_hp: '', source_path: location.pathname }),
        });
      } catch {}
    }
    out.addEventListener('click', function (ev) {
      const box = out.querySelector('[data-fb-box]');
      if (!box) return;
      const vb = ev.target.closest('[data-v]');
      if (vb) {
        lastVerdict = vb.getAttribute('data-v');
        sendFeedback(lastVerdict, '', null);
        box.innerHTML = '<span class="vr-fb-q">Thanks 🙏 — anything we couldn’t see?</span>'
          + '<input class="vr-fb-in" data-fb-est type="number" inputmode="numeric" placeholder="What it\x27s really worth (R)">'
          + '<textarea class="vr-fb-note" data-fb-note rows="2" placeholder="Extras, service history, why it\x27s off…"></textarea>'
          + '<button type="button" class="vr-fb-send" data-fb-send>Send</button>';
        return;
      }
      if (ev.target.closest('[data-fb-send]')) {
        const est = box.querySelector('[data-fb-est]');
        const note = box.querySelector('[data-fb-note]');
        const nv = note ? note.value.trim() : '', ev2 = est ? est.value.trim() : '';
        if (nv || ev2) sendFeedback(lastVerdict, nv, ev2 || null, true);
        box.innerHTML = '<span class="vr-fb-q">Thanks — noted. 🙏</span>';
      }
    });

    function confBadge(c) {
      const map = { high: ['High confidence', '#34D399'], medium: ['Good estimate', '#FBBF24'], low: ['Rough estimate', '#FB923C'], none: ['Not enough data', '#9CA3AF'] };
      const [label, col] = map[c] || map.none;
      return `<span class="vr-conf" style="color:${col}"><span class="vr-dotc" style="background:${col}"></span>${label}</span>`;
    }

    function renderEstimate(d) {
      const e = d.estimate, c = d.cohort;
      const reasons = (e.confidenceReasons || []).map(r => `<li>${esc(r)}</li>`).join('');
      return `
        <div class="vr">
          ${confBadge(e.confidence)}
          <p class="vr-q">${esc(d.vehicle)} — list it for around</p>
          <p class="vr-hero">${R(e.askingCeiling)}</p>
          <div class="vr-range">
            <span class="vr-end">${R(e.sellLow)}</span>
            <span class="vr-track"><span class="vr-pin"></span></span>
            <span class="vr-end">${R(e.sellHigh)}</span>
          </div>
          <p class="vr-ask">Likely sells for about <strong>${R(e.sellMid)}</strong></p>
          <a class="vr-btn" href="/listings/submit/">List my ${esc(d.modelText)} — free →</a>
          <details class="vr-more">
            <summary>How we got this</summary>
            <div>
              <p>Based on <strong>${c.size}</strong> comparable ${esc(c.label)} for sale now — most ask <strong>${R(c.p25)}–${R(c.p75)}</strong> (median ${R(c.medianPrice)}). We estimate what one like yours actually sells for.</p>
              ${reasons ? `<ul>${reasons}</ul>` : ''}
              <a class="vr-link" href="/market/${esc(d.model)}/">See the live ${esc(d.modelText)} market →</a>
              <p class="vr-disc">${esc(d.caveat)}</p>
            </div>
          </details>
          <div class="vr-fb" data-fb-box>
            <span class="vr-fb-q">Is this accurate?</span>
            <span class="vr-fb-btns">
              <button type="button" class="vr-fb-b" data-v="spot_on">Spot on</button>
              <button type="button" class="vr-fb-b" data-v="too_low">Too low</button>
              <button type="button" class="vr-fb-b" data-v="too_high">Too high</button>
            </span>
          </div>
        </div>`;
    }

    function renderNone(d) {
      return `
        <div class="vr vr-none">
          <p class="vr-q">${esc(d.vehicle || 'This Land Cruiser')}</p>
          <p class="vr-none-h">We need a few more like yours</p>
          <p class="vr-none-t">${esc(d.caveat)}</p>
          <a class="vr-btn" href="/contact/">Get a manual valuation →</a>
        </div>`;
    }

    function renderError(msg) {
      out.innerHTML = `<div class="vr vr-err"><p>${esc(msg)}</p></div>`;
    }

    form.addEventListener('submit', async (ev) => {
      ev.preventDefault();
      const fd = new FormData(form);
      const modelSel = form.querySelector('select[name="model"]');
      const modelText = (modelSel && modelSel.selectedOptions[0] && modelSel.value)
        ? modelSel.selectedOptions[0].textContent.trim().split(' — ')[0] : 'Land Cruiser';
      const spec = { engine: '', grade: '', body: '' };
      root.querySelectorAll('#vt-spec select[data-axis]').forEach(s => { spec[s.dataset.axis] = s.value || ''; });
      const payload = {
        model: fd.get('model') || '',
        year: Number(fd.get('year')),
        mileage: Number(fd.get('mileage')),
        condition: fd.get('condition') || 'good',
        province: fd.get('province') || '',
        engine: spec.engine, grade: spec.grade, body: spec.body,
        lcsa_hp: fd.get('lcsa_hp') || '',
        utm_source: utm,
        source_path: location.pathname,
      };
      if (!payload.model || !payload.year || !(payload.mileage >= 0)) {
        renderError('Please pick a model, year and mileage.');
        out.hidden = false;
        return;
      }
      const btn = form.querySelector('.vt-submit');
      const label = btn.textContent;
      btn.disabled = true; btn.textContent = 'CRUNCHING THE MARKET…';
      out.hidden = false;
      out.innerHTML = '<div class="vr vr-load"><div></div><div></div></div>';
      track('valuation_computed');
      try {
        const res = await fetch('/api/valuation', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload),
        });
        const data = await res.json();
        if (!res.ok) { renderError(data.error || 'Something went wrong. Please try again.'); return; }
        data.model = payload.model;
        data.modelText = modelText;
        data.vehicle = 'Your ' + payload.year + ' ' + modelText;
        out.innerHTML = data.estimate ? renderEstimate(data) : renderNone(data);
        if (data.estimate) {
          lastResult = { draftId: data.draftId, model: payload.model, year: payload.year, mileage: payload.mileage,
            spec: (data.cohort && data.cohort.label) || payload.model, estimateMid: data.estimate.sellMid };
        }
        out.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        const h = out.querySelector('.vr-q'); if (h) { h.setAttribute('tabindex', '-1'); h.focus(); }
      } catch {
        renderError('Network error. Please try again.');
      } finally {
        btn.disabled = false; btn.textContent = label;
      }
    });
  });
</script>

<style>
  .vt { background: #fff; border: 1px solid #DDD9D3; border-radius: 0.875rem; padding: 1.75rem 1.5rem; box-shadow: 0 2px 12px rgba(0,0,0,0.05); }
  .vt-h { font-family: var(--font-heading); font-weight: 700; text-transform: uppercase; font-size: clamp(1.25rem, 3vw, 1.6rem); color: #111; line-height: 1.05; margin-bottom: 1.25rem; }
  .vt-grid { display: grid; grid-template-columns: 1fr; gap: 0.875rem; }
  @media (min-width: 560px) { .vt-grid { grid-template-columns: 1fr 1fr; } }
  .vt-spec { display: grid; grid-template-columns: 1fr; gap: 0.875rem; margin-top: 0.875rem; }
  @media (min-width: 560px) { .vt-spec { grid-template-columns: 1fr 1fr; } }
  .vt-spec:empty { display: none; }
  .vt-field { display: flex; flex-direction: column; gap: 0.35rem; }
  .vt-field > span { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #6B7280; }
  .vt-field em { font-style: normal; color: #9CA3AF; font-weight: 600; }
  .vt-field select, .vt-field input { width: 100%; padding: 0.7rem 0.75rem; border: 1px solid #DDD9D3; border-radius: 0.5rem; font: inherit; font-size: 0.95rem; color: #111; background: #fff; }
  .vt-field select:focus, .vt-field input:focus { outline: 2px solid #F5A623; border-color: #F5A623; }

  .vt-cond { border: 0; padding: 0; margin: 1.1rem 0 0.25rem; }
  .vt-cond legend { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #6B7280; margin-bottom: 0.45rem; }
  .vt-pills { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .vt-pill { position: relative; }
  .vt-pill input { position: absolute; opacity: 0; inset: 0; cursor: pointer; }
  .vt-pill span { display: inline-block; padding: 0.5rem 0.9rem; border: 1px solid #DDD9D3; border-radius: 999px; font-size: 0.85rem; font-weight: 600; color: #374151; cursor: pointer; transition: all 0.12s; }
  .vt-pill input:checked + span { background: #111; color: #fff; border-color: #111; }
  .vt-pill input:focus-visible + span { outline: 2px solid #F5A623; }

  .vt-hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }

  .vt-submit { margin-top: 1.25rem; width: 100%; padding: 0.95rem; background: #F5A623; color: #111; font-family: var(--font-heading); font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; font-size: 1rem; border: 0; border-radius: 0.5rem; cursor: pointer; transition: background 0.15s; }
  .vt-submit:hover { background: #D4881A; }
  .vt-submit:disabled { opacity: 0.7; cursor: wait; }
  .vt-mini { margin-top: 0.6rem; font-size: 0.72rem; color: #9CA3AF; text-align: center; }

  .vt-result { margin-top: 1.25rem; }
</style>

<!-- The result card is injected via client JS (innerHTML), so Astro's scoped
     styles won't attach to it — these must be global. Namespaced under .vt. -->
<style is:global>
  /* Result = a dark hero card: big number first, everything else quiet/collapsed */
  .vt .vr { background: #111; border-radius: 0.875rem; padding: 1.75rem 1.5rem; color: #fff; text-align: center; }
  .vt .vr-conf { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 0.28rem 0.7rem; border-radius: 999px; background: rgba(255,255,255,0.08); margin-bottom: 0.9rem; }
  .vt .vr-dotc { width: 7px; height: 7px; border-radius: 50%; display: inline-block; }
  .vt .vr-q { font-size: 0.85rem; color: rgba(255,255,255,0.6); outline: none; }
  .vt .vr-hero { font-family: var(--font-heading); font-weight: 700; font-size: clamp(2.5rem, 11vw, 3.75rem); color: #F5A623; line-height: 1; margin: 0.3rem 0 0.1rem; }
  .vt .vr-range { display: flex; align-items: center; gap: 0.7rem; max-width: 360px; margin: 1.15rem auto 0; }
  .vt .vr-end { font-size: 0.78rem; font-weight: 600; color: rgba(255,255,255,0.55); white-space: nowrap; }
  .vt .vr-track { position: relative; flex: 1; height: 5px; border-radius: 999px; background: linear-gradient(90deg, rgba(245,166,35,0.25), #F5A623, rgba(245,166,35,0.25)); }
  .vt .vr-pin { position: absolute; left: 50%; top: 50%; transform: translate(-50%,-50%); width: 13px; height: 13px; border-radius: 50%; background: #fff; border: 3px solid #F5A623; }
  .vt .vr-ask { font-size: 0.85rem; color: rgba(255,255,255,0.7); margin-top: 1.15rem; }
  .vt .vr-ask strong { color: #fff; }
  .vt .vr-btn { display: inline-block; margin-top: 1.3rem; background: #F5A623; color: #111; font-family: var(--font-heading); font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; font-size: 0.9rem; padding: 0.8rem 1.5rem; border-radius: 0.5rem; text-decoration: none; }
  .vt .vr-btn:hover { background: #D4881A; }

  .vt .vr-more { margin-top: 1.2rem; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 0.9rem; text-align: left; font-size: 0.8rem; color: rgba(255,255,255,0.6); }
  .vt .vr-more summary { cursor: pointer; font-weight: 600; color: rgba(255,255,255,0.75); text-align: center; list-style: none; }
  .vt .vr-more summary::-webkit-details-marker { display: none; }
  .vt .vr-more summary::after { content: ' ▾'; }
  .vt .vr-more[open] summary::after { content: ' ▴'; }
  .vt .vr-more > div { margin-top: 0.85rem; line-height: 1.65; }
  .vt .vr-more strong { color: #fff; }
  .vt .vr-more ul { margin: 0.6rem 0 0 1.1rem; }
  .vt .vr-more li { margin-bottom: 0.25rem; }
  .vt .vr-link { display: inline-block; margin-top: 0.75rem; color: #F5A623; text-decoration: none; font-weight: 600; }
  .vt .vr-link:hover { text-decoration: underline; }
  .vt .vr-disc { margin-top: 0.85rem; font-size: 0.68rem; color: rgba(255,255,255,0.4); line-height: 1.5; }

  .vt .vr-fb { margin-top: 1.1rem; padding-top: 0.9rem; border-top: 1px solid rgba(255,255,255,0.1); display: flex; flex-wrap: wrap; align-items: center; gap: 0.55rem; }
  .vt .vr-fb-q { font-size: 0.78rem; color: rgba(255,255,255,0.55); }
  .vt .vr-fb-btns { display: inline-flex; gap: 0.4rem; flex-wrap: wrap; }
  .vt .vr-fb-b { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.85); border: 1px solid rgba(255,255,255,0.15); border-radius: 999px; padding: 0.3rem 0.8rem; font-size: 0.78rem; font-weight: 600; cursor: pointer; transition: all 0.12s; }
  .vt .vr-fb-b:hover { background: #F5A623; color: #111; border-color: #F5A623; }
  .vt .vr-fb-in, .vt .vr-fb-note { width: 100%; padding: 0.5rem 0.65rem; border-radius: 0.4rem; border: 1px solid rgba(255,255,255,0.18); background: rgba(255,255,255,0.06); color: #fff; font: inherit; font-size: 0.85rem; }
  .vt .vr-fb-in::placeholder, .vt .vr-fb-note::placeholder { color: rgba(255,255,255,0.4); }
  .vt .vr-fb-send { background: #F5A623; color: #111; border: 0; border-radius: 0.4rem; padding: 0.45rem 1rem; font-weight: 700; font-size: 0.8rem; cursor: pointer; }
  .vt .vr-fb-send:hover { background: #D4881A; }

  .vt .vr-none-h { font-family: var(--font-heading); font-weight: 700; text-transform: uppercase; font-size: 1.35rem; color: #fff; margin-top: 0.3rem; }
  .vt .vr-none-t { font-size: 0.85rem; color: rgba(255,255,255,0.6); margin: 0.55rem auto 0; max-width: 360px; line-height: 1.6; }
  .vt .vr-err { background: #7F1D1D; }
  .vt .vr-err p { font-size: 0.9rem; }

  .vt .vr-load { min-height: 130px; }
  .vt .vr-load div { height: 1.4rem; background: rgba(255,255,255,0.12); border-radius: 0.4rem; margin: 0 auto 0.7rem; animation: vtpulse 1.2s ease-in-out infinite; }
  .vt .vr-load div:first-child { height: 3rem; width: 55%; }
  .vt .vr-load div:last-child { width: 75%; }
  @keyframes vtpulse { 50% { opacity: 0.45; } }
</style>
