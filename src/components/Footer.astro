---
import { SITE } from '@/data/site';
---

<footer class="bg-[#111111] text-white mt-20">
  <div class="h-1 bg-[#F5A623]"></div>
  <div class="max-w-7xl mx-auto px-4 py-14">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">

      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/">
          <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/logo.png" alt="Land Cruiser SA" class="h-12 w-auto mb-4" />
        </a>
        <p class="text-sm text-white/50 leading-relaxed">
          South Africa's Land Cruiser listing aggregator — every Cruiser for sale in one place, with asking prices, supply and mileage tracked daily. The authoritative source for Land Cruiser market data, backed by SA's largest Land Cruiser community.
        </p>
        <div class="flex gap-3 mt-5">
          <a href={SITE.socials.instagram} target="_blank" rel="noopener"
            class="text-white/40 hover:text-[#F5A623] transition-colors" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href={SITE.socials.facebook} target="_blank" rel="noopener"
            class="text-white/40 hover:text-[#F5A623] transition-colors" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="font-heading font-bold uppercase text-xs tracking-widest text-white/40 mb-4">Explore</h3>
        <ul class="space-y-2 text-sm">
          {[
            ['Market Data & Prices', '/market/'],
            ['Vehicle Listings', '/listings/'],
            ['LC Model Guides', '/models/'],
            ['Useful Info', '/useful-info/'],
            ['4x4 Training', '/training/'],
            ['Store', '/store/'],
            ['Gallery', '/gallery/'],
          ].map(([label, href]) => (
            <li><a href={href} class="text-white/60 hover:text-[#F5A623] transition-colors">{label}</a></li>
          ))}
        </ul>
      </div>

      <!-- About -->
      <div>
        <h3 class="font-heading font-bold uppercase text-xs tracking-widest text-white/40 mb-4">About</h3>
        <ul class="space-y-2 text-sm">
          {[
            ['About Us', '/about/'],
            ['Partners', '/partners/'],
            ['Advertise With Us', '/advertise-with-us/'],
            ['Contact', '/contact/'],
            ['Privacy Policy', '/privacy-policy/'],
            ['Terms & Conditions', '/terms/'],
            ['Refunds & Returns', '/refunds/'],
          ].map(([label, href]) => (
            <li><a href={href} class="text-white/60 hover:text-[#F5A623] transition-colors">{label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Market CTA -->
      <div>
        <h3 class="font-heading font-bold uppercase text-xs tracking-widest text-white/40 mb-4">Live Market Data</h3>
        <p class="text-sm text-white/60 mb-4 leading-relaxed">
          Every Land Cruiser for sale in South Africa, aggregated and tracked daily — asking prices, supply and price drops.
        </p>
        <a
          href="/market/"
          class="inline-block bg-[#F5A623] text-[#111111] text-sm font-heading font-bold uppercase tracking-wide px-5 py-2.5 rounded hover:bg-[#D4881A] transition-colors"
        >
          Browse the Market
        </a>
      </div>

    </div>

    <div class="border-t border-white/10 mt-10 pt-6 flex flex-col md:flex-row justify-between items-center gap-3 text-xs text-white/30">
      <p>© {new Date().getFullYear()} Land Cruiser SA. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <a href="/admin/login" class="hover:text-[#F5A623] transition-colors">Admin</a>
        <p>Built by <a href="https://grodigital.co.za" class="hover:text-[#F5A623] transition-colors">Gro Digital</a></p>
      </div>
    </div>
  </div>
</footer>
