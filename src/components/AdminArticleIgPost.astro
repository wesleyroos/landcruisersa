---
// Article → Instagram posting kit (parallel to AdminIgPost, keyed by slug).
// Reuses the global .igp-* styles already emitted by AdminIgPost on the same
// page, so this only ships its own DOM (with aigp-* ids) and script.
//
// Usage: render once alongside <AdminIgPost />, then add buttons:
//   <button data-action="post-article" data-slug={post.slug}>Post to IG</button>
// Optional: an element with data-ig-article-slot={slug} gets a "✓ Posted" note.
---

<!-- ARTICLE CAPTION PREVIEW MODAL -->
<div id="aigp-modal" class="igp-backdrop" hidden>
  <div class="igp-modal">
    <p class="igp-title">Article Caption Preview</p>
    <p id="aigp-meta" class="igp-meta"></p>
    <textarea id="aigp-caption" class="igp-caption" rows="14" spellcheck="false"></textarea>
    <div class="igp-actions">
      <button id="aigp-cancel"    class="igp-btn igp-btn-outline">Cancel</button>
      <button id="aigp-rehashtag" class="igp-btn igp-btn-outline" style="margin-right:auto">↺ New hashtags</button>
      <button id="aigp-confirm"   class="igp-btn igp-btn-dark">Post Now</button>
    </div>
  </div>
</div>

<!-- TOAST (own element so it doesn't clash with the listings kit) -->
<div id="aigp-toast" class="igp-toast" hidden></div>

<script>
  let pendingSlug: string | null = null;

  const modal          = document.getElementById('aigp-modal')!;
  const modalCaption   = document.getElementById('aigp-caption') as HTMLTextAreaElement;
  const modalMeta      = document.getElementById('aigp-meta')!;
  const modalCancel    = document.getElementById('aigp-cancel')!;
  const modalRehashtag = document.getElementById('aigp-rehashtag') as HTMLButtonElement;
  const modalConfirm   = document.getElementById('aigp-confirm') as HTMLButtonElement;
  const toast          = document.getElementById('aigp-toast')!;

  const CTA_MARKER = '📖 Read the full guide — link in bio';
  const ENDPOINT   = '/api/admin/instagram/post-article';

  function showToast(msg: string, type: 'ok' | 'err') {
    toast.textContent = msg;
    toast.className = `igp-toast igp-toast-${type}`;
    toast.hidden = false;
    setTimeout(() => { toast.hidden = true; }, 3500);
  }

  modalCancel.addEventListener('click', () => { modal.hidden = true; pendingSlug = null; });
  modal.addEventListener('click', (e) => { if (e.target === modal) { modal.hidden = true; pendingSlug = null; } });

  // Delegated — any [data-action="post-article"] button on the page opens the modal
  document.addEventListener('click', async (e) => {
    const btn = (e.target as Element).closest<HTMLButtonElement>('[data-action="post-article"]');
    if (!btn) return;
    await openPreview(btn.dataset.slug!, btn);
  });

  async function openPreview(slug: string, btn: HTMLButtonElement) {
    const originalLabel = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Generating…';
    modalCaption.value = 'Generating caption with AI…';
    modalCaption.disabled = true;
    modalConfirm.disabled = true;
    modalMeta.textContent = '';
    pendingSlug = slug;
    modal.hidden = false;
    try {
      const res = await fetch(ENDPOINT, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug, previewOnly: true }),
      });
      const data = await res.json();
      if (!res.ok) {
        modal.hidden = true;
        pendingSlug = null;
        showToast(data.error ?? 'Failed to load preview', 'err');
        return;
      }
      modalCaption.value    = data.caption;
      modalCaption.disabled = false;
      modalConfirm.disabled = false;
      modalMeta.textContent = 'Featured image will be posted as a single image';
    } finally {
      btn.disabled = false;
      btn.textContent = originalLabel;
    }
  }

  // Regenerate hashtags — keep the body the user may have edited, swap only tags
  modalRehashtag.addEventListener('click', async () => {
    if (!pendingSlug) return;
    modalRehashtag.disabled = true;
    modalRehashtag.textContent = '…';
    let success = false;
    try {
      const res = await fetch(ENDPOINT, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug: pendingSlug, previewOnly: true }),
      });
      const data = await res.json();
      if (!res.ok) { showToast(data.error ?? 'Failed to regenerate', 'err'); return; }

      const ctaIdx = data.caption.indexOf(CTA_MARKER);
      const newHashtags = ctaIdx !== -1 ? data.caption.slice(ctaIdx + CTA_MARKER.length).trimStart() : '';

      const current = modalCaption.value;
      const bodyEnd = current.indexOf(CTA_MARKER);
      if (bodyEnd !== -1) {
        modalCaption.value = current.slice(0, bodyEnd + CTA_MARKER.length) + (newHashtags ? '\n\n' + newHashtags : '');
      } else {
        modalCaption.value = current.trimEnd() + '\n\n' + newHashtags;
      }
      success = true;
    } finally {
      modalRehashtag.disabled = false;
      modalRehashtag.textContent = success ? '✓ Updated!' : '↺ New hashtags';
      if (success) setTimeout(() => { modalRehashtag.textContent = '↺ New hashtags'; }, 1500);
    }
  });

  modalConfirm.addEventListener('click', async () => {
    if (!pendingSlug) return;
    const slug = pendingSlug;
    const caption = modalCaption.value;
    modal.hidden = true;
    pendingSlug = null;
    const btn = document.querySelector<HTMLButtonElement>(`[data-action="post-article"][data-slug="${slug}"]`);
    await doPost(slug, btn, caption);
  });

  function markPosted(slug: string, btn: HTMLButtonElement | null) {
    const slot = document.querySelector(`[data-ig-article-slot="${slug}"]`);
    if (slot) {
      const today = new Intl.DateTimeFormat('en-ZA', { day: 'numeric', month: 'short', year: 'numeric' }).format(new Date());
      // Update the existing note (repost) or create it (first post)
      let note = slot.querySelector('.ig-posted-note');
      if (!note) { note = document.createElement('p'); note.className = 'ig-posted-note'; slot.appendChild(note); }
      note.textContent = `✓ Posted to IG ${today}`;
    }
    if (btn) { btn.classList.remove('btn-post'); btn.classList.add('btn-repost'); btn.textContent = 'Repost'; btn.disabled = false; }
  }

  async function pollPosted(slug: string, btn: HTMLButtonElement | null, deadline: number) {
    if (Date.now() > deadline) {
      showToast('Post timed out — check Instagram to confirm', 'err');
      if (btn) { btn.disabled = false; btn.textContent = btn.classList.contains('btn-repost') ? 'Repost' : 'Post to IG'; }
      return;
    }
    const res = await fetch(`/api/admin/instagram/article-status?slug=${encodeURIComponent(slug)}`).catch(() => null);
    if (res?.ok) {
      const data = await res.json();
      if (data.posted) { showToast('Article posted to Instagram!', 'ok'); markPosted(slug, btn); return; }
      if (data.failed) {
        showToast(`Post failed: ${data.error ?? 'check Instagram'}`, 'err');
        if (btn) { btn.disabled = false; btn.textContent = btn.classList.contains('btn-repost') ? 'Repost' : 'Post to IG'; }
        return;
      }
    }
    setTimeout(() => pollPosted(slug, btn, deadline), 4000);
  }

  async function doPost(slug: string, btn: HTMLButtonElement | null, caption?: string) {
    if (btn) { btn.disabled = true; btn.textContent = 'Posting…'; }
    try {
      const res = await fetch(ENDPOINT, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug, ...(caption ? { caption } : {}) }),
      });
      const data = await res.json();
      if (res.status === 202 || res.ok) {
        pollPosted(slug, btn, Date.now() + 120_000);
      } else {
        showToast(data.error ?? 'Post failed', 'err');
        if (btn) { btn.disabled = false; btn.textContent = btn.classList.contains('btn-repost') ? 'Repost' : 'Post to IG'; }
      }
    } catch {
      showToast('Network error', 'err');
      if (btn) { btn.disabled = false; btn.textContent = 'Post to IG'; }
    }
  }
</script>
