---
// Land Cruiser rental operator comparison — the cornerstone page's centrepiece.
// Cards (not a wide table) so it's genuinely scannable on mobile. Editorial:
// outbound links rel="noopener" (no sponsored, no UTM) — this is not lead-gen.
import { RENTAL_OPERATORS } from '@/data/rental-operators';

const zar = (n: number) => `R${n.toLocaleString('en-ZA')}`;
const priceLabel = (p?: { low: number; high: number }) =>
  !p ? null : p.low === p.high ? `${zar(p.low)}/day` : `${zar(p.low)}–${zar(p.high)}/day`;
const fmtDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-ZA', { day: 'numeric', month: 'short', year: 'numeric' });

// Region tags for the "which rental is right for you?" finder to filter on.
const regionsOf = (op: { basedIn: string[]; pickupPoints?: string[] }) => {
  const s = [...op.basedIn, ...(op.pickupPoints ?? [])].join(' ').toLowerCase();
  const r: string[] = [];
  if (/gauteng|midrand|pretoria|alberton|johannesburg|tambo/.test(s)) r.push('gauteng');
  if (/western cape|cape town|paarl|atlantis/.test(s)) r.push('western-cape');
  if (/namibia|windhoek|walvis/.test(s)) r.push('namibia');
  if (/nationwide|airports/.test(s)) r.push('gauteng', 'western-cape');
  return [...new Set(r)];
};
---
<div class="not-prose my-8 flex flex-col gap-4">
  {RENTAL_OPERATORS.map((op) => {
    const maxSleeps = Math.max(...op.vehicles.map((v) => v.sleeps));
    const price = priceLabel(op.pricePerDayZar);
    return (
      <div
        class="rental-card rounded-2xl border border-[#DDD9D3] bg-white p-5"
        data-regions={regionsOf(op).join(' ')}
        data-crossborder={op.crossBorder ? 'true' : 'false'}
        data-maxsleeps={maxSleeps}
      >
        {/* Header */}
        <div class="flex flex-wrap items-baseline justify-between gap-x-3 gap-y-1 mb-1">
          <a href={op.website} target="_blank" rel="noopener" data-rental-op={op.slug} class="font-heading font-bold uppercase text-lg text-[#111111] !no-underline hover:!text-[#F5A623]">
            {op.name}
          </a>
          {op.rating && op.rating.verified ? (
            <span class="text-sm font-semibold text-[#111111] whitespace-nowrap">★ {op.rating.value} <span class="text-[#6B7280] font-normal">{op.rating.source} ({op.rating.count.toLocaleString('en-ZA')})</span></span>
          ) : op.rating ? (
            <span class="text-sm text-[#6B7280] whitespace-nowrap">Well reviewed</span>
          ) : null}
        </div>

        <p class="text-sm text-[#6B7280] mb-2">{op.basedIn.join(' · ')}</p>
        <p class="text-sm text-[#374151] leading-relaxed mb-3">{op.usp}</p>

        {/* At a glance */}
        <div class="flex flex-wrap gap-1.5 mb-3">
          {price && <span class="text-xs bg-[#F5F3EE] rounded-full px-2.5 py-1 text-[#111111] font-semibold">{price}</span>}
          <span class="text-xs bg-[#F5F3EE] rounded-full px-2.5 py-1 text-[#374151]">Sleeps up to {maxSleeps}</span>
          {op.unlimitedKm && <span class="text-xs bg-[#F5F3EE] rounded-full px-2.5 py-1 text-[#374151]">Unlimited km</span>}
          {op.crossBorder && <span class="text-xs bg-[#F5F3EE] rounded-full px-2.5 py-1 text-[#374151]">Cross-border ✓</span>}
          {op.oneWay && <span class="text-xs bg-[#F5F3EE] rounded-full px-2.5 py-1 text-[#374151]">One-way</span>}
          {op.minRentalDays && <span class="text-xs bg-[#F5F3EE] rounded-full px-2.5 py-1 text-[#374151]">Min {op.minRentalDays} days</span>}
        </div>

        <p class="text-xs text-[#6B7280] mb-1"><span class="font-semibold text-[#374151]">Vehicles:</span> {op.vehicles.map((v) => v.model).join(' · ')}</p>
        <p class="text-xs text-[#6B7280] mb-3"><span class="font-semibold text-[#374151]">Kit:</span> {op.equipment.join(' · ')}</p>

        <div class="flex items-center justify-between gap-3 flex-wrap">
          <a href={op.website} target="_blank" rel="noopener" data-rental-op={op.slug} class="inline-block bg-[#111111] !text-white !no-underline text-xs font-heading font-bold uppercase tracking-wide px-4 py-2 rounded-lg hover:bg-[#333] transition-colors">
            Visit website
          </a>
          <span class="text-xs text-[#9CA3AF]">Verified {fmtDate(op.lastVerified)}</span>
        </div>
      </div>
    );
  })}
  <p class="text-xs text-[#9CA3AF] mt-1">Rates and terms change with season and availability — always confirm directly with the operator before booking.</p>
</div>

<script>
  // First-party click tracking — which operators readers actually want.
  document.querySelectorAll('a[data-rental-op]').forEach((a) => {
    a.addEventListener('click', () => {
      try {
        navigator.sendBeacon('/api/track-rental', JSON.stringify({ operator_slug: (a as HTMLElement).dataset.rentalOp }));
      } catch {}
    });
  });
</script>
