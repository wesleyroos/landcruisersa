---
// "Which rental is right for you?" — client-side decision helper. Filters the
// RentalComparison cards (.rental-card) by region / cross-border / group size.
// Degrades gracefully: with JS off, the controls do nothing and all cards show.
const selectClass = 'mt-1 rounded-lg border border-[#DDD9D3] bg-white px-3 py-2 text-sm text-[#111111]';
---
<div class="not-prose my-8 rounded-2xl border border-[#DDD9D3] bg-[#F5F3EE] p-5">
  <p class="text-[#F5A623] font-heading font-bold uppercase tracking-widest text-xs mb-1">Find your match</p>
  <p class="font-heading font-bold uppercase text-xl leading-tight text-[#111111] mb-4">Which rental is right for you?</p>
  <div class="flex flex-wrap gap-4">
    <label class="flex flex-col text-xs font-semibold text-[#374151]">Where do you start?
      <select id="rf-region" class={selectClass}>
        <option value="">Anywhere</option>
        <option value="gauteng">Johannesburg / Gauteng</option>
        <option value="western-cape">Cape Town / Western Cape</option>
        <option value="namibia">Namibia</option>
      </select>
    </label>
    <label class="flex flex-col text-xs font-semibold text-[#374151]">Cross-border trip?
      <select id="rf-cross" class={selectClass}>
        <option value="">Doesn't matter</option>
        <option value="true">Yes — leaving SA</option>
      </select>
    </label>
    <label class="flex flex-col text-xs font-semibold text-[#374151]">Group size?
      <select id="rf-group" class={selectClass}>
        <option value="">Any</option>
        <option value="2">1–2 people</option>
        <option value="4">3–4 people</option>
      </select>
    </label>
  </div>
  <p id="rf-count" class="text-sm text-[#374151] mt-4 min-h-[1.25rem]"></p>
</div>

<script>
  const region = document.getElementById('rf-region') as HTMLSelectElement | null;
  const cross = document.getElementById('rf-cross') as HTMLSelectElement | null;
  const group = document.getElementById('rf-group') as HTMLSelectElement | null;
  const count = document.getElementById('rf-count');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.rental-card'));

  if (region && cross && group && count && cards.length) {
    const apply = () => {
      const r = region.value;
      const c = cross.value;
      const g = parseInt(group.value || '0', 10);
      let shown = 0;
      cards.forEach((el) => {
        const regions = (el.dataset.regions || '').split(' ');
        const okR = !r || regions.includes(r);
        const okC = !c || el.dataset.crossborder === 'true';
        const okG = !g || parseInt(el.dataset.maxsleeps || '0', 10) >= g;
        const show = okR && okC && okG;
        el.style.display = show ? '' : 'none';
        if (show) shown++;
      });
      const filtering = r || c || g;
      if (!filtering) count.textContent = '';
      else if (shown === 0) count.textContent = 'No exact match — try widening your filters.';
      else count.textContent = `${shown} operator${shown !== 1 ? 's' : ''} match your trip ↓`;
    };
    [region, cross, group].forEach((s) => s.addEventListener('change', apply));
  }
</script>
