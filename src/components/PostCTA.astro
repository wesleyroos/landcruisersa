---
// Contextual in-content CTA for guides — the Tier 3 conversion surface. Drops a
// styled "next step" card into article bodies so the high-traffic guides route
// readers to revenue surfaces (listings, valuation, partner) instead of bouncing.
// Internal links by default: keeps the session alive (improves bounce rate) and
// funnels toward conversion. Set external on a link for an off-site partner URL.
interface CtaLink { label: string; href: string; external?: boolean }
interface Props {
  eyebrow?: string;
  heading: string;
  blurb?: string;
  primary: CtaLink;
  secondary?: CtaLink;
}
const { eyebrow = 'Next step', heading, blurb, primary, secondary } = Astro.props;
const attrs = (l: CtaLink) => (l.external ? { target: '_blank', rel: 'noopener sponsored' } : {});
---
<aside class="not-prose my-8 rounded-2xl border border-[#DDD9D3] bg-[#F5F3EE] p-6">
  {eyebrow && <p class="text-[#F5A623] font-heading font-bold uppercase tracking-widest text-xs mb-2">{eyebrow}</p>}
  <p class="font-heading font-bold uppercase text-xl leading-tight text-[#111111] mb-2">{heading}</p>
  {blurb && <p class="text-sm text-[#4B5563] leading-relaxed mb-4">{blurb}</p>}
  <div class="flex flex-wrap gap-3">
    <a
      href={primary.href}
      {...attrs(primary)}
      class="inline-block bg-[#F5A623] text-[#111111] text-sm font-heading font-bold uppercase tracking-wide px-5 py-2.5 rounded-lg hover:bg-[#D4881A] transition-colors"
    >{primary.label}</a>
    {secondary && (
      <a
        href={secondary.href}
        {...attrs(secondary)}
        class="inline-block bg-white border border-[#DDD9D3] text-[#111111] text-sm font-heading font-bold uppercase tracking-wide px-5 py-2.5 rounded-lg hover:border-[#111111] transition-colors"
      >{secondary.label}</a>
    )}
  </div>
</aside>
