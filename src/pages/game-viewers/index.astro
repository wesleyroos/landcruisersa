---
export const prerender = false;

import Base from '@/layouts/Base.astro';
import { SITE } from '@/data/site';
import { db } from '@/db/index';
import { listings } from '@/db/schema';
import { and, eq, desc } from 'drizzle-orm';
import { firstThumb, firstPhoto, hasUsablePhoto } from '@/lib/photos';
import { getRecentPriceChanges } from '@/lib/price-changes';

// Body-type vertical, deliberately segment-agnostic: a Hilux or Mahindra-based
// game viewer is real inventory for this buyer, and listing detail pages are
// public for every segment.
let results = await db.select().from(listings)
  .where(and(eq(listings.status, 'active'), eq(listings.body_type, 'game-viewer')))
  .orderBy(desc(listings.featured), desc(listings.created_at));
results = results.filter(l => hasUsablePhoto(l.photos));

// Base vehicle per listing — the filter buyers actually think in (a lodge
// shopping at R500k wants the Mahindras; one at R1.3m wants LC79 conversions).
// Derived from segment/model first, brand names in the title as fallback.
function baseVehicle(l: { segment: string; model: string; title: string }): string {
  if (l.segment === 'land-cruiser') return 'Land Cruiser';
  if (l.model.startsWith('hilux')) return 'Hilux';
  const brand = l.title.match(/mahindra|land\s?rover|defender|suzuki|jimny|nissan|ford|isuzu|mitsubishi|jeep|dfsk/i)?.[0];
  if (brand) {
    const b = brand.toLowerCase();
    if (b.startsWith('land') || b === 'defender') return 'Land Rover';
    if (b === 'suzuki' || b === 'jimny') return 'Suzuki';
    if (b === 'dfsk') return 'DFSK';
    return b.charAt(0).toUpperCase() + b.slice(1);
  }
  return 'Other';
}
// Pills are data-driven: only bases actually in stock get one, with a count.
const baseCounts = new Map<string, number>();
for (const l of results) baseCounts.set(baseVehicle(l), (baseCounts.get(baseVehicle(l)) ?? 0) + 1);
const BASES = [...baseCounts.entries()].sort((a, b) => b[1] - a[1]);
const provincesPresent = [...new Set(results.map(l => l.province).filter(Boolean))].sort();

function formatPrice(n: number) { return 'R' + n.toLocaleString('en-ZA'); }
function formatMileage(n: number) { return n.toLocaleString('en-ZA') + ' km'; }

// Market strip — same maths as the per-model pages.
// POA units (price 0 — e.g. new factory Mahindras) count as for-sale stock but
// stay out of the price stats, which must only aggregate real asking prices.
const forSaleCount = results.filter(l => l.listing_type === 'for_sale').length;
const priced = results
  .filter(l => l.listing_type === 'for_sale' && l.price > 0)
  .map(l => l.price)
  .sort((a, b) => a - b);
const priceCount = priced.length;
const median = priceCount
  ? (priceCount % 2 ? priced[(priceCount - 1) / 2] : Math.round((priced[priceCount / 2 - 1] + priced[priceCount / 2]) / 2))
  : 0;
const minPrice = priceCount ? priced[0] : 0;
const maxPrice = priceCount ? priced[priceCount - 1] : 0;
const kms = results.filter(l => l.listing_type === 'for_sale' && l.mileage > 0).map(l => l.mileage);
const avgKm = kms.length ? Math.round(kms.reduce((s, m) => s + m, 0) / kms.length) : null;

const priceChanges = getRecentPriceChanges();
const dropBySlug = new Map<string, number>();
for (const l of results) {
  const c = priceChanges.get(l.slug) ?? 0;
  if (c < 0) dropBySlug.set(l.slug, Math.abs(c));
}

const kR = (n: number) =>
  n >= 1_000_000 ? 'R' + (n / 1_000_000).toFixed(n % 1_000_000 === 0 ? 0 : 1) + 'm' : 'R' + Math.round(n / 1000) + 'k';

const canonicalUrl = `${SITE.url}/game-viewers/`;
const title = 'Game Viewers For Sale in South Africa';

// ItemList schema — tells Google/LLMs this page is a listing hub for the whole
// category, with every vehicle enumerated (name, URL, price where public).
const itemListSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Game Viewers For Sale in South Africa — All Brands',
  description: 'Every game viewer (open safari vehicle) listed for sale in South Africa, across all brands.',
  numberOfItems: results.length,
  itemListElement: results.map((l, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    // POA listings (price 0) stay product-untyped: a Vehicle item without an
    // offer fails Google's "offers/review/aggregateRating required" rule, and
    // inventing a price or rating is worse than skipping the typing. Priced
    // stock gets the full Vehicle + Offer treatment.
    item: l.price > 0 ? {
      '@type': 'Vehicle',
      name: l.title,
      url: `${SITE.url}/listings/${l.slug}/`,
      image: firstPhoto(l.photos),
      bodyType: 'Game viewer (open safari vehicle)',
      itemCondition: l.new_or_used === 'New' ? 'https://schema.org/NewCondition' : 'https://schema.org/UsedCondition',
      offers: {
        '@type': 'Offer',
        price: l.price,
        priceCurrency: 'ZAR',
        availability: 'https://schema.org/InStock',
        itemCondition: l.new_or_used === 'New' ? 'https://schema.org/NewCondition' : 'https://schema.org/UsedCondition',
      },
    } : {
      '@type': 'Thing',
      name: l.title,
      url: `${SITE.url}/listings/${l.slug}/`,
      image: firstPhoto(l.photos),
    },
  })),
}).replace(/</g, '\\u003c');
const description = results.length
  ? (priceCount >= 2
      ? `Browse ${results.length} game viewer${results.length !== 1 ? 's' : ''} (open safari vehicles) for sale in South Africa — every brand: Land Cruiser and Hilux conversions, factory Mahindra units, Jimny builds and more. Median asking ${formatPrice(median)}, range ${kR(minPrice)}–${kR(maxPrice)}, updated daily.`
      : `Browse ${results.length} game viewer${results.length !== 1 ? 's' : ''} (open safari vehicles) for sale in South Africa across all brands — Land Cruiser, Mahindra and more, from dealers and private sellers, updated daily.`)
  : 'Game viewer (open safari vehicle) classifieds in South Africa across all brands — Land Cruiser, Mahindra and more, from dealers and private sellers — updated daily.';
---

<Base
  title={`${title} — Land Cruiser SA`}
  description={description}
  schema={{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE.url },
      { "@type": "ListItem", "position": 2, "name": "Listings", "item": `${SITE.url}/listings/` },
      { "@type": "ListItem", "position": 3, "name": "Game Viewers", "item": canonicalUrl },
    ],
  }}
>

  <div class="bg-[#111111]">
    <div class="max-w-7xl mx-auto px-4 py-8 sm:py-10 flex flex-col sm:flex-row sm:items-end justify-between gap-4">
      <div>
        <nav class="flex items-center gap-2 text-xs text-white/40 mb-4">
          <a href="/" class="hover:text-[#F5A623] transition-colors">Home</a>
          <span>›</span>
          <a href="/listings/" class="hover:text-[#F5A623] transition-colors">Listings</a>
          <span>›</span>
          <span class="text-white/70">Game Viewers</span>
        </nav>
        <p class="text-[#F5A623] font-heading font-bold uppercase tracking-widest text-xs mb-2">Open Safari Vehicles</p>
        <h1 class="font-heading font-bold uppercase text-white text-4xl md:text-5xl leading-none mb-3">{title}</h1>
        {priceCount >= 2 ? (
          <div class="flex flex-wrap items-baseline gap-x-6 gap-y-1.5 text-sm">
            <span class="text-white/80"><span class="font-heading font-bold text-white">{forSaleCount}</span> for sale</span>
            <span class="text-white/80">Median <span class="font-heading font-bold text-white">{formatPrice(median)}</span></span>
            <span class="text-white/80">Range <span class="font-heading font-bold text-white">{kR(minPrice)} – {kR(maxPrice)}</span></span>
            {avgKm && <span class="text-white/50 hidden sm:inline">Avg {formatMileage(avgKm)}</span>}
          </div>
        ) : (
          <p class="text-white/50 text-sm">{results.length} active listing{results.length !== 1 ? 's' : ''} · every brand · lodge-ready, converted and factory-built</p>
        )}
      </div>
      <a href="/listings/submit/?bt=game-viewer" class="inline-flex items-center gap-2 bg-[#F5A623] text-[#111111] font-heading font-bold uppercase tracking-wide px-6 py-3.5 rounded-xl hover:bg-[#D4881A] transition-colors text-sm self-start sm:self-auto touch-manipulation whitespace-nowrap">
        + List Your Game Viewer
      </a>
      <Fragment set:html={`<script type="application/ld+json">${itemListSchema}</script>`} />
    </div>
  </div>
  <div class="h-1 bg-[#F5A623]"></div>

  <div class="max-w-7xl mx-auto px-4 py-8 sm:py-10">

    {results.length === 0 ? (
      <div class="text-center py-24">
        <p class="text-[#6B7280] text-lg mb-4">No active game viewer listings right now.</p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a href="/listings/submit/?bt=game-viewer" class="inline-flex items-center gap-1.5 bg-[#F5A623] text-[#111111] font-heading font-bold uppercase tracking-wide px-6 py-3 rounded-xl text-sm hover:bg-[#D4881A] transition-colors">
            List your game viewer
          </a>
          <a href="/listings/" class="text-sm font-semibold text-[#6B7280] hover:text-[#111111] hover:underline px-2">Browse all listings</a>
        </div>
      </div>
    ) : (
      <>
      <!-- FILTER BAR — base-vehicle pills + dropdowns, mirrors the /listings/ house style -->
      <div class="flex flex-wrap items-center gap-2 mb-3" id="gv-base-pills">
        <button class="gv-pill active" data-base="" type="button">All ({results.length})</button>
        {BASES.map(([base, count]) => (
          <button class="gv-pill" data-base={base} type="button">{base} ({count})</button>
        ))}
      </div>
      <div class="flex flex-wrap items-center gap-2.5 mb-6" id="gv-filters">
        <div class="relative" id="gv-province">
          <button type="button" id="gv-province-btn" aria-expanded="false"
            class="border border-[#DDD9D3] rounded-xl px-4 py-2.5 text-sm bg-white focus:outline-none focus:border-[#F5A623] transition-colors cursor-pointer min-h-[44px] flex items-center gap-2 justify-between min-w-[150px]">
            <span id="gv-province-label" class="truncate">All Provinces</span>
            <svg width="10" height="6" viewBox="0 0 10 6" class="flex-shrink-0"><path d="M1 1l4 4 4-4" stroke="#9CA3AF" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div id="gv-province-panel" class="absolute z-30 mt-1 w-56 max-h-72 overflow-auto bg-white border border-[#DDD9D3] rounded-xl shadow-lg py-1 hidden">
            {provincesPresent.map(p => (
              <label class="flex items-center gap-2.5 px-4 py-2 text-sm cursor-pointer hover:bg-[#F5F3EE]">
                <input type="checkbox" value={p} class="gv-province-cb accent-[#F5A623] w-4 h-4" />
                <span>{p}</span>
              </label>
            ))}
          </div>
        </div>
        <div class="relative" id="gv-price">
          <button type="button" id="gv-price-btn" aria-expanded="false"
            class="border border-[#DDD9D3] rounded-xl px-4 py-2.5 text-sm bg-white focus:outline-none focus:border-[#F5A623] transition-colors cursor-pointer min-h-[44px] flex items-center gap-2 justify-between min-w-[140px]">
            <span id="gv-price-label" class="truncate">Any Price</span>
            <svg width="10" height="6" viewBox="0 0 10 6" class="flex-shrink-0"><path d="M1 1l4 4 4-4" stroke="#9CA3AF" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div id="gv-price-panel" class="absolute z-30 mt-1 w-72 bg-white border border-[#DDD9D3] rounded-xl shadow-lg py-1 hidden">
            <button type="button" class="gv-price-preset w-full text-left px-4 py-2 text-sm hover:bg-[#F5F3EE]" data-min="" data-max="">Any Price</button>
            <button type="button" class="gv-price-preset w-full text-left px-4 py-2 text-sm hover:bg-[#F5F3EE]" data-min="" data-max="500000">Under R500k</button>
            <button type="button" class="gv-price-preset w-full text-left px-4 py-2 text-sm hover:bg-[#F5F3EE]" data-min="500000" data-max="1000000">R500k – R1m</button>
            <button type="button" class="gv-price-preset w-full text-left px-4 py-2 text-sm hover:bg-[#F5F3EE]" data-min="1000000" data-max="1500000">R1m – R1.5m</button>
            <button type="button" class="gv-price-preset w-full text-left px-4 py-2 text-sm hover:bg-[#F5F3EE]" data-min="1500000" data-max="">Over R1.5m</button>
            <div class="border-t border-[#EEE] my-1"></div>
            <div class="px-3 py-2 flex items-center gap-1.5">
              <input type="number" inputmode="numeric" min="0" id="gv-price-min" placeholder="Min R" class="w-full min-w-0 border border-[#DDD9D3] rounded-lg px-2 py-1.5 text-sm focus:outline-none focus:border-[#F5A623]" />
              <span class="text-[#9CA3AF]">–</span>
              <input type="number" inputmode="numeric" min="0" id="gv-price-max" placeholder="Max R" class="w-full min-w-0 border border-[#DDD9D3] rounded-lg px-2 py-1.5 text-sm focus:outline-none focus:border-[#F5A623]" />
              <button type="button" id="gv-price-apply" class="flex-shrink-0 px-3 py-1.5 rounded-lg text-sm font-bold bg-[#111111] text-white hover:bg-[#F5A623] hover:text-[#111111] transition-colors">Go</button>
            </div>
          </div>
        </div>
        <div class="relative" id="gv-year">
          <button type="button" id="gv-year-btn" aria-expanded="false"
            class="border border-[#DDD9D3] rounded-xl px-4 py-2.5 text-sm bg-white focus:outline-none focus:border-[#F5A623] transition-colors cursor-pointer min-h-[44px] flex items-center gap-2 justify-between min-w-[130px]">
            <span id="gv-year-label" class="truncate">Any Year</span>
            <svg width="10" height="6" viewBox="0 0 10 6" class="flex-shrink-0"><path d="M1 1l4 4 4-4" stroke="#9CA3AF" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div id="gv-year-panel" class="absolute z-30 mt-1 w-52 bg-white border border-[#DDD9D3] rounded-xl shadow-lg py-1 hidden">
            <button type="button" class="gv-year-preset w-full text-left px-4 py-2 text-sm hover:bg-[#F5F3EE]" data-min="" data-max="">Any Year</button>
            <button type="button" class="gv-year-preset w-full text-left px-4 py-2 text-sm hover:bg-[#F5F3EE]" data-min="2020" data-max="">2020 &amp; newer</button>
            <button type="button" class="gv-year-preset w-full text-left px-4 py-2 text-sm hover:bg-[#F5F3EE]" data-min="2010" data-max="2019">2010 – 2019</button>
            <button type="button" class="gv-year-preset w-full text-left px-4 py-2 text-sm hover:bg-[#F5F3EE]" data-min="" data-max="2009">Pre-2010</button>
          </div>
        </div>
        <select id="gv-sort" aria-label="Sort game viewers"
          class="border border-[#DDD9D3] rounded-xl px-3 py-2.5 text-sm bg-white focus:outline-none focus:border-[#F5A623] transition-colors cursor-pointer min-h-[44px]">
          <option value="newest">Newest first</option>
          <option value="price-asc">Price: low → high</option>
          <option value="price-desc">Price: high → low</option>
        </select>
        <span id="gv-count" class="self-center text-sm text-[#6B7280] ml-auto"></span>
        <button id="gv-clear" type="button" class="hidden self-center text-sm font-semibold text-[#6B7280] hover:text-[#111111] hover:underline">Clear filters ✕</button>
      </div>
      <div id="gv-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {results.map((l, i) => (
          <a
            href={`/listings/${l.slug}/`}
            data-idx={i}
            data-price={l.listing_type === 'for_sale' && l.price > 0 ? l.price : ''}
            data-base={baseVehicle(l)}
            data-province={l.province}
            data-year={l.year}
            class="group border rounded-xl overflow-hidden transition-all flex flex-col bg-white border-[#DDD9D3] hover:border-[#F5A623] hover:shadow-md"
          >
            <div class="card-img">
              <img
                src={firstThumb(l.photos)}
                alt={l.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                width="800" height="500"
                loading={i < 6 ? 'eager' : 'lazy'}
                fetchpriority={i < 3 ? 'high' : 'auto'}
                decoding="async"
              />
              {l.province && <span class="card-badge">{l.province}</span>}
              {dropBySlug.has(l.slug) && (
                <span class="card-badge-drop">▼ R{dropBySlug.get(l.slug)!.toLocaleString('en-ZA')} drop</span>
              )}
            </div>
            <div class="p-4 sm:p-5 flex flex-col flex-1">
              <h2 class="font-heading font-bold uppercase text-base leading-tight mb-1 group-hover:text-[#F5A623] transition-colors line-clamp-2 text-[#111111]">
                {l.title}
              </h2>
              <p class="text-xs mb-4 truncate text-[#6B7280]">
                {formatMileage(l.mileage)} · {l.transmission === 'manual' ? 'Manual' : 'Auto'} · {l.province}
              </p>
              <div class="mt-auto">
                {l.listing_type === 'for_sale' && l.price > 0
                  ? <p class="font-heading font-bold text-2xl text-[#111111]">{formatPrice(l.price)}</p>
                  : <span class="text-xs font-bold text-[#F5A623] uppercase tracking-wide">POA</span>
                }
              </div>
            </div>
          </a>
        ))}
      </div>
      <div id="gv-empty" class="hidden text-center py-16">
        <p class="text-[#111111] text-lg font-heading font-bold uppercase mb-1">No matches right now</p>
        <p class="text-[#6B7280] text-sm mb-5 max-w-md mx-auto">No game viewers match those filters. Stock changes daily — or tell us what you're after below and we'll keep an eye out.</p>
        <button id="gv-reset" class="text-[#6B7280] text-sm font-semibold hover:text-[#111111] hover:underline min-h-[44px] px-2">Clear filters</button>
      </div>
      </>
    )}

    <!-- Definition + guide links — the "answer capsule" LLMs cite (position on
         the page doesn't affect citation/SEO; the top stays listings-first) -->
    <div class="mt-12">
      <h2 class="font-heading font-bold uppercase text-xl text-[#111111] mb-3">What is a game viewer?</h2>
      <p class="text-sm text-[#4A4A4A] leading-relaxed max-w-3xl">
        A <strong>game viewer</strong> is an open-sided safari vehicle with raised, tiered bench seating — typically a 9 to 11-seat conversion on a
        <a href="/listings/model/79-series/" class="underline hover:text-[#D4881A]">Land Cruiser 79</a> or
        <a href="/listings/model/78-series/" class="underline hover:text-[#D4881A]">78 Troopcarrier</a> chassis, used by South African lodges and reserves.
        This page lists <strong>every game viewer for sale in South Africa across all brands</strong> — Land Cruiser and Hilux conversions, factory Mahindra S4 and Scorpio units, Suzuki Jimny builds and more — updated daily from dealers and private sellers.
      </p>
      <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mt-3 text-sm">
        <a href="/useful-info/game-viewer-price-buyers-guide-south-africa/" class="font-semibold text-[#D4881A] hover:underline">Prices &amp; buyer's guide →</a>
        <a href="/market/79-series/" class="font-semibold text-[#111111] hover:text-[#D4881A] transition-colors">79 Series market data →</a>
      </div>
    </div>

    <!-- Sell CTA -->
    <div class="mt-12 p-5 bg-[#F5F3EE] border border-[#DDD9D3] rounded-xl flex flex-col sm:flex-row items-start sm:items-center gap-4">
      <div class="flex-1">
        <p class="text-xs font-bold uppercase tracking-widest text-[#F5A623] mb-1">Selling?</p>
        <p class="font-heading font-bold uppercase text-[#111111] text-base">List your game viewer on Land Cruiser SA</p>
        <p class="text-sm text-[#6B7280] mt-0.5">Free listing, reviewed within 24 hours — reaches lodges, operators and private buyers.</p>
      </div>
      <a href="/listings/submit/?bt=game-viewer" class="flex-shrink-0 inline-flex items-center bg-[#111111] text-white font-heading font-bold uppercase tracking-wide px-5 py-2.5 rounded-xl text-sm hover:bg-[#222] transition-colors">
        List Your Vehicle →
      </a>
    </div>

    <!-- Other sections -->
    <div class="mt-16 pt-10 border-t border-[#DDD9D3]">
      <h2 class="font-heading font-bold uppercase text-xl text-[#111111] mb-5">Browse by Model</h2>
      <div class="flex flex-wrap gap-2">
        {[
          ['76-series', '76 Series'], ['78-series', '78 Series (Troopcarrier)'], ['79-series', '79 Series'],
          ['80-series', '80 Series'], ['100-series', '100 Series'], ['200-series', '200 Series'],
          ['300-series', '300 Series'], ['prado', 'Prado'], ['fj-cruiser', 'FJ Cruiser'],
        ].map(([slug, label]) => (
          <a href={`/listings/model/${slug}/`} class="px-4 py-2 border border-[#DDD9D3] rounded-full text-sm text-[#4A4A4A] hover:border-[#F5A623] hover:text-[#F5A623] transition-colors">
            {label}
          </a>
        ))}
        <a href="/classics/" class="px-4 py-2 border border-[#DDD9D3] rounded-full text-sm text-[#4A4A4A] hover:border-[#F5A623] hover:text-[#F5A623] transition-colors">
          Classic Cruisers
        </a>
      </div>
    </div>

  </div>

</Base>

<script>
  // Filter + sort over the SSR'd cards via data-* attributes — no client
  // re-render needed at this inventory size. If stock passes ~150, graduate to
  // the /listings/ JSON + pagination pattern.
  const grid = document.getElementById('gv-grid');
  if (grid) {
    const cards = Array.from(grid.children) as HTMLElement[];
    const emptyEl = document.getElementById('gv-empty')!;
    const countEl = document.getElementById('gv-count')!;
    const clearBtn = document.getElementById('gv-clear')!;

    let base = '';
    let provinces: string[] = [];
    let priceMin = 0, priceMax = Infinity;
    let yearMin = 0, yearMax = Infinity;

    const provBtn = document.getElementById('gv-province-btn')!;
    const provPanel = document.getElementById('gv-province-panel')!;
    const provLabel = document.getElementById('gv-province-label')!;
    const provBoxes = Array.from(document.querySelectorAll<HTMLInputElement>('.gv-province-cb'));
    const priceBtn = document.getElementById('gv-price-btn')!;
    const pricePanel = document.getElementById('gv-price-panel')!;
    const priceLabel = document.getElementById('gv-price-label')!;
    const priceMinIn = document.getElementById('gv-price-min') as HTMLInputElement;
    const priceMaxIn = document.getElementById('gv-price-max') as HTMLInputElement;
    const yearBtn = document.getElementById('gv-year-btn')!;
    const yearPanel = document.getElementById('gv-year-panel')!;
    const yearLabel = document.getElementById('gv-year-label')!;
    const sortSel = document.getElementById('gv-sort') as HTMLSelectElement;

    const kR = (n: number) =>
      n >= 1_000_000 ? 'R' + (n / 1_000_000).toFixed(n % 1_000_000 === 0 ? 0 : 1) + 'm' : 'R' + Math.round(n / 1000) + 'k';

    function matches(el: HTMLElement): boolean {
      if (base && el.dataset.base !== base) return false;
      if (provinces.length && !provinces.includes(el.dataset.province || '')) return false;
      const priceActive = priceMin > 0 || isFinite(priceMax);
      if (priceActive) {
        // POA cards (no price) only show when no price filter is set.
        const p = el.dataset.price ? Number(el.dataset.price) : NaN;
        if (!isFinite(p) || p < priceMin || p > priceMax) return false;
      }
      const y = Number(el.dataset.year || 0);
      if ((yearMin > 0 || isFinite(yearMax)) && (y < yearMin || y > yearMax)) return false;
      return true;
    }

    function apply() {
      let shown = 0;
      const key = sortSel.value === 'price-asc'
        ? (el: HTMLElement) => (el.dataset.price ? Number(el.dataset.price) : Infinity)
        : sortSel.value === 'price-desc'
          ? (el: HTMLElement) => -(el.dataset.price ? Number(el.dataset.price) : 0)
          : (el: HTMLElement) => Number(el.dataset.idx ?? 0);
      cards.sort((a, b) => key(a) - key(b)).forEach(el => {
        const ok = matches(el);
        el.classList.toggle('hidden', !ok);
        if (ok) shown++;
        grid!.appendChild(el);
      });
      const filtered = Boolean(base || provinces.length || priceMin > 0 || isFinite(priceMax) || yearMin > 0 || isFinite(yearMax));
      countEl.textContent = filtered ? `${shown} of ${cards.length}` : `${cards.length} game viewers`;
      clearBtn.classList.toggle('hidden', !filtered);
      emptyEl.classList.toggle('hidden', shown > 0);
      grid!.classList.toggle('hidden', shown === 0);
    }

    // Base pills
    const pills = Array.from(document.querySelectorAll<HTMLButtonElement>('.gv-pill'));
    pills.forEach(p => p.addEventListener('click', () => {
      pills.forEach(x => x.classList.toggle('active', x === p));
      base = p.dataset.base || '';
      apply();
    }));

    // Dropdown open/close plumbing (shared behaviour)
    const dropdowns: [HTMLElement, HTMLElement, string][] = [
      [provBtn, provPanel, 'gv-province'], [priceBtn, pricePanel, 'gv-price'], [yearBtn, yearPanel, 'gv-year'],
    ];
    dropdowns.forEach(([btn, panel]) => btn.addEventListener('click', () => {
      const open = panel.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!open));
    }));
    document.addEventListener('click', e => {
      dropdowns.forEach(([btn, panel, rootId]) => {
        if (!document.getElementById(rootId)!.contains(e.target as Node)) {
          panel.classList.add('hidden');
          btn.setAttribute('aria-expanded', 'false');
        }
      });
    });

    // Province multi-select
    provBoxes.forEach(b => b.addEventListener('change', () => {
      provinces = provBoxes.filter(x => x.checked).map(x => x.value);
      provLabel.textContent =
        provinces.length === 0 ? 'All Provinces' : provinces.length === 1 ? provinces[0] : `${provinces.length} provinces`;
      apply();
    }));

    // Price presets + custom range
    function priceText(min: number, max: number): string {
      if (min <= 0 && !isFinite(max)) return 'Any Price';
      if (min <= 0) return 'Up to ' + kR(max);
      if (!isFinite(max)) return kR(min) + '+';
      return kR(min) + ' – ' + kR(max);
    }
    document.querySelectorAll<HTMLButtonElement>('.gv-price-preset').forEach(btn => btn.addEventListener('click', () => {
      priceMin = Number(btn.dataset.min || 0);
      priceMax = btn.dataset.max ? Number(btn.dataset.max) : Infinity;
      priceMinIn.value = priceMin > 0 ? String(priceMin) : '';
      priceMaxIn.value = isFinite(priceMax) ? String(priceMax) : '';
      priceLabel.textContent = btn.textContent!.trim();
      pricePanel.classList.add('hidden');
      apply();
    }));
    function applyCustomPrice() {
      let lo = Math.max(0, Number(priceMinIn.value) || 0);
      let hi = priceMaxIn.value ? Number(priceMaxIn.value) : Infinity;
      if (isFinite(hi) && lo > hi) { const t = lo; lo = hi; hi = t; }
      priceMin = lo; priceMax = hi;
      priceLabel.textContent = priceText(lo, hi);
      pricePanel.classList.add('hidden');
      apply();
    }
    document.getElementById('gv-price-apply')!.addEventListener('click', applyCustomPrice);
    [priceMinIn, priceMaxIn].forEach(inp => inp.addEventListener('keydown', e => {
      if ((e as KeyboardEvent).key === 'Enter') { e.preventDefault(); applyCustomPrice(); }
    }));

    // Year presets
    document.querySelectorAll<HTMLButtonElement>('.gv-year-preset').forEach(btn => btn.addEventListener('click', () => {
      yearMin = btn.dataset.min ? Number(btn.dataset.min) : 0;
      yearMax = btn.dataset.max ? Number(btn.dataset.max) : Infinity;
      yearLabel.textContent = btn.textContent!.trim();
      yearPanel.classList.add('hidden');
      apply();
    }));

    sortSel.addEventListener('change', apply);

    function clearAll() {
      base = ''; provinces = []; priceMin = 0; priceMax = Infinity; yearMin = 0; yearMax = Infinity;
      pills.forEach(x => x.classList.toggle('active', !x.dataset.base));
      provBoxes.forEach(x => { x.checked = false; });
      provLabel.textContent = 'All Provinces';
      priceMinIn.value = ''; priceMaxIn.value = '';
      priceLabel.textContent = 'Any Price';
      yearLabel.textContent = 'Any Year';
      sortSel.value = 'newest';
      apply();
    }
    clearBtn.addEventListener('click', clearAll);
    document.getElementById('gv-reset')!.addEventListener('click', clearAll);

    apply();
  }
</script>

