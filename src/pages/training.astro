---
import Base from '@/layouts/Base.astro';
---

<Base
  title="Advanced 4x4 Driving & Recovery Course — Land Cruiser SA"
  description="A full-day advanced 4x4 driving and recovery course in partnership with Toyota Advanced Driving. R4,250 per person. Zwartkops Raceway & De Wildt."
>

  <!-- ─── HERO ─────────────────────────────────────────────── -->
  <section class="bg-[#111111] grid md:grid-cols-2 min-h-[560px]">

    <!-- Left: text -->
    <div class="flex flex-col justify-center items-center text-center px-8 md:px-14 py-16 md:py-20">
      <p class="text-[#F5A623] font-heading font-bold uppercase tracking-[0.25em] text-xs mb-6">in partnership with Toyota Advanced Driving</p>
      <h1 class="font-heading font-bold uppercase text-white text-5xl md:text-7xl leading-none tracking-tight mb-6">
        Advanced<br/>4×4<br/>Course
      </h1>
      <p class="text-white/60 text-base leading-relaxed mb-10 max-w-sm">
        A full day of theory and hands-on driving — from which button to push when, to recovering a stuck vehicle safely.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 items-center">
        <a href="#enquire" class="bg-[#F5A623] text-[#111111] font-heading font-bold uppercase tracking-wide px-8 py-4 rounded-lg hover:bg-[#D4881A] transition-colors text-sm">
          Book Your Spot
        </a>
        <div class="text-white/50 text-sm self-center">
          <span class="text-white font-bold text-lg">R4,250</span> per person
        </div>
      </div>
    </div>

    <!-- Right: image, no overlay -->
    <div class="relative min-h-[300px] md:min-h-0">
      <img
        src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/training/training-wp-1.jpg"
        alt="Toyota Advanced Driving course — 4x4 on rocky terrain"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
      />
    </div>

  </section>

  <!-- ─── KEY FACTS ─────────────────────────────────────────── -->
  <div class="bg-[#111111]">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-white/10">
        <div class="px-6 py-6 text-center">
          <p class="text-[#F5A623] font-heading font-bold uppercase tracking-widest text-[10px] mb-1.5">Cost</p>
          <p class="text-white font-bold text-xl">R4,250</p>
          <p class="text-white/40 text-xs mt-0.5">incl. VAT</p>
        </div>
        <div class="px-6 py-6 text-center">
          <p class="text-[#F5A623] font-heading font-bold uppercase tracking-widest text-[10px] mb-1.5">Duration</p>
          <p class="text-white font-bold text-xl">Full Day</p>
          <p class="text-white/40 text-xs mt-0.5">08:00 – 16:30</p>
        </div>
        <div class="px-6 py-6 text-center">
          <p class="text-[#F5A623] font-heading font-bold uppercase tracking-widest text-[10px] mb-1.5">Venue</p>
          <p class="text-white font-bold text-base leading-tight">Zwartkops &amp; De Wildt</p>
          <p class="text-white/40 text-xs mt-0.5">Onsite also available</p>
        </div>
        <div class="px-6 py-6 text-center">
          <p class="text-[#F5A623] font-heading font-bold uppercase tracking-widest text-[10px] mb-1.5">Includes</p>
          <p class="text-white font-bold text-base leading-tight">Breakfast · Lunch</p>
          <p class="text-white/40 text-xs mt-0.5">Certificate &amp; cap</p>
        </div>
      </div>
    </div>
  </div>
  <div class="h-1 bg-[#F5A623]"></div>

  <!-- ─── ABOUT ──────────────────────────────────────────────── -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-[#F5A623] font-heading font-bold uppercase tracking-[0.2em] text-xs mb-4">About the Course</p>
        <h2 class="font-heading font-bold uppercase text-4xl leading-tight text-[#111111] mb-6">
          Built for any<br/>Land Cruiser driver
        </h2>
        <p class="text-[#4A4A4A] leading-relaxed mb-4">
          Heading to Deepest Darkest Africa — or just need to learn how not to damage your vehicle at the quarry down the road? This course is for you.
        </p>
        <p class="text-[#4A4A4A] leading-relaxed mb-4">
          The morning starts with a lecture session covering the essential do's and don'ts of off-road driving. Then you head straight into the practical — a variety of real terrain challenges that push both driver and vehicle, safely.
        </p>
        <p class="text-[#4A4A4A] leading-relaxed">
          You can also opt into the <strong>Recovery Technique Session</strong> — winching, snatch straps and self-recovery. Confirm this when you sign up. Vehicles can be supplied on request at no additional cost.
        </p>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/training/training-wp-1.jpg" alt="4x4 driving on rocky terrain" class="w-full aspect-[4/3] object-cover object-center rounded-xl col-span-2" />
        <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/training/training-wp-3.jpg" alt="Toyota 4x4 off-road" class="w-full aspect-square object-cover object-top rounded-xl" />
        <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/training/training-wp-4.jpg" alt="4x4 on dirt track" class="w-full aspect-square object-cover object-top rounded-xl" />
      </div>
    </div>
  </section>

  <!-- ─── CURRICULUM ────────────────────────────────────────── -->
  <section class="bg-[#111111] py-20">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-14">
        <p class="text-[#F5A623] font-heading font-bold uppercase tracking-[0.2em] text-xs mb-4">The Programme</p>
        <h2 class="font-heading font-bold uppercase text-4xl text-white">What You'll Learn</h2>
      </div>

      <div class="space-y-1">

        <div class="grid md:grid-cols-[160px_1fr] gap-4 md:gap-8 border border-white/10 rounded-xl p-6 hover:border-[#F5A623]/40 transition-colors">
          <div>
            <p class="text-[#F5A623] font-heading font-bold text-sm">08:00 – 08:30</p>
            <p class="text-white font-heading font-bold uppercase text-base mt-1">Arrival</p>
          </div>
          <div>
            <p class="text-white/60 text-sm leading-relaxed">Tea, coffee and muffins on arrival. Meet your instructor and fellow drivers before heading into the day.</p>
          </div>
        </div>

        <div class="grid md:grid-cols-[160px_1fr] gap-4 md:gap-8 border border-white/10 rounded-xl p-6 hover:border-[#F5A623]/40 transition-colors">
          <div>
            <p class="text-[#F5A623] font-heading font-bold text-sm">08:30 – 09:30</p>
            <p class="text-white font-heading font-bold uppercase text-base mt-1">Lecture Session</p>
          </div>
          <div>
            <p class="text-white/60 text-sm leading-relaxed mb-3">Theory covering the essential do's and don'ts of off-road driving.</p>
            <div class="grid grid-cols-2 gap-x-6 gap-y-1.5">
              <p class="text-white/80 text-sm flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#F5A623] flex-shrink-0"></span>Vehicle dynamics</p>
              <p class="text-white/80 text-sm flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#F5A623] flex-shrink-0"></span>4×4 transmission operations</p>
              <p class="text-white/80 text-sm flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#F5A623] flex-shrink-0"></span>Multi-terrain select (MTS)</p>
              <p class="text-white/80 text-sm flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#F5A623] flex-shrink-0"></span>Tyres &amp; tyre pressures</p>
              <p class="text-white/80 text-sm flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#F5A623] flex-shrink-0"></span>Engaging low range &amp; diff-lock</p>
              <p class="text-white/80 text-sm flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#F5A623] flex-shrink-0"></span>Suspension</p>
            </div>
          </div>
        </div>

        <div class="grid md:grid-cols-[160px_1fr] gap-4 md:gap-8 border border-white/10 rounded-xl p-6 hover:border-[#F5A623]/40 transition-colors">
          <div>
            <p class="text-[#F5A623] font-heading font-bold text-sm">10:00 – 12:30</p>
            <p class="text-white font-heading font-bold uppercase text-base mt-1">Practical Driving</p>
          </div>
          <div>
            <p class="text-white/60 text-sm leading-relaxed mb-3">Into the field — hands-on practice across real terrain.</p>
            <div class="grid grid-cols-2 gap-x-6 gap-y-1.5">
              <p class="text-white/80 text-sm flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#F5A623] flex-shrink-0"></span>Steep descents (up to 70%)</p>
              <p class="text-white/80 text-sm flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#F5A623] flex-shrink-0"></span>Steep ascents (up to 70%)</p>
              <p class="text-white/80 text-sm flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#F5A623] flex-shrink-0"></span>Ditch crossing with diff-lock</p>
              <p class="text-white/80 text-sm flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#F5A623] flex-shrink-0"></span>Side slopes</p>
            </div>
          </div>
        </div>

        <div class="grid md:grid-cols-[160px_1fr] gap-4 md:gap-8 bg-white/5 rounded-xl p-6">
          <div>
            <p class="text-white/30 font-heading font-bold text-sm">12:30 – 13:00</p>
            <p class="text-white/50 font-heading font-bold uppercase text-base mt-1">Lunch Break</p>
          </div>
          <div>
            <p class="text-white/40 text-sm">Lunch, colddrinks and water provided.</p>
          </div>
        </div>

        <div class="grid md:grid-cols-[160px_1fr] gap-4 md:gap-8 border border-white/10 rounded-xl p-6 hover:border-[#F5A623]/40 transition-colors">
          <div>
            <p class="text-[#F5A623] font-heading font-bold text-sm">13:00 – 16:00</p>
            <p class="text-white font-heading font-bold uppercase text-base mt-1">Practical Continues</p>
          </div>
          <div>
            <p class="text-white/60 text-sm leading-relaxed mb-3">More terrain, more challenges — including the optional recovery session.</p>
            <div class="grid grid-cols-2 gap-x-6 gap-y-1.5">
              <p class="text-white/80 text-sm flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#F5A623] flex-shrink-0"></span>Rock crawling</p>
              <p class="text-white/80 text-sm flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#F5A623] flex-shrink-0"></span>Mud driving (seasonal)</p>
              <p class="text-white/80 text-sm flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#F5A623] flex-shrink-0"></span>Winching techniques</p>
              <p class="text-white/80 text-sm flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#F5A623] flex-shrink-0"></span>Recovery strap usage</p>
              <p class="text-white/80 text-sm flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#F5A623] flex-shrink-0"></span>Self-recovery methods</p>
            </div>
          </div>
        </div>

        <div class="grid md:grid-cols-[160px_1fr] gap-4 md:gap-8 border border-[#F5A623]/30 bg-[#F5A623]/5 rounded-xl p-6">
          <div>
            <p class="text-[#F5A623] font-heading font-bold text-sm">16:00 – 16:30</p>
            <p class="text-white font-heading font-bold uppercase text-base mt-1">Debrief</p>
          </div>
          <div>
            <p class="text-white/60 text-sm leading-relaxed">Wrap-up discussion, certificate presentation and your Toyota Advanced Driving cap — well earned.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── PHOTO STRIP ───────────────────────────────────────── -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-3 gap-3">
        <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/training/training-wp-2.jpg" alt="4x4 on rocky trail" class="w-full h-80 object-cover object-top rounded-xl" />
        <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/training/training-wp-3.jpg" alt="Toyota 4x4 off-road training" class="w-full h-80 object-cover object-top rounded-xl" />
        <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/training/training-wp-4.jpg" alt="4x4 on dirt track" class="w-full h-80 object-cover object-top rounded-xl" />
      </div>
    </div>
  </section>

  <!-- ─── FORM ───────────────────────────────────────────────── -->
  <section id="enquire" class="bg-[#F5F3EE] py-20 border-t border-[#DDD9D3]">
    <div class="max-w-5xl mx-auto px-4 grid md:grid-cols-2 gap-16 items-start">

      <div>
        <p class="text-[#F5A623] font-heading font-bold uppercase tracking-[0.2em] text-xs mb-4">Enquire Now</p>
        <h2 class="font-heading font-bold uppercase text-4xl leading-tight text-[#111111] mb-6">
          Ready to<br/>Book Your Spot?
        </h2>
        <p class="text-[#6B7280] leading-relaxed mb-8">
          Fill in the form and one of our team will be in touch with available dates and anything else you need to know.
        </p>
        <div class="space-y-4 border-t border-[#DDD9D3] pt-8">
          <div class="flex items-start gap-3">
            <span class="mt-1 w-4 h-4 rounded-full bg-[#F5A623] flex-shrink-0"></span>
            <p class="text-sm text-[#4A4A4A]">Breakfast, lunch, colddrinks and certificate included in the R4,250 fee</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="mt-1 w-4 h-4 rounded-full bg-[#F5A623] flex-shrink-0"></span>
            <p class="text-sm text-[#4A4A4A]">Vehicles supplied on request at no extra cost</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="mt-1 w-4 h-4 rounded-full bg-[#F5A623] flex-shrink-0"></span>
            <p class="text-sm text-[#4A4A4A]">Optional recovery session — confirm when you sign up</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="mt-1 w-4 h-4 rounded-full bg-[#F5A623] flex-shrink-0"></span>
            <p class="text-sm text-[#4A4A4A]">Courses subject to a minimum of 8 drivers on the day</p>
          </div>
        </div>

        <div class="mt-10 pt-8 border-t border-[#DDD9D3]">
          <p class="text-xs text-[#6B7280] uppercase tracking-widest mb-3">In partnership with</p>
          <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/training/tad-logo.png" alt="Toyota Advanced Driving" class="h-8 w-auto" />
        </div>
      </div>

      <div id="training-success" class="hidden bg-green-50 border border-green-200 text-green-800 rounded-xl px-5 py-4 text-sm font-medium mb-5">
        Enquiry sent — we'll be in touch with available dates shortly.
      </div>
      <div id="training-error" class="hidden bg-red-50 border border-red-200 text-red-800 rounded-xl px-5 py-4 text-sm font-medium mb-5">
        Something went wrong. Please try again or email us directly.
      </div>
      <form
        id="training-form"
        class="bg-white rounded-2xl shadow-sm border border-[#DDD9D3] p-8 space-y-5"
      >
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="first-name" class="block text-xs font-bold uppercase tracking-wide text-[#111111] mb-2">Name</label>
            <input type="text" id="first-name" name="first-name" required
              class="w-full border border-[#DDD9D3] rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#F5A623] transition-colors" />
          </div>
          <div>
            <label for="surname" class="block text-xs font-bold uppercase tracking-wide text-[#111111] mb-2">Surname</label>
            <input type="text" id="surname" name="surname" required
              class="w-full border border-[#DDD9D3] rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#F5A623] transition-colors" />
          </div>
        </div>
        <div>
          <label for="email" class="block text-xs font-bold uppercase tracking-wide text-[#111111] mb-2">Email</label>
          <input type="email" id="email" name="email" required
            class="w-full border border-[#DDD9D3] rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#F5A623] transition-colors" />
        </div>
        <div>
          <label for="phone" class="block text-xs font-bold uppercase tracking-wide text-[#111111] mb-2">Contact Number</label>
          <input type="tel" id="phone" name="phone" required
            class="w-full border border-[#DDD9D3] rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#F5A623] transition-colors" />
        </div>
        <div>
          <label for="location" class="block text-xs font-bold uppercase tracking-wide text-[#111111] mb-2">Where are you based?</label>
          <input type="text" id="location" name="location"
            class="w-full border border-[#DDD9D3] rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#F5A623] transition-colors" />
        </div>
        <div>
          <label for="land-cruiser" class="block text-xs font-bold uppercase tracking-wide text-[#111111] mb-2">Do you own a Land Cruiser? Which model?</label>
          <input type="text" id="land-cruiser" name="land-cruiser"
            placeholder="e.g. 79 Series, 200 Series, or 'Not yet'"
            class="w-full border border-[#DDD9D3] rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#F5A623] transition-colors placeholder:text-[#9CA3AF]" />
        </div>
        <div>
          <label for="message" class="block text-xs font-bold uppercase tracking-wide text-[#111111] mb-2">Message</label>
          <textarea id="message" name="message" rows="3"
            class="w-full border border-[#DDD9D3] rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#F5A623] transition-colors resize-none"></textarea>
        </div>
        <button type="submit" id="training-submit"
          class="w-full bg-[#F5A623] text-[#111111] font-heading font-bold uppercase tracking-wide py-4 rounded-lg hover:bg-[#D4881A] transition-colors disabled:opacity-50">
          Send Enquiry
        </button>
      </form>

    </div>
  </section>

</Base>

<script>
  const form = document.getElementById('training-form') as HTMLFormElement;
  const submitBtn = document.getElementById('training-submit') as HTMLButtonElement;
  const successEl = document.getElementById('training-success')!;
  const errorEl = document.getElementById('training-error')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    successEl.classList.add('hidden');
    errorEl.classList.add('hidden');

    const data = Object.fromEntries(new FormData(form));
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    try {
      const res = await fetch('/api/training-enquiry', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (res.ok) {
        successEl.classList.remove('hidden');
        form.reset();
      } else {
        errorEl.classList.remove('hidden');
      }
    } catch {
      errorEl.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Enquiry';
    }
  });
</script>
