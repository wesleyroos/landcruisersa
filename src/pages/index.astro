---
export const prerender = false;

import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';
import { SITE } from '@/data/site';
import { PARTNERS } from '@/data/partners';
import { db } from '@/db/index';
import { listings, priceEvents, favorites } from '@/db/schema';
import { eq, desc, and, not, sql, gte } from 'drizzle-orm';
import { getSiteStats } from '@/lib/site-stats';
import { getCurrentUser } from '@/lib/auth-user';
import { firstThumb, hasUsablePhoto } from '@/lib/photos';
import VehicleSearch from '@/components/VehicleSearch.astro';

const allPosts = await getCollection('posts', p => !p.data.draft && !p.data.unlisted);
const posts = allPosts
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 6);

const SLOTS = 3;

// Only Land Cruiser listings are shown publicly (Hilux/Fortuner are collected
// for data but live behind segment = 'toyota-4x4').
const LC = eq(listings.segment, 'land-cruiser');

// Only feature listings we can actually picture — skip any with no real photo.
const pinnedListings = (await db
  .select()
  .from(listings)
  .where(and(eq(listings.status, 'active'), LC, eq(listings.featured, true)))
  .orderBy(desc(listings.created_at))
  .limit(SLOTS))
  .filter(l => hasUsablePhoto(l.photos));

const fillNeeded = SLOTS - pinnedListings.length;
const fillListings = fillNeeded > 0
  ? (await db
      .select()
      .from(listings)
      .where(and(eq(listings.status, 'active'), LC, not(eq(listings.featured, true))))
      .orderBy(desc(listings.created_at))
      .limit(fillNeeded + 8)) // buffer so photo-less rows don't shrink the row
      .filter(l => hasUsablePhoto(l.photos))
      .slice(0, fillNeeded)
  : [];

const featuredListings = [...pinnedListings, ...fillListings];

// Seed the save-heart state on the featured cards for a signed-in user.
const homeUser = getCurrentUser(Astro.cookies);
const homeFavSet = new Set(
  homeUser
    ? db.select({ s: favorites.listing_slug }).from(favorites).where(eq(favorites.user_id, homeUser.id)).all().map(r => r.s)
    : []
);
const homeLoggedIn = Boolean(homeUser);

// Live hero stats — the first fold's claims stay true automatically.
// Counts come from the shared single source of truth so the homepage, About
// and market pages never quote conflicting numbers.
const { liveListings: activeCount, models: modelCount } = getSiteStats();
const dropCount = (db.select({ n: sql<number>`count(DISTINCT slug)` })
  .from(priceEvents)
  .where(and(
    gte(priceEvents.recorded_at, new Date(Date.now() - 30 * 24 * 3600 * 1000)),
    sql`new_price < old_price`,
    sql`model NOT IN ('hilux','fortuner')`,
  )).get())?.n ?? 0;
const activeStr = activeCount.toLocaleString('en-ZA');

function formatPrice(n: number) {
  return 'R ' + n.toLocaleString('en-ZA');
}
---

<Base
  title="Land Cruiser SA — Every Land Cruiser For Sale in South Africa"
  description={`Every Land Cruiser for sale in South Africa, in one place. ${activeStr} live listings aggregated from every major platform — prices tracked daily, drops flagged. Plus guides, builds and 4x4 training.`}
  schema={{
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": SITE.name,
    "alternateName": ["LandCruiserSA", "Landcruiser SA", "LC SA"],
    "url": SITE.url,
    "description": "Every Land Cruiser for sale in South Africa, in one place — live listings from every major platform with prices tracked daily. Plus guides, builds and 4x4 training.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": `${SITE.url}/listings/?q={search_term_string}`,
      "query-input": "required name=search_term_string"
    }
  }}
>

  <!-- ═══════════════════════════════════ HERO -->
  <section class="hero">
    <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/hero-lineup.webp" alt="The Toyota Land Cruiser range lined up at sunset in the African bush" class="hero-img" fetchpriority="high" width="1920" height="1080" />
    <div class="hero-scrim"></div>
    <div class="hero-inner">
      <p class="hero-eyebrow">South Africa's Land Cruiser Marketplace</p>
      <h1 class="hero-heading">Every Land Cruiser<br/>for sale in SA.<br/>One place.</h1>
      <div class="hero-search">
        <p class="hero-search-label">Search for a vehicle — just type what you're looking for</p>
        <VehicleSearch mode="navigate" />
      </div>
      <div class="hero-actions">
        <a href="/listings/" class="btn-primary">Browse {activeStr} Cruisers</a>
        <a href="/valuation/" class="btn-ghost">Vehicle Valuation</a>
        <a href="/market/" class="btn-ghost">Live Market Data</a>
      </div>
      <div class="hero-stats">
        <span class="hstat"><strong>{activeStr}</strong> live listings</span>
        <span class="hstat-dot">·</span>
        <span class="hstat"><strong>{dropCount}</strong> price drop{dropCount !== 1 ? 's' : ''} this month</span>
        <span class="hstat-dot">·</span>
        <span class="hstat"><strong>{modelCount}</strong> models tracked daily</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════ LISTINGS -->
  <section class="s-listings">
    <div class="wrap">
      <div class="s-head">
        <div>
          <p class="eyebrow">Buy & sell</p>
          <h2 class="s-title">Land Cruiser Classifieds</h2>
        </div>
        <a href="/listings/" class="link-more">All listings →</a>
      </div>
      <div class="listings-row" data-logged-in={homeLoggedIn ? '1' : '0'}>
        {featuredListings.map(l => (
          <a href={`/listings/${l.slug}/`} class="lc lc-light">
            <div class="lc-img">
              <img src={firstThumb(l.photos)} alt={l.title} loading="lazy" />
              <span class="lc-badge">{l.model.replace('-', ' ').toUpperCase()}</span>
              {l.featured && <span class="lc-badge-featured">★ Featured</span>}
              <span
                class="card-fav"
                data-fav-slug={l.slug}
                data-saved={homeFavSet.has(l.slug) ? 'true' : 'false'}
                role="button" tabindex="0" aria-label="Save vehicle"
                style="position:absolute;top:0.75rem;right:0.75rem;z-index:10;width:2.25rem;height:2.25rem;display:flex;align-items:center;justify-content:center;border-radius:9999px;background:rgba(0,0,0,0.4);cursor:pointer;backdrop-filter:blur(2px);"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill={homeFavSet.has(l.slug) ? '#F5A623' : 'none'} stroke={homeFavSet.has(l.slug) ? '#F5A623' : 'white'} stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
              </span>
            </div>
            <div class="lc-body">
              <p class="lc-title lc-title-dark">{l.title}</p>
              <p class="lc-meta lc-meta-light">{l.province} · {l.mileage.toLocaleString('en-ZA')} km · {l.transmission.charAt(0).toUpperCase() + l.transmission.slice(1)}</p>
              <p class="lc-price lc-price-dark">{formatPrice(l.price)}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="listings-foot">
        <a href="/listings/submit/" class="btn-outline">+ List Your Vehicle</a>
        <a href="/game-viewers/" class="btn-outline">🦒 Game Viewers</a>
        <a href="/listings/" class="btn-primary">View All Listings</a>
      </div>
      <p class="ig-note">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        List your Land Cruiser free — we'll post it to our <strong>18,800 followers</strong> on Instagram.
      </p>
    </div>
  </section>

  <script>
    // Save-heart on the featured cards. These are static (no client re-render),
    // so a delegated listener on the row is enough.
    const row = document.querySelector('.listings-row');
    if (row) {
      const loggedIn = row.getAttribute('data-logged-in') === '1';
      const go = () => {
        const w = window as any;
        if (typeof w.lcsaSignin === 'function') w.lcsaSignin(location.pathname);
        else location.href = `/signin/?next=${encodeURIComponent(location.pathname)}`;
      };
      const toggle = async (btn: HTMLElement) => {
        if (!loggedIn) { go(); return; }
        const slug = btn.dataset.favSlug!;
        const saved = btn.dataset.saved === 'true';
        btn.style.pointerEvents = 'none';
        try {
          const res = await fetch('/api/favorites', {
            method: saved ? 'DELETE' : 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ slug }),
          });
          if (res.status === 401) { go(); return; }
          if (!res.ok) return;
          const now = !saved;
          btn.dataset.saved = String(now);
          const svg = btn.querySelector('svg');
          if (svg) { svg.setAttribute('fill', now ? '#F5A623' : 'none'); svg.setAttribute('stroke', now ? '#F5A623' : 'white'); }
        } finally { btn.style.pointerEvents = ''; }
      };
      row.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('.card-fav') as HTMLElement | null;
        if (!btn) return;
        e.preventDefault(); e.stopPropagation();
        toggle(btn);
      });
      row.addEventListener('keydown', (e) => {
        if (e.key !== 'Enter' && e.key !== ' ') return;
        const btn = (e.target as HTMLElement).closest('.card-fav') as HTMLElement | null;
        if (!btn) return;
        e.preventDefault();
        toggle(btn);
      });
    }
  </script>

  <!-- ═══════════════════════════════════ ARTICLES -->

  <section class="s-light">
    <div class="wrap">
      <div class="s-head">
        <div>
          <p class="eyebrow">From the community</p>
          <h2 class="s-title">Guides & Advice</h2>
        </div>
        <a href="/useful-info/" class="link-more">All guides →</a>
      </div>
      <div class="articles-grid">
        {posts.map(post => (
          <a href={`/useful-info/${post.slug}/`} class="article-card">
            <div class="ac-img">
              <img src={post.data.featuredImage} alt={post.data.featuredImageAlt} loading="lazy" />
              <span class="ac-tag">{post.data.category.replace('-', ' ')}</span>
            </div>
            <div class="ac-body">
              <h3 class="ac-title">{post.data.title}</h3>
              <p class="ac-excerpt">{post.data.excerpt}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════ TRAINING -->
  <section class="training">
    <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/training/training-wp-1.jpg" alt="" class="training-img" loading="lazy" />
    <div class="training-scrim"></div>
    <div class="wrap training-inner">
      <div class="training-text">
        <p class="eyebrow-gold">In partnership with Toyota Advanced Driving</p>
        <h2 class="training-h">Advanced 4×4<br/>Driving & Recovery</h2>
        <p class="training-p">A full day of hands-on terrain driving — sand, mud, winching, vehicle recovery. Breakfast, lunch and certificate included.</p>
        <div class="training-facts">
          <div class="tf"><span class="tf-v">R4,250</span><span class="tf-l">Per person</span></div>
          <div class="tf"><span class="tf-v">Full day</span><span class="tf-l">Duration</span></div>
          <div class="tf"><span class="tf-v">Zwartkops</span><span class="tf-l">Venue</span></div>
        </div>
        <a href="/training/" class="btn-primary-lg">Book Your Spot →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════ MODELS -->
  <section class="s-light">
    <div class="wrap">
      <div class="s-head">
        <div>
          <p class="eyebrow">Explore the range</p>
          <h2 class="s-title">Land Cruiser Models</h2>
        </div>
      </div>
      <div class="models-grid">
        <a href="/models/76-series/" class="mc">
          <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/models/lc-76.jpg" alt="LC 76 Series" loading="lazy" />
          <div class="mc-overlay"></div>
          <div class="mc-label"><span>76 Series</span><span class="mc-arrow">→</span></div>
        </a>
        <a href="/models/78-series/" class="mc">
          <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/models/lc-78.jpg" alt="LC 78 Series" loading="lazy" />
          <div class="mc-overlay"></div>
          <div class="mc-label"><span>78 Series</span><span class="mc-arrow">→</span></div>
        </a>
        <a href="/models/79-series/" class="mc">
          <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/models/lc-79-new.jpg" alt="LC 79 Series" loading="lazy" />
          <div class="mc-overlay"></div>
          <div class="mc-label"><span>79 Series</span><span class="mc-arrow">→</span></div>
        </a>
        <a href="/models/200-series/" class="mc">
          <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/models/lc-200-new.jpg" alt="LC 200 Series" loading="lazy" />
          <div class="mc-overlay"></div>
          <div class="mc-label"><span>200 Series</span><span class="mc-arrow">→</span></div>
        </a>
        <a href="/models/300-series/" class="mc">
          <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/models/lc-300-new.jpg" alt="LC 300 Series" loading="lazy" />
          <div class="mc-overlay"></div>
          <div class="mc-label"><span>300 Series</span><span class="mc-arrow">→</span></div>
        </a>
        <a href="/models/prado-150/" class="mc">
          <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/models/prado-150.jpg" alt="Land Cruiser Prado 150" loading="lazy" />
          <div class="mc-overlay"></div>
          <div class="mc-label"><span>Prado 150</span><span class="mc-arrow">→</span></div>
        </a>
        <a href="/models/prado-250/" class="mc">
          <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/models/prado-250.jpg" alt="Land Cruiser Prado 250" loading="lazy" />
          <div class="mc-overlay"></div>
          <div class="mc-label"><span>Prado 250</span><span class="mc-arrow">→</span></div>
        </a>
        <a href="/models/fj-cruiser/" class="mc">
          <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/models/fj-cruiser.jpg" alt="FJ Cruiser" loading="lazy" />
          <div class="mc-overlay"></div>
          <div class="mc-label"><span>FJ Cruiser</span><span class="mc-arrow">→</span></div>
        </a>
        <a href="/models/land-cruiser-fj/" class="mc">
          <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/models/lc-fj-2026.jpg" alt="Land Cruiser FJ" loading="lazy" />
          <div class="mc-overlay"></div>
          <div class="mc-label"><span>Land Cruiser FJ</span><span class="mc-arrow">→</span></div>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════ PARTNERS -->
  <section class="s-light partners-section">
    <div class="wrap">
      <div class="s-head">
        <div>
          <p class="eyebrow">Trusted by the community</p>
          <h2 class="s-title">Our Partners</h2>
        </div>
        <a href="/partners/" class="link-more">All partners →</a>
      </div>
      <div class="partners-track-wrap">
        <div class="partners-track">
          {[...PARTNERS, ...PARTNERS].map((p, i) => (
            <a href={`/partners/${p.slug}/`} class={`partner-tile${p.logo ? ' partner-tile-logo' : ''}`}>
              <div class="pt-img">
                {p.logo ? (
                  <img src={p.logo} alt={`${p.name} logo`} width="480" height="300"
                    class="pt-logo-img"
                    loading={i < 4 ? 'eager' : 'lazy'}
                    fetchpriority={i < 2 ? 'high' : 'auto'}
                    decoding="async" />
                ) : (
                  <img src={p.hero} alt={p.name} width="480" height="300"
                    loading={i < 4 ? 'eager' : 'lazy'}
                    fetchpriority={i < 2 ? 'high' : 'auto'}
                    decoding="async" />
                )}
              </div>
              <div class="pt-body">
                <span class="pt-cat">{p.category}</span>
                <p class="pt-name">{p.name}</p>
                <p class="pt-loc">{p.location}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ─ HERO ──────────────────────────────────────── */
  .hero {
    /* Mobile-first: grow with the content (search bar + buttons + stats made
       it taller than the old fixed band, which clipped the heading and pushed
       the stats onto the white background below). The absolutely-positioned
       image + scrim cover whatever height results. */
    position: relative;
    min-height: 65vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3.5rem 0 2.75rem;
  }
  /* Wider screens keep the cinematic band via min-height ONLY — never a hard
     height. A hard 65vh clipped the hero on short-wide viewports (landscape
     tablets ~1333x643: heading cut off, the third button + stats pushed onto
     the white background). clamp() = at least 480px, at most demand 700px;
     the hero still grows beyond that whenever the content needs it. */
  @media (min-width: 768px) {
    .hero {
      min-height: clamp(480px, 65vh, 700px);
      padding: 3rem 0 2.5rem;
    }
  }
  .hero-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; object-position: center 60%;
  }
  .hero-scrim {
    position: absolute; inset: 0;
    background: linear-gradient(
      105deg,
      rgba(0,0,0,0.80) 0%,
      rgba(0,0,0,0.55) 55%,
      rgba(0,0,0,0.20) 100%
    );
  }
  .hero-inner {
    position: relative; z-index: 10;
    text-align: center;
    padding: 0 2rem;
    max-width: 780px;
  }
  .hero-eyebrow {
    font-size: 0.7rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.18em;
    color: #F5A623; margin-bottom: 1.25rem;
  }
  .hero-heading {
    font-family: var(--font-heading);
    font-weight: 700; text-transform: uppercase;
    color: white; line-height: 0.95;
    font-size: clamp(2.5rem, 6.5vw, 4.5rem);
    margin-bottom: 0.875rem;
  }
  .hero-tagline {
    font-size: 0.9rem; color: rgba(255,255,255,0.65);
    letter-spacing: 0.04em; margin-bottom: 1.75rem;
  }
  .hero-search { display: flex; flex-direction: column; align-items: center; margin: 1.5rem auto 1.4rem; }
  .hero-search-label { margin-bottom: 0.7rem; font-size: 0.85rem; font-weight: 500; color: rgba(255,255,255,0.82); }
  .hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; justify-content: center; }
  .hero-stats {
    display: flex; align-items: center; justify-content: center; gap: 0.75rem;
    flex-wrap: wrap; margin-top: 1.75rem;
    font-size: 0.78rem; color: rgba(255,255,255,0.7);
  }
  .hero-stats strong { color: #F5A623; font-weight: 700; }
  .hstat-dot { color: rgba(255,255,255,0.3); }

  /* ─ BUTTONS ───────────────────────────────────── */
  .btn-primary {
    display: inline-flex; align-items: center;
    background: #F5A623; color: #111111;
    font-family: var(--font-heading); font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em;
    font-size: 0.875rem; padding: 0.875rem 1.75rem;
    border-radius: 0.5rem; text-decoration: none;
    transition: background 0.15s;
  }
  .btn-primary:hover { background: #D4881A; }

  .btn-primary-lg {
    display: inline-flex; align-items: center;
    background: #F5A623; color: #111111;
    font-family: var(--font-heading); font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em;
    font-size: 1rem; padding: 1.125rem 2.25rem;
    border-radius: 0.5rem; text-decoration: none;
    transition: background 0.15s;
  }
  .btn-primary-lg:hover { background: #D4881A; }

  .btn-ghost {
    display: inline-flex; align-items: center;
    background: rgba(255,255,255,0.1); color: white;
    border: 1.5px solid rgba(255,255,255,0.3);
    font-family: var(--font-heading); font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em;
    font-size: 0.875rem; padding: 0.875rem 1.75rem;
    border-radius: 0.5rem; text-decoration: none;
    backdrop-filter: blur(4px);
    transition: background 0.15s, border-color 0.15s;
  }
  .btn-ghost:hover { background: rgba(255,255,255,0.2); border-color: rgba(255,255,255,0.6); }

  .btn-ghost-gold {
    display: inline-flex; align-items: center;
    background: transparent; color: rgba(255,255,255,0.7);
    border: 1.5px solid rgba(255,255,255,0.2);
    font-family: var(--font-heading); font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em;
    font-size: 0.875rem; padding: 0.875rem 1.75rem;
    border-radius: 0.5rem; text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-ghost-gold:hover { border-color: #F5A623; color: #F5A623; }

  /* ─ SHARED ────────────────────────────────────── */
  .wrap { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
  .s-light    { background: #F5F3EE; padding: 5rem 0; }
  .s-dark     { background: #111111; padding: 5rem 0; }
  .s-listings { background: #F5F3EE; padding: 5rem 0; }

  .s-head, .s-head-dark {
    display: flex; align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 2.5rem; gap: 1rem;
  }
  .eyebrow {
    font-size: 0.65rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.16em;
    color: #F5A623; margin-bottom: 0.4rem;
    display: block;
  }
  .eyebrow-gold {
    font-size: 0.65rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.16em;
    color: #F5A623; margin-bottom: 0.4rem;
    display: block;
  }
  .s-title {
    font-family: var(--font-heading); font-weight: 700;
    text-transform: uppercase; color: #111111;
