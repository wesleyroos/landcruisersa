<script define:vars={{ partnerCount: PARTNERS.length }}>
  const track = document.querySelector('.partners-track');
  if (track) {
    const tiles = track.querySelectorAll('.partner-tile');
    const realCount = partnerCount;
    let current = 0;
    let animating = false;
    let timer = null;

    function advance() {
      if (animating) return;
      animating = true;

      const next = current + 1;
      const offset = tiles[next].offsetLeft;

      track.style.transition = 'transform 0.55s cubic-bezier(0.4, 0, 0.2, 1)';
      track.style.transform = `translateX(-${offset}px)`;
      current = next;

      setTimeout(() => {
        if (current >= realCount) {
          track.style.transition = 'none';
          track.style.transform = 'translateX(0)';
          current = 0;
        }
        animating = false;
      }, 600);
    }

    function start() { timer = setInterval(advance, 3000); }
    function stop()  { clearInterval(timer); }

    start();
    track.addEventListener('mouseenter', stop);
    track.addEventListener('mouseleave', start);
  }
</script>
