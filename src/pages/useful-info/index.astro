---
import Base from '@/layouts/Base.astro';
import { SITE } from '@/data/site';
import PostCard from '@/components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', p => !p.data.draft && !p.data.unlisted);
const posts = allPosts.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const categories = [
  { slug: 'all', label: 'All' },
  { slug: 'useful-info', label: 'Useful Info' },
  { slug: 'gear', label: 'Gear' },
  { slug: 'routes', label: 'Routes' },
  { slug: 'builds', label: 'Builds' },
];
---

<Base
  title="Useful Info — Land Cruiser SA"
  description="Guides, buyers guides, how-tos and overlanding tips for South African Land Cruiser owners. Updated regularly."
  schema={{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE.url },
      { "@type": "ListItem", "position": 2, "name": "Useful Info", "item": `${SITE.url}/useful-info/` }
    ]
  }}
>
  <!-- Header -->
  <div class="bg-[#111111] text-white">
    <div class="max-w-7xl mx-auto px-4 py-12">
      <p class="text-[#F5A623] font-heading font-bold uppercase tracking-widest text-sm mb-2">Knowledge base</p>
      <h1 class="font-heading font-bold uppercase text-4xl md:text-5xl">Useful Info</h1>
    </div>
  </div>
  <div class="h-1 bg-[#F5A623]"></div>

  <div class="max-w-7xl mx-auto px-4 py-16">
    {posts.length === 0 ? (
      <p class="text-[#6B7280] text-center py-20">Articles coming soon.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map(post => <PostCard post={post} />)}
      </div>
    )}
  </div>
</Base>
