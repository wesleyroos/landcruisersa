---
import Base from '@/layouts/Base.astro';
import { SITE } from '@/data/site';
---

<Base
  title="Advertise With Us — Land Cruiser SA"
  description="Reach South Africa's most passionate Land Cruiser community. Partner with Land Cruiser SA to put your brand in front of serious 4x4 enthusiasts."
>

  <!-- PAGE HEADER -->
  <div class="page-header">
    <div class="ph-inner">
      <p class="ph-eyebrow">Grow with the community</p>
      <h1 class="ph-title">Advertise With Us</h1>
      <p class="ph-sub">Put your brand in front of South Africa's most passionate Land Cruiser community — from casual weekend adventurers to hardcore off-road builders.</p>
    </div>
  </div>

  <!-- WHY ADVERTISE -->
  <section class="s-white">
    <div class="wrap">
      <div class="intro-grid">
        <div class="intro-text">
          <p class="eyebrow">Why Land Cruiser SA</p>
          <h2 class="section-title">A Highly Engaged, <br/>Niche Audience</h2>
          <p class="body-p">Land Cruiser SA is the go-to destination for serious Toyota Land Cruiser owners and enthusiasts across South Africa. Our audience isn't scrolling past — they're actively researching builds, planning trips, and spending money on their passion.</p>
          <p class="body-p">Whether you're an outdoor retailer, vehicle accessory brand, recovery gear supplier, insurance provider, or 4x4 tour operator — this is exactly who you want to reach.</p>
        </div>
        <div class="stats-grid">
          <div class="stat-box">
            <span class="stat-num">Land Cruiser</span>
            <span class="stat-label">Owners & Enthusiasts</span>
          </div>
          <div class="stat-box">
            <span class="stat-num">South Africa</span>
            <span class="stat-label">Focused Audience</span>
          </div>
          <div class="stat-box">
            <span class="stat-num">Guides</span>
            <span class="stat-label">Classifieds & Training</span>
          </div>
          <div class="stat-box">
            <span class="stat-num">High Intent</span>
            <span class="stat-label">Buyers & Builders</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHO WE WORK WITH -->
  <section class="s-cream">
    <div class="wrap">
      <div class="center-head">
        <p class="eyebrow">Who we work with</p>
        <h2 class="section-title">Ideal Partners</h2>
        <p class="sub-p">We partner with brands that the Land Cruiser community genuinely uses and trusts.</p>
      </div>
      <div class="partner-types">
        <div class="pt-card">
          <div class="pt-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3 class="pt-title">Outdoor & Adventure Retail</h3>
          <p class="pt-desc">Outdoor Warehouse, Cape Union Mart, and similar retailers selling gear this audience actively buys.</p>
        </div>
        <div class="pt-card">
          <div class="pt-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          </div>
          <h3 class="pt-title">Vehicle Accessories & Parts</h3>
          <p class="pt-desc">Lift kits, bullbars, roof racks, winches, ARB, Old Man Emu — products this audience searches for daily.</p>
        </div>
        <div class="pt-card">
          <div class="pt-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="pt-title">Insurance & Finance</h3>
          <p class="pt-desc">Specialist off-road or vehicle insurance providers, and vehicle finance options for buyers in the classifieds.</p>
        </div>
        <div class="pt-card">
          <div class="pt-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
          </div>
          <h3 class="pt-title">Tours & Experiences</h3>
          <p class="pt-desc">4x4 tour operators, overlanding routes, safari companies, and bush camp experiences across Southern Africa.</p>
        </div>
        <div class="pt-card">
          <div class="pt-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <h3 class="pt-title">Recovery & Safety Gear</h3>
          <p class="pt-desc">Snatch straps, hi-lift jacks, recovery boards, communications gear — essential kit for the serious enthusiast.</p>
        </div>
        <div class="pt-card">
          <div class="pt-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
          <h3 class="pt-title">Other Premium Brands</h3>
          <p class="pt-desc">Any brand that aligns with the Land Cruiser lifestyle — adventure, quality, and purpose-built products.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- OPPORTUNITIES -->
  <section class="s-white">
    <div class="wrap">
      <div class="center-head">
        <p class="eyebrow">Advertising options</p>
        <h2 class="section-title">How We Can Work Together</h2>
      </div>
      <div class="opps-list">
        <div class="opp-row">
          <div class="opp-num">01</div>
          <div class="opp-content">
            <h3 class="opp-title">Sponsored Content & Guides</h3>
            <p class="opp-desc">Co-created editorial content that lives on the site permanently — gear reviews, how-to guides, or feature stories that add genuine value to the community while showcasing your brand.</p>
          </div>
        </div>
        <div class="opp-row">
          <div class="opp-num">02</div>
          <div class="opp-content">
            <h3 class="opp-title">Partner Listing & Directory</h3>
            <p class="opp-desc">A dedicated partner page on Land Cruiser SA with your brand, products, location, and link — surfaced throughout the site and in relevant guides.</p>
          </div>
        </div>
        <div class="opp-row">
          <div class="opp-num">03</div>
          <div class="opp-content">
            <h3 class="opp-title">Banner & Display Advertising</h3>
            <p class="opp-desc">Strategic placement across high-traffic pages including the home page, listings, and model guides. Contextually relevant, not intrusive.</p>
          </div>
        </div>
        <div class="opp-row">
          <div class="opp-num">04</div>
          <div class="opp-content">
            <h3 class="opp-title">Classifieds Sponsorship</h3>
            <p class="opp-desc">Brand your presence in the classifieds section — ideal for insurance, finance, or accessory brands reaching active buyers at the point of decision.</p>
          </div>
        </div>
        <div class="opp-row">
          <div class="opp-num">05</div>
          <div class="opp-content">
            <h3 class="opp-title">Custom Packages</h3>
            <p class="opp-desc">Have a campaign in mind? We're happy to build something bespoke. Tell us your goals and we'll propose a package that delivers real results for your brand.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT FORM -->
  <section class="s-cream">
    <div class="wrap">
      <div class="form-wrap">
        <div class="form-intro">
          <p class="eyebrow">Get started</p>
          <h2 class="section-title">Let's Talk</h2>
          <p class="body-p">Fill in the form and we'll get back to you within one business day. No pushy sales — just a straightforward conversation about how we can help your brand reach the right people.</p>
          <div class="contact-detail">
            <span class="cd-label">Prefer email?</span>
            <a href={`mailto:${SITE.advertiseEmail}`} class="cd-link">{SITE.advertiseEmail}</a>
          </div>
        </div>
        <div class="form-card">
          <div id="advert-success" class="hidden" style="background:#F0FDF4;border:1px solid #BBF7D0;color:#166534;border-radius:0.5rem;padding:0.875rem 1.125rem;font-size:0.875rem;font-weight:600;margin-bottom:1.25rem;">Enquiry sent — we'll be in touch within one business day.</div>
          <div id="advert-error" class="hidden" style="background:#FEF2F2;border:1px solid #FECACA;color:#991B1B;border-radius:0.5rem;padding:0.875rem 1.125rem;font-size:0.875rem;margin-bottom:1.25rem;">Something went wrong. Please try again or email us directly.</div>
          <form class="advert-form" id="advert-form" novalidate>
            <div class="field-row">
              <div class="field">
                <label class="label" for="name">Your Name</label>
                <input class="input" type="text" id="name" name="name" placeholder="Jane Smith" required />
              </div>
              <div class="field">
                <label class="label" for="company">Company / Brand</label>
                <input class="input" type="text" id="company" name="company" placeholder="Outdoor Warehouse" required />
              </div>
            </div>
            <div class="field-row">
              <div class="field">
                <label class="label" for="email">Email Address</label>
                <input class="input" type="email" id="email" name="email" placeholder="jane@company.co.za" required />
              </div>
              <div class="field">
                <label class="label" for="phone">Phone Number</label>
                <input class="input" type="tel" id="phone" name="phone" placeholder="+27 82 000 0000" />
              </div>
            </div>
            <div class="field">
              <label class="label" for="interest">What interests you most?</label>
              <select class="input select" id="interest" name="interest" required>
                <option value="" disabled selected>Select an option</option>
                <option value="sponsored-content">Sponsored Content / Guides</option>
                <option value="partner-listing">Partner Listing & Directory</option>
                <option value="banner-display">Banner & Display Advertising</option>
                <option value="classifieds">Classifieds Sponsorship</option>
                <option value="custom">Custom Package</option>
                <option value="unsure">Not Sure — Let's Chat</option>
              </select>
            </div>
            <div class="field">
              <label class="label" for="message">Tell us about your brand & goals</label>
              <textarea class="input textarea" id="message" name="message" rows="5" placeholder="What does your brand do, who's your target customer, and what are you hoping to achieve?"></textarea>
            </div>
            <button type="submit" class="submit-btn" id="advert-submit-btn">Send Enquiry →</button>
          </form>
        </div>
      </div>
    </div>
  </section>

</Base>

<script>
  const form = document.getElementById('advert-form') as HTMLFormElement;
  const submitBtn = document.getElementById('advert-submit-btn') as HTMLButtonElement;
  const successEl = document.getElementById('advert-success')!;
  const errorEl = document.getElementById('advert-error')!;

  const INTEREST_LABELS: Record<string, string> = {
    'sponsored-content': 'Sponsored Content / Guides',
    'partner-listing': 'Partner Listing & Directory',
    'banner-display': 'Banner & Display Advertising',
    'classifieds': 'Classifieds Sponsorship',
    'custom': 'Custom Package',
    'unsure': 'Not Sure — Let\'s Chat',
  };

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    successEl.classList.add('hidden');
    errorEl.classList.add('hidden');

    const fd = new FormData(form);
    const name = (fd.get('name') as string ?? '').trim();
    const company = (fd.get('company') as string ?? '').trim();
    const email = (fd.get('email') as string ?? '').trim();
    const phone = (fd.get('phone') as string ?? '').trim();
    const interest = fd.get('interest') as string ?? '';
    const message = (fd.get('message') as string ?? '').trim();

    const fullMessage = [
      `Company: ${company}`,
      phone ? `Phone: ${phone}` : null,
      `Interest: ${INTEREST_LABELS[interest] ?? interest}`,
      message ? `\nMessage:\n${message}` : null,
    ].filter(Boolean).join('\n');

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, phone, subject: 'partnership', message: fullMessage }),
      });
      if (res.ok) {
        form.classList.add('hidden');
        successEl.classList.remove('hidden');
      } else {
        errorEl.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Enquiry →';
      }
    } catch {
      errorEl.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Enquiry →';
    }
  });
</script>

<style>
  /* ─ PAGE HEADER ─────────────────────────────── */
  .page-header {
    background: #111111;
    padding: 5rem 1.5rem 4rem;
    text-align: center;
  }
  .ph-inner { max-width: 660px; margin: 0 auto; }
  .ph-eyebrow {
    font-size: 0.65rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.2em;
    color: #F5A623; margin-bottom: 1rem; display: block;
  }
  .ph-title {
    font-family: var(--font-heading); font-weight: 700;
    text-transform: uppercase; color: white;
    font-size: clamp(2.25rem, 6vw, 3.5rem); line-height: 1;
    margin-bottom: 1.25rem;
  }
  .ph-sub {
    color: rgba(255,255,255,0.6); font-size: 1rem; line-height: 1.7;
  }

  /* ─ SHARED ──────────────────────────────────── */
  .wrap { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
  .s-white { background: #ffffff; padding: 5rem 0; }
  .s-cream { background: #F5F3EE; padding: 5rem 0; }

  .eyebrow {
    font-size: 0.65rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.16em;
    color: #F5A623; margin-bottom: 0.5rem; display: block;
  }
  .section-title {
    font-family: var(--font-heading); font-weight: 700;
    text-transform: uppercase; color: #111111;
    font-size: clamp(1.75rem, 4vw, 2.5rem); line-height: 1.05;
    margin-bottom: 1.25rem;
  }
  .body-p {
    color: #4B5563; font-size: 0.9375rem; line-height: 1.75;
    margin-bottom: 1rem;
  }
  .sub-p {
    color: #6B7280; font-size: 0.9rem; line-height: 1.7;
    max-width: 520px; margin: 0 auto;
  }
  .center-head { text-align: center; margin-bottom: 3rem; }

  /* ─ INTRO / WHY ─────────────────────────────── */
  .intro-grid {
    display: grid; gap: 4rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) { .intro-grid { grid-template-columns: 1fr 1fr; align-items: center; } }

  .stats-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
  }
  .stat-box {
    background: #F5F3EE; border-radius: 0.75rem;
    padding: 1.5rem 1.25rem;
    display: flex; flex-direction: column; gap: 0.35rem;
  }
  .stat-num {
    font-family: var(--font-heading); font-weight: 700;
    text-transform: uppercase; color: #111111;
    font-size: 1.0625rem; line-height: 1.2;
  }
  .stat-label {
    font-size: 0.7rem; text-transform: uppercase;
    letter-spacing: 0.1em; color: #9CA3AF; font-weight: 600;
  }

  /* ─ PARTNER TYPES ───────────────────────────── */
  .partner-types {
    display: grid; gap: 1.25rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
  .pt-card {
    background: white; border: 1px solid #E5E2DC;
    border-radius: 0.875rem; padding: 1.75rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .pt-card:hover {
    border-color: #F5A623;
    box-shadow: 0 8px 24px rgba(0,0,0,0.07);
  }
  .pt-icon {
    color: #F5A623; margin-bottom: 1rem;
  }
  .pt-title {
    font-family: var(--font-heading); font-weight: 700;
    text-transform: uppercase; color: #111111;
    font-size: 0.9375rem; margin-bottom: 0.5rem;
  }
  .pt-desc {
    font-size: 0.8125rem; color: #6B7280; line-height: 1.65;
  }

  /* ─ OPPORTUNITIES ───────────────────────────── */
  .opps-list {
    display: flex; flex-direction: column;
    max-width: 760px; margin: 0 auto;
  }
  .opp-row {
    display: flex; gap: 2rem; align-items: flex-start;
    padding: 2rem 0;
    border-bottom: 1px solid #E5E2DC;
  }
  .opp-row:last-child { border-bottom: none; }
  .opp-num {
    font-family: var(--font-heading); font-weight: 700;
    font-size: 1.75rem; color: #E5E2DC; line-height: 1;
    flex-shrink: 0; width: 3rem;
  }
  .opp-title {
    font-family: var(--font-heading); font-weight: 700;
    text-transform: uppercase; color: #111111;
    font-size: 1rem; margin-bottom: 0.5rem;
  }
  .opp-desc {
    font-size: 0.875rem; color: #6B7280; line-height: 1.7;
  }

  /* ─ CONTACT FORM ────────────────────────────── */
  .form-wrap {
    display: grid; gap: 4rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 900px) { .form-wrap { grid-template-columns: 340px 1fr; align-items: start; } }

  .contact-detail { margin-top: 2rem; }
  .cd-label {
    display: block; font-size: 0.7rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    color: #9CA3AF; margin-bottom: 0.3rem;
  }
  .cd-link {
    color: #F5A623; font-weight: 600; text-decoration: none;
    font-size: 0.9375rem;
    transition: color 0.15s;
  }
  .cd-link:hover { color: #D4881A; }

  .form-card {
    background: white; border: 1px solid #E5E2DC;
    border-radius: 1rem; padding: 2.5rem;
  }

  .advert-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .field-row { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  @media (min-width: 560px) { .field-row { grid-template-columns: 1fr 1fr; } }
  .field { display: flex; flex-direction: column; gap: 0.375rem; }
  .label {
    font-size: 0.75rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: #374151;
  }
  .input {
    width: 100%; padding: 0.75rem 1rem;
    background: #F9F8F6; border: 1.5px solid #E5E2DC;
    border-radius: 0.5rem; font-size: 0.9rem; color: #111111;
    transition: border-color 0.15s;
    font-family: inherit;
  }
  .input:focus { outline: none; border-color: #F5A623; background: white; }
  .select { cursor: pointer; }
  .textarea { resize: vertical; min-height: 120px; }

  .submit-btn {
    background: #F5A623; color: #111111;
    font-family: var(--font-heading); font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em;
    font-size: 0.9375rem; padding: 1rem 2rem;
    border-radius: 0.5rem; border: none;
    cursor: pointer; transition: background 0.15s;
    align-self: flex-start;
  }
  .submit-btn:hover { background: #D4881A; }
</style>
