---
export const prerender = false;

import Base from '@/layouts/Base.astro';
import { SITE } from '@/data/site';
import { db } from '@/db/index';
import { listings } from '@/db/schema';
import { and, eq, desc } from 'drizzle-orm';
import { firstPhoto } from '@/lib/photos';

const PROVINCE_MAP: Record<string, string> = {
  'gauteng': 'Gauteng',
  'western-cape': 'Western Cape',
  'kwazulu-natal': 'KwaZulu-Natal',
  'eastern-cape': 'Eastern Cape',
  'limpopo': 'Limpopo',
  'mpumalanga': 'Mpumalanga',
  'north-west': 'North West',
  'free-state': 'Free State',
  'northern-cape': 'Northern Cape',
};

const { province } = Astro.params;
const provinceName = PROVINCE_MAP[province!];

if (!provinceName) return Astro.redirect('/listings/');

const results = await db.select().from(listings)
  .where(and(eq(listings.status, 'active'), eq(listings.segment, 'land-cruiser'), eq(listings.province, provinceName)))
  .orderBy(desc(listings.featured), desc(listings.created_at));

function formatPrice(n: number) { return 'R' + n.toLocaleString('en-ZA'); }
function formatMileage(n: number) { return n.toLocaleString('en-ZA') + ' km'; }

const canonicalUrl = `${SITE.url}/listings/province/${province}/`;
const title = `Land Cruiser For Sale in ${provinceName}`;
const description = results.length
  ? `Browse ${results.length} Toyota Land Cruiser${results.length !== 1 ? 's' : ''} for sale in ${provinceName}. Classifieds updated daily — 70 Series, 79, 100, 200, 300 Series and Prado.`
  : `Toyota Land Cruiser classifieds in ${provinceName}. Browse listings from private sellers and dealers — updated daily.`;
---

<Base
  title={`${title} — Land Cruiser SA`}
  description={description}
  schema={{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE.url },
      { "@type": "ListItem", "position": 2, "name": "Listings", "item": `${SITE.url}/listings/` },
      { "@type": "ListItem", "position": 3, "name": provinceName, "item": canonicalUrl },
    ],
  }}
>

  <div class="bg-[#111111]">
    <div class="max-w-7xl mx-auto px-4 py-8 sm:py-10">
      <nav class="flex items-center gap-2 text-xs text-white/40 mb-4">
        <a href="/" class="hover:text-[#F5A623] transition-colors">Home</a>
        <span>›</span>
        <a href="/listings/" class="hover:text-[#F5A623] transition-colors">Listings</a>
        <span>›</span>
        <span class="text-white/70">{provinceName}</span>
      </nav>
      <p class="text-[#F5A623] font-heading font-bold uppercase tracking-widest text-xs mb-2">{provinceName}</p>
      <h1 class="font-heading font-bold uppercase text-white text-4xl md:text-5xl leading-none mb-2">{title}</h1>
      <p class="text-white/50 text-sm">{results.length} active listing{results.length !== 1 ? 's' : ''}</p>
    </div>
  </div>
  <div class="h-1 bg-[#F5A623]"></div>

  <div class="max-w-7xl mx-auto px-4 py-8 sm:py-10">

    {results.length === 0 ? (
      <div class="text-center py-24">
        <p class="text-[#6B7280] text-lg mb-4">No active listings in {provinceName} right now.</p>
        <a href="/listings/" class="inline-flex items-center bg-[#F5A623] text-[#111111] font-heading font-bold uppercase tracking-wide px-6 py-3 rounded-xl text-sm hover:bg-[#D4881A] transition-colors">
          Browse All Listings
        </a>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {results.map((l, i) => (
          <a
            href={`/listings/${l.slug}/`}
            class={`group border rounded-xl overflow-hidden transition-all flex flex-col ${
              l.listing_type === 'show_off'
                ? 'bg-[#1A1A1A] border-[rgba(245,166,35,0.15)] hover:border-[#F5A623]'
                : 'bg-white border-[#DDD9D3] hover:border-[#F5A623] hover:shadow-md'
            }`}
          >
            <div class="card-img">
              <img
                src={firstPhoto(l.photos)}
                alt={l.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                width="800" height="500"
                loading={i < 6 ? 'eager' : 'lazy'}
                fetchpriority={i < 3 ? 'high' : 'auto'}
                decoding="async"
              />
              <span class="card-badge">{l.model.replaceAll('-', ' ').toUpperCase()}</span>
            </div>
            <div class="p-4 sm:p-5 flex flex-col flex-1">
              <h2 class={`font-heading font-bold uppercase text-base leading-tight mb-1 group-hover:text-[#F5A623] transition-colors line-clamp-2 ${l.listing_type === 'show_off' ? 'text-white' : 'text-[#111111]'}`}>
                {l.title}
              </h2>
              <p class={`text-xs mb-4 truncate ${l.listing_type === 'show_off' ? 'text-white/40' : 'text-[#6B7280]'}`}>
                {formatMileage(l.mileage)} · {l.transmission === 'manual' ? 'Manual' : 'Auto'} · {l.colour}
              </p>
              <div class="mt-auto">
                {l.listing_type === 'for_sale'
                  ? <p class="font-heading font-bold text-2xl text-[#111111]">{formatPrice(l.price)}</p>
                  : <span class="text-xs font-bold text-[#F5A623] uppercase tracking-wide">★ Community Build</span>
                }
              </div>
            </div>
          </a>
        ))}
      </div>
    )}

    <!-- Other Provinces -->
    <div class="mt-16 pt-10 border-t border-[#DDD9D3]">
      <h2 class="font-heading font-bold uppercase text-xl text-[#111111] mb-5">Browse by Province</h2>
      <div class="flex flex-wrap gap-2">
        {Object.entries(PROVINCE_MAP).filter(([slug]) => slug !== province).map(([slug, name]) => (
          <a href={`/listings/province/${slug}/`} class="px-4 py-2 border border-[#DDD9D3] rounded-full text-sm text-[#4A4A4A] hover:border-[#F5A623] hover:text-[#F5A623] transition-colors">
            {name}
          </a>
        ))}
      </div>
    </div>

  </div>

</Base>

<style>
  .card-img {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #F5F3EE;
  }
  .card-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: #111111;
    color: white;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.5rem;
    border-radius: 0.25rem;
  }
</style>
