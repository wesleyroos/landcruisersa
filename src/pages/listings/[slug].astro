<style>
  /* ─ BASE ─────────────────────────────────────── */
  .page-bg { background: #F5F3EE; min-height: 100vh; }

  /* Every section centres content and adds horizontal padding */
  .section-breadcrumb,
  .section-header,
  .section-mosaic,
  .section-chips,
  .section-body,
  .section-similar {
    max-width: 1200px;
    margin: 0 auto;
    padding-left: 2rem;
    padding-right: 2rem;
  }
  @media (min-width: 768px) {
    .section-breadcrumb,
    .section-header,
    .section-mosaic,
    .section-chips,
    .section-body,
    .section-similar {
      padding-left: 3rem;
      padding-right: 3rem;
    }
  }

  .section-breadcrumb { padding-top: 1.5rem;  padding-bottom: 0.75rem; }
  .section-header      { padding-bottom: 1.5rem; }
  .section-mosaic      { padding-bottom: 1.5rem; }
  .section-chips       { padding-bottom: 2.5rem; }
  .section-body        { padding-bottom: 7rem; }
  @media (min-width: 1024px) { .section-body { padding-bottom: 5rem; } }
  .section-similar     { padding-top: 4rem; padding-bottom: 4rem; }

  /* Back */
  .back-link {
    display: inline-flex; align-items: center; gap: 0.375rem;
    font-size: 0.75rem; color: #6B7280; text-decoration: none;
    transition: color 0.15s;
  }
  .back-link:hover { color: #111111; }

  /* Header */
  .header-row {
    display: flex; align-items: flex-start;
    gap: 1rem; flex-wrap: wrap;
  }
  .header-left { flex: 1; min-width: 0; }
  .header-meta { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; }
  .model-pill {
    background: #F5A623; color: #111111;
    font-size: 0.6rem; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; padding: 0.25rem 0.625rem;
    border-radius: 9999px;
  }
  .year-pill { font-size: 0.75rem; color: #6B7280; font-weight: 600; }
  .listing-title {
    font-family: var(--font-heading); font-weight: 700;
    text-transform: uppercase; color: #111111; line-height: 1.05;
    font-size: clamp(1.5rem, 3.5vw, 2.5rem);
    margin-bottom: 0.4rem;
  }
  .listing-location {
    display: flex; align-items: center; gap: 0.3rem;
    font-size: 0.75rem; color: #6B7280;
  }
  .wa-btn-header {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: #25D366; color: white; text-decoration: none;
    font-family: var(--font-heading); font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.06em;
    font-size: 0.8125rem; padding: 0.75rem 1.25rem;
    border-radius: 0.5rem; white-space: nowrap; flex-shrink: 0;
    transition: background 0.15s;
  }
  .wa-btn-header:hover { background: #1da851; }

  /* MOSAIC */
  .mosaic {
    border-radius: 0.875rem; overflow: hidden;
    background: white; height: 380px;
    display: grid; gap: 4px;
  }
  .mosaic-single { grid-template-columns: 1fr; }
  .mosaic-split { grid-template-columns: 1fr; }
  .mosaic-split .mosaic-grid { display: none; }
  @media (min-width: 768px) {
    .mosaic { height: 480px; }
    .mosaic-split { grid-template-columns: 3fr 2fr; }
    .mosaic-split .mosaic-grid { display: grid; }
  }
  .mosaic-main {
    position: relative; overflow: hidden;
    border: none; padding: 0; cursor: pointer; background: none;
    display: block; width: 100%; height: 100%;
  }
  .mosaic-main img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
  .mosaic-main:hover img { transform: scale(1.02); }
  .photo-count {
    position: absolute; bottom: 0.875rem; left: 0.875rem;
    background: rgba(0,0,0,0.65); color: white; backdrop-filter: blur(4px);
    font-size: 0.7rem; font-weight: 600; padding: 0.35rem 0.75rem;
    border-radius: 9999px;
  }
  .mosaic-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 4px;
  }
  .mosaic-thumb {
    border: none; padding: 0; cursor: pointer;
    overflow: hidden; background: #1a1a1a;
    display: block;
  }
  .mosaic-thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
  .mosaic-thumb:hover img { transform: scale(1.05); }

  /* SPEC CHIPS */
  .spec-chips { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .chip {
    display: inline-flex; align-items: center; gap: 0.375rem;
    background: white; border: 1px solid #E5E2DC;
    color: #4A4A4A; font-size: 0.75rem; font-weight: 600;
    padding: 0.4rem 0.875rem; border-radius: 9999px;
  }
  .chip-icon {
    display: block; flex-shrink: 0;
    filter: brightness(0) invert(29%); /* black → #4A4A4A */
  }

  /* BODY GRID */
  .body-grid {
    display: grid; grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 1024px) {
    .body-grid { grid-template-columns: 1fr 340px; gap: 2rem; }
  }

  /* CARDS */
  .card {
    background: white; border-radius: 0.875rem;
    padding: 1.75rem 2rem; margin-bottom: 1.25rem;
  }
  .card-heading {
    font-family: var(--font-heading); font-weight: 700;
    text-transform: uppercase; font-size: 1.125rem;
