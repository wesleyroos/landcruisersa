---
export const prerender = false;

import Base from '@/layouts/Base.astro';
import { db } from '@/db/index';
import { listings, favorites, savedSearches } from '@/db/schema';
import { and, eq, ne } from 'drizzle-orm';
import { getCurrentUser } from '@/lib/auth-user';
import { parsePhotos, firstThumb, LISTING_PLACEHOLDER } from '@/lib/photos';
// NB: do NOT import modelLabel/normalize here — this page already pulls modelLabel
// transitively via getMarketPosition, and a second direct import creates a
// bundler init-order crash ("Cannot access 'modelLabel2' before initialization").

const { slug } = Astro.params;
const [listing] = await db.select().from(listings).where(eq(listings.slug, slug!));

// All segments are public (Land Cruiser + Toyota 4x4); only pending/missing redirect.
if (!listing || listing.status === 'pending') {
  return Astro.redirect('/listings/');
}
// We don't display vehicles we can't picture — a listing with no real photo
// (none, or only the AutoTrader "no image" placeholder) is hidden everywhere,
// so its detail page redirects rather than showing an empty gallery.
if (parsePhotos(listing.photos).length === 0) {
  return Astro.redirect('/listings/');
}

const isSold = listing.status === 'sold';
const isExternal = Boolean(listing.source_url);
const isShowOff = listing.listing_type === 'show_off';

const mLabel = listing.model.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()).replace(/Fj/, 'FJ');
// /valuation/<model>/ redirects to the hub for non-valuation slugs (70-series/other), so this is safe.
const valuationHref = `/valuation/${listing.model}/`;

const SOURCE_LABEL: Record<string, string> = {
  autotrader: 'AutoTrader',
  wbc:        'WeBuyCars',
  adios:      'Adios',
  wbb:        'WeBuy Bakkies',
  carsza:     'Cars.co.za',
};
const portalName = SOURCE_LABEL[listing.source] ?? 'AutoTrader';

// Similar: same model first, then any active listing in the same segment as fallback
const SEG = eq(listings.segment, listing.segment);
const sameModel = await db.select().from(listings)
  .where(and(eq(listings.status, 'active'), SEG, eq(listings.model, listing.model)))
  .limit(5);
const sameModelFiltered = sameModel.filter(l => l.slug !== slug);

let similarFiltered = sameModelFiltered.slice(0, 3);
if (similarFiltered.length < 3) {
  const others = await db.select().from(listings)
    .where(and(eq(listings.status, 'active'), SEG, ne(listings.model, listing.model)))
    .limit(6);
  const needed = 3 - similarFiltered.length;
  similarFiltered = [...similarFiltered, ...others.filter(l => l.slug !== slug).slice(0, needed)];
}

const photos: string[] = parsePhotos(listing.photos);
const hasPhotos = photos.length > 0;
const mainPhoto = photos[0] ?? LISTING_PLACEHOLDER;
const gridPhotos = photos.slice(1, 5);

// Is this listing already saved by the signed-in user? (drives the heart state)
const currentUser = getCurrentUser(Astro.cookies);
let isFavorited = false;
let hasMatchingSearch = false;   // suppress the save-search nudge if already covered
if (currentUser) {
  const [fav] = await db.select({ id: favorites.id }).from(favorites)
    .where(and(eq(favorites.user_id, currentUser.id), eq(favorites.listing_slug, listing.slug)));
  isFavorited = Boolean(fav);

  // Already has a saved search that would alert on this car (same model + province,
  // or a broader one)? Then don't nudge them to make another.
  const userSearches = await db.select({ model: savedSearches.model, province: savedSearches.province })
    .from(savedSearches)
    .where(and(eq(savedSearches.user_id, currentUser.id), eq(savedSearches.active, true)));
  hasMatchingSearch = userSearches.some(s => {
    const models = (s.model ?? '').split(',').filter(Boolean);
    const provinces = (s.province ?? '').split(',').filter(Boolean);
    const modelOk = models.length === 0 || models.includes(listing.model);
    const provOk = provinces.length === 0 || !listing.province || provinces.includes(listing.province);
    return modelOk && provOk;
  });
}

function maskPhone(phone: string): string {
  const d = phone.trim();
  return d.length > 4 ? d.slice(0, 3) + ' ··· ····' : '··· ····';
}
function maskEmail(email: string): string {
  const [user, domain] = email.split('@');
  if (!domain) return '·····';
  return (user[0] ?? '·') + '····@' + (domain[0] ?? '·') + '····';
}

function waPhone(phone: string): string {
  const digits = phone.replace(/\D/g, '');
  if (digits.startsWith('27') && digits.length >= 11) return digits;
  if (digits.startsWith('0')) return '27' + digits.slice(1);
  return '27' + digits;
}
function waUrl(phone: string, title: string): string {
  return `https://wa.me/${waPhone(phone)}?text=${encodeURIComponent(`Hi, I saw your ${title} on Land Cruiser SA.`)}`;
}

import { getRecentPriceChanges } from '@/lib/price-changes';
import { getMarketPosition } from '@/lib/market-position';
const priceDropAmount = (() => {
  const c = getRecentPriceChanges().get(listing.slug) ?? 0;
  return c < 0 ? Math.abs(c) : 0;
})();

// Cross-platform market position (null when the cohort is too thin)
const marketPos = (!isShowOff && listing.status === 'active') ? getMarketPosition(listing) : null;
const atMarket = marketPos ? Math.abs(marketPos.priceDiff) < marketPos.medianPrice * 0.02 : false;

function formatPrice(n: number) {
  return 'R ' + n.toLocaleString('en-ZA');
}
function formatMileage(n: number) {
  return n.toLocaleString('en-ZA') + ' km';
}
function cap(s: string) {
  return s.charAt(0).toUpperCase() + s.slice(1);
}

const modelLabel = listing.model.replaceAll('-', ' ').toUpperCase();

// Vehicle JSON-LD for AI agents and Google
const vehicleSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "Vehicle",
  "name": listing.title,
  "brand": { "@type": "Brand", "name": "Toyota" },
  "description": listing.description,
  "vehicleModelDate": String(listing.year),
  "color": listing.colour,
  "vehicleTransmission": listing.transmission === 'manual' ? 'ManualTransmission' : 'AutomaticTransmission',
  "image": mainPhoto.startsWith('http') ? mainPhoto : `https://landcruisersa.co.za${mainPhoto}`,
  "url": `https://landcruisersa.co.za/listings/${listing.slug}/`,
  ...(listing.mileage > 0 ? {
    "mileageFromOdometer": {
      "@type": "QuantitativeValue",
      "value": listing.mileage,
      "unitCode": "KMT"
    }
  } : {}),
  ...(!isShowOff && listing.price > 0 ? {
    "offers": {
      "@type": "Offer",
      "price": listing.price,
      "priceCurrency": "ZAR",
      "availability": isSold ? "https://schema.org/SoldOut" : "https://schema.org/InStock",
      // Drop the seller identity from structured data once sold.
      ...(isSold ? {} : {
        "seller": {
          "@type": "Person",
          "name": listing.seller_name
        }
      })
    }
  } : {})
};

// ── SEO: clean unique <title> + always-present meta description ──────────────
// Ahrefs flagged this shared template for 214 "title too long", 538 "meta
// description too short" and 88 "missing". Root causes: raw dealer titles
// sometimes double the year ("2024 2024 Toyota…") and run long, and dealer
// descriptions are frequently empty or duplicated across listings. Build BOTH
// from structured fields so every listing page is unique + correctly sized.
const collapse = (s: string) => (s ?? '').replace(/\s+/g, ' ').trim();
// Collapse an immediately-repeated word: "2024 2024 Toyota" → "2024 Toyota".
const tidyTitle = (t: string) => collapse(t).replace(/\b(\w+)(\s+\1\b)+/gi, '$1');

const cleanTitle = tidyTitle(listing.title);
const TITLE_SUFFIX = ' | Land Cruiser SA';
// Keep the brand suffix only while the whole title stays ≤ 60 chars; otherwise
// use the bare title, truncating on a word boundary past 65.
const pageTitle = (cleanTitle.length + TITLE_SUFFIX.length) <= 60
  ? cleanTitle + TITLE_SUFFIX
  : cleanTitle.length <= 65
    ? cleanTitle
    : cleanTitle.slice(0, 62).replace(/\s+\S*$/, '') + '…';

// Structured, unique meta description — never empty, always ~120-160 chars.
const _yr = listing.year && listing.year > 1900 ? `${listing.year} ` : '';
const _loc = listing.province ? ` in ${listing.province}` : '';
const _km = listing.mileage > 0 ? `${listing.mileage.toLocaleString('en-ZA')} km` : null;
const _spec = [_km, [listing.fuel_type, listing.transmission].filter(Boolean).join(' ').toLowerCase()]
  .filter(Boolean).join(', ');
const _price = (!isShowOff && listing.price > 0) ? `R ${listing.price.toLocaleString('en-ZA')}` : null;

let metaDescription: string;
if (isShowOff) {
  metaDescription = collapse(
    `${_yr}Toyota Land Cruiser ${mLabel} community build${_loc}. See the mods, photos and full spec, plus live ${mLabel} market prices on Land Cruiser SA.`
  );
} else if (isSold) {
  metaDescription = collapse(
    `${_yr}Toyota Land Cruiser ${mLabel}${_loc} — no longer available. Browse similar Land Cruisers for sale and live ${mLabel} market prices on Land Cruiser SA.`
  );
} else {
  metaDescription = collapse(
    `${_yr}Toyota Land Cruiser ${mLabel} for sale${_loc}${_spec ? ` — ${_spec}` : ''}${_price ? `, ${_price}` : ''}. Compare specs, market position & finance on Land Cruiser SA.`
  );
}
if (metaDescription.length > 160) {
  metaDescription = metaDescription.slice(0, 157).replace(/\s+\S*$/, '') + '…';
}
---

<Base
  title={pageTitle}
  description={metaDescription}
  image={mainPhoto}
  schema={vehicleSchema}
  ogType="product"
>

<div class="page-bg">

  <!-- BREADCRUMB -->
  <div class="section-breadcrumb">
    <a href="/listings/" class="back-link">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
      Back to listings
    </a>
  </div>

  <!-- SOLD BANNER -->
  {isSold && (
    <div class="sold-banner-wrap">
      <div class="sold-banner">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <div>
          <strong>This vehicle is no longer available.</strong>
          <span>The listing has been removed from the source — it may have sold or been withdrawn. Browse similar vehicles below.</span>
        </div>
        <a href="/listings/" class="sold-browse">Browse listings →</a>
      </div>
    </div>
  )}

  <!-- HEADER ROW -->
  <div class="section-header">
    <div class="header-row">
      <div class="header-left">
        <div class="header-meta">
          {isShowOff && <span class="show-off-pill">★ Community Build</span>}
          <span class="model-pill">{listing.model.replaceAll('-', ' ').toUpperCase()}</span>
          <span class="year-pill">{listing.year}</span>
        </div>
        <h1 class="listing-title">{listing.title}</h1>
        <p class="listing-location">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/></svg>
          {listing.province} · Listed {(listing.created_at instanceof Date ? listing.created_at : new Date((listing.created_at as unknown as number) * 1000)).toLocaleDateString('en-ZA', { day: 'numeric', month: 'long', year: 'numeric' })}
        </p>
      </div>
      {isSold && (
        <span class="sold-pill">No Longer Available</span>
      )}
      {!isSold && !isExternal && !isShowOff && (
        <a
          href={waUrl(listing.seller_phone, listing.title)}
          target="_blank" rel="noopener"
          class="wa-btn-header" data-track-wa
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.126.554 4.122 1.526 5.855L.057 23.886a.5.5 0 00.606.619l6.222-1.638A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.9a9.89 9.89 0 01-5.033-1.371l-.36-.214-3.733.982.998-3.648-.235-.374A9.861 9.861 0 012.1 12c0-5.459 4.441-9.9 9.9-9.9 5.459 0 9.9 4.441 9.9 9.9 0 5.459-4.441 9.9-9.9 9.9z"/></svg>
          WhatsApp Seller
        </a>
      )}
      {!isSold && isExternal && (
        <a href={listing.source_url!} target="_blank" rel="noopener" class="wa-btn-header ext-btn" data-track-external>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          View on {portalName}
        </a>
      )}
      <button
        id="fav-btn"
        class={`fav-btn ${isFavorited ? 'is-saved' : ''}`}
        data-slug={listing.slug}
        data-saved={isFavorited ? 'true' : 'false'}
        aria-pressed={isFavorited ? 'true' : 'false'}
        aria-label="Save this vehicle"
      >
        <svg class="fav-heart" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        <span class="fav-label">{isFavorited ? 'Saved' : 'Save'}</span>
      </button>
    </div>
  </div>

  <!-- SAVE-SEARCH NUDGE (revealed after you favourite this vehicle; hidden if the
       user already has a saved search that covers this car) -->
  {!hasMatchingSearch && (
    <div id="fav-nudge" class="fav-nudge-wrap hidden" data-model={listing.model} data-province={listing.province}>
      <div class="fav-nudge">
        <span class="fav-nudge-text">Saved! Want alerts for more <strong>{mLabel}</strong>{listing.province ? <> in <strong>{listing.province}</strong></> : null}?</span>
        <button id="nudge-yes" class="fav-nudge-yes" type="button">Yes, alert me</button>
        <button id="nudge-dismiss" class="fav-nudge-x" type="button" aria-label="Dismiss">✕</button>
      </div>
    </div>
  )}

  <!-- PHOTO MOSAIC -->
  <div class="section-mosaic">
    <div class={`mosaic ${gridPhotos.length > 0 ? 'mosaic-split' : 'mosaic-single'}`}>
      {hasPhotos ? (
        <button class="mosaic-main lb-trigger" data-index="0">
          <img src={mainPhoto} alt={listing.title} fetchpriority="high" loading="eager" decoding="async" />
          <span class="photo-count">{photos.length} photos · click to view</span>
        </button>
      ) : (
        <div class="mosaic-main mosaic-noimg">
          <img src={mainPhoto} alt="No photos available for this listing" fetchpriority="high" loading="eager" decoding="async" />
          {isExternal && listing.source_url && (
            <a href={listing.source_url} target="_blank" rel="noopener" class="noimg-cta" data-track-external>See photos on {portalName} →</a>
          )}
        </div>
      )}
      {gridPhotos.length > 0 && (
        <div class="mosaic-grid">
          {gridPhotos.map((p, i) => (
            <button class="mosaic-thumb lb-trigger" data-index={i + 1}>
              <img src={p} alt={`Photo ${i + 2}`} loading="lazy" />
            </button>
          ))}
        </div>
      )}
    </div>
  </div>

  <!-- SPEC CHIPS -->
  <div class="section-chips">
    <div class="spec-chips">
      <span class="chip">
        <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/icons/year.svg" width="14" height="14" alt="" class="chip-icon" />
        {listing.year}
      </span>
      <span class="chip">
        <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/icons/mileage.svg" width="14" height="14" alt="" class="chip-icon" />
        {formatMileage(listing.mileage)}
      </span>
      <span class="chip">
        <img src={`/images/icons/transmission-${listing.transmission}.svg`} width="14" height="14" alt="" class="chip-icon" />
        {cap(listing.transmission)}
      </span>
      {listing.fuel_type && (
        <span class="chip">
          {['diesel', 'petrol'].includes(listing.fuel_type.toLowerCase()) && (
            <img src={`/images/icons/${listing.fuel_type.toLowerCase()}.svg`} width="14" height="14" alt="" class="chip-icon" />
          )}
          {listing.fuel_type}
        </span>
      )}
      {listing.fuel_consumption && (
        <span class="chip">
          <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/icons/fuel-nozzle.svg" width="14" height="14" alt="" class="chip-icon" />
          {listing.fuel_consumption} L/100km
        </span>
      )}
      {listing.power_kw && (
        <span class="chip">
          <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/icons/engine-power.svg" width="14" height="14" alt="" class="chip-icon" />
          {listing.power_kw} kW
        </span>
      )}
      {listing.seats && (
        <span class="chip">
          <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/icons/seats.svg" width="14" height="14" alt="" class="chip-icon" />
          {listing.seats} Seats
        </span>
      )}
      {listing.co2 && (
        <span class="chip">
          <img src="https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/icons/carbon-emissions.svg" width="14" height="14" alt="" class="chip-icon" />
          {listing.co2} g/km CO₂
        </span>
      )}
      <span class="chip">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="12" cy="12" r="10"/><polyline points="12 8 12 12 14 14"/></svg>
        {listing.new_or_used}
      </span>
    </div>
  </div>

  <!-- BODY -->
  <div class="section-body">
    <div class="body-grid">

      <!-- LEFT -->
      <div class="body-left">

        <!-- Market position -->
        {marketPos && (
          <div class="card mp-card">
            <h2 class="card-heading">Market Position</h2>
            <div class="mp-grid">
              <div class="mp-tile">
                <p class={`mp-big ${marketPos.priceDiff < 0 && !atMarket ? 'mp-good' : ''}`}>
                  {atMarket
                    ? 'At market price'
                    : `R ${Math.abs(marketPos.priceDiff).toLocaleString('en-ZA')} ${marketPos.priceDiff < 0 ? 'below' : 'above'} market`}
                </p>
                <p class="mp-sub">vs median of {marketPos.cohortSize} similar {marketPos.cohortLabel} listings (R {marketPos.medianPrice.toLocaleString('en-ZA')})</p>
              </div>
              {marketPos.mileageDiff !== null && (
                <div class="mp-tile">
                  <p class={`mp-big ${marketPos.mileageDiff < 0 ? 'mp-good' : ''}`}>
                    {Math.abs(marketPos.mileageDiff).toLocaleString('en-ZA')} km {marketPos.mileageDiff < 0 ? 'below' : 'above'} average
                  </p>
                  <p class="mp-sub">similar vehicles average {marketPos.avgMileage!.toLocaleString('en-ZA')} km</p>
                </div>
              )}
              <div class="mp-tile">
                <p class="mp-big">1 of {marketPos.modelSupply} for sale</p>
                <p class="mp-sub"><a href={`/market/${listing.model}/`}>{listing.model.replace(/-/g, ' ').toUpperCase()} live market data →</a></p>
              </div>
            </div>
            {marketPos.history.length > 0 && (
              <div class="mp-history">
                <p class="mp-history-head">Price history on this vehicle</p>
                {marketPos.history.map(h => (
                  <p class="mp-history-row">
                    <span class="mp-date">{h.at.toLocaleDateString('en-ZA', { day: 'numeric', month: 'short' })}</span>
                    <span class="mp-old">R {h.old_price.toLocaleString('en-ZA')}</span>
                    <span class="mp-arrow">→</span>
                    <span class={h.new_price < h.old_price ? 'mp-new-drop' : 'mp-new'}>R {h.new_price.toLocaleString('en-ZA')}</span>
                  </p>
                ))}
              </div>
            )}
          </div>
        )}

        <!-- About -->
        <div class="card">
          <h2 class="card-heading">{isShowOff ? 'Build Story' : 'About this vehicle'}</h2>
          <p class="description-text">{listing.description}</p>
        </div>

        <!-- Value-my-Cruiser CTA -->
        <div class="card" style="display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;background:#111">
          <div>
            <h2 class="card-heading" style="color:#fff">Own a {mLabel}?</h2>
            <p style="color:rgba(255,255,255,0.7);font-size:0.9rem;margin-top:0.3rem">Free instant estimate of what yours is worth — from live market prices.</p>
          </div>
          <a href={valuationHref} style="background:#F5A623;color:#111;font-family:var(--font-heading);font-weight:700;text-transform:uppercase;letter-spacing:0.03em;font-size:0.85rem;padding:0.7rem 1.2rem;border-radius:0.5rem;text-decoration:none;white-space:nowrap">Value my {mLabel} →</a>
        </div>

        <!-- Mods (show_off only) -->
        {isShowOff && listing.mods && (
          <div class="card">
            <h2 class="card-heading">Build Mods</h2>
            <div class="mods-list">
              {listing.mods.split(/[\n,]/).map((m: string) => m.trim()).filter(Boolean).map((mod: string) => (
                <span class="mod-tag">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  {mod}
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- Finance calculator -->
        {!isShowOff && !isSold && listing.price > 0 && (
          <div class="card fin-card" id="fin-card" data-price={listing.price}>
            <h2 class="card-heading">Finance Estimate</h2>
            <div class="fin-grid">
              <div class="fin-inputs">
                <label class="fin-label">
                  Deposit
                  <div class="fin-input-row">
                    <span class="fin-prefix">R</span>
                    <input type="number" id="fin-deposit" class="fin-input" min="0" step="5000" />
                  </div>
                  <span class="fin-hint" id="fin-deposit-pct"></span>
                </label>
                <label class="fin-label">
                  Term
