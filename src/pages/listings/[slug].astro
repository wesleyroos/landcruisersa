    font-size: 0.875rem; color: #4A4A4A;
    line-height: 1.75; white-space: pre-wrap;
  }
  .specs-table { display: flex; flex-direction: column; gap: 0; }
  .spec-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.75rem 0; border-bottom: 1px solid #F5F3EE;
  }
  .spec-row:last-child { border-bottom: none; }
  .spec-k { font-size: 0.8125rem; color: #6B7280; }
  .spec-v { font-size: 0.8125rem; font-weight: 600; color: #111111; }

  .safety-card {
    display: flex; align-items: flex-start; gap: 0.75rem;
    background: #FFFBF0; border: 1px solid rgba(245,166,35,0.25);
    border-radius: 0.75rem; padding: 1.25rem 1.5rem;
  }
  .safety-card svg { flex-shrink: 0; margin-top: 1px; }
  .safety-card p { font-size: 0.8125rem; color: #6B7280; line-height: 1.6; }
  .safety-card strong { color: #111111; }

  /* PRICE CARD */
  .price-card {
    background: white; border-radius: 0.875rem;
    overflow: hidden; position: sticky; top: 80px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
  }
  .price-header {
    background: #111111; padding: 1.5rem 1.75rem;
    display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem;
  }
  .price-label { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #F5A623; margin-bottom: 0.4rem; }
  .price-value {
    font-family: var(--font-heading); font-weight: 700;
    color: white; font-size: 2.25rem; line-height: 1; margin-bottom: 0.3rem;
  }
  .price-sub { font-size: 0.7rem; color: rgba(255,255,255,0.35); }
  .condition-badge {
    font-size: 0.65rem; font-weight: 700; text-transform: uppercase;
    padding: 0.3rem 0.75rem; border-radius: 9999px; white-space: nowrap; flex-shrink: 0;
  }
  .cb-neutral { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.7); }

  .seller-section {
    padding: 1.25rem 1.75rem; border-bottom: 1px solid #F0EDE8;
  }
  .seller-label { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #9CA3AF; margin-bottom: 0.5rem; }
  .seller-name { font-weight: 700; font-size: 0.9375rem; color: #111111; margin-bottom: 0.75rem; }
