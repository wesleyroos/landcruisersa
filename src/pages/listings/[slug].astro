<script define:vars={{ _viewSlug: listing.slug }}>
  // Track one view per listing per session — refreshes don't inflate counts
  try {
    const seenKey = 'lcsa_viewed_' + _viewSlug;
    if (!sessionStorage.getItem(seenKey)) {
      sessionStorage.setItem(seenKey, '1');
      const utm = new URLSearchParams(location.search).get('utm_source')
        || sessionStorage.getItem('lcsa_utm')
        || null;
      navigator.sendBeacon('/api/track-view', JSON.stringify({
        listing_slug: _viewSlug,
        utm_source: utm,
      }));
    }
  } catch {}
</script>

{isExternal && (
  <script define:vars={{ _slug: listing.slug, _title: listing.title, _source: listing.source }}>
    document.querySelectorAll('[data-track-external]').forEach(function(a) {
      a.addEventListener('click', function() {
        try {
          navigator.sendBeacon('/api/track-click', JSON.stringify({
            listing_slug: _slug,
            listing_title: _title,
            source: _source,
            client_id: window.__lcsaCid || null,
          }));
        } catch {}
      });
    });
  </script>
)}

<script define:vars={{ _slug: listing.slug, _title: listing.title, _model: listing.model }}>
    // ── Finance calculator ───────────────────────────────────────────────────
    (function () {
      const card = document.getElementById('fin-card');
      if (!card) return;
      const price = Number(card.dataset.price);
      const R = (n) => 'R ' + Math.round(n).toLocaleString('en-ZA');
      let lastCalc = null; // most recent calculator state, attached to a lead on submit

      const els = {
        deposit: document.getElementById('fin-deposit'),
        term: document.getElementById('fin-term'),
        rate: document.getElementById('fin-rate'),
        balloon: document.getElementById('fin-balloon'),
        monthly: document.getElementById('fin-monthly'),
        financed: document.getElementById('fin-financed'),
        interest: document.getElementById('fin-interest'),
        fees: document.getElementById('fin-fees'),
        total: document.getElementById('fin-total'),
        balloonRow: document.getElementById('fin-balloon-row'),
        balloonAmt: document.getElementById('fin-balloon-amt'),
        depositPct: document.getElementById('fin-deposit-pct'),
      };

      // NCA standard fees (incl. VAT)
      const INITIATION = 1207.5;
      const SERVICE = 69;

      els.deposit.value = String(Math.round(price * 0.1 / 1000) * 1000);

      let tracked = false;
      function calc() {
        const deposit = Math.min(Math.max(Number(els.deposit.value) || 0, 0), price);
        const n = Number(els.term.value);
        const annual = Math.min(Math.max(Number(els.rate.value) || 11.5, 5), 25);
        const i = annual / 100 / 12;
        const balloonAmt = price * (Number(els.balloon.value) / 100);

        const principal = price - deposit + INITIATION;
        // Payment with balloon as future value
        const pmt = i > 0
          ? (i * (principal - balloonAmt * Math.pow(1 + i, -n))) / (1 - Math.pow(1 + i, -n))
          : (principal - balloonAmt) / n;
        const monthly = pmt + SERVICE;

        const totalPaid = monthly * n + deposit + balloonAmt;
        const totalInterest = totalPaid - price - INITIATION - SERVICE * n;

        els.monthly.innerHTML = R(monthly) + ' <em>p/m</em>';
        els.financed.textContent = R(principal);
        els.interest.textContent = R(Math.max(0, totalInterest));
        els.fees.textContent = R(INITIATION + SERVICE * n);
        els.total.textContent = R(totalPaid);
        els.depositPct.textContent = price > 0 ? Math.round(deposit / price * 100) + '% of asking price' : '';
        els.balloonRow.hidden = balloonAmt <= 0;
        els.balloonAmt.textContent = R(balloonAmt);
        lastCalc = { deposit, term: n, rate: annual, balloonPct: Number(els.balloon.value), monthly };
      }

      ['input', 'change'].forEach(evt => {
        [els.deposit, els.term, els.rate, els.balloon].forEach(el => el.addEventListener(evt, function () {
          calc();
          if (!tracked) {
            tracked = true; // one demand-signal event per page view, on first interaction
            try {
              navigator.sendBeacon('/api/track-click', JSON.stringify({
                listing_slug: _slug, listing_title: _title, source: 'finance_calc',
                client_id: window.__lcsaCid || null,
              }));
            } catch {}
          }
        }));
      });

      calc();

      // ── Lead capture: calculation → real callback ──────────────────────────
      const leadBtn = document.getElementById('fin-cta-btn');
      const leadForm = document.getElementById('fin-lead-form');
      const leadSuccess = document.getElementById('fin-lead-success');
      const leadErr = document.getElementById('fin-lead-err');
      const leadSubmit = document.getElementById('fin-lead-submit');

      if (leadBtn && leadForm) {
        leadBtn.addEventListener('click', function () {
          leadForm.hidden = false;
          leadBtn.hidden = true;
          const nameEl = document.getElementById('fin-lead-name');
          if (nameEl) nameEl.focus();
        });

        leadForm.addEventListener('submit', async function (e) {
          e.preventDefault();
          const name    = document.getElementById('fin-lead-name').value.trim();
          const phone   = document.getElementById('fin-lead-phone').value.trim();
          const email   = document.getElementById('fin-lead-email').value.trim();
          const consent = document.getElementById('fin-lead-consent').checked;
          if (!name || !phone || !email || !consent) return;

          leadErr.hidden = true;
          leadSubmit.disabled = true;
          leadSubmit.textContent = 'Sending…';

          const c = lastCalc || {};
          try {
            const res = await fetch('/api/finance-lead', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                name, phone, email, consent, client_id: window.__lcsaCid || null,
                listing_slug: _slug, listing_title: _title, model: _model, price,
                deposit: c.deposit, term_months: c.term, interest_rate: c.rate,
                balloon_pct: c.balloonPct,
                est_monthly: c.monthly != null ? Math.round(c.monthly) : null,
              }),
            });
            if (!res.ok) throw new Error('bad status');
            leadForm.hidden = true;
            leadSuccess.hidden = false;
          } catch {
            leadErr.textContent = 'Something went wrong — please try again, or use WhatsApp / call the seller above.';
            leadErr.hidden = false;
            leadSubmit.disabled = false;
            leadSubmit.textContent = 'Request callback';
          }
        });
      }
    })();
</script>

{!isExternal && !isShowOff && !isSold && (
  <script define:vars={{ _slug: listing.slug, _title: listing.title }}>
    document.querySelectorAll('[data-track-wa]').forEach(function(a) {
      a.addEventListener('click', function() {
        try {
          navigator.sendBeacon('/api/track-click', JSON.stringify({
            listing_slug: _slug,
            listing_title: _title,
            source: 'whatsapp',
            client_id: window.__lcsaCid || null,
          }));
        } catch {}
      });
    });
    document.querySelectorAll('[data-track-call]').forEach(function(a) {
      a.addEventListener('click', function() {
        try {
          navigator.sendBeacon('/api/track-click', JSON.stringify({
            listing_slug: _slug,
            listing_title: _title,
            source: 'call',
            client_id: window.__lcsaCid || null,
          }));
        } catch {}
      });
    });
    document.querySelectorAll('[data-track-email]').forEach(function(a) {
      a.addEventListener('click', function() {
        try {
          navigator.sendBeacon('/api/track-click', JSON.stringify({
            listing_slug: _slug,
            listing_title: _title,
            source: 'email',
            client_id: window.__lcsaCid || null,
          }));
        } catch {}
      });
    });

    // Click-to-reveal contact — the value isn't in the page until requested,
    // and the request itself is the tracked event
    document.querySelectorAll('[data-reveal]').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        const kind = btn.getAttribute('data-reveal');
        btn.disabled = true;
        try {
          const res = await fetch('/api/listing-contact?slug=' + encodeURIComponent(_slug) + '&kind=' + kind);
          if (!res.ok) { btn.disabled = false; return; }
          const data = await res.json();
          const a = document.createElement('a');
          a.className = 'seller-contact';
          if (kind === 'phone') {
            a.href = 'tel:' + String(data.value).replace(/\s/g, '');
            a.setAttribute('data-track-call', '');
          } else {
            a.href = 'mailto:' + data.value;
            a.setAttribute('data-track-email', '');
          }
          a.textContent = data.value;
          a.addEventListener('click', function() {
            try {
              navigator.sendBeacon('/api/track-click', JSON.stringify({
                listing_slug: _slug, listing_title: _title,
                source: kind === 'phone' ? 'call' : 'email',
                client_id: window.__lcsaCid || null,
              }));
            } catch {}
          });
          btn.replaceWith(a);
        } catch { btn.disabled = false; }
      });
    });

  </script>
)}

