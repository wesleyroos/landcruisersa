<script define:vars={{ photos }}>
  const lb = document.getElementById('lightbox');
  const lbImg = document.getElementById('lb-img');
  const lbCounter = document.getElementById('lb-counter');
  let current = 0;

  // Preload photos so a swipe shows the next image instantly instead of
  // kicking off an on-demand fetch (the source of the sluggish feel).
  const preloaded = new Set();
  function preload(i) {
    const idx = (i + photos.length) % photos.length;
    if (preloaded.has(idx) || !photos[idx]) return;
    preloaded.add(idx);
    new Image().src = photos[idx];
  }

  function render() {
    lbImg.src = photos[current];
    lbCounter.textContent = `${current + 1} / ${photos.length}`;
    preload(current + 1);   // keep immediate neighbours warm
    preload(current - 1);
  }
  function open(index) {
    current = index;
    lbImg.style.transition = '';
    lbImg.style.transform = '';
    render();
    // warm the whole gallery in the background so every swipe is instant
    photos.forEach((_, i) => preload(i));
    lb.classList.add('lb-open');
    document.body.style.overflow = 'hidden';
  }
  function close() {
    lb.classList.remove('lb-open');
    document.body.style.overflow = '';
  }
  function prev() { current = (current - 1 + photos.length) % photos.length; render(); }
  function next() { current = (current + 1) % photos.length; render(); }

  document.querySelectorAll('.lb-trigger').forEach(btn => {
    btn.addEventListener('click', () => open(Number(btn.dataset.index)));
  });
  document.getElementById('lb-close').addEventListener('click', close);
  document.getElementById('lb-prev').addEventListener('click', prev);
  document.getElementById('lb-next').addEventListener('click', next);
  lb.addEventListener('click', e => { if (e.target === lb) close(); });
  document.addEventListener('keydown', e => {
    if (!lb.classList.contains('lb-open')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') prev();
    if (e.key === 'ArrowRight') next();
  });

  /* ─ Touch swipe (mobile) ─ image follows the finger, snaps past a threshold.
     Axis-locked so vertical scroll and pinch-zoom (2 fingers) still work. */
  let startX = 0, startY = 0, dx = 0, dragging = false, axis = null;
  const SWIPE_THRESHOLD = 50;

  lb.addEventListener('touchstart', e => {
    if (e.touches.length !== 1) { dragging = false; return; }
    startX = e.touches[0].clientX;
    startY = e.touches[0].clientY;
    dx = 0; axis = null; dragging = true;
    lbImg.style.transition = 'none';
  }, { passive: true });

  lb.addEventListener('touchmove', e => {
    if (!dragging || e.touches.length !== 1) return;
    const mvX = e.touches[0].clientX - startX;
    const mvY = e.touches[0].clientY - startY;
    if (axis === null) {
      if (Math.abs(mvX) < 8 && Math.abs(mvY) < 8) return;
      axis = Math.abs(mvX) > Math.abs(mvY) ? 'x' : 'y';
    }
    if (axis !== 'x') return;          // vertical / pinch → leave to the browser
    dx = mvX;
    e.preventDefault();                // stop the page from scrolling sideways
    lbImg.style.transform = `translateX(${dx}px)`;
  }, { passive: false });

  lb.addEventListener('touchend', () => {
    if (!dragging) return;
    dragging = false;
    lbImg.style.transition = 'transform 0.2s ease';
    if (axis === 'x' && Math.abs(dx) > SWIPE_THRESHOLD) {
      dx < 0 ? next() : prev();
    }
    lbImg.style.transform = '';
  });
</script>

<script>
  // Save / unsave this vehicle. The session cookie is httpOnly, so the client
  // can't read login state — instead we call the API and, on a 401, open the
  // sign-in modal (falling back to the /signin page if it isn't loaded yet).
  function goSignin() {
    const next = location.pathname + location.search;
    const w = window as any;
    if (typeof w.lcsaSignin === 'function') w.lcsaSignin(next);
    else location.href = `/signin/?next=${encodeURIComponent(next)}`;
  }
  const favBtn = document.getElementById('fav-btn');
  if (favBtn) {
    const label = favBtn.querySelector('.fav-label');
    favBtn.addEventListener('click', async () => {
      const slug = favBtn.dataset.slug;
      const saved = favBtn.dataset.saved === 'true';
      favBtn.setAttribute('disabled', 'true');
      try {
        const res = await fetch('/api/favorites', {
          method: saved ? 'DELETE' : 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug }),
        });
        if (res.status === 401) { goSignin(); return; }
        if (!res.ok) throw new Error('request failed');
        const nowSaved = !saved;
        favBtn.dataset.saved = String(nowSaved);
        favBtn.setAttribute('aria-pressed', String(nowSaved));
        favBtn.classList.toggle('is-saved', nowSaved);
        if (label) label.textContent = nowSaved ? 'Saved' : 'Save';
        // Just saved? Offer a matching alert search (once per page view).
        if (nowSaved) maybeShowNudge();
      } catch {
        // leave state unchanged on failure
      } finally {
        favBtn.removeAttribute('disabled');
      }
    });
  }

  // ── Favourite → "alert me for similar" nudge ──
  const nudge = document.getElementById('fav-nudge');
  let nudgeHandled = false;   // don't re-show after accept/dismiss this page view
  function maybeShowNudge() {
    if (!nudge || nudgeHandled) return;
    nudge.classList.remove('hidden');
  }
  document.getElementById('nudge-dismiss')?.addEventListener('click', () => {
    nudgeHandled = true;
    nudge?.classList.add('hidden');
  });
  document.getElementById('nudge-yes')?.addEventListener('click', async () => {
    if (!nudge) return;
    const yes = document.getElementById('nudge-yes') as HTMLButtonElement;
    const model = nudge.dataset.model;
    const province = nudge.dataset.province;
    yes.disabled = true;
    try {
      const res = await fetch('/api/saved-search', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ model: model ? [model] : [], province: province ? [province] : [] }),
      });
      if (res.status === 401) { goSignin(); return; }
      const data = await res.json().catch(() => ({}));
      nudgeHandled = true;
      const text = nudge.querySelector('.fav-nudge-text');
      if (res.ok && data.ok) {
        if (text) text.innerHTML = "✓ Done — we'll email you when a match is listed. Manage in <a href='/account/' style='color:#D4881A;text-decoration:underline;'>your account</a>.";
        yes.style.display = 'none';
      } else {
        if (text) text.textContent = data.error || 'Could not save that search.';
      }
    } catch {
      yes.disabled = false;
    }
  });
</script>

