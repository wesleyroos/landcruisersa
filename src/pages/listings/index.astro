---
export const prerender = false;

import Base from '@/layouts/Base.astro';
import { SITE } from '@/data/site';
import { db } from '@/db/index';
import { listings } from '@/db/schema';
import { inArray, desc } from 'drizzle-orm';
import { getRecentPriceChanges } from '@/lib/price-changes';

// All segments are public — Land Cruisers plus the Toyota 4x4 line (Hilux/Fortuner).
// Only the columns the cards need — avoids hauling description/mods/source text
// for ~2,000 rows on every request (the old SELECT * was the main page slowness).
const rawListings = await db
  .select({
    slug: listings.slug, title: listings.title, model: listings.model, year: listings.year,
    price: listings.price, mileage: listings.mileage, province: listings.province,
    transmission: listings.transmission, colour: listings.colour, photos: listings.photos,
    listing_type: listings.listing_type, status: listings.status,
    new_or_used: listings.new_or_used, featured: listings.featured,
  })
  .from(listings)
  .where(inArray(listings.status, ['active', 'sold']))
  .orderBy(desc(listings.featured), desc(listings.created_at));

const priceChanges = getRecentPriceChanges();
const PAGE_SIZE = 18;

// Compact client dataset — filtered & paginated in the browser. Shipping this as
// JSON (~12 small fields/row) is far lighter than rendering ~2,000 card elements.
const data = rawListings.map(l => ({
  slug: l.slug, title: l.title, model: l.model, year: l.year, price: l.price,
  mileage: l.mileage, province: l.province, transmission: l.transmission,
  colour: l.colour, photo: firstPhoto(l.photos), type: l.listing_type,
  status: l.status, nu: l.new_or_used, drop: priceChanges.get(l.slug) ?? 0,
}));
const dataJson = JSON.stringify(data).replace(/</g, '\\u003c');

// Server-render only the first page (default view: active, newest first) for fast
// first paint + no-JS fallback; the client takes over filtering/pagination.
const ssrCards = data.filter(d => d.status === 'active').slice(0, PAGE_SIZE);

const PROVINCES = ['All', 'Gauteng', 'Western Cape', 'KwaZulu-Natal', 'Eastern Cape', 'Limpopo', 'Mpumalanga', 'North West', 'Free State', 'Northern Cape'];
const MODELS = [
  { value: 'all', label: 'All Models' },
  { value: '76-series', label: '76 Series' },
  { value: '78-series', label: '78 Series' },
  { value: '79-series', label: '79 Series' },
  { value: '80-series', label: '80 Series' },
  { value: '100-series', label: '100 Series' },
  { value: '200-series', label: '200 Series' },
  { value: '300-series', label: '300 Series' },
  { value: 'prado', label: 'Prado' },
  { value: 'fj', label: 'FJ' },
  { value: 'hilux', label: 'Hilux' },
  { value: 'fortuner', label: 'Fortuner' },
  { value: 'other', label: 'Other' },
];
const MODEL_OPTIONS = MODELS;

function formatPrice(n: number) {
  return 'R' + n.toLocaleString('en-ZA');
}
function formatMileage(n: number) {
  return n.toLocaleString('en-ZA') + ' km';
}
function firstPhoto(photos: string) {
  try { return JSON.parse(photos)[0] ?? 'https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/og-default.jpg'; }
  catch { return 'https://pub-6c900fb2e73a4b89bc049099101e4591.r2.dev/images/og-default.jpg'; }
}
---

<Base
  title="Land Cruiser Listings — Buy & Sell in South Africa"
  description="Browse Land Cruiser classifieds in South Africa. For sale and community build showcases — 70, 79, 100, 200 and 300 Series."
  schema={{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE.url },
      { "@type": "ListItem", "position": 2, "name": "Listings", "item": `${SITE.url}/listings/` }
    ]
  }}
>

  <!-- HEADER -->
  <div class="bg-[#111111]">
    <div class="max-w-7xl mx-auto px-4 py-8 sm:py-10 flex flex-col sm:flex-row sm:items-end justify-between gap-4">
      <div>
        <p class="text-[#F5A623] font-heading font-bold uppercase tracking-widest text-xs mb-2">Classifieds</p>
        <h1 class="font-heading font-bold uppercase text-white text-4xl md:text-5xl leading-none">Land Cruiser Listings</h1>
      </div>
      <a href="/listings/submit/" class="inline-flex items-center gap-2 bg-[#F5A623] text-[#111111] font-heading font-bold uppercase tracking-wide px-6 py-3.5 rounded-xl hover:bg-[#D4881A] transition-colors text-sm self-start sm:self-auto touch-manipulation">
        + List Your Vehicle
      </a>
    </div>
  </div>
  <div class="h-1 bg-[#F5A623]"></div>


  <div class="max-w-7xl mx-auto px-4 py-8 sm:py-10">

    <!-- TYPE TOGGLE -->
    <div class="flex gap-2 mb-5" id="type-filter">
      <button class="type-pill active" data-type="all">All</button>
      <button class="type-pill" data-type="for_sale">For Sale</button>
      <button class="type-pill" data-type="show_off">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        Show Off
      </button>
      <button class="type-pill" data-type="sold">Sold</button>
    </div>

    <!-- DROPDOWN FILTERS -->
    <div class="flex flex-wrap gap-2.5 mb-8" id="filters">
      <div class="relative" id="ms-model">
        <button type="button" id="ms-model-btn" aria-expanded="false"
          class="border border-[#DDD9D3] rounded-xl px-4 py-2.5 text-sm bg-white focus:outline-none focus:border-[#F5A623] transition-colors cursor-pointer min-h-[44px] flex items-center gap-2 justify-between min-w-[150px]">
          <span id="ms-model-label" class="truncate">All Models</span>
          <svg width="10" height="6" viewBox="0 0 10 6" class="flex-shrink-0"><path d="M1 1l4 4 4-4" stroke="#9CA3AF" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div id="ms-model-panel" class="absolute z-30 mt-1 w-56 max-h-72 overflow-auto bg-white border border-[#DDD9D3] rounded-xl shadow-lg py-1 hidden">
          {MODEL_OPTIONS.filter(m => m.value !== 'all').map(m => (
            <label class="flex items-center gap-2.5 px-4 py-2 text-sm cursor-pointer hover:bg-[#F5F3EE]">
              <input type="checkbox" value={m.value} class="ms-model-cb accent-[#F5A623] w-4 h-4" />
              <span>{m.label}</span>
            </label>
          ))}
        </div>
      </div>
      <div class="relative" id="ms-province">
        <button type="button" id="ms-province-btn" aria-expanded="false"
          class="border border-[#DDD9D3] rounded-xl px-4 py-2.5 text-sm bg-white focus:outline-none focus:border-[#F5A623] transition-colors cursor-pointer min-h-[44px] flex items-center gap-2 justify-between min-w-[150px]">
          <span id="ms-province-label" class="truncate">All Provinces</span>
          <svg width="10" height="6" viewBox="0 0 10 6" class="flex-shrink-0"><path d="M1 1l4 4 4-4" stroke="#9CA3AF" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div id="ms-province-panel" class="absolute z-30 mt-1 w-56 max-h-72 overflow-auto bg-white border border-[#DDD9D3] rounded-xl shadow-lg py-1 hidden">
          {PROVINCES.filter(p => p !== 'All').map(p => (
            <label class="flex items-center gap-2.5 px-4 py-2 text-sm cursor-pointer hover:bg-[#F5F3EE]">
              <input type="checkbox" value={p} class="ms-province-cb accent-[#F5A623] w-4 h-4" />
              <span>{p}</span>
            </label>
          ))}
        </div>
      </div>
      <div class="relative" id="price-filter">
        <button type="button" id="price-btn" aria-expanded="false"
          class="border border-[#DDD9D3] rounded-xl px-4 py-2.5 text-sm bg-white focus:outline-none focus:border-[#F5A623] transition-colors cursor-pointer min-h-[44px] flex items-center gap-2 justify-between min-w-[140px]">
          <span id="price-label" class="truncate">Any Price</span>
          <svg width="10" height="6" viewBox="0 0 10 6" class="flex-shrink-0"><path d="M1 1l4 4 4-4" stroke="#9CA3AF" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div id="price-panel" class="absolute z-30 mt-1 w-72 bg-white border border-[#DDD9D3] rounded-xl shadow-lg py-1 hidden">
          <button type="button" class="price-preset w-full text-left px-4 py-2 text-sm hover:bg-[#F5F3EE]" data-min="0" data-max="">Any Price</button>
          <button type="button" class="price-preset w-full text-left px-4 py-2 text-sm hover:bg-[#F5F3EE]" data-min="0" data-max="300000">Under R300k</button>
          <button type="button" class="price-preset w-full text-left px-4 py-2 text-sm hover:bg-[#F5F3EE]" data-min="300000" data-max="600000">R300k – R600k</button>
          <button type="button" class="price-preset w-full text-left px-4 py-2 text-sm hover:bg-[#F5F3EE]" data-min="600000" data-max="1000000">R600k – R1m</button>
          <button type="button" class="price-preset w-full text-left px-4 py-2 text-sm hover:bg-[#F5F3EE]" data-min="1000000" data-max="1500000">R1m – R1.5m</button>
          <button type="button" class="price-preset w-full text-left px-4 py-2 text-sm hover:bg-[#F5F3EE]" data-min="1500000" data-max="">Over R1.5m</button>
          <div class="border-t border-[#EEE] my-1"></div>
          <div class="px-3 py-2 flex items-center gap-1.5">
            <input type="number" inputmode="numeric" min="0" id="price-min" placeholder="Min R" class="w-full min-w-0 border border-[#DDD9D3] rounded-lg px-2 py-1.5 text-sm focus:outline-none focus:border-[#F5A623]" />
            <span class="text-[#9CA3AF]">–</span>
            <input type="number" inputmode="numeric" min="0" id="price-max" placeholder="Max R" class="w-full min-w-0 border border-[#DDD9D3] rounded-lg px-2 py-1.5 text-sm focus:outline-none focus:border-[#F5A623]" />
            <button type="button" id="price-apply" class="flex-shrink-0 px-3 py-1.5 rounded-lg text-sm font-bold bg-[#111111] text-white hover:bg-[#F5A623] hover:text-[#111111] transition-colors">Go</button>
          </div>
        </div>
      </div>
      <div class="relative" id="ms-mileage">
        <button type="button" id="ms-mileage-btn" aria-expanded="false"
          class="border border-[#DDD9D3] rounded-xl px-4 py-2.5 text-sm bg-white focus:outline-none focus:border-[#F5A623] transition-colors cursor-pointer min-h-[44px] flex items-center gap-2 justify-between min-w-[150px]">
          <span id="ms-mileage-label" class="truncate">Any Mileage</span>
          <svg width="10" height="6" viewBox="0 0 10 6" class="flex-shrink-0"><path d="M1 1l4 4 4-4" stroke="#9CA3AF" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div id="ms-mileage-panel" class="absolute z-30 mt-1 w-56 max-h-72 overflow-auto bg-white border border-[#DDD9D3] rounded-xl shadow-lg py-1 hidden">
          <label class="flex items-center gap-2.5 px-4 py-2 text-sm cursor-pointer hover:bg-[#F5F3EE]">
            <input type="checkbox" data-min="0" data-max="50000" class="ms-mileage-cb accent-[#F5A623] w-4 h-4" /><span>Under 50k km</span>
          </label>
          <label class="flex items-center gap-2.5 px-4 py-2 text-sm cursor-pointer hover:bg-[#F5F3EE]">
            <input type="checkbox" data-min="50000" data-max="100000" class="ms-mileage-cb accent-[#F5A623] w-4 h-4" /><span>50k – 100k km</span>
          </label>
          <label class="flex items-center gap-2.5 px-4 py-2 text-sm cursor-pointer hover:bg-[#F5F3EE]">
            <input type="checkbox" data-min="100000" data-max="150000" class="ms-mileage-cb accent-[#F5A623] w-4 h-4" /><span>100k – 150k km</span>
          </label>
          <label class="flex items-center gap-2.5 px-4 py-2 text-sm cursor-pointer hover:bg-[#F5F3EE]">
            <input type="checkbox" data-min="150000" data-max="200000" class="ms-mileage-cb accent-[#F5A623] w-4 h-4" /><span>150k – 200k km</span>
          </label>
          <label class="flex items-center gap-2.5 px-4 py-2 text-sm cursor-pointer hover:bg-[#F5F3EE]">
            <input type="checkbox" data-min="200000" data-max="" class="ms-mileage-cb accent-[#F5A623] w-4 h-4" /><span>Over 200k km</span>
          </label>
        </div>
      </div>
      <span id="results-count" class="self-center text-sm text-[#6B7280] ml-auto"></span>
    </div>

    <!-- GRID — first page server-rendered; client re-renders from JSON below -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" id="listings-grid">
      {ssrCards.map((l, i) => (
        <a
          href={`/listings/${l.slug}/`}
          class={`listing-card group border rounded-xl overflow-hidden transition-all flex flex-col ${
            l.type === 'show_off'
              ? 'bg-[#1A1A1A] border-[rgba(245,166,35,0.15)] hover:border-[#F5A623] hover:shadow-lg hover:shadow-[rgba(245,166,35,0.1)]'
              : 'bg-white border-[#DDD9D3] hover:border-[#F5A623] hover:shadow-md'
          } ${l.status === 'sold' ? 'is-sold' : ''}`}
        >
          <div class="card-img-wrap">
            <img
              src={l.photo}
              alt={l.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              width="800"
              height="500"
              loading={i < 6 ? 'eager' : 'lazy'}
              fetchpriority={i < 3 ? 'high' : 'auto'}
              decoding="async"
            />
            <div class="absolute top-3 left-3 flex gap-1.5 flex-wrap">
              <span class={`card-badge ${l.type === 'show_off' ? 'card-badge-show' : ''}`}>
                {l.type === 'show_off' ? '★ ' : ''}{l.model.replaceAll('-', ' ').toUpperCase()}
              </span>
              {l.status === 'sold' && <span class="card-badge card-badge-sold">Sold</span>}
              {l.status === 'active' && l.drop < 0 && (
                <span class="card-badge card-badge-drop">▼ R{Math.abs(l.drop).toLocaleString('en-ZA')}</span>
              )}
            </div>
            {l.type === 'show_off' && (
              <span class="show-off-ribbon">Community Build</span>
            )}
          </div>
          <div class="p-4 sm:p-5 flex flex-col flex-1">
            <h2 class={`font-heading font-bold uppercase text-base leading-tight mb-1 transition-colors group-hover:text-[#F5A623] line-clamp-2 ${l.type === 'show_off' ? 'text-white' : 'text-[#111111]'}`}>
              {l.title}
            </h2>
            {l.type === 'show_off' ? (
              <p class="text-xs text-[rgba(255,255,255,0.4)] mb-4 truncate">{l.province} · {l.year} · {l.transmission === 'manual' ? 'Manual' : 'Auto'} · {l.colour}</p>
            ) : (
              <p class="text-xs text-[#6B7280] mb-4 truncate">{l.province} · {formatMileage(l.mileage)} · {l.transmission === 'manual' ? 'Manual' : 'Auto'} · {l.colour}</p>
            )}
            <div class="flex items-center justify-between mt-auto">
              {l.type === 'for_sale' ? (
                <>
                  <p class="font-heading font-bold text-2xl text-[#111111]">
                    {formatPrice(l.price)}
                    {l.drop < 0 && (
                      <span class="was-price">{formatPrice(l.price - l.drop)}</span>
                    )}
                  </p>
                  <span class="text-xs font-bold uppercase px-2.5 py-1 rounded-full bg-[#F5F3EE] text-[#6B7280]">{l.nu}</span>
                </>
              ) : (
                <>
                  <span class="show-off-tag">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    Show Off
                  </span>
                  <span class="text-xs font-bold uppercase px-2.5 py-1 rounded-full bg-[#1c1c1c] text-[#9CA3AF]">{l.nu}</span>
                </>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>
    <script type="application/json" id="listings-data" set:html={dataJson}></script>

    <!-- PAGINATION -->
    <div id="pagination" class="hidden mt-8 flex items-center justify-center gap-2"></div>

    <!-- BROWSE BY PROVINCE / MODEL -->
    <div class="mt-14 pt-10 border-t border-[#DDD9D3] grid grid-cols-1 md:grid-cols-2 gap-10">
      <div>
        <h2 class="font-heading font-bold uppercase text-base text-[#111111] mb-3">Browse by Province</h2>
        <div class="flex flex-wrap gap-2">
          {['gauteng','western-cape','kwazulu-natal','eastern-cape','limpopo','mpumalanga','north-west','free-state','northern-cape'].map(slug => (
            <a href={`/listings/province/${slug}/`} class="px-3.5 py-1.5 border border-[#DDD9D3] rounded-full text-sm text-[#4A4A4A] hover:border-[#F5A623] hover:text-[#F5A623] transition-colors capitalize">
              {slug.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()).replace('Kwazulu Natal', 'KwaZulu-Natal')}
            </a>
          ))}
        </div>
      </div>
      <div>
        <h2 class="font-heading font-bold uppercase text-base text-[#111111] mb-3">Browse by Model</h2>
        <div class="flex flex-wrap gap-2">
          {[['76-series','76 Series'],['78-series','78 Series'],['79-series','79 Series'],['80-series','80 Series'],['100-series','100 Series'],['200-series','200 Series'],['300-series','300 Series'],['prado','Prado'],['fj-cruiser','FJ Cruiser'],['hilux','Hilux'],['fortuner','Fortuner']].map(([slug, label]) => (
            <a href={`/listings/model/${slug}/`} class="px-3.5 py-1.5 border border-[#DDD9D3] rounded-full text-sm text-[#4A4A4A] hover:border-[#F5A623] hover:text-[#F5A623] transition-colors">
              {label}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- EMPTY STATE -->
    <div id="empty-state" class="hidden text-center py-24">
      <p class="text-[#6B7280] text-lg mb-2">No listings match your filters.</p>
      <button id="reset-filters" class="text-[#F5A623] text-sm font-semibold hover:underline min-h-[44px] px-4">Clear filters</button>
    </div>

  </div>

</Base>

<!-- Global: these classes are also applied to cards rendered client-side via
     innerHTML, which don't carry Astro's scoped-style attribute. -->
<style is:global>
  .card-img-wrap {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #F5F3EE;
  }
  .card-badge {
    background: #111111;
    color: white;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.5rem;
    border-radius: 0.25rem;
  }
  .card-badge-show {
    background: rgba(245,166,35,0.9);
    color: #111111;
  }
  .card-badge-sold { background: #dc2626; }
  .card-badge-drop { background: #166534; }
  .was-price {
    display: block; font-family: var(--font-body); font-weight: 500;
    font-size: 0.72rem; color: #9CA3AF; text-decoration: line-through;
  }

  .show-off-ribbon {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    background: rgba(245,166,35,0.9);
    color: #111111;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.25rem 0.625rem;
    border-radius: 0.375rem;
    backdrop-filter: blur(4px);
  }

  .show-off-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: rgba(245,166,35,0.12);
    color: #F5A623;
    border: 1px solid rgba(245,166,35,0.3);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
  }

  /* Type pill buttons */
  .type-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: white;
    border: 1.5px solid #DDD9D3;
    color: #6B7280;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-family: var(--font-heading);
    padding: 0.5rem 1rem;
    border-radius: 999px;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
    min-height: 40px;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }
  .type-pill.active {
    background: #111111;
    border-color: #111111;
    color: white;
  }
  .type-pill[data-type="sold"].active {
    background: #6B7280;
    border-color: #6B7280;
  }
  .type-pill:not(.active):hover {
    border-color: #F5A623;
    color: #F5A623;
  }
  .listing-card.is-sold {
    opacity: 0.6;
    filter: grayscale(0.4);
  }
</style>

<script>
  type Listing = {
    slug: string; title: string; model: string; year: number; price: number;
    mileage: number; province: string; transmission: string; colour: string;
    photo: string; type: string; status: string; nu: string; drop: number;
  };
  const DATA: Listing[] = JSON.parse(document.getElementById('listings-data')!.textContent || '[]');

  const grid = document.getElementById('listings-grid')!;
  const emptyState = document.getElementById('empty-state')!;
  const countEl = document.getElementById('results-count')!;
  const paginationEl = document.getElementById('pagination')!;

  const esc = (s: unknown) => String(s).replace(/[&<>"']/g, c =>
    ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));
  const za = (n: number) => n.toLocaleString('en-ZA');

  // Mirrors the server-rendered card markup above — keep the two in sync.
  function cardHTML(l: Listing, i: number): string {
    const isShow = l.type === 'show_off';
    const isSold = l.status === 'sold';
    const cls = `listing-card group border rounded-xl overflow-hidden transition-all flex flex-col ${
      isShow
        ? 'bg-[#1A1A1A] border-[rgba(245,166,35,0.15)] hover:border-[#F5A623] hover:shadow-lg hover:shadow-[rgba(245,166,35,0.1)]'
        : 'bg-white border-[#DDD9D3] hover:border-[#F5A623] hover:shadow-md'
    } ${isSold ? 'is-sold' : ''}`;
    const badges =
      `<span class="card-badge ${isShow ? 'card-badge-show' : ''}">${isShow ? '★ ' : ''}${esc(l.model.replaceAll('-', ' ').toUpperCase())}</span>` +
      (isSold ? '<span class="card-badge card-badge-sold">Sold</span>' : '') +
      (!isSold && l.drop < 0 ? `<span class="card-badge card-badge-drop">▼ R${za(Math.abs(l.drop))}</span>` : '');
    const meta = isShow
      ? `<p class="text-xs text-[rgba(255,255,255,0.4)] mb-4 truncate">${esc(l.province)} · ${l.year} · ${l.transmission === 'manual' ? 'Manual' : 'Auto'} · ${esc(l.colour)}</p>`
      : `<p class="text-xs text-[#6B7280] mb-4 truncate">${esc(l.province)} · ${za(l.mileage)} km · ${l.transmission === 'manual' ? 'Manual' : 'Auto'} · ${esc(l.colour)}</p>`;
    const foot = l.type === 'for_sale'
      ? `<p class="font-heading font-bold text-2xl text-[#111111]">R${za(l.price)}${l.drop < 0 ? `<span class="was-price">R${za(l.price - l.drop)}</span>` : ''}</p>` +
        `<span class="text-xs font-bold uppercase px-2.5 py-1 rounded-full bg-[#F5F3EE] text-[#6B7280]">${esc(l.nu)}</span>`
      : `<span class="show-off-tag"><svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>Show Off</span>` +
        `<span class="text-xs font-bold uppercase px-2.5 py-1 rounded-full bg-[#1c1c1c] text-[#9CA3AF]">${esc(l.nu)}</span>`;
    return `<a href="/listings/${esc(l.slug)}/" class="${cls}">` +
      `<div class="card-img-wrap">` +
        `<img src="${esc(l.photo)}" alt="${esc(l.title)}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" width="800" height="500" loading="${i < 6 ? 'eager' : 'lazy'}" decoding="async" />` +
        `<div class="absolute top-3 left-3 flex gap-1.5 flex-wrap">${badges}</div>` +
        (isShow ? '<span class="show-off-ribbon">Community Build</span>' : '') +
      `</div>` +
      `<div class="p-4 sm:p-5 flex flex-col flex-1">` +
        `<h2 class="font-heading font-bold uppercase text-base leading-tight mb-1 transition-colors group-hover:text-[#F5A623] line-clamp-2 ${isShow ? 'text-white' : 'text-[#111111]'}">${esc(l.title)}</h2>` +
        meta +
        `<div class="flex items-center justify-between mt-auto">${foot}</div>` +
      `</div>` +
    `</a>`;
  }

  const typePills = document.querySelectorAll<HTMLButtonElement>('.type-pill');

  // ── Multi-select model dropdown ──────────────────────────────────────────
  const msBtn = document.getElementById('ms-model-btn')!;
  const msPanel = document.getElementById('ms-model-panel')!;
  const msLabel = document.getElementById('ms-model-label')!;
  const msBoxes = Array.from(document.querySelectorAll<HTMLInputElement>('.ms-model-cb'));
  let selectedModels: string[] = [];

  function updateModelLabel() {
    selectedModels = msBoxes.filter(b => b.checked).map(b => b.value);
    msLabel.textContent =
      selectedModels.length === 0 ? 'All Models'
      : selectedModels.length === 1 ? (msBoxes.find(b => b.checked)!.nextElementSibling!.textContent ?? '1 model')
      : `${selectedModels.length} models`;
  }
  msBtn.addEventListener('click', () => {
    const open = msPanel.classList.toggle('hidden');
    msBtn.setAttribute('aria-expanded', String(!open));
  });
  document.addEventListener('click', e => {
    if (!document.getElementById('ms-model')!.contains(e.target as Node)) {
      msPanel.classList.add('hidden');
      msBtn.setAttribute('aria-expanded', 'false');
    }
  });
  msBoxes.forEach(b => b.addEventListener('change', () => { updateModelLabel(); applyFilters(); }));

  // ── Multi-select province dropdown ───────────────────────────────────────
  const provBtn = document.getElementById('ms-province-btn')!;
  const provPanel = document.getElementById('ms-province-panel')!;
  const provLabel = document.getElementById('ms-province-label')!;
  const provBoxes = Array.from(document.querySelectorAll<HTMLInputElement>('.ms-province-cb'));
  let selectedProvinces: string[] = [];
  function updateProvinceLabel() {
    selectedProvinces = provBoxes.filter(b => b.checked).map(b => b.value);
    provLabel.textContent =
      selectedProvinces.length === 0 ? 'All Provinces'
      : selectedProvinces.length === 1 ? selectedProvinces[0]
      : `${selectedProvinces.length} provinces`;
  }
  provBtn.addEventListener('click', () => {
    const open = provPanel.classList.toggle('hidden');
    provBtn.setAttribute('aria-expanded', String(!open));
  });
  document.addEventListener('click', e => {
    if (!document.getElementById('ms-province')!.contains(e.target as Node)) {
      provPanel.classList.add('hidden');
      provBtn.setAttribute('aria-expanded', 'false');
    }
  });
  provBoxes.forEach(b => b.addEventListener('change', () => { updateProvinceLabel(); applyFilters(); }));

  // ── Multi-select mileage dropdown (ranges) ───────────────────────────────
  const mileBtn = document.getElementById('ms-mileage-btn')!;
  const milePanel = document.getElementById('ms-mileage-panel')!;
  const mileLabel = document.getElementById('ms-mileage-label')!;
  const mileBoxes = Array.from(document.querySelectorAll<HTMLInputElement>('.ms-mileage-cb'));
  let selectedMileages: [number, number][] = [];
  function updateMileageLabel() {
    selectedMileages = mileBoxes.filter(b => b.checked).map(b =>
      [Number(b.dataset.min || 0), b.dataset.max ? Number(b.dataset.max) : Infinity] as [number, number]);
    mileLabel.textContent =
      selectedMileages.length === 0 ? 'Any Mileage'
      : selectedMileages.length === 1 ? (mileBoxes.find(b => b.checked)!.nextElementSibling!.textContent ?? '1 range')
      : `${selectedMileages.length} ranges`;
  }
  mileBtn.addEventListener('click', () => {
    const open = milePanel.classList.toggle('hidden');
    mileBtn.setAttribute('aria-expanded', String(!open));
  });
  document.addEventListener('click', e => {
    if (!document.getElementById('ms-mileage')!.contains(e.target as Node)) {
      milePanel.classList.add('hidden');
      mileBtn.setAttribute('aria-expanded', 'false');
    }
  });
  mileBoxes.forEach(b => b.addEventListener('change', () => { updateMileageLabel(); applyFilters(); }));

  // ── Price dropdown (presets + custom min/max) ────────────────────────────
  const priceBtn = document.getElementById('price-btn')!;
  const pricePanel = document.getElementById('price-panel')!;
  const priceLabelEl = document.getElementById('price-label')!;
  const priceMinInput = document.getElementById('price-min') as HTMLInputElement;
  const priceMaxInput = document.getElementById('price-max') as HTMLInputElement;
  const pricePresets = Array.from(document.querySelectorAll<HTMLButtonElement>('.price-preset'));
  let priceMin = 0;
  let priceMax = Infinity;

  const kR = (n: number) =>
    n >= 1000000 ? 'R' + (n / 1000000).toFixed(n % 1000000 === 0 ? 0 : 1) + 'm'
    : 'R' + Math.round(n / 1000) + 'k';

  function customPriceLabel(min: number, max: number): string {
    if (min <= 0 && !isFinite(max)) return 'Any Price';
    if (min <= 0) return 'Up to ' + kR(max);
    if (!isFinite(max)) return kR(min) + '+';
    return kR(min) + ' – ' + kR(max);
  }

  function closePricePanel() {
    pricePanel.classList.add('hidden');
    priceBtn.setAttribute('aria-expanded', 'false');
  }

  function setPrice(min: number, max: number, label: string) {
    priceMin = min;
    priceMax = max;
    priceLabelEl.textContent = label;
    applyFilters();
  }

  function resetPrice() {
    priceMinInput.value = '';
    priceMaxInput.value = '';
    priceMin = 0;
    priceMax = Infinity;
    priceLabelEl.textContent = 'Any Price';
  }

  priceBtn.addEventListener('click', () => {
    const open = pricePanel.classList.toggle('hidden');
    priceBtn.setAttribute('aria-expanded', String(!open));
  });
  document.addEventListener('click', e => {
    if (!document.getElementById('price-filter')!.contains(e.target as Node)) closePricePanel();
  });

  pricePresets.forEach(btn => btn.addEventListener('click', () => {
    const min = Number(btn.dataset.min || 0);
    const max = btn.dataset.max ? Number(btn.dataset.max) : Infinity;
    priceMinInput.value = min > 0 ? String(min) : '';
    priceMaxInput.value = isFinite(max) ? String(max) : '';
    setPrice(min, max, btn.textContent!.trim());
    closePricePanel();
  }));

  function applyCustomPrice() {
    let lo = Math.max(0, Number(priceMinInput.value) || 0);
    let hi = priceMaxInput.value ? Number(priceMaxInput.value) : Infinity;
    if (isFinite(hi) && lo > hi) { const t = lo; lo = hi; hi = t; } // swap if reversed
    priceMinInput.value = lo > 0 ? String(lo) : '';
    priceMaxInput.value = isFinite(hi) ? String(hi) : '';
    setPrice(lo, hi, customPriceLabel(lo, hi));
    closePricePanel();
  }
  document.getElementById('price-apply')!.addEventListener('click', applyCustomPrice);
  [priceMinInput, priceMaxInput].forEach(inp => inp.addEventListener('keydown', e => {
    if ((e as KeyboardEvent).key === 'Enter') { e.preventDefault(); applyCustomPrice(); }
  }));

  const PAGE_SIZE = 18;
  let activeType = 'all';
  let currentPage = 1;

  function matchesFilters(l: Listing): boolean {
    const showingSold = activeType === 'sold';
    const isSold = l.status === 'sold';
    if (showingSold !== isSold) return false;

    const isShowOff = l.type === 'show_off';

    const priceOk = isShowOff || showingSold || (l.price >= priceMin && l.price <= priceMax);

    const mileageOk = isShowOff || selectedMileages.length === 0 ||
      selectedMileages.some(([mn, mx]) => l.mileage >= mn && l.mileage <= mx);

    const modelMatch = selectedModels.length === 0 || selectedModels.some(sel =>
      (sel === 'prado' && l.model.startsWith('prado')) ||
      (sel === 'fj' && (l.model === 'fj-cruiser' || l.model === 'land-cruiser-fj')) ||
      (sel === 'hilux' && l.model.startsWith('hilux')) ||
      (sel === 'fortuner' && l.model.startsWith('fortuner')) ||
      l.model === sel
    );

    const typeMatch = showingSold || activeType === 'all' || l.type === activeType;

    return modelMatch &&
      (selectedProvinces.length === 0 || selectedProvinces.includes(l.province)) &&
      priceOk &&
      mileageOk &&
      typeMatch;
  }

  function renderPagination(totalVisible: number, totalPages: number) {
    if (totalPages <= 1) {
      paginationEl.classList.add('hidden');
      return;
    }
    paginationEl.classList.remove('hidden');
    paginationEl.innerHTML = '';

    const btn = (label: string, page: number, disabled: boolean, active = false) => {
      const el = document.createElement('button');
      el.textContent = label;
      el.className = active
        ? 'px-4 py-2 rounded-lg text-sm font-bold font-heading uppercase bg-[#111111] text-white border border-[#111111] min-h-[40px]'
        : disabled
          ? 'px-4 py-2 rounded-lg text-sm font-bold font-heading uppercase border border-[#DDD9D3] text-[#C0BDB8] cursor-not-allowed min-h-[40px]'
          : 'px-4 py-2 rounded-lg text-sm font-bold font-heading uppercase border border-[#DDD9D3] text-[#4A4A4A] hover:border-[#F5A623] hover:text-[#F5A623] transition-colors min-h-[40px]';
      if (!disabled && !active) {
        el.addEventListener('click', () => {
          currentPage = page;
          applyFilters(false);
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
      return el;
    };

    paginationEl.appendChild(btn('← Prev', currentPage - 1, currentPage === 1));

    // Show up to 5 page numbers around current
    const start = Math.max(1, currentPage - 2);
    const end = Math.min(totalPages, currentPage + 2);
    if (start > 1) paginationEl.appendChild(btn('1', 1, false));
    if (start > 2) {
      const dots = document.createElement('span');
      dots.textContent = '…';
      dots.className = 'px-2 text-[#9CA3AF] text-sm';
      paginationEl.appendChild(dots);
    }
    for (let p = start; p <= end; p++) {
      paginationEl.appendChild(btn(String(p), p, false, p === currentPage));
    }
    if (end < totalPages - 1) {
      const dots = document.createElement('span');
      dots.textContent = '…';
      dots.className = 'px-2 text-[#9CA3AF] text-sm';
      paginationEl.appendChild(dots);
    }
    if (end < totalPages) paginationEl.appendChild(btn(String(totalPages), totalPages, false));

    paginationEl.appendChild(btn('Next →', currentPage + 1, currentPage === totalPages));
  }

  function applyFilters(resetPage = true) {
    if (resetPage) currentPage = 1;

    const matched = DATA.filter(matchesFilters);
    const totalPages = Math.ceil(matched.length / PAGE_SIZE);
    if (currentPage > totalPages) currentPage = Math.max(1, totalPages);
    const start = (currentPage - 1) * PAGE_SIZE;
    const pageItems = matched.slice(start, start + PAGE_SIZE);

    grid.innerHTML = pageItems.map((l, i) => cardHTML(l, i)).join('');
    grid.classList.toggle('hidden', matched.length === 0);
    emptyState.classList.toggle('hidden', matched.length > 0);
    countEl.textContent = `${matched.length} listing${matched.length !== 1 ? 's' : ''}`;
    renderPagination(matched.length, totalPages);
  }

  typePills.forEach(pill => {
    pill.addEventListener('click', () => {
      activeType = pill.dataset.type ?? 'all';
      typePills.forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      const priceFilter = document.getElementById('price-filter') as HTMLElement;
      const hide = (activeType === 'show_off' || activeType === 'sold') ? 'none' : '';
      priceFilter.style.display = hide;
      (document.getElementById('ms-mileage') as HTMLElement).style.display = (activeType === 'show_off') ? 'none' : '';
      applyFilters();
    });
  });

  document.getElementById('reset-filters')?.addEventListener('click', () => {
    msBoxes.forEach(b => { b.checked = false; });
    updateModelLabel();
    provBoxes.forEach(b => { b.checked = false; });
    updateProvinceLabel();
    mileBoxes.forEach(b => { b.checked = false; });
    updateMileageLabel();
    resetPrice();
    activeType = 'all';
    typePills.forEach(p => p.classList.toggle('active', p.dataset.type === 'all'));
    applyFilters();
  });

  // Pre-select models from ?model= (e.g. market-page "browse listings" links)
  const urlModels = new URLSearchParams(location.search).get('model');
  if (urlModels) {
    const wanted = urlModels.split(',');
    msBoxes.forEach(b => { if (wanted.includes(b.value)) b.checked = true; });
  }
  updateModelLabel();
  updateProvinceLabel();
  updateMileageLabel();

  applyFilters();
</script>
