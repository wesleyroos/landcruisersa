---
export const prerender = false;

import Base from '@/layouts/Base.astro';
import { SITE } from '@/data/site';
import { db } from '@/db/index';
import { listings } from '@/db/schema';
import { and, eq, desc, or, like } from 'drizzle-orm';
import { MODELS } from '@/data/models';
import { firstThumb, hasUsablePhoto } from '@/lib/photos';
import { getRecentPriceChanges } from '@/lib/price-changes';

const MODEL_MAP: Record<string, { label: string; description: string }> = {
  '76-series': { label: '76 Series', description: 'Toyota Land Cruiser 76 Series' },
  '78-series': { label: '78 Series (Troopcarrier)', description: 'Toyota Land Cruiser 78 Series Troopcarrier' },
  '79-series': { label: '79 Series', description: 'Toyota Land Cruiser 79 Series' },
  '80-series': { label: '80 Series', description: 'Toyota Land Cruiser 80 Series' },
  '100-series': { label: '100 Series', description: 'Toyota Land Cruiser 100 Series' },
  '200-series': { label: '200 Series', description: 'Toyota Land Cruiser 200 Series' },
  '300-series': { label: '300 Series', description: 'Toyota Land Cruiser 300 Series' },
  'prado': { label: 'Prado', description: 'Toyota Land Cruiser Prado' },
  'fj-cruiser': { label: 'FJ Cruiser', description: 'Toyota FJ Cruiser' },
  // Hilux/Fortuner are intentionally absent — they're not public (any request
  // for those slugs falls through to the /listings/ redirect below).
};

const { model } = Astro.params;

// The classics graduated to their own vertical at /classics/ (nav, guide,
// market strip) a day after this grouped slug shipped — permanent-redirect the
// short-lived URL so nothing splits between two pages.
if (model === 'classic' || model === '40-series' || model === '55-series' || model === '60-series') {
  return Astro.redirect('/classics/', 301);
}

const modelInfo = MODEL_MAP[model!];

if (!modelInfo) return Astro.redirect('/listings/');

// Match how the listings index filter works for each model. Model uniquely
// determines segment, so no segment filter is needed — and Hilux/Fortuner can
// never reach here (their MODEL_MAP entries were removed → redirect above).
let results;
if (model === 'prado') {
  results = await db.select().from(listings)
    .where(and(eq(listings.status, 'active'), like(listings.model, `${model}%`)))
    .orderBy(desc(listings.featured), desc(listings.created_at));
} else if (model === 'fj-cruiser') {
  results = await db.select().from(listings)
    .where(and(
      eq(listings.status, 'active'),
      or(eq(listings.model, 'fj-cruiser'), eq(listings.model, 'land-cruiser-fj'))
    ))
    .orderBy(desc(listings.featured), desc(listings.created_at));
} else {
  results = await db.select().from(listings)
    .where(and(eq(listings.status, 'active'), eq(listings.model, model!)))
    .orderBy(desc(listings.featured), desc(listings.created_at));
}
// Hide vehicles with no real photo — we don't list what we can't picture.
results = results.filter(l => hasUsablePhoto(l.photos));

// Find matching model guide if it exists
const modelGuide = MODELS.find(m =>
  m.slug === model ||
  (model === 'fj-cruiser' && (m.slug === 'fj-cruiser' || m.slug === 'land-cruiser-fj'))
);

function formatPrice(n: number) { return 'R' + n.toLocaleString('en-ZA'); }
function formatMileage(n: number) { return n.toLocaleString('en-ZA') + ' km'; }

// ── Live market strip — the "wat kos hulle nou?" answer, computed from the
//    listings on this page (for-sale with a real price; show-offs excluded).
const priced = results
  .filter(l => l.listing_type === 'for_sale' && l.price > 0)
  .map(l => l.price)
  .sort((a, b) => a - b);
const priceCount = priced.length;
const median = priceCount
  ? (priceCount % 2 ? priced[(priceCount - 1) / 2] : Math.round((priced[priceCount / 2 - 1] + priced[priceCount / 2]) / 2))
  : 0;
const minPrice = priceCount ? priced[0] : 0;
const maxPrice = priceCount ? priced[priceCount - 1] : 0;
const kms = results.filter(l => l.listing_type === 'for_sale' && l.mileage > 0).map(l => l.mileage);
const avgKm = kms.length ? Math.round(kms.reduce((s, m) => s + m, 0) / kms.length) : null;

// Net 30d price drops for these listings (negative map value = drop).
const priceChanges = getRecentPriceChanges();
const dropBySlug = new Map<string, number>();
for (const l of results) {
  const c = priceChanges.get(l.slug) ?? 0;
  if (c < 0) dropBySlug.set(l.slug, Math.abs(c));
}
const biggestDrop = dropBySlug.size ? Math.max(...dropBySlug.values()) : 0;

const kR = (n: number) =>
  n >= 1_000_000 ? 'R' + (n / 1_000_000).toFixed(n % 1_000_000 === 0 ? 0 : 1) + 'm' : 'R' + Math.round(n / 1000) + 'k';

// The listings page's model filter uses 'fj' for FJ Cruisers.
const listingsModelParam = model === 'fj-cruiser' ? 'fj' : model;

const canonicalUrl = `${SITE.url}/listings/model/${model}/`;
const title = `${modelInfo.description} For Sale in South Africa`;
const description = results.length
  ? (priceCount >= 2
      ? `Browse ${results.length} ${modelInfo.description} listing${results.length !== 1 ? 's' : ''} for sale in South Africa — median asking ${formatPrice(median)}, range ${kR(minPrice)}–${kR(maxPrice)}. Updated daily.`
      : `Browse ${results.length} ${modelInfo.description} listing${results.length !== 1 ? 's' : ''} for sale in South Africa. Private sellers and dealer listings — updated daily.`)
  : `${modelInfo.description} classifieds in South Africa. Browse listings from private sellers and dealers — updated daily.`;
---

<Base
  title={`${title} — Land Cruiser SA`}
  description={description}
  schema={{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE.url },
      { "@type": "ListItem", "position": 2, "name": "Listings", "item": `${SITE.url}/listings/` },
      { "@type": "ListItem", "position": 3, "name": modelInfo.label, "item": canonicalUrl },
    ],
  }}
>

  <div class="bg-[#111111]">
    <div class="max-w-7xl mx-auto px-4 py-8 sm:py-10">
      <nav class="flex items-center gap-2 text-xs text-white/40 mb-4">
        <a href="/" class="hover:text-[#F5A623] transition-colors">Home</a>
        <span>›</span>
        <a href="/listings/" class="hover:text-[#F5A623] transition-colors">Listings</a>
        <span>›</span>
        <span class="text-white/70">{modelInfo.label}</span>
      </nav>
      <p class="text-[#F5A623] font-heading font-bold uppercase tracking-widest text-xs mb-2">{modelInfo.label}</p>
      <h1 class="font-heading font-bold uppercase text-white text-4xl md:text-5xl leading-none mb-2">{title}</h1>
      <p class="text-white/50 text-sm">{results.length} active listing{results.length !== 1 ? 's' : ''}</p>
    </div>
  </div>
  <div class="h-1 bg-[#F5A623]"></div>

  <div class="max-w-7xl mx-auto px-4 py-8 sm:py-10">

    {priceCount >= 2 && (
      <div class="mb-4 bg-white border border-[#DDD9D3] rounded-xl px-5 py-4">
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-x-6 gap-y-4">
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#9CA3AF] mb-0.5">Median asking</p>
            <p class="font-heading font-bold text-xl text-[#111111]">{formatPrice(median)}</p>
          </div>
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#9CA3AF] mb-0.5">Range</p>
            <p class="font-heading font-bold text-xl text-[#111111]">{kR(minPrice)} – {kR(maxPrice)}</p>
          </div>
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#9CA3AF] mb-0.5">Avg mileage</p>
            <p class="font-heading font-bold text-xl text-[#111111]">{avgKm ? formatMileage(avgKm) : '—'}</p>
          </div>
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#9CA3AF] mb-0.5">For sale</p>
            <p class="font-heading font-bold text-xl text-[#111111]">{priceCount}</p>
          </div>
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#9CA3AF] mb-0.5">Price drops · 30d</p>
            <p class="font-heading font-bold text-xl text-[#111111]">
              {dropBySlug.size > 0
                ? <>{dropBySlug.size} <span class="text-sm font-semibold text-[#16803C]">· biggest −{kR(biggestDrop)}</span></>
                : '0'}
            </p>
          </div>
        </div>
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mt-4 pt-3.5 border-t border-[#F0EDE6] text-sm">
          <a href={`/valuation/${model}/`} class="font-semibold text-[#111111] hover:text-[#D4881A] transition-colors">Own one? See what it's worth →</a>
          <a href={`/market/${model}/`} class="font-semibold text-[#111111] hover:text-[#D4881A] transition-colors">Full {modelInfo.label} market data →</a>
          <a href={`/listings/?model=${listingsModelParam}&alert=1`} class="inline-flex items-center gap-1.5 font-semibold text-[#111111] hover:text-[#D4881A] transition-colors">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
            Alert me when one is listed
          </a>
        </div>
      </div>
    )}

    {modelGuide && (
      <div class="mb-8 p-5 bg-[#F5F3EE] border border-[#DDD9D3] rounded-xl flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <div class="flex-1">
          <p class="text-xs font-bold uppercase tracking-widest text-[#F5A623] mb-1">Model Guide</p>
          <p class="font-heading font-bold uppercase text-[#111111] text-base">Want to know more about the {modelInfo.label}?</p>
          <p class="text-sm text-[#6B7280] mt-0.5">Specs, common issues, buying tips, and who it's really for.</p>
        </div>
        <a href={`/models/${modelGuide.slug}/`} class="flex-shrink-0 inline-flex items-center bg-[#111111] text-white font-heading font-bold uppercase tracking-wide px-5 py-2.5 rounded-xl text-sm hover:bg-[#222] transition-colors">
          Read the Guide →
        </a>
      </div>
    )}

    {results.length === 0 ? (
      <div class="text-center py-24">
        <p class="text-[#6B7280] text-lg mb-4">No active {modelInfo.label} listings right now.</p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a href={`/listings/?model=${listingsModelParam}&alert=1`} class="inline-flex items-center gap-1.5 bg-[#F5A623] text-[#111111] font-heading font-bold uppercase tracking-wide px-6 py-3 rounded-xl text-sm hover:bg-[#D4881A] transition-colors">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
            Alert me when one is listed
          </a>
          <a href="/listings/" class="text-sm font-semibold text-[#6B7280] hover:text-[#111111] hover:underline px-2">Browse all listings</a>
        </div>
      </div>
    ) : (
      <>
      <div class="flex items-center justify-end gap-1.5 mb-4">
        <span class="text-xs text-[#9CA3AF] mr-1">Sort:</span>
        <button class="sort-btn active" data-sort="newest" type="button">Newest</button>
        <button class="sort-btn" data-sort="price" type="button">Price: low → high</button>
      </div>
      <div id="model-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {results.map((l, i) => (
          <a
            href={`/listings/${l.slug}/`}
            data-idx={i}
            data-price={l.listing_type === 'for_sale' && l.price > 0 ? l.price : ''}
            class={`group border rounded-xl overflow-hidden transition-all flex flex-col ${
              l.listing_type === 'show_off'
                ? 'bg-[#1A1A1A] border-[rgba(245,166,35,0.15)] hover:border-[#F5A623]'
                : 'bg-white border-[#DDD9D3] hover:border-[#F5A623] hover:shadow-md'
            }`}
          >
            <div class="card-img">
              <img
                src={firstThumb(l.photos)}
                alt={l.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                width="800" height="500"
                loading={i < 6 ? 'eager' : 'lazy'}
                fetchpriority={i < 3 ? 'high' : 'auto'}
                decoding="async"
              />
              <span class="card-badge">{l.province}</span>
              {dropBySlug.has(l.slug) && (
                <span class="card-badge-drop">▼ R{dropBySlug.get(l.slug)!.toLocaleString('en-ZA')} drop</span>
              )}
            </div>
            <div class="p-4 sm:p-5 flex flex-col flex-1">
              <h2 class={`font-heading font-bold uppercase text-base leading-tight mb-1 group-hover:text-[#F5A623] transition-colors line-clamp-2 ${l.listing_type === 'show_off' ? 'text-white' : 'text-[#111111]'}`}>
                {l.title}
              </h2>
              <p class={`text-xs mb-4 truncate ${l.listing_type === 'show_off' ? 'text-white/40' : 'text-[#6B7280]'}`}>
                {l.mileage > 0 ? `${formatMileage(l.mileage)} · ` : ''}{l.transmission === 'manual' ? 'Manual' : 'Auto'} · {l.province}
              </p>
              <div class="mt-auto">
                {l.listing_type === 'for_sale'
                  ? <p class="font-heading font-bold text-2xl text-[#111111]">{formatPrice(l.price)}</p>
                  : <span class="text-xs font-bold text-[#F5A623] uppercase tracking-wide">★ Community Build</span>
                }
              </div>
            </div>
          </a>
        ))}
      </div>
      </>
    )}

    <!-- Other Models -->
    <div class="mt-16 pt-10 border-t border-[#DDD9D3]">
      <h2 class="font-heading font-bold uppercase text-xl text-[#111111] mb-5">Browse by Model</h2>
      <div class="flex flex-wrap gap-2">
        {Object.entries(MODEL_MAP).filter(([slug]) => slug !== model).map(([slug, info]) => (
          <a href={`/listings/model/${slug}/`} class="px-4 py-2 border border-[#DDD9D3] rounded-full text-sm text-[#4A4A4A] hover:border-[#F5A623] hover:text-[#F5A623] transition-colors">
            {info.label}
          </a>
        ))}
        <a href="/game-viewers/" class="px-4 py-2 border border-[#DDD9D3] rounded-full text-sm text-[#4A4A4A] hover:border-[#F5A623] hover:text-[#F5A623] transition-colors">
          Game Viewers
        </a>
      </div>
    </div>

  </div>

</Base>

<script>
  // Sort toggle: newest (server order) vs price low→high. Pure DOM reorder —
  // show-offs / POA (no data-price) sink to the end on price sort.
  const grid = document.getElementById('model-grid');
  const btns = Array.from(document.querySelectorAll<HTMLButtonElement>('.sort-btn'));
  if (grid && btns.length) {
    btns.forEach(btn => btn.addEventListener('click', () => {
      btns.forEach(b => b.classList.toggle('active', b === btn));
      const cards = Array.from(grid.children) as HTMLElement[];
      const key = btn.dataset.sort === 'price'
        ? (el: HTMLElement) => (el.dataset.price ? Number(el.dataset.price) : Infinity)
        : (el: HTMLElement) => Number(el.dataset.idx ?? 0);
      cards.sort((a, b) => key(a) - key(b)).forEach(el => grid.appendChild(el));
    }));
  }
</script>

<style>
  .card-img {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #F5F3EE;
  }
  .card-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: #111111;
    color: white;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.5rem;
    border-radius: 0.25rem;
  }
  .card-badge-drop {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background: #16803C;
    color: white;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.5rem;
    border-radius: 0.25rem;
  }
  .sort-btn {
    font-size: 0.75rem;
    font-weight: 600;
    color: #6B7280;
    background: #fff;
    border: 1px solid #DDD9D3;
    border-radius: 9999px;
    padding: 0.3rem 0.8rem;
    cursor: pointer;
    transition: all 0.15s;
  }
  .sort-btn:hover { border-color: #F5A623; color: #111; }
  .sort-btn.active { background: #111; color: #fff; border-color: #111; }
</style>
