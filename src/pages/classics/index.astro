---
export const prerender = false;

import Base from '@/layouts/Base.astro';
import { SITE } from '@/data/site';
import { db } from '@/db/index';
import { listings } from '@/db/schema';
import { and, eq, desc, inArray } from 'drizzle-orm';
import { firstThumb, hasUsablePhoto } from '@/lib/photos';
import { getRecentPriceChanges } from '@/lib/price-changes';

// The chassis-code classics as one vertical — buyers shop the era ("an old FJ"),
// not a chassis code, and each series alone is a car or two at a time. Keep in
// step with the classic patterns in lib/sources/normalize.ts MODEL_MAP.
const CLASSIC_MODELS = ['40-series', '55-series', '60-series'];

let results = await db.select().from(listings)
  .where(and(eq(listings.status, 'active'), inArray(listings.model, CLASSIC_MODELS)))
  .orderBy(desc(listings.featured), desc(listings.created_at));
results = results.filter(l => hasUsablePhoto(l.photos));

function formatPrice(n: number) { return 'R' + n.toLocaleString('en-ZA'); }

// Market strip — same maths as the per-model pages. No mileage tile: classics
// rarely advertise an odometer reading (and it doesn't set the price anyway);
// the year spread is the number this buyer actually scans for.
const priced = results
  .filter(l => l.listing_type === 'for_sale' && l.price > 0)
  .map(l => l.price)
  .sort((a, b) => a - b);
const priceCount = priced.length;
const median = priceCount
  ? (priceCount % 2 ? priced[(priceCount - 1) / 2] : Math.round((priced[priceCount / 2 - 1] + priced[priceCount / 2]) / 2))
  : 0;
const minPrice = priceCount ? priced[0] : 0;
const maxPrice = priceCount ? priced[priceCount - 1] : 0;
const years = results.map(l => l.year);
const yearSpan = years.length ? `${Math.min(...years)}–${Math.max(...years)}` : '—';

const priceChanges = getRecentPriceChanges();
const dropBySlug = new Map<string, number>();
for (const l of results) {
  const c = priceChanges.get(l.slug) ?? 0;
  if (c < 0) dropBySlug.set(l.slug, Math.abs(c));
}

const kR = (n: number) =>
  n >= 1_000_000 ? 'R' + (n / 1_000_000).toFixed(n % 1_000_000 === 0 ? 0 : 1) + 'm' : 'R' + Math.round(n / 1000) + 'k';

const canonicalUrl = `${SITE.url}/classics/`;
const title = 'Classic Land Cruisers For Sale in South Africa';
const description = results.length
  ? (priceCount >= 2
      ? `Browse ${results.length} classic Land Cruiser${results.length !== 1 ? 's' : ''} (FJ40, FJ45, FJ55, FJ60/62 era) for sale in South Africa — median asking ${formatPrice(median)}, range ${kR(minPrice)}–${kR(maxPrice)}. Updated daily.`
      : `Browse ${results.length} classic Land Cruiser${results.length !== 1 ? 's' : ''} (FJ40, FJ45, FJ55, FJ60/62 era) for sale in South Africa. Updated daily.`)
  : 'Classic Land Cruiser classifieds in South Africa — FJ40, FJ45, FJ55 and FJ60/62 era, from specialist dealers and private sellers. Updated daily.';
---

<Base
  title={`${title} — Land Cruiser SA`}
  description={description}
  schema={{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE.url },
      { "@type": "ListItem", "position": 2, "name": "Listings", "item": `${SITE.url}/listings/` },
      { "@type": "ListItem", "position": 3, "name": "Classic Cruisers", "item": canonicalUrl },
    ],
  }}
>

  <div class="bg-[#111111]">
    <div class="max-w-7xl mx-auto px-4 py-8 sm:py-10">
      <nav class="flex items-center gap-2 text-xs text-white/40 mb-4">
        <a href="/" class="hover:text-[#F5A623] transition-colors">Home</a>
        <span>›</span>
        <a href="/listings/" class="hover:text-[#F5A623] transition-colors">Listings</a>
        <span>›</span>
        <span class="text-white/70">Classic Cruisers</span>
      </nav>
      <p class="text-[#F5A623] font-heading font-bold uppercase tracking-widest text-xs mb-2">FJ40 · FJ45 · FJ55 · FJ60/62</p>
      <h1 class="font-heading font-bold uppercase text-white text-4xl md:text-5xl leading-none mb-2">{title}</h1>
      <p class="text-white/50 text-sm">{results.length} active listing{results.length !== 1 ? 's' : ''} · restored, original and everything in between</p>
    </div>
  </div>
  <div class="h-1 bg-[#F5A623]"></div>

  <div class="max-w-7xl mx-auto px-4 py-8 sm:py-10">

    {priceCount >= 2 && (
      <div class="mb-4 bg-white border border-[#DDD9D3] rounded-xl px-5 py-4">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-x-6 gap-y-4">
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#9CA3AF] mb-0.5">Median asking</p>
            <p class="font-heading font-bold text-xl text-[#111111]">{formatPrice(median)}</p>
          </div>
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#9CA3AF] mb-0.5">Range</p>
            <p class="font-heading font-bold text-xl text-[#111111]">{kR(minPrice)} – {kR(maxPrice)}</p>
          </div>
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#9CA3AF] mb-0.5">Years</p>
            <p class="font-heading font-bold text-xl text-[#111111]">{yearSpan}</p>
          </div>
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-[#9CA3AF] mb-0.5">For sale</p>
            <p class="font-heading font-bold text-xl text-[#111111]">{priceCount}</p>
          </div>
        </div>
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mt-4 pt-3.5 border-t border-[#F0EDE6] text-sm">
          <a href="/listings/submit/" class="font-semibold text-[#111111] hover:text-[#D4881A] transition-colors">Selling a classic? List it here →</a>
          <a href="/market/40-series/" class="font-semibold text-[#111111] hover:text-[#D4881A] transition-colors">40 Series market data →</a>
        </div>
      </div>
    )}

    <!-- One-line definition — the "answer capsule" LLMs cite; depth lives in the buyer's guide -->
    <p class="mb-8 text-sm text-[#4A4A4A] leading-relaxed max-w-3xl">
      The <strong>classic Land Cruisers</strong> are the chassis-code era: the FJ40/FJ45 (40 Series, 1960–1984),
      the FJ55 wagon and the FJ60/FJ62 (60 Series, 1980–1990) — appreciating collectibles priced on originality
      and provenance rather than year and mileage.
      <a href="/useful-info/classic-land-cruiser-price-buyers-guide-south-africa/" class="font-semibold text-[#D4881A] hover:underline whitespace-nowrap">Prices &amp; buyer's guide →</a>
    </p>

    {results.length === 0 ? (
      <div class="text-center py-24">
        <p class="text-[#6B7280] text-lg mb-4">No active classic listings right now.</p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a href="/listings/submit/" class="inline-flex items-center gap-1.5 bg-[#F5A623] text-[#111111] font-heading font-bold uppercase tracking-wide px-6 py-3 rounded-xl text-sm hover:bg-[#D4881A] transition-colors">
            List your classic
          </a>
          <a href="/listings/" class="text-sm font-semibold text-[#6B7280] hover:text-[#111111] hover:underline px-2">Browse all listings</a>
        </div>
      </div>
    ) : (
      <>
      <div class="flex items-center justify-end gap-1.5 mb-4">
        <span class="text-xs text-[#9CA3AF] mr-1">Sort:</span>
        <button class="sort-btn active" data-sort="newest" type="button">Newest</button>
        <button class="sort-btn" data-sort="price" type="button">Price: low → high</button>
      </div>
      <div id="cl-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {results.map((l, i) => (
          <a
            href={`/listings/${l.slug}/`}
            data-idx={i}
            data-price={l.listing_type === 'for_sale' && l.price > 0 ? l.price : ''}
            class="group border rounded-xl overflow-hidden transition-all flex flex-col bg-white border-[#DDD9D3] hover:border-[#F5A623] hover:shadow-md"
          >
            <div class="card-img">
              <img
                src={firstThumb(l.photos)}
                alt={l.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                width="800" height="500"
                loading={i < 6 ? 'eager' : 'lazy'}
                fetchpriority={i < 3 ? 'high' : 'auto'}
                decoding="async"
              />
              <span class="card-badge">{l.province}</span>
              {dropBySlug.has(l.slug) && (
                <span class="card-badge-drop">▼ R{dropBySlug.get(l.slug)!.toLocaleString('en-ZA')} drop</span>
              )}
            </div>
            <div class="p-4 sm:p-5 flex flex-col flex-1">
              <h2 class="font-heading font-bold uppercase text-base leading-tight mb-1 group-hover:text-[#F5A623] transition-colors line-clamp-2 text-[#111111]">
                {l.title}
              </h2>
              <p class="text-xs mb-4 truncate text-[#6B7280]">
                {l.year} · {l.model.replace('-series', ' Series')} · {l.transmission === 'manual' ? 'Manual' : 'Auto'} · {l.province}
              </p>
              <div class="mt-auto">
                {l.listing_type === 'for_sale' && l.price > 0
                  ? <p class="font-heading font-bold text-2xl text-[#111111]">{formatPrice(l.price)}</p>
                  : <span class="text-xs font-bold text-[#F5A623] uppercase tracking-wide">POA</span>
                }
              </div>
            </div>
          </a>
        ))}
      </div>
      </>
    )}

    <!-- Sell CTA -->
    <div class="mt-12 p-5 bg-[#F5F3EE] border border-[#DDD9D3] rounded-xl flex flex-col sm:flex-row items-start sm:items-center gap-4">
      <div class="flex-1">
        <p class="text-xs font-bold uppercase tracking-widest text-[#F5A623] mb-1">Selling?</p>
        <p class="font-heading font-bold uppercase text-[#111111] text-base">List your classic Cruiser on Land Cruiser SA</p>
        <p class="text-sm text-[#6B7280] mt-0.5">Free listing, reviewed within 24 hours — reaches collectors, restorers and specialist dealers.</p>
      </div>
      <a href="/listings/submit/" class="flex-shrink-0 inline-flex items-center bg-[#111111] text-white font-heading font-bold uppercase tracking-wide px-5 py-2.5 rounded-xl text-sm hover:bg-[#222] transition-colors">
        List Your Vehicle →
      </a>
    </div>

    <!-- Other sections -->
    <div class="mt-16 pt-10 border-t border-[#DDD9D3]">
      <h2 class="font-heading font-bold uppercase text-xl text-[#111111] mb-5">Browse by Model</h2>
      <div class="flex flex-wrap gap-2">
        {[
          ['76-series', '76 Series'], ['78-series', '78 Series (Troopcarrier)'], ['79-series', '79 Series'],
          ['80-series', '80 Series'], ['100-series', '100 Series'], ['200-series', '200 Series'],
          ['300-series', '300 Series'], ['prado', 'Prado'], ['fj-cruiser', 'FJ Cruiser'],
        ].map(([slug, label]) => (
          <a href={`/listings/model/${slug}/`} class="px-4 py-2 border border-[#DDD9D3] rounded-full text-sm text-[#4A4A4A] hover:border-[#F5A623] hover:text-[#F5A623] transition-colors">
            {label}
          </a>
        ))}
        <a href="/game-viewers/" class="px-4 py-2 border border-[#DDD9D3] rounded-full text-sm text-[#4A4A4A] hover:border-[#F5A623] hover:text-[#F5A623] transition-colors">
          Game Viewers
        </a>
      </div>
    </div>

  </div>

</Base>

<script>
  // Sort toggle — same pure-DOM reorder as the per-model pages.
  const grid = document.getElementById('cl-grid');
  const btns = Array.from(document.querySelectorAll<HTMLButtonElement>('.sort-btn'));
  if (grid && btns.length) {
    btns.forEach(btn => btn.addEventListener('click', () => {
      btns.forEach(b => b.classList.toggle('active', b === btn));
      const cards = Array.from(grid.children) as HTMLElement[];
      const key = btn.dataset.sort === 'price'
        ? (el: HTMLElement) => (el.dataset.price ? Number(el.dataset.price) : Infinity)
        : (el: HTMLElement) => Number(el.dataset.idx ?? 0);
      cards.sort((a, b) => key(a) - key(b)).forEach(el => grid.appendChild(el));
    }));
  }
</script>

<style>
  .card-img {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #F5F3EE;
  }
  .card-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: #111111;
    color: white;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.5rem;
    border-radius: 0.25rem;
  }
  .card-badge-drop {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background: #16803C;
    color: white;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.5rem;
    border-radius: 0.25rem;
  }
  .sort-btn {
    font-size: 0.75rem;
    font-weight: 600;
    color: #6B7280;
    background: #fff;
    border: 1px solid #DDD9D3;
    border-radius: 9999px;
    padding: 0.3rem 0.8rem;
    cursor: pointer;
    transition: all 0.15s;
  }
  .sort-btn:hover { border-color: #F5A623; color: #111; }
  .sort-btn.active { background: #111; color: #fff; border-color: #111; }
</style>
