---
export const prerender = false;

import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/db/index';
import { listings, ingestRuns } from '@/db/schema';
import { desc, eq, sql } from 'drizzle-orm';
import { getScheduledMap, getExtraMap, EXTRA_SEGMENT_SOURCES } from '@/lib/scraper-config';

const SOURCES: { key: string; label: string }[] = [
  { key: 'autotrader', label: 'AutoTrader' },
  { key: 'wbc',        label: 'WeBuyCars' },
  { key: 'carsza',     label: 'Cars.co.za' },
  { key: 'adios',      label: 'Adios' },
  { key: 'wbb',        label: 'We Buy Bakkies' },
];

// Per-source "run on schedule" flags (admin-toggleable; default on).
const scheduled = getScheduledMap();
// Per-source "also collect Hilux/Fortuner" flags (default off). Adios has no
// such stock, so it never gets the toggle.
const extra = getExtraMap();
const SUPPORTS_EXTRA = new Set<string>(EXTRA_SEGMENT_SOURCES);

const MODELS = [
  '79-series', '76-series', '78-series', '70-series', '80-series', '100-series',
  '200-series', '300-series', 'prado-150', 'prado-250', 'fj-cruiser', 'land-cruiser-fj',
  // Adjacent Toyota 4x4 segment — tracked for cross-segment benchmarking, kept off the public LC site.
  'hilux-gd6', 'hilux-d4d', 'fortuner-gd6', 'fortuner-d4d', 'other',
];

// ── Last runs per source (latest 6 each) ─────────────────────────────────────
const allRuns = db.select().from(ingestRuns).orderBy(desc(ingestRuns.run_at)).limit(120).all();
const runsBySource = new Map<string, typeof allRuns>();
for (const r of allRuns) {
  const list = runsBySource.get(r.source) ?? [];
  if (list.length < 6) { list.push(r); runsBySource.set(r.source, list); }
}

// ── Active listings per source × model ───────────────────────────────────────
const counts = db.select({
  source: listings.source,
  model:  listings.model,
  n:      sql<number>`count(*)`,
}).from(listings)
  .where(eq(listings.status, 'active'))
  .groupBy(listings.source, listings.model)
  .all();

const matrix = new Map<string, Map<string, number>>(); // source → model → n
const modelTotals = new Map<string, number>();
for (const c of counts) {
  if (!matrix.has(c.source)) matrix.set(c.source, new Map());
  matrix.get(c.source)!.set(c.model, c.n);
  modelTotals.set(c.model, (modelTotals.get(c.model) ?? 0) + c.n);
}
const sourceTotals = new Map<string, number>();
for (const [src, models] of matrix) {
  sourceTotals.set(src, [...models.values()].reduce((a, b) => a + b, 0));
}

// ── Market coverage (all tracked segments: Land Cruiser + adjacent Toyota 4x4) ─
const covCounts = db.select({
  source:  listings.source,
  segment: listings.segment,
  n:       sql<number>`count(*)`,
}).from(listings)
  .where(eq(listings.status, 'active'))
  .groupBy(listings.source, listings.segment)
  .all();

// source → { lc, hf, total } — hf = Hilux & Fortuner (the toyota-4x4 segment)
const covBySource = new Map<string, { lc: number; hf: number; total: number }>();
for (const c of covCounts) {
  const e = covBySource.get(c.source) ?? { lc: 0, hf: 0, total: 0 };
  if (c.segment === 'land-cruiser') e.lc += c.n; else e.hf += c.n;
  e.total += c.n;
  covBySource.set(c.source, e);
}
const lcTotal      = covCounts.filter(c => c.segment === 'land-cruiser').reduce((s, c) => s + c.n, 0);
const hfTotal      = covCounts.filter(c => c.segment !== 'land-cruiser').reduce((s, c) => s + c.n, 0);
const trackedTotal = lcTotal + hfTotal;

// Penetration per source from its latest run that reported a source total.
// Cars.co.za & WeBuyCars expose one; the others don't (we watch their caps).
function latestPenetration(key: string): { pct: number; found: number; total: number } | null {
  const r = (runsBySource.get(key) ?? []).find(x => x.source_total != null && x.source_total > 0);
  if (!r) return null;
  return { pct: Math.round((r.found / r.source_total!) * 100), found: r.found, total: r.source_total! };
}

// How recently the supply was refreshed overall (most recent successful run, any source)
const lastRefresh = allRuns.find(r => r.ok)?.run_at ?? null;

// Coverage anomaly: source carries decent stock overall but has ZERO of a model
// that other sources hold plenty of — the exact failure mode that hid WBC 79s.
function isAnomaly(source: string, model: string): boolean {
  if (model === 'other') return false; // catch-all bucket, not a real model
  const own = matrix.get(source)?.get(model) ?? 0;
  if (own > 0) return false;
  const others = (modelTotals.get(model) ?? 0);
  const ownTotal = sourceTotals.get(source) ?? 0;
  return ownTotal >= 25 && others >= 15;
}

// ── Health verdict per source ────────────────────────────────────────────────
const now = Date.now();
type Health = { state: 'ok' | 'warn' | 'down'; reason: string };
function healthFor(key: string): Health {
  const runs = runsBySource.get(key) ?? [];
  if (runs.length === 0) return { state: 'warn', reason: 'No runs recorded yet' };
  const last = runs[0];
  const ageH = (now - last.run_at.getTime()) / 3_600_000;
  if (!last.ok) return { state: 'down', reason: last.note ?? 'Last run failed' };
  if (last.cap_hit) return { state: 'warn', reason: 'Hit a pagination cap — may be truncating listings' };
  if (ageH > 48) return { state: 'warn', reason: `Last run ${Math.round(ageH)}h ago` };
  if (runs.length > 1 && runs[1].found > 0) {
    const drop = (runs[1].found - last.found) / runs[1].found;
    if (drop > 0.4) return { state: 'warn', reason: `Found dropped ${Math.round(drop * 100)}% vs previous run` };
  }
  if (last.found > 0 && last.created + last.updated === 0 && last.skipped >= last.found * 0.9) {
    return { state: 'warn', reason: 'Nearly all fetches skipped — per-listing fetch may be broken' };
  }
  return { state: 'ok', reason: '' };
}

function ago(d: Date): string {
  const mins = Math.round((now - d.getTime()) / 60_000);
  if (mins < 60) return `${mins}m ago`;
  const h = Math.round(mins / 60);
  if (h < 48) return `${h}h ago`;
  return `${Math.round(h / 24)}d ago`;
}
const MODEL_LABEL_OVERRIDE: Record<string, string> = {
  'hilux-gd6': 'HILUX GD-6', 'hilux-d4d': 'HILUX D-4D',
  'fortuner-gd6': 'FORTUNER GD-6', 'fortuner-d4d': 'FORTUNER D-4D',
};
function fmtModel(m: string): string {
  return MODEL_LABEL_OVERRIDE[m] ?? (m.replaceAll('-', ' ').replace('series', '').trim().toUpperCase() || m);
}
---

<AdminLayout title="Scrapers" activePage="scrapers">

  <!-- MARKET COVERAGE -->
  <div class="coverage">
    <div class="cov-head">
      <div>
        <p class="cov-eyebrow">Market Coverage</p>
        <p class="cov-total"><strong>{trackedTotal.toLocaleString('en-ZA')}</strong> active listings tracked</p>
        <p class="cov-total-split">
          <strong>{lcTotal.toLocaleString('en-ZA')}</strong> Land Cruiser
          <span class="cov-split-dot">·</span>
          <strong>{hfTotal.toLocaleString('en-ZA')}</strong> Hilux &amp; Fortuner
        </p>
      </div>
      {lastRefresh && <span class="cov-refresh">Refreshed {ago(lastRefresh)}</span>}
    </div>
    <p class="cov-claim">
      Aggregated across South Africa's dominant used-vehicle platforms — <strong>AutoTrader</strong> (the
      country's #1 marketplace, ~130k total listings &amp; 11M monthly visits), <strong>Cars.co.za</strong>
      (#2, ~74k listings) and <strong>WeBuyCars</strong> — plus the Land Cruiser specialists Adios &amp; We Buy
      Bakkies. For Land Cruisers specifically, this is effectively the entire online market. We also track the
      adjacent Toyota 4&times;4 market — <strong>Hilux &amp; Fortuner</strong> — for cross-segment price and
      depreciation benchmarking; these stay out of the public LC classifieds.
    </p>

    <div class="cov-grid">
      {SOURCES.map(({ key, label }) => {
        const e = covBySource.get(key) ?? { lc: 0, hf: 0, total: 0 };
        const pen = latestPenetration(key);
        const share = trackedTotal > 0 ? Math.round((e.total / trackedTotal) * 100) : 0;
        return (
          <div class="cov-src">
            <p class="cov-src-name">{label}</p>
            <p class="cov-src-n">{e.total.toLocaleString('en-ZA')}<span class="cov-src-share"> · {share}% of tracked</span></p>
            <p class="cov-src-split">{e.lc.toLocaleString('en-ZA')} LC <span class="cov-split-dot">·</span> {e.hf.toLocaleString('en-ZA')} Hilux/Fortuner</p>
            {pen
              ? <p class="cov-src-pen">Penetration <strong>{pen.pct}%</strong> <span>({pen.found.toLocaleString('en-ZA')} of {pen.total.toLocaleString('en-ZA')} the source reports)</span></p>
              : <p class="cov-src-pen cov-src-pen-na">No source total — coverage tracked via pagination caps</p>
            }
          </div>
        );
      })}
    </div>

    <p class="cov-foot">
      <strong>Penetration</strong> = listings we captured ÷ the total the source's own counter reports.
      Cars.co.za reports a true per-model total (so its % is real coverage); WeBuyCars reports text-search
      hits incl. non-LC, so its % reads low by design. "Effectively the entire market" means online-listed
      stock — private off-platform sales (Facebook, word-of-mouth) are out of scope and unmeasurable.
    </p>
  </div>

  <!-- SOURCE HEALTH CARDS -->
  <div class="health-grid">
    {SOURCES.map(({ key, label }) => {
      const h = healthFor(key);
      const runs = runsBySource.get(key) ?? [];
      const last = runs[0];
      return (
        <div class={`hcard hcard-${h.state}${scheduled[key] === false ? ' hcard-paused' : ''}`}>
          <div class="hcard-top">
            <span class={`dot dot-${h.state}`}></span>
            <span class="hcard-name">{label}</span>
            {scheduled[key] === false && <span class="paused-pill">Paused</span>}
            <span class="hcard-active">{sourceTotals.get(key) ?? 0} active</span>
            <label class="sched-toggle" title="Run this scraper on its schedule. Off = paused; the manual Run button still works.">
              <input type="checkbox" class="sched-input" data-source={key} checked={scheduled[key] !== false} />
              <span class="sched-track"><span class="sched-thumb"></span></span>
            </label>
          </div>
          {SUPPORTS_EXTRA.has(key) && (
            <label class="extra-toggle" title="Also scrape Hilux & Fortuner from this source (collected for market data — never shown in the public LC listings). Off = Land Cruiser only.">
              <input type="checkbox" class="extra-input" data-source={key} checked={extra[key] === true} />
              <span class="sched-track"><span class="sched-thumb"></span></span>
              <span class="extra-label">Scrape Hilux &amp; Fortuner</span>
            </label>
          )}
          {last ? (
            <>
              <p class="hcard-last">
                Last run {ago(last.run_at)} — found {last.found},
                +{last.created} new, {last.updated} updated, {last.skipped} skipped{last.removed > 0 ? `, ${last.removed} removed` : ''}
              </p>
              {last.source_total != null && last.source_total > 0 && (
                <p class="hcard-pen">
                  Penetration <strong>{Math.round((last.found / last.source_total) * 100)}%</strong>
                  <span class="pen-sub"> — {last.found} of {last.source_total} reported by source</span>
                </p>
              )}
              {h.reason && <p class={`hcard-reason reason-${h.state}`}>{h.reason}</p>}
              <p class="rh-label">Recent runs — listings found <span class="rh-dir">newest ←→ oldest</span></p>
              <div class="run-history">
                {runs.slice(0, 6).map(r => (
                  <div class={`run-pill${r.ok ? '' : ' run-fail'}`} title={r.ok ? r.run_at.toLocaleString('en-ZA') : `${r.run_at.toLocaleString('en-ZA')} — failed${r.note ? ': ' + r.note : ''}`}>
                    <span class="rp-found">{r.ok ? r.found : '✕'}</span>
                    <span class="rp-time">{ago(r.run_at)}</span>
                  </div>
                ))}
              </div>
            </>
          ) : (
            <p class="hcard-last">No ingest runs recorded yet — stats appear after the next run.</p>
          )}
        </div>
      );
    })}
  </div>

  <!-- Background jobs (not source ingests) — their own health so a rate-limit
       abort is visible here, not just in the logs. -->
  <p class="section-head" style="margin-top:1.5rem">Background jobs</p>
  <div class="health-grid">
    {(() => {
      const jr = runsBySource.get('at-images') ?? [];
      const jl = jr[0];
      const st = !jl ? 'ok' : (jl.ok ? 'ok' : 'down');
      return (
        <div class={`hcard hcard-${st}`}>
          <div class="hcard-top">
            <span class={`dot dot-${st}`}></span>
            <span class="hcard-name">AT Image Backfill</span>
          </div>
          {jl ? (
            <>
              <p class="hcard-last">
                Last run {ago(jl.run_at)} — {jl.updated} galleries filled, {jl.skipped} skipped
              </p>
              {!jl.ok && <p class="hcard-reason reason-down">⚠ {jl.note ?? 'aborted'}</p>}
              <p class="rh-label">Recent runs — galleries filled <span class="rh-dir">newest ←→ oldest</span></p>
              <div class="run-history">
                {jr.slice(0, 6).map(r => (
                  <div class={`run-pill${r.ok ? '' : ' run-fail'}`} title={r.ok ? r.run_at.toLocaleString('en-ZA') : `${r.run_at.toLocaleString('en-ZA')} — ${r.note ?? 'failed'}`}>
                    <span class="rp-found">{r.ok ? r.updated : '✕'}</span>
                    <span class="rp-time">{ago(r.run_at)}</span>
                  </div>
                ))}
              </div>
            </>
          ) : (
            <p class="hcard-last">No backfill runs recorded yet — fills missing AutoTrader photo galleries on each daily run (Land Cruiser only by default).</p>
          )}
        </div>
      );
    })()}
  </div>

  <!-- TOOLS — manual runs; local dev only (AT blocks Fly IPs) -->
  {import.meta.env.DEV && (
    <div class="tools-row">
      <div class="tool-card">
        <div class="tool-info">
          <p class="tool-name">Ingest Listings <span class="local-badge">LOCAL</span></p>
          <p class="tool-desc">Discover and import new listings from AutoTrader, WBC, Adios, and We Buy Bakkies using your residential IP.</p>
          <p class="tool-times">
            <span class="time-label">Last run:</span> <span id="ingest-last-run" class="time-val">—</span>
            <span id="ingest-status" class="tool-status-inline"></span>
            <span class="time-next">
              <span class="time-label">Next:</span> <span id="ingest-next-run" class="time-val">—</span>
            </span>
          </p>
          <div id="ingest-progress" class="tool-progress" hidden>
            <div class="tool-progress-track"><span id="ingest-progress-fill"></span></div>
            <span id="ingest-progress-label" class="tool-progress-label"></span>
          </div>
        </div>
        <div class="tool-controls">
          <button id="run-ingest-btn" class="btn btn-tool">Run Ingest</button>
        </div>
      </div>
      <div class="tool-card">
        <div class="tool-info">
          <p class="tool-name">AT Image Backfill <span class="local-badge">LOCAL</span></p>
          <p class="tool-desc">Fetch full image sets for AT listings with &lt;2 photos.</p>
          <p class="tool-times">
            <span class="time-label">Last run:</span> <span id="backfill-last-run" class="time-val">—</span>
            <span id="backfill-status" class="tool-status-inline"></span>
            <span class="time-next">
              <span class="time-label">Next:</span> <span id="backfill-next-run" class="time-val">—</span>
            </span>
          </p>
        </div>
        <div class="tool-controls">
          <button id="run-backfill-btn" class="btn btn-tool">Run Backfill</button>
        </div>
      </div>
      <div class="tool-card">
        <div class="tool-info">
          <p class="tool-name">AT Description Backfill <span class="local-badge">LOCAL</span></p>
          <p class="tool-desc">Pull seller comments &amp; colour for AT listings missing a description.</p>
          <p class="tool-times">
            <span class="time-label">Last run:</span> <span id="desc-backfill-last-run" class="time-val">—</span>
            <span id="desc-backfill-status" class="tool-status-inline"></span>
            <span class="time-next">
              <span class="time-label">Next:</span> <span id="desc-backfill-next-run" class="time-val">—</span>
            </span>
          </p>
        </div>
        <div class="tool-controls">
          <button id="run-desc-backfill-btn" class="btn btn-tool">Run</button>
        </div>
      </div>
    </div>
  )}

  {import.meta.env.DEV && (
    <div id="ingest-modal" class="modal-backdrop" hidden>
      <div class="modal">
        <p class="modal-title">Run Ingest</p>
        <p class="modal-label">Segments</p>
        <div class="modal-sources modal-segments">
          <label class="source-opt"><input type="checkbox" name="segment" value="land-cruiser" checked /> Land Cruiser</label>
          <label class="source-opt"><input type="checkbox" name="segment" value="jimny" checked /> Jimny</label>
        </div>
        <p class="modal-label">Sources</p>
        <p class="modal-hint">Jimny only crawls AutoTrader, WBC &amp; Cars.co.za; Adios &amp; We Buy Bakkies are Land&nbsp;Cruiser-only.</p>
        <div class="modal-sources">
          <label class="source-opt"><input type="checkbox" name="source" value="autotrader" checked /> AutoTrader</label>
          <label class="source-opt"><input type="checkbox" name="source" value="wbc" checked /> WBC</label>
          <label class="source-opt"><input type="checkbox" name="source" value="adios" checked /> Adios</label>
          <label class="source-opt"><input type="checkbox" name="source" value="wbb" checked /> We Buy Bakkies</label>
          <label class="source-opt"><input type="checkbox" name="source" value="carsza" checked /> Cars.co.za</label>
        </div>
        <div class="modal-actions">
          <button id="ingest-cancel-btn" class="btn btn-edit">Cancel</button>
          <button id="ingest-confirm-btn" class="btn btn-tool">Run</button>
        </div>
      </div>
    </div>
  )}

  <!-- COVERAGE MATRIX -->
  <div class="section">
    <p class="section-head">Coverage — active listings by source &times; model</p>
    <p class="section-sub">
      Red cells: the source carries stock overall but has <strong>zero</strong> of a model other
      sources hold plenty of — usually means its scraper isn't seeing that model.
    </p>
    <div class="matrix-wrap">
      <table class="matrix">
        <thead>
          <tr>
            <th></th>
            {MODELS.map(m => <th>{fmtModel(m)}</th>)}
            <th class="col-total">Total</th>
          </tr>
        </thead>
        <tbody>
          {SOURCES.map(({ key, label }) => (
            <tr>
              <td class="row-label">{label}</td>
              {MODELS.map(m => {
                const n = matrix.get(key)?.get(m) ?? 0;
                const bad = isAnomaly(key, m);
                return <td class={`cell${n === 0 ? ' cell-zero' : ''}${bad ? ' cell-bad' : ''}`}>{n || '—'}</td>;
              })}
              <td class="col-total">{sourceTotals.get(key) ?? 0}</td>
            </tr>
          ))}
          <tr class="row-totals">
            <td class="row-label">All sources</td>
            {MODELS.map(m => <td class="cell">{modelTotals.get(m) ?? 0}</td>)}
            <td class="col-total">{[...sourceTotals.values()].reduce((a, b) => a + b, 0)}</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- HOW IT WORKS -->
  <div class="section">
    <p class="section-head">How scraping health is measured</p>
    <ul class="explain">
      <li><strong>Found</strong> — how many Land Cruiser listings the scraper discovered on the source site this run. A sudden drop means the source changed their site/API or is blocking us.</li>
      <li><strong>Penetration</strong> — found ÷ the total the source's own counter reports. Only shown for sources that expose a total. <em>Cars.co.za</em> and <em>AutoTrader</em> both report a real per-model total, so their % is true coverage; <em>WeBuyCars</em> reports text-search hits (which include non-LC and not-for-sale), so its % reads low by design — we keep only LC for-sale. Sources with no total (Adios, We Buy Bakkies) show no %; we watch their pagination caps instead.</li>
      <li><strong>Completeness</strong> — AutoTrader exposes its own <em>totalCount</em> per model, so we crawl every page and then check captured ÷ reported. If any model comes up short (or a page errored mid-crawl), the card turns amber — a reliable "we didn't get them all" signal, not a guess. Adios (100, no pagination) and We Buy Bakkies (10 sitemap files) still stop at a fixed ceiling we watch.</li>
      <li><strong>Skipped</strong> — listings discovered but not saved: per-listing fetch failures (blocking, rate limits) or cross-source duplicates. Near-100% skipped with 0 created/updated means the fetcher is broken even though discovery works.</li>
      <li><strong>Zero-model anomalies</strong> — the red cells above. This is exactly how the missing WBC 79-series would have been caught automatically.</li>
      <li>Each ingest script reports its run here automatically; failures (zero results) report too, so a silent scraper shows up as a red card, not an empty page.</li>
    </ul>
  </div>

</AdminLayout>

<script>
  // Per-source schedule toggle → POST to admin endpoint; revert on failure.
  document.querySelectorAll<HTMLInputElement>('.sched-input').forEach((input) => {
    input.addEventListener('change', async () => {
      const source = input.dataset.source!;
      const scheduled = input.checked;
      input.disabled = true;
      try {
        const res = await fetch('/api/admin/set-scraper-schedule', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ source, scheduled }),
        });
        if (!res.ok) throw new Error('failed');
        input.closest('.hcard')?.classList.toggle('hcard-paused', !scheduled);
        const top = input.closest('.hcard-top');
        const existing = top?.querySelector('.paused-pill');
        if (!scheduled && top && !existing) {
          const pill = document.createElement('span');
          pill.className = 'paused-pill';
          pill.textContent = 'Paused';
          top.querySelector('.hcard-name')?.after(pill);
        } else if (scheduled && existing) {
          existing.remove();
        }
      } catch {
        input.checked = !scheduled; // revert
        alert('Could not update the schedule — please try again.');
      } finally {
        input.disabled = false;
      }
    });
  });

  // Per-source "scrape Hilux & Fortuner" toggle → POST; revert on failure.
  document.querySelectorAll<HTMLInputElement>('.extra-input').forEach((input) => {
    input.addEventListener('change', async () => {
      const source = input.dataset.source!;
      const extra = input.checked;
      input.disabled = true;
      try {
        const res = await fetch('/api/admin/set-scraper-extra', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ source, extra }),
        });
        if (!res.ok) throw new Error('failed');
      } catch {
        input.checked = !extra; // revert
        alert('Could not update Hilux/Fortuner scraping — please try again.');
      } finally {
        input.disabled = false;
      }
    });
  });
</script>

<script>
  // Manual scraper runs — local dev only (the tool cards are DEV-gated; AT
  // blocks Fly IPs so these must run from the residential machine).
  if (import.meta.env.DEV) {
    function fmtTime(ms: number | null): string {
      if (!ms) return '—';
      return new Intl.DateTimeFormat('en-ZA', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }).format(new Date(ms));
    }

    function fmtNext(ms: number): string {
      const now = Date.now();
      const diff = ms - now;
      if (diff < 0) return 'overdue';
      const mins = Math.round(diff / 60000);
      if (mins < 60) return `in ${mins}m`;
      const d = new Date(ms);
      const isToday = new Date(now).toDateString() === d.toDateString();
      const isTomorrow = new Date(now + 86400000).toDateString() === d.toDateString();
      const timeStr = d.toLocaleTimeString('en-ZA', { hour: '2-digit', minute: '2-digit' });
      if (isToday) return `today at ${timeStr}`;
      if (isTomorrow) return `tomorrow at ${timeStr}`;
      return fmtTime(ms);
    }

    async function loadRunTimes() {
      try {
        const data = await fetch('/api/admin/run-times').then(r => r.json());
        const il = document.getElementById('ingest-last-run');
        const in_ = document.getElementById('ingest-next-run');
        const bl = document.getElementById('backfill-last-run');
        const bn = document.getElementById('backfill-next-run');
        const dl = document.getElementById('desc-backfill-last-run');
        const dn = document.getElementById('desc-backfill-next-run');
        if (il) il.textContent = fmtTime(data.ingest.lastRun);
        if (in_) in_.textContent = fmtNext(data.ingest.nextRun);
        if (bl) bl.textContent = fmtTime(data.backfill.lastRun);
        if (bn) bn.textContent = fmtNext(data.backfill.nextRun);
        if (dl) dl.textContent = fmtTime(data.descBackfill?.lastRun);
        if (dn) dn.textContent = fmtNext(data.descBackfill?.nextRun);
      } catch { /* non-critical */ }
    }

    loadRunTimes();

    // Ingest — open source picker modal first
    const ingestModal  = document.getElementById('ingest-modal')!;
    const ingestBtn    = document.getElementById('run-ingest-btn') as HTMLButtonElement | null;
    const cancelBtn    = document.getElementById('ingest-cancel-btn')!;
    const confirmBtn   = document.getElementById('ingest-confirm-btn') as HTMLButtonElement;
    const statusEl     = document.getElementById('ingest-status')!;
    const progressEl   = document.getElementById('ingest-progress')!;
    const progressFill = document.getElementById('ingest-progress-fill')!;
    const progressLbl  = document.getElementById('ingest-progress-label')!;

    ingestBtn?.addEventListener('click', () => { ingestModal.hidden = false; });
    cancelBtn?.addEventListener('click', () => { ingestModal.hidden = true; });
    ingestModal?.addEventListener('click', (e) => { if (e.target === ingestModal) ingestModal.hidden = true; });

    confirmBtn?.addEventListener('click', async () => {
      const checked = [...ingestModal.querySelectorAll<HTMLInputElement>('input[name="source"]:checked')]
        .map(el => el.value);
      const segments = [...ingestModal.querySelectorAll<HTMLInputElement>('input[name="segment"]:checked')]
        .map(el => el.value);
      if (!checked.length) { alert('Select at least one source.'); return; }
      if (!segments.length) { alert('Select at least one segment (Land Cruiser and/or Jimny).'); return; }

      ingestModal.hidden = true;
      ingestBtn!.disabled = true;
      ingestBtn!.textContent = 'Running…';
      statusEl.textContent = 'Starting…';
      progressEl.hidden = false;
      (progressFill as HTMLElement).style.width = '0%';
      progressLbl.textContent = 'Starting…';

      // Keyed by `${segment}:${source}` so the same source under both segments
      // doesn't collide.
      const sourceResults: Record<string, { created: number; updated: number; ok: boolean }> = {};
      const summaryRe = /\] done — created: (\d+), updated: (\d+)/;
      const SEG_LABELS: Record<string, string> = { 'land-cruiser': 'LC', 'jimny': 'Jimny' };
      const SRC_LABELS: Record<string, string> = {
        autotrader: 'AT', wbc: 'WBC', adios: 'Adios', wbb: 'WBB', carsza: 'Cars.co.za',
        'gallery-backfill': 'Galleries', 'image-rehost': 'Image rehost',
      };
      let currentSegment = '';
      let currentSource = '';

      try {
        const url = `/api/admin/run-ingest?segments=${segments.join(',')}&sources=${checked.join(',')}`;
        const res = await fetch(url);
        if (!res.ok || !res.body) throw new Error(`HTTP ${res.status}`);
        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buf = '';
        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          buf += decoder.decode(value, { stream: true });
          const parts = buf.split('\n\n');
          buf = parts.pop() ?? '';
          for (const part of parts) {
            if (!part.startsWith('data: ')) continue;
            let ev: Record<string, unknown>;
            try { ev = JSON.parse(part.slice(6)); } catch { continue; }
            if (ev.type === 'segment-start') {
              currentSegment = String(ev.segment);
              statusEl.textContent = `${SEG_LABELS[currentSegment] ?? currentSegment}…`;
            } else if (ev.type === 'script-start') {
              currentSource = String(ev.name);
              const seg = SEG_LABELS[String(ev.segment ?? currentSegment)] ?? '';
              const lbl = SRC_LABELS[currentSource] ?? currentSource;
              statusEl.textContent = `Running ${seg ? seg + ' · ' : ''}${lbl}…`;
              (progressFill as HTMLElement).style.width = '0%';
              progressLbl.textContent = `${seg ? seg + ' · ' : ''}${lbl} · Starting…`;
            } else if (ev.type === 'log') {
              const text = String(ev.text);
              statusEl.textContent = text.slice(0, 80);
              const m = summaryRe.exec(text);
              if (m && currentSource) {
                sourceResults[`${currentSegment}:${currentSource}`] = { created: Number(m[1]), updated: Number(m[2]), ok: true };
              }
            } else if (ev.type === 'progress') {
              const done = Number(ev.done), total = Number(ev.total) || 1;
              const pct = Math.min(100, Math.round((done / total) * 100));
              (progressFill as HTMLElement).style.width = pct + '%';
              const phase = ev.phase === 'discover' ? 'Discovering' : 'Importing';
              const detail = ev.sub ? String(ev.sub) : `${Math.floor(done).toLocaleString()}/${total.toLocaleString()}`;
              const seg = SEG_LABELS[currentSegment] ?? '';
              const lbl = SRC_LABELS[currentSource] ?? currentSource;
              progressLbl.textContent = `${seg ? seg + ' · ' : ''}${lbl ? lbl + ' · ' : ''}${phase} ${pct}% — ${detail}`;
            } else if (ev.type === 'script-done') {
              const key = `${ev.segment ?? currentSegment}:${ev.name ?? currentSource}`;
              if (!sourceResults[key]) {
                sourceResults[key] = { created: 0, updated: 0, ok: Boolean(ev.ok) };
              }
            } else if (ev.type === 'done') {
              const summary = Object.entries(sourceResults)
                // The image steps don't report a created count — drop them from the headline.
                .filter(([key]) => !key.endsWith(':gallery-backfill') && !key.endsWith(':image-rehost'))
                .map(([key, r]) => {
                  const [seg, src] = key.split(':');
                  return `${SEG_LABELS[seg] ?? seg} ${SRC_LABELS[src] ?? src} +${r.created}`;
                })
                .join(' · ');
              statusEl.textContent = summary || 'Done.';
              (progressFill as HTMLElement).style.width = '100%';
              progressLbl.textContent = 'Done';
              setTimeout(() => { progressEl.hidden = true; }, 2500);
              const el = document.getElementById('ingest-last-run');
              if (el) el.textContent = fmtTime(Date.now());
            }
          }
        }
      } catch (err) {
        statusEl.textContent = String(err);
        statusEl.classList.add('is-error');
      }
      ingestBtn!.disabled = false;
      ingestBtn!.textContent = 'Run Ingest';
    });

    // AT image backfill — streams SSE progress
    document.getElementById('run-backfill-btn')?.addEventListener('click', async function () {
      const btn = this as HTMLButtonElement;
      const statusEl = document.getElementById('backfill-status')!;

      btn.disabled = true;
      btn.textContent = 'Running…';
      statusEl.textContent = 'Starting…';

      try {
        const res = await fetch('/api/admin/run-backfill');
        if (!res.ok || !res.body) throw new Error(`HTTP ${res.status}`);

        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buf = '';

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          buf += decoder.decode(value, { stream: true });
          const parts = buf.split('\n\n');
          buf = parts.pop() ?? '';
          for (const part of parts) {
            if (!part.startsWith('data: ')) continue;
            let ev: Record<string, unknown>;
            try { ev = JSON.parse(part.slice(6)); } catch { continue; }
            if (ev.type === 'start') {
              statusEl.textContent = 'Starting…';
            } else if (ev.type === 'log') {
              // The script streams its stdout; show the latest meaningful line.
              const line = String(ev.text ?? '').trim();
              if (line) statusEl.textContent = line.slice(0, 100);
            } else if (ev.type === 'done') {
              statusEl.textContent = 'Done — see the “AT Image Backfill” card above for the result.';
              const el = document.getElementById('backfill-last-run');
              if (el) el.textContent = fmtTime(Date.now());
            }
          }
        }
      } catch (err) {
        statusEl.textContent = String(err);
        statusEl.classList.add('is-error');
      }

      btn.disabled = false;
      btn.textContent = 'Run Backfill';
    });

    // AT description backfill — streams SSE progress
    document.getElementById('run-desc-backfill-btn')?.addEventListener('click', async function () {
      const btn = this as HTMLButtonElement;
      const statusEl = document.getElementById('desc-backfill-status')!;

      btn.disabled = true;
      btn.textContent = 'Running…';
      statusEl.textContent = 'Starting…';
      statusEl.classList.remove('is-error');

      try {
        const res = await fetch('/api/admin/backfill-descriptions');
        if (!res.ok || !res.body) throw new Error(`HTTP ${res.status}`);

        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buf = '';

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          buf += decoder.decode(value, { stream: true });
          const parts = buf.split('\n\n');
          buf = parts.pop() ?? '';
          for (const part of parts) {
            if (!part.startsWith('data: ')) continue;
            let ev: Record<string, unknown>;
            try { ev = JSON.parse(part.slice(6)); } catch { continue; }
            if (ev.type === 'start') {
              statusEl.textContent = 'Starting…';
            } else if (ev.type === 'log') {
              const line = String(ev.text ?? '').trim();
              if (line) statusEl.textContent = line.slice(0, 100);
            } else if (ev.type === 'done') {
              statusEl.textContent = 'Done — see the AT desc-backfill health for the result.';
              const el = document.getElementById('desc-backfill-last-run');
              if (el) el.textContent = fmtTime(Date.now());
            }
          }
        }
      } catch (err) {
        statusEl.textContent = String(err);
        statusEl.classList.add('is-error');
      }

      btn.disabled = false;
      btn.textContent = 'Run';
    });
  }
</script>

