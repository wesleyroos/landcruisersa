---
export const prerender = false;

import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/db/index';
import { listings, ingestRuns } from '@/db/schema';
import { desc, eq, sql } from 'drizzle-orm';
import { getScheduledMap } from '@/lib/scraper-config';

const SOURCES: { key: string; label: string }[] = [
  { key: 'autotrader', label: 'AutoTrader' },
  { key: 'wbc',        label: 'WeBuyCars' },
  { key: 'carsza',     label: 'Cars.co.za' },
  { key: 'adios',      label: 'Adios' },
  { key: 'wbb',        label: 'We Buy Bakkies' },
];

// Per-source "run on schedule" flags (admin-toggleable; default on).
const scheduled = getScheduledMap();

const MODELS = [
  '79-series', '76-series', '78-series', '70-series', '80-series', '100-series',
  '200-series', '300-series', 'prado-150', 'prado-250', 'fj-cruiser', 'land-cruiser-fj',
  // Adjacent Toyota 4x4 segment — tracked for cross-segment benchmarking, kept off the public LC site.
  'hilux-gd6', 'hilux-d4d', 'fortuner-gd6', 'fortuner-d4d', 'other',
];

// ── Last runs per source (latest 6 each) ─────────────────────────────────────
const allRuns = db.select().from(ingestRuns).orderBy(desc(ingestRuns.run_at)).limit(120).all();
const runsBySource = new Map<string, typeof allRuns>();
for (const r of allRuns) {
  const list = runsBySource.get(r.source) ?? [];
  if (list.length < 6) { list.push(r); runsBySource.set(r.source, list); }
}

// ── Active listings per source × model ───────────────────────────────────────
const counts = db.select({
  source: listings.source,
  model:  listings.model,
  n:      sql<number>`count(*)`,
}).from(listings)
  .where(eq(listings.status, 'active'))
  .groupBy(listings.source, listings.model)
  .all();

const matrix = new Map<string, Map<string, number>>(); // source → model → n
const modelTotals = new Map<string, number>();
for (const c of counts) {
  if (!matrix.has(c.source)) matrix.set(c.source, new Map());
  matrix.get(c.source)!.set(c.model, c.n);
  modelTotals.set(c.model, (modelTotals.get(c.model) ?? 0) + c.n);
}
const sourceTotals = new Map<string, number>();
for (const [src, models] of matrix) {
  sourceTotals.set(src, [...models.values()].reduce((a, b) => a + b, 0));
}

// ── Market coverage (all tracked segments: Land Cruiser + adjacent Toyota 4x4) ─
const covCounts = db.select({
  source:  listings.source,
  segment: listings.segment,
  n:       sql<number>`count(*)`,
}).from(listings)
  .where(eq(listings.status, 'active'))
  .groupBy(listings.source, listings.segment)
  .all();

// source → { lc, hf, total } — hf = Hilux & Fortuner (the toyota-4x4 segment)
const covBySource = new Map<string, { lc: number; hf: number; total: number }>();
for (const c of covCounts) {
  const e = covBySource.get(c.source) ?? { lc: 0, hf: 0, total: 0 };
  if (c.segment === 'land-cruiser') e.lc += c.n; else e.hf += c.n;
  e.total += c.n;
  covBySource.set(c.source, e);
}
const lcTotal      = covCounts.filter(c => c.segment === 'land-cruiser').reduce((s, c) => s + c.n, 0);
const hfTotal      = covCounts.filter(c => c.segment !== 'land-cruiser').reduce((s, c) => s + c.n, 0);
const trackedTotal = lcTotal + hfTotal;

// Penetration per source from its latest run that reported a source total.
// Cars.co.za & WeBuyCars expose one; the others don't (we watch their caps).
function latestPenetration(key: string): { pct: number; found: number; total: number } | null {
  const r = (runsBySource.get(key) ?? []).find(x => x.source_total != null && x.source_total > 0);
  if (!r) return null;
  return { pct: Math.round((r.found / r.source_total!) * 100), found: r.found, total: r.source_total! };
}

// How recently the supply was refreshed overall (most recent successful run, any source)
const lastRefresh = allRuns.find(r => r.ok)?.run_at ?? null;

// Coverage anomaly: source carries decent stock overall but has ZERO of a model
// that other sources hold plenty of — the exact failure mode that hid WBC 79s.
function isAnomaly(source: string, model: string): boolean {
  if (model === 'other') return false; // catch-all bucket, not a real model
  const own = matrix.get(source)?.get(model) ?? 0;
  if (own > 0) return false;
  const others = (modelTotals.get(model) ?? 0);
  const ownTotal = sourceTotals.get(source) ?? 0;
  return ownTotal >= 25 && others >= 15;
}

// ── Health verdict per source ────────────────────────────────────────────────
const now = Date.now();
type Health = { state: 'ok' | 'warn' | 'down'; reason: string };
function healthFor(key: string): Health {
  const runs = runsBySource.get(key) ?? [];
  if (runs.length === 0) return { state: 'warn', reason: 'No runs recorded yet' };
  const last = runs[0];
  const ageH = (now - last.run_at.getTime()) / 3_600_000;
  if (!last.ok) return { state: 'down', reason: last.note ?? 'Last run failed' };
  if (last.cap_hit) return { state: 'warn', reason: 'Hit a pagination cap — may be truncating listings' };
  if (ageH > 48) return { state: 'warn', reason: `Last run ${Math.round(ageH)}h ago` };
  if (runs.length > 1 && runs[1].found > 0) {
    const drop = (runs[1].found - last.found) / runs[1].found;
    if (drop > 0.4) return { state: 'warn', reason: `Found dropped ${Math.round(drop * 100)}% vs previous run` };
  }
  if (last.found > 0 && last.created + last.updated === 0 && last.skipped >= last.found * 0.9) {
    return { state: 'warn', reason: 'Nearly all fetches skipped — per-listing fetch may be broken' };
  }
  return { state: 'ok', reason: '' };
}

function ago(d: Date): string {
  const mins = Math.round((now - d.getTime()) / 60_000);
  if (mins < 60) return `${mins}m ago`;
  const h = Math.round(mins / 60);
  if (h < 48) return `${h}h ago`;
  return `${Math.round(h / 24)}d ago`;
}
const MODEL_LABEL_OVERRIDE: Record<string, string> = {
  'hilux-gd6': 'HILUX GD-6', 'hilux-d4d': 'HILUX D-4D',
  'fortuner-gd6': 'FORTUNER GD-6', 'fortuner-d4d': 'FORTUNER D-4D',
};
function fmtModel(m: string): string {
  return MODEL_LABEL_OVERRIDE[m] ?? (m.replaceAll('-', ' ').replace('series', '').trim().toUpperCase() || m);
}
---

<AdminLayout title="Scrapers" activePage="scrapers">

  <!-- MARKET COVERAGE -->
  <div class="coverage">
    <div class="cov-head">
      <div>
        <p class="cov-eyebrow">Market Coverage</p>
        <p class="cov-total"><strong>{trackedTotal.toLocaleString('en-ZA')}</strong> active listings tracked</p>
        <p class="cov-total-split">
          <strong>{lcTotal.toLocaleString('en-ZA')}</strong> Land Cruiser
          <span class="cov-split-dot">·</span>
          <strong>{hfTotal.toLocaleString('en-ZA')}</strong> Hilux &amp; Fortuner
        </p>
      </div>
      {lastRefresh && <span class="cov-refresh">Refreshed {ago(lastRefresh)}</span>}
    </div>
    <p class="cov-claim">
      Aggregated across South Africa's dominant used-vehicle platforms — <strong>AutoTrader</strong> (the
      country's #1 marketplace, ~130k total listings &amp; 11M monthly visits), <strong>Cars.co.za</strong>
      (#2, ~74k listings) and <strong>WeBuyCars</strong> — plus the Land Cruiser specialists Adios &amp; We Buy
      Bakkies. For Land Cruisers specifically, this is effectively the entire online market. We also track the
      adjacent Toyota 4&times;4 market — <strong>Hilux &amp; Fortuner</strong> — for cross-segment price and
      depreciation benchmarking; these stay out of the public LC classifieds.
    </p>

    <div class="cov-grid">
      {SOURCES.map(({ key, label }) => {
        const e = covBySource.get(key) ?? { lc: 0, hf: 0, total: 0 };
        const pen = latestPenetration(key);
        const share = trackedTotal > 0 ? Math.round((e.total / trackedTotal) * 100) : 0;
        return (
          <div class="cov-src">
            <p class="cov-src-name">{label}</p>
            <p class="cov-src-n">{e.total.toLocaleString('en-ZA')}<span class="cov-src-share"> · {share}% of tracked</span></p>
            <p class="cov-src-split">{e.lc.toLocaleString('en-ZA')} LC <span class="cov-split-dot">·</span> {e.hf.toLocaleString('en-ZA')} Hilux/Fortuner</p>
            {pen
              ? <p class="cov-src-pen">Penetration <strong>{pen.pct}%</strong> <span>({pen.found.toLocaleString('en-ZA')} of {pen.total.toLocaleString('en-ZA')} the source reports)</span></p>
              : <p class="cov-src-pen cov-src-pen-na">No source total — coverage tracked via pagination caps</p>
            }
          </div>
        );
      })}
    </div>

    <p class="cov-foot">
      <strong>Penetration</strong> = listings we captured ÷ the total the source's own counter reports.
      Cars.co.za reports a true per-model total (so its % is real coverage); WeBuyCars reports text-search
      hits incl. non-LC, so its % reads low by design. "Effectively the entire market" means online-listed
      stock — private off-platform sales (Facebook, word-of-mouth) are out of scope and unmeasurable.
    </p>
  </div>

  <!-- SOURCE HEALTH CARDS -->
  <div class="health-grid">
    {SOURCES.map(({ key, label }) => {
      const h = healthFor(key);
      const runs = runsBySource.get(key) ?? [];
      const last = runs[0];
      return (
        <div class={`hcard hcard-${h.state}${scheduled[key] === false ? ' hcard-paused' : ''}`}>
          <div class="hcard-top">
            <span class={`dot dot-${h.state}`}></span>
            <span class="hcard-name">{label}</span>
            {scheduled[key] === false && <span class="paused-pill">Paused</span>}
            <span class="hcard-active">{sourceTotals.get(key) ?? 0} active</span>
            <label class="sched-toggle" title="Run this scraper on its schedule. Off = paused; the manual Run button still works.">
              <input type="checkbox" class="sched-input" data-source={key} checked={scheduled[key] !== false} />
              <span class="sched-track"><span class="sched-thumb"></span></span>
            </label>
          </div>
          {last ? (
            <>
              <p class="hcard-last">
                Last run {ago(last.run_at)} — found {last.found},
                +{last.created} new, {last.updated} updated, {last.skipped} skipped{last.removed > 0 ? `, ${last.removed} removed` : ''}
              </p>
              {last.source_total != null && last.source_total > 0 && (
                <p class="hcard-pen">
                  Penetration <strong>{Math.round((last.found / last.source_total) * 100)}%</strong>
                  <span class="pen-sub"> — {last.found} of {last.source_total} reported by source</span>
                </p>
              )}
              {h.reason && <p class={`hcard-reason reason-${h.state}`}>{h.reason}</p>}
              <p class="rh-label">Recent runs — listings found <span class="rh-dir">newest ←→ oldest</span></p>
              <div class="run-history">
                {runs.slice(0, 6).map(r => (
                  <div class={`run-pill${r.ok ? '' : ' run-fail'}`} title={r.ok ? r.run_at.toLocaleString('en-ZA') : `${r.run_at.toLocaleString('en-ZA')} — failed${r.note ? ': ' + r.note : ''}`}>
                    <span class="rp-found">{r.ok ? r.found : '✕'}</span>
                    <span class="rp-time">{ago(r.run_at)}</span>
                  </div>
                ))}
              </div>
            </>
          ) : (
            <p class="hcard-last">No ingest runs recorded yet — stats appear after the next run.</p>
          )}
        </div>
      );
    })}
  </div>

  <!-- COVERAGE MATRIX -->
  <div class="section">
    <p class="section-head">Coverage — active listings by source &times; model</p>
    <p class="section-sub">
      Red cells: the source carries stock overall but has <strong>zero</strong> of a model other
      sources hold plenty of — usually means its scraper isn't seeing that model.
    </p>
    <div class="matrix-wrap">
      <table class="matrix">
        <thead>
          <tr>
            <th></th>
            {MODELS.map(m => <th>{fmtModel(m)}</th>)}
            <th class="col-total">Total</th>
          </tr>
        </thead>
        <tbody>
          {SOURCES.map(({ key, label }) => (
            <tr>
              <td class="row-label">{label}</td>
              {MODELS.map(m => {
                const n = matrix.get(key)?.get(m) ?? 0;
                const bad = isAnomaly(key, m);
                return <td class={`cell${n === 0 ? ' cell-zero' : ''}${bad ? ' cell-bad' : ''}`}>{n || '—'}</td>;
              })}
              <td class="col-total">{sourceTotals.get(key) ?? 0}</td>
            </tr>
          ))}
          <tr class="row-totals">
            <td class="row-label">All sources</td>
            {MODELS.map(m => <td class="cell">{modelTotals.get(m) ?? 0}</td>)}
            <td class="col-total">{[...sourceTotals.values()].reduce((a, b) => a + b, 0)}</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- HOW IT WORKS -->
  <div class="section">
    <p class="section-head">How scraping health is measured</p>
    <ul class="explain">
      <li><strong>Found</strong> — how many Land Cruiser listings the scraper discovered on the source site this run. A sudden drop means the source changed their site/API or is blocking us.</li>
      <li><strong>Penetration</strong> — found ÷ the total the source's own counter reports. Only shown for sources that expose a total. <em>Cars.co.za</em> and <em>AutoTrader</em> both report a real per-model total, so their % is true coverage; <em>WeBuyCars</em> reports text-search hits (which include non-LC and not-for-sale), so its % reads low by design — we keep only LC for-sale. Sources with no total (Adios, We Buy Bakkies) show no %; we watch their pagination caps instead.</li>
      <li><strong>Completeness</strong> — AutoTrader exposes its own <em>totalCount</em> per model, so we crawl every page and then check captured ÷ reported. If any model comes up short (or a page errored mid-crawl), the card turns amber — a reliable "we didn't get them all" signal, not a guess. Adios (100, no pagination) and We Buy Bakkies (10 sitemap files) still stop at a fixed ceiling we watch.</li>
      <li><strong>Skipped</strong> — listings discovered but not saved: per-listing fetch failures (blocking, rate limits) or cross-source duplicates. Near-100% skipped with 0 created/updated means the fetcher is broken even though discovery works.</li>
      <li><strong>Zero-model anomalies</strong> — the red cells above. This is exactly how the missing WBC 79-series would have been caught automatically.</li>
      <li>Each ingest script reports its run here automatically; failures (zero results) report too, so a silent scraper shows up as a red card, not an empty page.</li>
    </ul>
  </div>

</AdminLayout>

<script>
  // Per-source schedule toggle → POST to admin endpoint; revert on failure.
  document.querySelectorAll<HTMLInputElement>('.sched-input').forEach((input) => {
    input.addEventListener('change', async () => {
      const source = input.dataset.source!;
      const scheduled = input.checked;
      input.disabled = true;
      try {
        const res = await fetch('/api/admin/set-scraper-schedule', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ source, scheduled }),
        });
        if (!res.ok) throw new Error('failed');
        input.closest('.hcard')?.classList.toggle('hcard-paused', !scheduled);
        const top = input.closest('.hcard-top');
        const existing = top?.querySelector('.paused-pill');
        if (!scheduled && top && !existing) {
          const pill = document.createElement('span');
          pill.className = 'paused-pill';
          pill.textContent = 'Paused';
          top.querySelector('.hcard-name')?.after(pill);
        } else if (scheduled && existing) {
          existing.remove();
        }
      } catch {
        input.checked = !scheduled; // revert
        alert('Could not update the schedule — please try again.');
      } finally {
        input.disabled = false;
      }
    });
  });
</script>

<style>
  /* MARKET COVERAGE */
  .coverage {
    border: 1.5px solid #111111; border-radius: 0.875rem; padding: 1.25rem 1.5rem;
    margin-bottom: 1.5rem; background: #FBFBFA;
  }
  .cov-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .cov-eyebrow { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: #D4881A; margin-bottom: 0.3rem; }
  .cov-total { font-family: var(--font-heading, inherit); font-size: 1.5rem; color: #6B7280; }
  .cov-total strong { color: #111111; font-weight: 800; }
  .cov-total-split { font-size: 0.72rem; font-weight: 600; color: #9CA3AF; margin-top: 0.15rem; }
  .cov-total-split strong { color: #6B7280; font-weight: 700; }
  .cov-split-dot { color: #D1D5DB; margin: 0 0.15rem; }
  .cov-refresh { font-size: 0.65rem; font-weight: 700; color: #9CA3AF; white-space: nowrap; }
  .cov-claim { font-size: 0.8rem; color: #4A4A4A; line-height: 1.6; margin-top: 0.75rem; max-width: 760px; }
  .cov-claim strong { color: #111; }

  .cov-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 0.625rem; margin: 1rem 0 0.875rem; }
  .cov-src { border: 1px solid #EAE7E0; border-radius: 0.625rem; padding: 0.75rem 0.875rem; background: white; }
  .cov-src-name { font-size: 0.7rem; font-weight: 700; color: #111; }
  .cov-src-n { font-size: 1.125rem; font-weight: 800; color: #111; margin-top: 0.1rem; }
  .cov-src-share { font-size: 0.62rem; font-weight: 600; color: #9CA3AF; }
  .cov-src-split { font-size: 0.62rem; font-weight: 600; color: #9CA3AF; margin-top: 0.15rem; }
  .cov-src-pen { font-size: 0.62rem; color: #166534; font-weight: 700; margin-top: 0.3rem; }
  .cov-src-pen span { color: #9CA3AF; font-weight: 500; }
  .cov-src-pen-na { color: #9CA3AF; font-weight: 500; }
  .cov-foot { font-size: 0.66rem; color: #9CA3AF; line-height: 1.55; margin-top: 0.25rem; }
  .cov-foot strong { color: #6B7280; }
</style>
<style>
  .health-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 0.625rem; margin-bottom: 1.5rem; }
  .hcard { border: 1.5px solid #E5E7EB; border-radius: 0.75rem; padding: 0.875rem 1rem; }
  .hcard-down { border-color: #FECACA; background: #FFF8F8; }
  .hcard-warn { border-color: #FDE68A; background: #FFFDF5; }

  .hcard-top { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.4rem; }
  .dot { width: 8px; height: 8px; border-radius: 9999px; flex-shrink: 0; }
  .dot-ok   { background: #16A34A; }
  .dot-warn { background: #F5A623; }
  .dot-down { background: #DC2626; }
  .hcard-name { font-size: 0.8rem; font-weight: 700; color: #111111; }
  .hcard-active { margin-left: auto; font-size: 0.65rem; font-weight: 700; color: #9CA3AF; }
  .paused-pill { font-size: 0.55rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #92400E; background: #FEF3C7; border: 1px solid #FDE68A; border-radius: 9999px; padding: 0.1rem 0.4rem; }
  .hcard-paused { opacity: 0.65; }
  .sched-toggle { display: inline-flex; align-items: center; cursor: pointer; flex-shrink: 0; }
  .sched-input { position: absolute; opacity: 0; width: 0; height: 0; }
  .sched-track { width: 32px; height: 18px; border-radius: 9999px; background: #E5E7EB; position: relative; transition: background 0.15s; }
  .sched-thumb { position: absolute; top: 2px; left: 2px; width: 14px; height: 14px; border-radius: 50%; background: #fff; transition: transform 0.15s; box-shadow: 0 1px 2px rgba(0,0,0,0.25); }
  .sched-input:checked + .sched-track { background: #F5A623; }
  .sched-input:checked + .sched-track .sched-thumb { transform: translateX(14px); }
  .sched-input:disabled + .sched-track { opacity: 0.5; cursor: wait; }

  .hcard-last { font-size: 0.7rem; color: #6B7280; line-height: 1.5; }
  .hcard-pen { font-size: 0.7rem; color: #374151; margin-top: 0.3rem; }
  .hcard-pen strong { color: #111111; }
  .pen-sub { color: #9CA3AF; }
  .hcard-reason { font-size: 0.7rem; font-weight: 700; margin-top: 0.3rem; }
  .reason-warn { color: #B45309; }
  .reason-down { color: #991B1B; }

  .rh-label {
    font-size: 0.58rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
    color: #9CA3AF; margin-top: 0.75rem; margin-bottom: 0.3rem;
    display: flex; align-items: center; gap: 0.4rem;
  }
  .rh-dir { font-weight: 600; text-transform: none; letter-spacing: 0; color: #C4C4C4; font-size: 0.55rem; }
  .run-history { display: flex; gap: 0.3rem; }
  .run-pill {
    display: flex; flex-direction: column; align-items: center; gap: 0.05rem;
    min-width: 38px; padding: 0.3rem 0.4rem; border-radius: 0.4rem;
    background: #F3F4F6; font-variant-numeric: tabular-nums;
  }
  .rp-found { font-size: 0.8rem; font-weight: 700; color: #111111; line-height: 1; }
  .rp-time { font-size: 0.5rem; font-weight: 600; color: #9CA3AF; white-space: nowrap; }
  .run-fail { background: #FEE2E2; }
  .run-fail .rp-found { color: #991B1B; }
  .run-fail .rp-time { color: #B91C1C; }

  .section { margin-bottom: 2rem; }
  .section-head {
    font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em;
    color: #9CA3AF; margin-bottom: 0.5rem; padding-bottom: 0.5rem; border-bottom: 1.5px solid #F3F4F6;
  }
  .section-sub { font-size: 0.72rem; color: #9CA3AF; margin-bottom: 0.75rem; }

  .matrix-wrap { overflow-x: auto; }
  .matrix { border-collapse: collapse; font-size: 0.7rem; width: 100%; }
  .matrix th {
    font-size: 0.58rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
    color: #9CA3AF; padding: 0.4rem 0.5rem; text-align: center; white-space: nowrap;
  }
  .matrix td { padding: 0.4rem 0.5rem; text-align: center; border-top: 1px solid #F3F4F6; font-variant-numeric: tabular-nums; }
  .row-label { font-weight: 700; color: #111111; text-align: left !important; white-space: nowrap; }
  .cell-zero { color: #D1D5DB; }
  .cell-bad { background: #FEE2E2; color: #991B1B !important; font-weight: 700; border-radius: 0.25rem; }
  .col-total { font-weight: 700; color: #111111; }
  .row-totals td { border-top: 1.5px solid #E5E7EB; color: #6B7280; }
  .row-totals .cell { font-weight: 600; }

  .explain { font-size: 0.75rem; color: #6B7280; line-height: 1.7; padding-left: 1.1rem; }
  .explain li { margin-bottom: 0.4rem; }
  .explain strong { color: #374151; }
</style>
