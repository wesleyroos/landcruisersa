---
export const prerender = false;

import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/db/index';
import { trainingLeads, clickEvents, viewEvents, visitEvents, partnerClicks, listings } from '@/db/schema';
import { sql, desc, eq, and } from 'drizzle-orm';
import { PARTNERS } from '@/data/partners';

const cookie = Astro.cookies.get('lcsa_admin');
const adminSecret = import.meta.env.ADMIN_SECRET ?? process.env.ADMIN_SECRET ?? '';
if (!cookie || cookie.value !== adminSecret) {
  return Astro.redirect('/admin/login');
}

const leads = db.select().from(trainingLeads).orderBy(desc(trainingLeads.created_at)).all();

// ─── Outbound clicks ──────────────────────────────────────────────────────────

const clicksBySource = db.select({
  source: clickEvents.source,
  count: sql<number>`cast(count(*) as int)`,
}).from(clickEvents).groupBy(clickEvents.source).all();

const totalClicks = clicksBySource.reduce((s, r) => s + r.count, 0);

const clicksPerSlug = new Map(
  db.select({
    listing_slug: clickEvents.listing_slug,
    listing_title: clickEvents.listing_title,
    count: sql<number>`cast(count(*) as int)`,
  }).from(clickEvents).groupBy(clickEvents.listing_slug).all()
    .map(r => [r.listing_slug, { title: r.listing_title, count: r.count }])
);

// ─── Campaign link clicks (sessions arriving with a utm_source) ──────────────

const visitsBySource = db.select({
  source: visitEvents.utm_source,
  count: sql<number>`cast(count(*) as int)`,
}).from(visitEvents).groupBy(visitEvents.utm_source).all();

const totalVisits = visitsBySource.reduce((s, r) => s + r.count, 0);

const visitsDaily = db.select({
  day: sql<string>`date(created_at, 'unixepoch')`,
  count: sql<number>`cast(count(*) as int)`,
}).from(visitEvents)
  .where(sql`created_at > unixepoch('now', '-14 days')`)
  .groupBy(sql`date(created_at, 'unixepoch')`)
  .orderBy(sql`date(created_at, 'unixepoch')`)
  .all();

const visitsDailyMax = Math.max(1, ...visitsDaily.map(r => r.count));

const visitLandings = db.select({
  source: visitEvents.utm_source,
  path: visitEvents.landing_path,
  count: sql<number>`cast(count(*) as int)`,
}).from(visitEvents)
  .groupBy(visitEvents.utm_source, visitEvents.landing_path)
  .orderBy(sql`count(*) desc`)
  .limit(12)
  .all();

// ─── Listing views ────────────────────────────────────────────────────────────

const viewsBySource = db.select({
  source: sql<string>`COALESCE(utm_source, 'direct')`,
  count: sql<number>`cast(count(*) as int)`,
}).from(viewEvents).groupBy(sql`COALESCE(utm_source, 'direct')`).all();

const totalViews = viewsBySource.reduce((s, r) => s + r.count, 0);

const viewsByListing = db.select({
  listing_slug: viewEvents.listing_slug,
  listing_title: viewEvents.listing_title,
  count: sql<number>`cast(count(*) as int)`,
}).from(viewEvents)
  .groupBy(viewEvents.listing_slug)
  .orderBy(sql`count(*) desc`)
  .all();

// ─── Combined listing performance: views + clicks in one table ───────────────
// Union of everything that was viewed or clicked; clicks predate view tracking
// so some rows have clicks but no views.

type PerfRow = { slug: string; title: string | null; views: number; clicks: number };
const perfMap = new Map<string, PerfRow>();
for (const v of viewsByListing) {
  perfMap.set(v.listing_slug, { slug: v.listing_slug, title: v.listing_title, views: v.count, clicks: 0 });
}
for (const [slug, c] of clicksPerSlug) {
  const row = perfMap.get(slug);
  if (row) {
    row.clicks = c.count;
  } else {
    perfMap.set(slug, { slug, title: c.title, views: 0, clicks: c.count });
  }
}
const perfRows = [...perfMap.values()]
  .sort((a, b) => b.views - a.views || b.clicks - a.clicks)
  .slice(0, 25);

// ─── Demand by model: views vs supply ─────────────────────────────────────────

const viewsByModel = db.select({
  model: viewEvents.model,
  count: sql<number>`cast(count(*) as int)`,
}).from(viewEvents).groupBy(viewEvents.model).all();

const activeByModel = new Map(
  db.select({
    model: listings.model,
    count: sql<number>`cast(count(*) as int)`,
  }).from(listings).where(eq(listings.status, 'active')).groupBy(listings.model).all()
    .map(r => [r.model, r.count])
);

function fmtPerListing(views: number, supply: number): string {
  if (supply === 0) return '—';
  const v = views / supply;
  if (v >= 10) return String(Math.round(v));
  if (v >= 1) return v.toFixed(1);
  return v.toFixed(2); // small values stay visible instead of rounding to 0
}

const demandRows = viewsByModel
  .filter(r => r.model)
  .map(r => {
    const supply = activeByModel.get(r.model!) ?? 0;
    return {
      model: r.model!,
      views: r.count,
      supply,
      perListing: fmtPerListing(r.count, supply),
    };
  })
  .sort((a, b) => b.views - a.views);

// ─── Partner clicks ───────────────────────────────────────────────────────────

const partnerClickRows = db.select({
  partner_slug: partnerClicks.partner_slug,
  kind: partnerClicks.kind,
  count: sql<number>`cast(count(*) as int)`,
}).from(partnerClicks).groupBy(partnerClicks.partner_slug, partnerClicks.kind).all();

const PARTNER_NAME = new Map(PARTNERS.map(p => [p.slug, p.name]));
const partnerTotals = new Map<string, { website: number; email: number; instagram: number; total: number }>();
for (const r of partnerClickRows) {
  const row = partnerTotals.get(r.partner_slug) ?? { website: 0, email: 0, instagram: 0, total: 0 };
  row[r.kind as 'website' | 'email' | 'instagram'] += r.count;
  row.total += r.count;
  partnerTotals.set(r.partner_slug, row);
}
const partnerRows = [...partnerTotals.entries()]
  .map(([slug, counts]) => ({ slug, name: PARTNER_NAME.get(slug) ?? slug, ...counts }))
  .sort((a, b) => b.total - a.total);
const totalPartnerClicks = partnerRows.reduce((s, r) => s + r.total, 0);

// ─── Formatting helpers ───────────────────────────────────────────────────────

function fmt(d: Date | null) {
  if (!d) return '—';
  return new Intl.DateTimeFormat('en-ZA', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }).format(d);
}

const SOURCE_LABEL: Record<string, string> = {
  autotrader: 'AutoTrader',
  wbc: 'WeBuyCars',
  adios: 'Adios',
  wbb: 'WeBuy Bakkies',
};

const TRAFFIC_LABEL: Record<string, string> = {
  ig: 'Instagram',
  direct: 'Direct / Other',
};

const igViews = viewsBySource.find(r => r.source === 'ig')?.count ?? 0;
---

<AdminLayout title="Insights" activePage="insights">
  <div class="insights-wrap">

    <!-- ── KPI STRIP ──────────────────────────────────────── -->
    <div class="kpi-strip">
      <div class="kpi">
        <span class="kpi-dir dir-in">↓ In</span>
        <p class="kpi-value">{totalVisits}</p>
        <p class="kpi-label">Campaign Link Clicks</p>
      </div>
      <div class="kpi">
        <p class="kpi-value">{totalViews}</p>
        <p class="kpi-label">Listing Views</p>
      </div>
      <div class="kpi">
        <span class="kpi-dir dir-in">↓ In</span>
        <p class="kpi-value">{igViews}</p>
        <p class="kpi-label">Views from IG</p>
      </div>
      <div class="kpi">
        <span class="kpi-dir dir-out">↑ Out</span>
        <p class="kpi-value">{totalClicks}</p>
        <p class="kpi-label">Outbound Listing Clicks</p>
      </div>
      <div class="kpi">
        <span class="kpi-dir dir-out">↑ Out</span>
        <p class="kpi-value">{totalPartnerClicks}</p>
        <p class="kpi-label">Partner Clicks</p>
      </div>
      <div class="kpi">
        <p class="kpi-value">{leads.length}</p>
        <p class="kpi-label">Training Leads</p>
      </div>
    </div>

    <!-- ── ROW: CAMPAIGN TRAFFIC + DEMAND ─────────────────── -->
    <div class="grid-2">

      <section class="card">
        <div class="card-head">
          <h2 class="card-title">Campaign Traffic</h2>
          <span class="badge">{totalVisits}</span>
        </div>
        {totalVisits === 0 ? (
          <p class="empty">No campaign clicks yet. IG bio link: <code>landcruisersa.co.za/listings/?utm_source=ig</code></p>
        ) : (
          <div class="card-body">
            <div class="chip-row">
              {visitsBySource.map(r => (
                <span class="stat-chip">{TRAFFIC_LABEL[r.source] ?? r.source} <strong>{r.count}</strong></span>
              ))}
            </div>
            {visitLandings.length > 0 && (
              <div>
                <p class="mini-label">Landing Pages</p>
                <div class="landing-list">
                  {visitLandings.map(r => (
                    <div class="landing-row">
                      <span class="landing-src">{TRAFFIC_LABEL[r.source] ?? r.source}</span>
                      <a href={r.path ?? '/'} target="_blank" class="landing-path">{r.path ?? '/'}</a>
                      <span class="landing-count">{r.count}</span>
                    </div>
                  ))}
                </div>
              </div>
            )}
            {visitsDaily.length > 0 && (
              <div class="bar-chart">
                {visitsDaily.map(r => (
                  <div class="bar-row">
                    <span class="bar-day">{r.day.slice(5)}</span>
                    <div class="bar-track">
                      <div class="bar-fill" style={`width:${Math.round((r.count / visitsDailyMax) * 100)}%`}></div>
                    </div>
                    <span class="bar-count">{r.count}</span>
                  </div>
                ))}
              </div>
            )}
          </div>
        )}
      </section>

      <section class="card">
        <div class="card-head">
          <h2 class="card-title">Demand by Model</h2>
          <span class="badge-sub">views ÷ active supply</span>
        </div>
        {demandRows.length === 0 ? (
          <p class="empty">No view data yet.</p>
        ) : (
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Model</th>
                  <th class="num-c">Views</th>
                  <th class="num-c">Supply</th>
                  <th class="num-c">Views per Listing</th>
                </tr>
              </thead>
              <tbody>
                {demandRows.map(r => (
                  <tr>
                    <td style="font-weight:600">{r.model.replace(/-/g, ' ').toUpperCase()}</td>
                    <td class="num-c" style="font-weight:700">{r.views}</td>
                    <td class="num-c">{r.supply}</td>
                    <td class="num-c" style="color:#D4881A;font-weight:700">{r.perListing}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </section>

    </div>

    <!-- ── LISTING PERFORMANCE (views + clicks combined) ──── -->
    <section class="card">
      <div class="card-head">
        <h2 class="card-title">Listing Performance</h2>
        <span class="badge">{totalViews} views · {totalClicks} click-outs</span>
        {totalClicks > 0 && (
          <span class="chip-row chip-row-inline">
            {clicksBySource.map(r => (
              <span class="stat-chip">{SOURCE_LABEL[r.source] ?? r.source} <strong>{r.count}</strong></span>
            ))}
          </span>
        )}
      </div>
      {perfRows.length === 0 ? (
        <p class="empty">No listing activity tracked yet.</p>
      ) : (
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>Listing</th>
                <th class="num-c">Views</th>
                <th class="num-c">Click-outs</th>
                <th class="num-c">CTR</th>
              </tr>
            </thead>
            <tbody>
              {perfRows.map(r => (
                <tr>
                  <td>
                    <a href={`/listings/${r.slug}/`} target="_blank">{r.title ?? r.slug}</a>
                  </td>
                  <td class="num-c" style="font-weight:700">{r.views}</td>
                  <td class="num-c">{r.clicks}</td>
                  <td class="num-c" style="color:#9CA3AF">{r.views > 0 ? Math.round((r.clicks / r.views) * 100) + '%' : '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </section>

    <!-- ── ROW: PARTNERS + TRAINING LEADS ─────────────────── -->
    <div class="grid-2">

      <section class="card">
        <div class="card-head">
          <h2 class="card-title">Partner Clicks</h2>
          <span class="badge">{totalPartnerClicks}</span>
        </div>
        {totalPartnerClicks === 0 ? (
          <p class="empty">No partner clicks tracked yet.</p>
        ) : (
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Partner</th>
                  <th class="num">Web</th>
                  <th class="num">Email</th>
                  <th class="num">IG</th>
                  <th class="num">Total</th>
                </tr>
              </thead>
              <tbody>
                {partnerRows.map(r => (
                  <tr>
                    <td><a href={`/partners/${r.slug}/`} target="_blank">{r.name}</a></td>
                    <td class="num">{r.website}</td>
                    <td class="num">{r.email}</td>
                    <td class="num">{r.instagram}</td>
                    <td class="num" style="font-weight:700">{r.total}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </section>

      <section class="card">
        <div class="card-head">
          <h2 class="card-title">Training Enquiries</h2>
          <span class="badge">{leads.length}</span>
        </div>
        {leads.length === 0 ? (
          <p class="empty">No enquiries yet.</p>
        ) : (
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Name</th>
                  <th>Contact</th>
                  <th>Message</th>
                </tr>
              </thead>
              <tbody>
                {leads.map(l => (
                  <tr>
                    <td class="nowrap">{fmt(l.created_at)}</td>
                    <td class="nowrap">{l.name}</td>
                    <td>
                      <a href={`mailto:${l.email}`}>{l.email}</a>
                      <span class="sub-line">{l.phone}{l.location ? ` · ${l.location}` : ''}</span>
                    </td>
                    <td class="msg">{l.message ?? '—'}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </section>

    </div>

  </div>
</AdminLayout>

<style>
  .insights-wrap { display: flex; flex-direction: column; gap: 1.25rem; }

  /* KPI strip */
  .kpi-strip {
    display: grid; gap: 0.75rem;
    grid-template-columns: repeat(2, 1fr);
  }
  @media (min-width: 640px)  { .kpi-strip { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1024px) { .kpi-strip { grid-template-columns: repeat(6, 1fr); } }
  .kpi {
    background: white; border: 1px solid #E5E7EB; border-radius: 0.75rem;
    padding: 0.875rem 1.125rem; position: relative;
  }
  .kpi-value { font-size: 1.625rem; font-weight: 800; color: #111; line-height: 1.1; }
  .kpi-label { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #9CA3AF; margin-top: 0.2rem; }
  .kpi-dir {
    position: absolute; top: 0.625rem; right: 0.75rem;
    font-size: 0.6rem; font-weight: 700; letter-spacing: 0.04em;
    padding: 0.125rem 0.45rem; border-radius: 9999px;
  }
  .dir-in  { background: #F0FDF4; color: #16A34A; border: 1px solid #BBF7D0; }
  .dir-out { background: #EFF6FF; color: #2563EB; border: 1px solid #BFDBFE; }

  /* Two-column row */
  .grid-2 { display: grid; gap: 1.25rem; grid-template-columns: 1fr; align-items: start; }
  @media (min-width: 1024px) { .grid-2 { grid-template-columns: 1fr 1fr; } }

  .card {
    background: white; border: 1px solid #E5E7EB; border-radius: 0.75rem; overflow: hidden;
  }
  .card-head {
    display: flex; align-items: center; gap: 0.625rem; flex-wrap: wrap;
    padding: 0.875rem 1.25rem; border-bottom: 1px solid #F3F4F6;
  }
  .card-title { font-size: 0.875rem; font-weight: 700; color: #111; }
  .card-body { padding: 1rem 1.25rem; display: flex; flex-direction: column; gap: 1rem; }
  .badge {
    background: #F5A623; color: #111; font-size: 0.65rem; font-weight: 700;
    letter-spacing: 0.04em; padding: 0.2rem 0.5rem; border-radius: 9999px; white-space: nowrap;
  }
  .badge-sub { font-size: 0.65rem; color: #9CA3AF; }
  .empty { padding: 1.25rem; color: #9CA3AF; font-size: 0.8125rem; }
  .empty code { font-size: 0.75rem; background: #F3F4F6; padding: 0.1rem 0.3rem; border-radius: 0.25rem; }

  /* Stat chips */
  .chip-row { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .chip-row-inline { margin-left: auto; }
  .stat-chip {
    display: inline-flex; align-items: center; gap: 0.375rem;
    background: #F9FAFB; border: 1px solid #E5E7EB; border-radius: 9999px;
    font-size: 0.7rem; font-weight: 600; color: #6B7280;
    padding: 0.25rem 0.625rem;
  }
  .stat-chip strong { color: #111; font-weight: 800; }

  /* Tables */
  .table-wrap { overflow-x: auto; max-height: 420px; overflow-y: auto; }
  .data-table { width: 100%; border-collapse: collapse; font-size: 0.78rem; }
  .data-table th {
    background: #F9FAFB; text-align: left; padding: 0.5rem 1rem;
    font-size: 0.625rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; color: #6B7280; white-space: nowrap;
    border-bottom: 1px solid #E5E7EB;
    position: sticky; top: 0;
  }
  .data-table td {
    padding: 0.5rem 1rem; border-bottom: 1px solid #F3F4F6;
    color: #374151; vertical-align: top;
  }
  .data-table tr:last-child td { border-bottom: none; }
  .data-table a { color: #111; }
  .data-table a:hover { color: #F5A623; }
  .num { text-align: right; }
  .num-c { text-align: center; }

  /* Landing pages */
  .mini-label {
    font-size: 0.625rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; color: #9CA3AF; margin-bottom: 0.5rem;
  }
  .landing-list { display: flex; flex-direction: column; gap: 0.25rem; }
  .landing-row {
    display: flex; align-items: center; gap: 0.625rem;
    font-size: 0.75rem; padding: 0.25rem 0;
  }
  .landing-src {
    flex-shrink: 0; font-size: 0.65rem; font-weight: 700; color: #6B7280;
    background: #F9FAFB; border: 1px solid #E5E7EB; border-radius: 9999px;
    padding: 0.1rem 0.5rem;
  }
  .landing-path {
    flex: 1; min-width: 0; color: #374151; text-decoration: none;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .landing-path:hover { color: #F5A623; }
  .landing-count { flex-shrink: 0; font-weight: 700; color: #111; }
  .nowrap { white-space: nowrap; }
  .msg { max-width: 220px; white-space: pre-wrap; font-size: 0.72rem; color: #6B7280; }
  .sub-line { display: block; font-size: 0.68rem; color: #9CA3AF; margin-top: 0.1rem; }

  /* Bar chart */
  .bar-chart { display: flex; flex-direction: column; gap: 0.3rem; }
  .bar-row { display: flex; align-items: center; gap: 0.625rem; }
  .bar-day { font-size: 0.65rem; color: #9CA3AF; width: 38px; flex-shrink: 0; font-variant-numeric: tabular-nums; }
  .bar-track { flex: 1; height: 14px; background: #F3F4F6; border-radius: 4px; overflow: hidden; }
  .bar-fill { height: 100%; background: #F5A623; border-radius: 4px; min-width: 2px; }
  .bar-count { font-size: 0.72rem; font-weight: 700; color: #111; width: 30px; text-align: right; flex-shrink: 0; }
</style>
