          <h2 class="card-title">Campaign Traffic</h2>
          <span class="badge">{totalVisitsP}</span>
          <span class="badge-sub">{periodLabel}</span>
          <span class="info" data-tip="People arriving via a tracked link — IG bio (?utm_source=ig), ChatGPT citations, or any utm_source-tagged link. Landing Pages shows where each one landed.">?</span>
        </div>
        {totalVisitsP === 0 ? (
          <p class="empty">No campaign clicks in {periodLabel}. IG bio link: <code>landcruisersa.co.za/listings/?utm_source=ig</code></p>
