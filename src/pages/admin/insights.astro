---
export const prerender = false;

import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/db/index';
import { trainingLeads, clickEvents, viewEvents, visitEvents, partnerClicks, listings, financeLeads } from '@/db/schema';
import { sql, desc, eq, and } from 'drizzle-orm';
import { PARTNERS } from '@/data/partners';
import type { SQL } from 'drizzle-orm';

const cookie = Astro.cookies.get('lcsa_admin');
const adminSecret = import.meta.env.ADMIN_SECRET ?? process.env.ADMIN_SECRET ?? '';
if (!cookie || cookie.value !== adminSecret) {
  return Astro.redirect('/admin/login');
}

// ─── Period selection ─────────────────────────────────────────────────────────

const period = Astro.url.searchParams.get('period') ?? '30d';
const VALID_PERIODS = ['today', '7d', '30d', '90d', '6m', '12m'] as const;
type Period = typeof VALID_PERIODS[number];
const validPeriod: Period = (VALID_PERIODS as readonly string[]).includes(period) ? period as Period : '30d';

const pWhere: SQL = (() => {
  if (validPeriod === 'today') return sql`date(created_at, 'unixepoch') = date('now')`;
  if (validPeriod === '7d')   return sql`created_at >= unixepoch('now', '-7 days')`;
  if (validPeriod === '90d')  return sql`created_at >= unixepoch('now', '-90 days')`;
  if (validPeriod === '6m')   return sql`created_at >= unixepoch('now', '-180 days')`;
  if (validPeriod === '12m')  return sql`created_at >= unixepoch('now', '-365 days')`;
  return sql`created_at >= unixepoch('now', '-30 days')`;
})();

const PERIOD_LABEL: Record<string, string> = {
  today: 'today', '7d': 'last 7 days', '30d': 'last 30 days',
  '90d': 'last 90 days', '6m': 'last 6 months', '12m': 'last 12 months',
};
const periodLabel = PERIOD_LABEL[validPeriod] ?? 'last 30 days';

// ─── Static "at a glance" queries (always all-time) ──────────────────────────

const leads = db.select().from(trainingLeads).orderBy(desc(trainingLeads.created_at)).all();

// Finance pre-approval leads — the new monetisation funnel. Calc-opens come
// from the finance_calc demand-signal beacon; submits are the captured leads.
// The gap between them is the "does anyone actually submit?" answer.
const financeLeadRows = db.select().from(financeLeads).orderBy(desc(financeLeads.created_at)).all();
const financeCalcOpens = (db.select({ n: sql<number>`cast(count(*) as int)` })
  .from(clickEvents).where(eq(clickEvents.source, 'finance_calc')).get())?.n ?? 0;
const financeSubmitRate = financeCalcOpens > 0
  ? Math.round((financeLeadRows.length / financeCalcOpens) * 100)
  : 0;

// Single grouped pass over listing statuses — drives the supply / off-market KPIs.
const statusCounts = db.select({ status: listings.status, n: sql<number>`cast(count(*) as int)` })
  .from(listings).groupBy(listings.status).all();
const byStatus: Record<string, number> = {};
for (const r of statusCounts) byStatus[r.status] = r.n;
const activeListingCount  = byStatus['active']  ?? 0;
const soldListingCount    = byStatus['sold']    ?? 0;
const removedListingCount = byStatus['removed'] ?? 0;
const pendingListingCount = byStatus['pending'] ?? 0;
const totalListingCount   = activeListingCount + soldListingCount + removedListingCount + pendingListingCount;
// "Off the market" = sold (a sale we know about) + removed (poller found it delisted at source).
const offMarketCount = soldListingCount + removedListingCount;
const turnoverPct = totalListingCount > 0 ? Math.round((offMarketCount / totalListingCount) * 100) : 0;

function median(xs: number[]): number | null {
  if (xs.length === 0) return null;
  const s = [...xs].sort((a, b) => a - b);
  const m = Math.floor(s.length / 2);
  return s.length % 2 ? s[m] : (s[m - 1] + s[m]) / 2;
}

// Median days a listing spends on the market (list → off-market). Only listings
// that left *after* off_market_at tracking began carry a timestamp, so this is
// a forward-accruing metric. SQLite has no median — compute in JS.
const medianDom = median(
  db.select({ days: sql<number>`(off_market_at - created_at) / 86400.0` })
    .from(listings)
    .where(sql`off_market_at IS NOT NULL AND off_market_at >= created_at`)
    .all()
    .map(r => r.days)
);

// Median age of current active stock — how stale the live inventory is.
const medianActiveAge = median(
  db.select({ days: sql<number>`(unixepoch('now') - created_at) / 86400.0` })
    .from(listings)
    .where(eq(listings.status, 'active'))
    .all()
    .map(r => r.days)
);

const partnerClickRows = db.select({
  partner_slug: partnerClicks.partner_slug,
  kind: partnerClicks.kind,
  count: sql<number>`cast(count(*) as int)`,
}).from(partnerClicks).groupBy(partnerClicks.partner_slug, partnerClicks.kind).all();

const PARTNER_NAME = new Map(PARTNERS.map(p => [p.slug, p.name]));
const partnerTotals = new Map<string, { website: number; email: number; instagram: number; total: number }>();
for (const r of partnerClickRows) {
  const row = partnerTotals.get(r.partner_slug) ?? { website: 0, email: 0, instagram: 0, total: 0 };
  row[r.kind as 'website' | 'email' | 'instagram'] += r.count;
  row.total += r.count;
  partnerTotals.set(r.partner_slug, row);
}
const partnerRows = [...partnerTotals.entries()]
  .map(([slug, counts]) => ({ slug, name: PARTNER_NAME.get(slug) ?? slug, ...counts }))
  .sort((a, b) => b.total - a.total);
const totalPartnerClicks = partnerRows.reduce((s, r) => s + r.total, 0);

// ─── All-time demand by model ─────────────────────────────────────────────────

const viewsByModel = db.select({
  model: viewEvents.model,
  count: sql<number>`cast(count(*) as int)`,
}).from(viewEvents).groupBy(viewEvents.model).all();

const activeByModel = new Map(
  db.select({
    model: listings.model,
    count: sql<number>`cast(count(*) as int)`,
  }).from(listings).where(eq(listings.status, 'active')).groupBy(listings.model).all()
    .map(r => [r.model, r.count])
);

function fmtPerListing(views: number, supply: number): string {
  if (supply === 0) return '—';
  const v = views / supply;
  if (v >= 10) return String(Math.round(v));
  if (v >= 1) return v.toFixed(1);
  return v.toFixed(2);
}

const modelViews = new Map(viewsByModel.filter(r => r.model).map(r => [r.model!, r.count]));
const allModels = new Set([...modelViews.keys(), ...activeByModel.keys()]);
const demandRows = [...allModels]
  .map(model => {
    const views = modelViews.get(model) ?? 0;
    const supply = activeByModel.get(model) ?? 0;
    return { model, views, supply, perListing: fmtPerListing(views, supply) };
  })
  .sort((a, b) => {
    // Sort by views/listing descending; models with no supply go to bottom
    const aRate = a.supply > 0 ? a.views / a.supply : -1;
    const bRate = b.supply > 0 ? b.views / b.supply : -1;
    return bRate - aRate;
  });

// ─── Listings growth (all-time) ───────────────────────────────────────────────

const listingsPerDay = db.select({
  day: sql<string>`date(created_at, 'unixepoch')`,
  count: sql<number>`cast(count(*) as int)`,
}).from(listings)
  .groupBy(sql`date(created_at, 'unixepoch')`)
  .orderBy(sql`date(created_at, 'unixepoch')`)
  .all();

let running = 0;
const listingsGrowth = listingsPerDay.map(r => {
  running += r.count;
  return { day: r.day, count: r.count, total: running };
});

const maxDailyCount = Math.max(1, ...listingsGrowth.map(r => r.count));

// ─── Period-filtered activity queries ────────────────────────────────────────

// New listings in period
const newListingsP = (db.select({ n: sql<number>`cast(count(*) as int)` })
  .from(listings).where(pWhere).get())?.n ?? 0;

// Listings that left the market in period (sold or delisted). off_market_at is
// only populated going forward, so this counts post-launch departures.
const leftMarketPWhere: SQL = (() => {
  if (validPeriod === 'today') return sql`date(off_market_at, 'unixepoch') = date('now')`;
  if (validPeriod === '7d')   return sql`off_market_at >= unixepoch('now', '-7 days')`;
  if (validPeriod === '90d')  return sql`off_market_at >= unixepoch('now', '-90 days')`;
  if (validPeriod === '6m')   return sql`off_market_at >= unixepoch('now', '-180 days')`;
  if (validPeriod === '12m')  return sql`off_market_at >= unixepoch('now', '-365 days')`;
  return sql`off_market_at >= unixepoch('now', '-30 days')`;
})();
const leftMarketP = (db.select({ n: sql<number>`cast(count(*) as int)` })
  .from(listings).where(leftMarketPWhere).get())?.n ?? 0;

// Campaign visits in period
const visitsBySourceP = db.select({
  source: visitEvents.utm_source,
  count: sql<number>`cast(count(*) as int)`,
}).from(visitEvents).where(pWhere).groupBy(visitEvents.utm_source).all();
const totalVisitsP = visitsBySourceP.reduce((s, r) => s + r.count, 0);

const visitLandingsP = db.select({
  source: visitEvents.utm_source,
  path: visitEvents.landing_path,
  count: sql<number>`cast(count(*) as int)`,
}).from(visitEvents)
  .where(pWhere)
  .groupBy(visitEvents.utm_source, visitEvents.landing_path)
  .orderBy(sql`count(*) desc`)
  .limit(12).all();

// Bar chart buckets — daily for short periods, weekly for 90d, monthly for 6m/12m
const useDailyBuckets  = ['today', '7d', '30d'].includes(validPeriod);
const useWeeklyBuckets = validPeriod === '90d';

const visitsBuckets = useDailyBuckets
  ? db.select({ bucket: sql<string>`date(created_at, 'unixepoch')`, count: sql<number>`cast(count(*) as int)` })
      .from(visitEvents).where(pWhere)
      .groupBy(sql`date(created_at, 'unixepoch')`).orderBy(sql`date(created_at, 'unixepoch')`).all()
  : useWeeklyBuckets
  ? db.select({ bucket: sql<string>`strftime('%Y-W%W', datetime(created_at, 'unixepoch'))`, count: sql<number>`cast(count(*) as int)` })
      .from(visitEvents).where(pWhere)
      .groupBy(sql`strftime('%Y-W%W', datetime(created_at, 'unixepoch'))`).orderBy(sql`strftime('%Y-W%W', datetime(created_at, 'unixepoch'))`).all()
  : db.select({ bucket: sql<string>`strftime('%Y-%m', datetime(created_at, 'unixepoch'))`, count: sql<number>`cast(count(*) as int)` })
      .from(visitEvents).where(pWhere)
      .groupBy(sql`strftime('%Y-%m', datetime(created_at, 'unixepoch'))`).orderBy(sql`strftime('%Y-%m', datetime(created_at, 'unixepoch'))`).all();
const visitsBucketsMax = Math.max(1, ...visitsBuckets.map(r => r.count));

function bucketLabel(b: string): string {
  if (/^\d{4}-\d{2}-\d{2}$/.test(b)) return b.slice(5);
  if (/^\d{4}-W\d{2}$/.test(b))      return b.slice(5);
  if (/^\d{4}-\d{2}$/.test(b)) {
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    return months[parseInt(b.slice(5)) - 1] ?? b.slice(5);
  }
  return b;
}

// Listing views in period
const viewsBySourceP = db.select({
  source: sql<string>`COALESCE(utm_source, 'direct')`,
  count: sql<number>`cast(count(*) as int)`,
}).from(viewEvents).where(pWhere).groupBy(sql`COALESCE(utm_source, 'direct')`).all();
const totalViewsP = viewsBySourceP.reduce((s, r) => s + r.count, 0);
const igViewsP    = viewsBySourceP.filter(r => r.source?.startsWith('ig')).reduce((s, r) => s + r.count, 0);

// Listing performance in period (views + clicks)
type PerfRow = { slug: string; title: string | null; views: number; clicks: number };

const viewsByListingP = db.select({
  listing_slug: viewEvents.listing_slug,
  listing_title: viewEvents.listing_title,
  count: sql<number>`cast(count(*) as int)`,
}).from(viewEvents).where(pWhere).groupBy(viewEvents.listing_slug).orderBy(sql`count(*) desc`).all();

const allClicksBySourceP = db.select({
  source: clickEvents.source,
  count: sql<number>`cast(count(*) as int)`,
}).from(clickEvents).where(pWhere).groupBy(clickEvents.source).all();
const totalClicksP = allClicksBySourceP.reduce((s, r) => s + r.count, 0);

const clicksPerSlugP = new Map(
  db.select({
    listing_slug: clickEvents.listing_slug,
    listing_title: clickEvents.listing_title,
    count: sql<number>`cast(count(*) as int)`,
  }).from(clickEvents).where(pWhere).groupBy(clickEvents.listing_slug).all()
    .map(r => [r.listing_slug, { title: r.listing_title, count: r.count }])
);

const perfMapP = new Map<string, PerfRow>();
for (const v of viewsByListingP) {
  perfMapP.set(v.listing_slug, { slug: v.listing_slug, title: v.listing_title, views: v.count, clicks: 0 });
}
for (const [slug, c] of clicksPerSlugP) {
  const row = perfMapP.get(slug);
  if (row) row.clicks = c.count;
  else perfMapP.set(slug, { slug, title: c.title, views: 0, clicks: c.count });
}
const perfRowsP = [...perfMapP.values()]
  .sort((a, b) => b.views - a.views || b.clicks - a.clicks)
  .slice(0, 25);

// Contact / lead clicks in period — high-intent actions on own listings.
// 'reveal' = clicked Show number / Show email (often the only signal we get,
// since people then dial from their phone rather than our tel: link).
const contactClicksP = db.select({
  listing_slug: clickEvents.listing_slug,
  listing_title: clickEvents.listing_title,
  source: clickEvents.source,
  count: sql<number>`cast(count(*) as int)`,
}).from(clickEvents)
  .where(and(pWhere, sql`source IN ('whatsapp', 'call', 'email', 'reveal_number', 'reveal_email')`))
  .groupBy(clickEvents.listing_slug, clickEvents.source)
  .all();

const contactTotalsP: Record<string, number> = { whatsapp: 0, call: 0, email: 0, reveal: 0 };
const contactByListingP = new Map<string, { title: string | null; whatsapp: number; call: number; email: number; reveal: number; total: number }>();
for (const r of contactClicksP) {
  const bucket = (r.source === 'reveal_number' || r.source === 'reveal_email') ? 'reveal' : r.source;
  contactTotalsP[bucket] = (contactTotalsP[bucket] ?? 0) + r.count;
  const row = contactByListingP.get(r.listing_slug) ?? { title: r.listing_title, whatsapp: 0, call: 0, email: 0, reveal: 0, total: 0 };
  row[bucket as 'whatsapp' | 'call' | 'email' | 'reveal'] += r.count;
  row.total += r.count;
  contactByListingP.set(r.listing_slug, row);
}
const contactRowsP = [...contactByListingP.entries()]
  .map(([slug, v]) => ({ slug, ...v }))
  .sort((a, b) => b.total - a.total)
  .slice(0, 15);
const totalContactClicksP = contactTotalsP.whatsapp + contactTotalsP.call + contactTotalsP.email + contactTotalsP.reveal;

// ─── Conversion funnel (period) ───────────────────────────────────────────────
// Views → any outbound action → high-intent contact. Admin sessions are
// excluded at the tracking layer, so these are genuine buyers only.
const actionRateP  = totalViewsP > 0 ? (totalClicksP / totalViewsP) * 100 : 0;
const contactRateP = totalViewsP > 0 ? (totalContactClicksP / totalViewsP) * 100 : 0;
function pct(n: number): string { return n >= 10 ? n.toFixed(0) + '%' : n.toFixed(1) + '%'; }

// Per-model funnel. Views carry model directly; clicks resolve model via the
// listings table — needs a qualified created_at since the join makes it ambiguous.
const pWhereClicks: SQL = (() => {
  if (validPeriod === 'today') return sql`date(click_events.created_at, 'unixepoch') = date('now')`;
  if (validPeriod === '7d')   return sql`click_events.created_at >= unixepoch('now', '-7 days')`;
  if (validPeriod === '90d')  return sql`click_events.created_at >= unixepoch('now', '-90 days')`;
  if (validPeriod === '6m')   return sql`click_events.created_at >= unixepoch('now', '-180 days')`;
  if (validPeriod === '12m')  return sql`click_events.created_at >= unixepoch('now', '-365 days')`;
  return sql`click_events.created_at >= unixepoch('now', '-30 days')`;
})();

const viewsByModelFunnel = db.select({
  model: viewEvents.model,
  count: sql<number>`cast(count(*) as int)`,
}).from(viewEvents).where(and(pWhere, sql`model IS NOT NULL`)).groupBy(viewEvents.model).all();

const clicksByModelFunnel = db.select({
  model:   listings.model,
  portal:  sql<number>`cast(sum(CASE WHEN click_events.source NOT IN ('whatsapp','call','email') THEN 1 ELSE 0 END) as int)`,
  contact: sql<number>`cast(sum(CASE WHEN click_events.source IN ('whatsapp','call','email','reveal_number','reveal_email') THEN 1 ELSE 0 END) as int)`,
}).from(clickEvents)
  .leftJoin(listings, eq(listings.slug, clickEvents.listing_slug))
  .where(pWhereClicks)
  .groupBy(listings.model)
  .all();

type FunnelRow = { model: string; views: number; portal: number; contact: number; rate: number };
const funnelMap = new Map<string, FunnelRow>();
for (const v of viewsByModelFunnel) {
  if (!v.model) continue;
  funnelMap.set(v.model, { model: v.model, views: v.count, portal: 0, contact: 0, rate: 0 });
}
for (const c of clicksByModelFunnel) {
  if (!c.model) continue;
  const row = funnelMap.get(c.model) ?? { model: c.model, views: 0, portal: 0, contact: 0, rate: 0 };
  row.portal = c.portal;
  row.contact = c.contact;
  funnelMap.set(c.model, row);
}
const funnelRows = [...funnelMap.values()]
  .map(r => ({ ...r, rate: r.views > 0 ? ((r.portal + r.contact) / r.views) * 100 : 0 }))
  .filter(r => r.views + r.portal + r.contact > 0)
  .sort((a, b) => b.views - a.views);

// ─── IG follower curve — daily snapshots from the insights sync ───────────────
const igSnapNow = db.get<{ followers_count: number | null; fetched_at: number }>(sql`
  SELECT followers_count, fetched_at FROM ig_account_snapshots ORDER BY fetched_at DESC LIMIT 1
`);
const igSnap30 = db.get<{ followers_count: number | null }>(sql`
  SELECT followers_count FROM ig_account_snapshots
  WHERE fetched_at <= ${Math.floor(Date.now() / 1000) - 30 * 86400}
  ORDER BY fetched_at DESC LIMIT 1
`);
const igFollowers = igSnapNow?.followers_count ?? null;
const igFollowersDelta = (igFollowers !== null && igSnap30?.followers_count != null)
  ? igFollowers - igSnap30.followers_count : null;
const igFollowersAt = igSnapNow
  ? new Intl.DateTimeFormat('en-ZA', { day: 'numeric', month: 'short' }).format(new Date(igSnapNow.fetched_at * 1000))
  : '';

// ─── IG post performance — outcomes since each post date ─────────────────────
const igPosts = db.select({
  id: listings.id,
  slug: listings.slug,
  title: listings.title,
  model: listings.model,
  posted_at: listings.ig_posted_at,
}).from(listings).where(sql`ig_posted_at IS NOT NULL`).orderBy(sql`ig_posted_at DESC`).all();

const igPostRows = igPosts.map(p => {
  const since = Math.floor(p.posted_at!.getTime() / 1000);
  const views = (db.get<{ n: number }>(sql`SELECT count(*) n FROM view_events WHERE listing_slug = ${p.slug} AND created_at >= ${since}`))?.n ?? 0;
  const igViews = (db.get<{ n: number }>(sql`SELECT count(*) n FROM view_events WHERE listing_slug = ${p.slug} AND created_at >= ${since} AND utm_source LIKE 'ig%'`))?.n ?? 0;
  const contacts = (db.get<{ n: number }>(sql`SELECT count(*) n FROM click_events WHERE listing_slug = ${p.slug} AND created_at >= ${since} AND source IN ('whatsapp','call','email','reveal_number','reveal_email')`))?.n ?? 0;
  const portal = (db.get<{ n: number }>(sql`SELECT count(*) n FROM click_events WHERE listing_slug = ${p.slug} AND created_at >= ${since} AND source NOT IN ('whatsapp','call','email')`))?.n ?? 0;
  const days = Math.max(0.1, (Date.now() - p.posted_at!.getTime()) / 86_400_000);
  return { ...p, views, igViews, contacts, portal, days: Math.round(days * 10) / 10 };
});

// ─── Misc helpers ─────────────────────────────────────────────────────────────

function fmt(d: Date | null) {
  if (!d) return '—';
  return new Intl.DateTimeFormat('en-ZA', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }).format(d);
}

const TRAFFIC_LABEL: Record<string, string> = {
  'ig': 'IG bio',
  'ig-story': 'IG story',
  'fb-caption': 'FB caption',
  'direct': 'Direct / Other',
};

const SOURCE_LABEL: Record<string, string> = {
  autotrader: 'AutoTrader', wbc: 'WeBuyCars', adios: 'Adios', wbb: 'WeBuy Bakkies',
};
---

<AdminLayout title="Insights" activePage="insights">
  <div class="insights-wrap">

    <!-- ── HEADER: period tabs + section jump pills ──────────── -->
    <div class="activity-header">
      <div class="period-tabs">
        {(['today', '7d', '30d', '90d', '6m', '12m'] as const).map(p => (
          <a href={`?period=${p}`} class={`ptab${validPeriod === p ? ' ptab-active' : ''}`}>
            {p === 'today' ? 'Today' : p}
          </a>
        ))}
      </div>
      <div class="jump-pills">
        <a href="#audience" class="jump">📣 Audience</a>
        <a href="#market" class="jump">🚗 Market</a>
        <a href="#leads" class="jump">🎯 Leads</a>
        <a href="#archive" class="jump">🗄 More</a>
      </div>
    </div>

    <!-- ── FLYWHEEL STRIP — the five numbers that say whether the wheel turned.
         Everything else lives in its section below. ─────────────────────────── -->
    <div class="kpi-strip kpi-strip-5">
      <div class="kpi kpi-hero">
        <p class="kpi-value">{igFollowers === null ? '—' : igFollowers.toLocaleString('en-ZA')}</p>
        <p class="kpi-label">IG Followers</p>
        <p class="kpi-sub">{igFollowers === null
          ? 'first snapshot lands 07:00 tomorrow'
          : igFollowersDelta === null
            ? `as of ${igFollowersAt}`
            : `${igFollowersDelta >= 0 ? '+' : ''}${igFollowersDelta.toLocaleString('en-ZA')} in 30d`}</p>
      </div>
      <div class="kpi">
        <span class="kpi-dir dir-in">↓ In</span>
        <p class="kpi-value">{igViewsP}</p>
        <p class="kpi-label">Views from IG</p>
        <p class="kpi-sub">bio + story links, {periodLabel}</p>
      </div>
      <div class="kpi">
        <span class="kpi-dir dir-out">↑ Out</span>
        <p class="kpi-value">{totalContactClicksP}</p>
        <p class="kpi-label">Contact Clicks</p>
        <p class="kpi-sub">WA + call + email + reveal, {periodLabel}</p>
      </div>
      <div class="kpi">
        <p class="kpi-value">{financeLeadRows.length + leads.length}</p>
        <p class="kpi-label">Leads</p>
        <p class="kpi-sub">{financeLeadRows.length} finance · {leads.length} training, all time</p>
      </div>
      <div class="kpi">
        <p class="kpi-value">{activeListingCount.toLocaleString('en-ZA')}</p>
        <p class="kpi-label">Active Listings</p>
        <p class="kpi-sub">{newListingsP} new {periodLabel}</p>
      </div>
    </div>

    <!-- ══ SECTION: AUDIENCE & INSTAGRAM ═══════════════════════ -->
    <h2 class="section-head" id="audience">📣 Audience &amp; Instagram</h2>

    <!-- ── IG POST PERFORMANCE ───────────────────────────────── -->
    {igPostRows.length > 0 && (
