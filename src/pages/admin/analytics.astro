---
export const prerender = false;

import AdminLayout from '@/layouts/AdminLayout.astro';
import { getTrafficSummary } from '@/lib/traffic-summary';
import { getGscSummary } from '@/lib/gsc-summary';
import { db } from '@/db/index';
import { partnerClicks, rentalClicks, outboundClicks } from '@/db/schema';
import { PARTNERS } from '@/data/partners';
import { RENTAL_OPERATORS } from '@/data/rental-operators';
import { sql, gte } from 'drizzle-orm';

const cookie = Astro.cookies.get('lcsa_admin');
const adminSecret = import.meta.env.ADMIN_SECRET ?? process.env.ADMIN_SECRET ?? '';
if (!cookie || cookie.value !== adminSecret) {
  return Astro.redirect('/admin/login');
}

// Outbound referral clicks we've sent each partner (last 30d) — the evidence base
// for turning an informal referral into a paid arrangement. Broken out by kind.
const partnerName = new Map(PARTNERS.map(p => [p.slug, p.name]));
let partnerReferrals: { name: string; website: number; email: number; instagram: number; total: number }[] = [];
try {
  const since30 = new Date(Date.now() - 30 * 86_400_000);
  const rows = db.select({
    slug: partnerClicks.partner_slug,
    kind: partnerClicks.kind,
    n: sql<number>`count(*)`,
  }).from(partnerClicks).where(gte(partnerClicks.created_at, since30))
    .groupBy(partnerClicks.partner_slug, partnerClicks.kind).all();

  const agg = new Map<string, { website: number; email: number; instagram: number; total: number }>();
  for (const r of rows) {
    const a = agg.get(r.slug) ?? { website: 0, email: 0, instagram: 0, total: 0 };
    if (r.kind === 'website' || r.kind === 'email' || r.kind === 'instagram') a[r.kind] += r.n;
    a.total += r.n;
    agg.set(r.slug, a);
  }
  partnerReferrals = [...agg.entries()]
    .map(([slug, a]) => ({ name: partnerName.get(slug) ?? slug, ...a }))
    .sort((x, y) => y.total - x.total);
} catch { partnerReferrals = []; }

// Rental operator interest (30d) — which operators readers click through to.
// First-party demand data → tells us who to approach first for the booking platform.
const rentalName = new Map(RENTAL_OPERATORS.map((o) => [o.slug, o.name]));
let rentalInterest: { name: string; clicks: number; lastClick: Date | null }[] = [];
try {
  const since30 = new Date(Date.now() - 30 * 86_400_000);
  const rows = db.select({
    slug: rentalClicks.operator_slug,
    n: sql<number>`count(*)`,
    // created_at is stored as epoch seconds (Drizzle timestamp mode); raw max()
    // bypasses Drizzle's Date mapping, so convert back to a Date below.
    last: sql<number>`max(${rentalClicks.created_at})`,
  }).from(rentalClicks).where(gte(rentalClicks.created_at, since30))
    .groupBy(rentalClicks.operator_slug).all();
  rentalInterest = rows
    .map((r) => ({ name: rentalName.get(r.slug) ?? r.slug, clicks: r.n, lastClick: r.last ? new Date(r.last * 1000) : null }))
    .sort((a, b) => b.clicks - a.clicks);
} catch { rentalInterest = []; }

// Outbound clicks (30d) — every external destination readers click from a guide
// page (operators, partners, resources), across all articles. First-party
// content/demand signal + the data any future trackable referral would need.
let outboundInterest: { host: string; clicks: number; lastClick: Date | null }[] = [];
try {
  const since30 = new Date(Date.now() - 30 * 86_400_000);
  const rows = db.select({
    host: outboundClicks.dest_host,
    n: sql<number>`count(*)`,
    last: sql<number>`max(${outboundClicks.created_at})`,
  }).from(outboundClicks).where(gte(outboundClicks.created_at, since30))
    .groupBy(outboundClicks.dest_host).all();
  outboundInterest = rows
    .map((r) => ({ host: r.host, clicks: r.n, lastClick: r.last ? new Date(r.last * 1000) : null }))
    .sort((a, b) => b.clicks - a.clicks)
    .slice(0, 20);
} catch { outboundInterest = []; }

// Natural-language vehicle searches (30d) — adoption + demand gaps (zero-result
// searches = vehicles buyers wanted but we didn't have). Powers the P11 review.
let searchTotal = 0;
let searchTop: { q: string; n: number }[] = [];
let searchGaps: { q: string; n: number }[] = [];
try {
  const s30 = Math.floor((Date.now() - 30 * 86_400_000) / 1000);
  searchTotal = db.get<{ n: number }>(sql.raw(`SELECT count(*) n FROM search_queries WHERE created_at >= ${s30}`))?.n ?? 0;
  searchTop = db.all<{ q: string; n: number }>(sql.raw(
    `SELECT q, count(*) n FROM search_queries WHERE created_at >= ${s30} GROUP BY lower(q) ORDER BY n DESC LIMIT 10`));
  searchGaps = db.all<{ q: string; n: number }>(sql.raw(
    `SELECT q, count(*) n FROM search_queries WHERE created_at >= ${s30} AND result_count = 0 GROUP BY lower(q) ORDER BY n DESC LIMIT 10`));
} catch { searchTotal = 0; searchTop = []; searchGaps = []; }

// Never let an analytics hiccup take down the page — fall back to the embed.
let t: Awaited<ReturnType<typeof getTrafficSummary>> | null = null;
try { t = await getTrafficSummary(); } catch { t = null; }

// Google Search Console — the actual search queries. Independent of Plausible so
// one failing never blocks the other.
let g: Awaited<ReturnType<typeof getGscSummary>> | null = null;
try { g = await getGscSummary(); } catch { g = null; }

const fmt = (n: number) => n.toLocaleString('en-ZA');
const fmtDate = (d: Date | null) => d ? new Date(d).toLocaleString('en-ZA', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) : '—';
// 7-day trend badge: last 7 days vs the 7 days before.
function trend(last: number, prior: number) {
  if (prior === 0 && last === 0) return { txt: '—', col: '#9CA3AF' };
  if (prior === 0) return { txt: `+${last} new`, col: '#16A34A' };
  const d = last - prior;
  const pct = Math.round((d / prior) * 100);
  if (d === 0) return { txt: 'flat', col: '#9CA3AF' };
  return { txt: `${d > 0 ? '▲' : '▼'} ${Math.abs(pct)}%`, col: d > 0 ? '#16A34A' : '#DC2626' };
}
---

<AdminLayout title="Analytics" activePage="analytics">
  {t && (
    <section style="margin-bottom: 28px;">
      {!t.apiConfigured && (
        <div style="background:#FEF3C7;border:1px solid #FCD34D;border-radius:8px;padding:10px 14px;margin-bottom:16px;font-size:13px;color:#92400E;">
          Live traffic metrics need <code>PLAUSIBLE_API_KEY</code> set in this environment
          (<code>fly secrets set PLAUSIBLE_API_KEY=…</code>). Conversion counts below come straight from the database and are accurate regardless.
        </div>
      )}

      <h2 style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#6B7280;margin:0 0 12px;">Last 30 days · business view</h2>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;">
        {/* Visitors */}
        <div style="background:#fff;border:1px solid #E5E7EB;border-radius:12px;padding:16px;">
          <div style="font-size:12px;color:#6B7280;font-weight:600;">Visitors</div>
          <div style="font-size:28px;font-weight:800;color:#111;line-height:1.2;">{fmt(t.visitors.d30)}</div>
          <div style={`font-size:12px;font-weight:600;color:${trend(t.visitors.last7, t.visitors.prior7).col};`}>
            {trend(t.visitors.last7, t.visitors.prior7).txt} <span style="color:#9CA3AF;font-weight:400;">7d vs prior</span>
          </div>
        </div>

        {/* AI-referred — the hero metric */}
        <div style="background:linear-gradient(135deg,#FFF7ED,#FFEDD5);border:1px solid #F5A623;border-radius:12px;padding:16px;">
          <div style="font-size:12px;color:#B45309;font-weight:700;">🤖 AI-referred</div>
          <div style="font-size:28px;font-weight:800;color:#111;line-height:1.2;">{fmt(t.ai.d30)}</div>
          <div style={`font-size:12px;font-weight:600;color:${trend(t.ai.last7, t.ai.prior7).col};`}>
            {trend(t.ai.last7, t.ai.prior7).txt} <span style="color:#9CA3AF;font-weight:400;">7d vs prior</span>
          </div>
        </div>

        {/* Valuations */}
        <div style="background:#fff;border:1px solid #E5E7EB;border-radius:12px;padding:16px;">
          <div style="font-size:12px;color:#6B7280;font-weight:600;">Valuations</div>
          <div style="font-size:28px;font-weight:800;color:#111;line-height:1.2;">{fmt(t.conversions30.valuations)}</div>
          <div style="font-size:12px;color:#9CA3AF;font-weight:400;">{t.rates30.valuationPct}% of visitors</div>
        </div>

        {/* Enquiries */}
        <div style="background:#fff;border:1px solid #E5E7EB;border-radius:12px;padding:16px;">
          <div style="font-size:12px;color:#6B7280;font-weight:600;">Enquiries</div>
          <div style="font-size:28px;font-weight:800;color:#111;line-height:1.2;">{fmt(t.conversions30.enquiries)}</div>
          <div style="font-size:12px;color:#9CA3AF;font-weight:400;">{t.rates30.enquiryPct}% of visitors</div>
        </div>

        {/* Finance leads */}
        <div style="background:#fff;border:1px solid #E5E7EB;border-radius:12px;padding:16px;">
          <div style="font-size:12px;color:#6B7280;font-weight:600;">Finance leads</div>
          <div style="font-size:28px;font-weight:800;color:#111;line-height:1.2;">{fmt(t.conversions30.financeLeads)}</div>
          <div style="font-size:12px;color:#9CA3AF;font-weight:400;">{t.rates30.leadPct}% of visitors</div>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:12px;">
        {/* AI source breakdown */}
        <div style="background:#fff;border:1px solid #E5E7EB;border-radius:12px;padding:16px;">
          <div style="font-size:12px;color:#6B7280;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:10px;">AI sources (30d)</div>
          {t.ai.sources.length === 0 ? (
            <div style="font-size:13px;color:#9CA3AF;">No AI-referred visits captured yet.</div>
          ) : (
            <div style="display:flex;flex-direction:column;gap:6px;">
              {t.ai.sources.map(s => (
                <div style="display:flex;justify-content:space-between;font-size:13px;color:#374151;">
                  <span>{s.source}</span><span style="font-weight:700;">{fmt(s.visitors)}</span>
                </div>
              ))}
            </div>
          )}
        </div>

        {/* Top guides */}
        <div style="background:#fff;border:1px solid #E5E7EB;border-radius:12px;padding:16px;">
          <div style="font-size:12px;color:#6B7280;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:10px;">Top guides (30d)</div>
          {t.topGuides.length === 0 ? (
            <div style="font-size:13px;color:#9CA3AF;">No guide traffic captured yet.</div>
          ) : (
            <div style="display:flex;flex-direction:column;gap:6px;">
              {t.topGuides.map(g => (
                <div style="display:flex;justify-content:space-between;gap:10px;font-size:13px;color:#374151;">
                  <a href={g.page} target="_blank" style="color:#4F46E5;text-decoration:none;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{g.page.replace('/useful-info/', '').replace(/\/$/, '')}</a>
                  <span style="font-weight:700;white-space:nowrap;">{fmt(g.visitors)}</span>
                </div>
              ))}
            </div>
          )}
        </div>
      </div>

      {/* LLM citations (first-party) — the thing Plausible can't show: WHICH guide each AI cited */}
      <div style="background:linear-gradient(135deg,#FFF7ED,#FFEDD5);border:1px solid #F5A623;border-radius:12px;padding:16px;margin-top:12px;">
        <div style="display:flex;justify-content:space-between;align-items:baseline;gap:12px;margin-bottom:12px;flex-wrap:wrap;">
          <div style="font-size:12px;color:#B45309;font-weight:700;text-transform:uppercase;letter-spacing:.05em;">🔗 LLM citations — first-party (30d)</div>
          <div style="font-size:11px;color:#9CA3AF;">Captured directly from referrers — which guide each AI cited. Not Plausible-sampled.</div>
        </div>

        {t.aiFirstParty.d30 === 0 ? (
          <div style="font-size:13px;color:#92400E;background:#FEF3C7;border-radius:8px;padding:10px 12px;">
            No LLM citations captured yet — this fills in as ChatGPT / Gemini / Perplexity / Copilot start linking to your pages. (Tracking went live 2026-06-17; expect a slow trickle at current traffic.)
          </div>
        ) : (
          <div style="display:grid;grid-template-columns:230px 1fr;gap:20px;">
            {/* left: count + trend + per-source */}
            <div>
              <div style="font-size:32px;font-weight:800;color:#111;line-height:1.1;">{fmt(t.aiFirstParty.d30)}</div>
              <div style="font-size:12px;color:#6B7280;margin-bottom:4px;">cited visits · 30d</div>
              <div style={`font-size:12px;font-weight:600;color:${trend(t.aiFirstParty.last7, t.aiFirstParty.prior7).col};`}>
                {trend(t.aiFirstParty.last7, t.aiFirstParty.prior7).txt} <span style="color:#9CA3AF;font-weight:400;">7d vs prior</span>
              </div>
              <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:12px;">
                {t.aiFirstParty.bySource.map(s => (
                  <span style="font-size:12px;background:#fff;border:1px solid #FCD34D;border-radius:999px;padding:2px 10px;color:#374151;">{s.source} <strong>{fmt(s.n)}</strong></span>
                ))}
              </div>
            </div>
            {/* right: which pages got cited */}
            <div>
              <div style="font-size:11px;color:#6B7280;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px;">Top cited pages</div>
              <div style="display:flex;flex-direction:column;gap:6px;">
                {t.aiFirstParty.topPages.map(p => (
                  <div style="display:flex;justify-content:space-between;gap:10px;font-size:13px;color:#374151;">
                    <a href={p.landing_path} target="_blank" style="color:#4F46E5;text-decoration:none;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{p.landing_path}</a>
                    <span style="font-weight:700;white-space:nowrap;">{fmt(p.n)}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
          <div style="margin-top:14px;padding-top:12px;border-top:1px solid #FCD34D;font-size:13px;color:#374151;">
            <strong>Citation → conversion:</strong> {fmt(t.aiFirstParty.conversion.converted)} of {fmt(t.aiFirstParty.conversion.referred)} AI-referred visitors later engaged (contact click, finance lead or valuation).
            <span style="color:#9CA3AF;"> Only counts referrals since client-id tracking went live — fills in over time.</span>
          </div>
        )}
      </div>
    </section>
  )}

  {/* ── Google Search Console: the actual search queries ───────────────────── */}
  <section style="margin-bottom:28px;">
    <h2 style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#6B7280;margin:0 0 12px;">🔍 Search queries · Google Search Console</h2>

    {(!g || !g.configured) && (
      <div style="background:#FEF3C7;border:1px solid #FCD34D;border-radius:8px;padding:10px 14px;font-size:13px;color:#92400E;">
        Search Console data needs a service-account key in <code>GSC_SERVICE_ACCOUNT_JSON</code>
        (<code>fly secrets set GSC_SERVICE_ACCOUNT_JSON=$(base64 &lt; key.json)</code>), and the service
        account added as a user on the GSC property. Once set, the queries you rank for show up here.
      </div>
    )}

    {g && g.configured && !g.authOk && (
      <div style="background:#FEE2E2;border:1px solid #FCA5A5;border-radius:8px;padding:10px 14px;font-size:13px;color:#991B1B;">
        Key is present but Google rejected it. Check: API enabled, key valid, and the service-account
        email added as a user on the <code>landcruisersa.co.za</code> property in Search Console.
      </div>
    )}

    {g && g.configured && g.authOk && (
      <>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin-bottom:12px;">
          <div style="background:#fff;border:1px solid #E5E7EB;border-radius:12px;padding:16px;">
            <div style="font-size:12px;color:#6B7280;font-weight:600;">Clicks</div>
            <div style="font-size:28px;font-weight:800;color:#111;line-height:1.2;">{fmt(g.totals.clicks)}</div>
            <div style="font-size:12px;color:#9CA3AF;">{g.range.startDate} → {g.range.endDate}</div>
          </div>
          <div style="background:#fff;border:1px solid #E5E7EB;border-radius:12px;padding:16px;">
            <div style="font-size:12px;color:#6B7280;font-weight:600;">Impressions</div>
            <div style="font-size:28px;font-weight:800;color:#111;line-height:1.2;">{fmt(g.totals.impressions)}</div>
            <div style="font-size:12px;color:#9CA3AF;">search appearances</div>
          </div>
          <div style="background:#fff;border:1px solid #E5E7EB;border-radius:12px;padding:16px;">
            <div style="font-size:12px;color:#6B7280;font-weight:600;">Avg CTR</div>
            <div style="font-size:28px;font-weight:800;color:#111;line-height:1.2;">{g.avgCtr}%</div>
            <div style="font-size:12px;color:#9CA3AF;">clicks ÷ impressions</div>
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
          {/* Top queries by clicks */}
          <div style="background:#fff;border:1px solid #E5E7EB;border-radius:12px;padding:16px;">
            <div style="font-size:12px;color:#6B7280;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:10px;">Top queries — by clicks</div>
            {g.topQueries.length === 0 ? (
              <div style="font-size:13px;color:#9CA3AF;">No query data in this window yet.</div>
            ) : (
              <div style="display:flex;flex-direction:column;gap:5px;">
                {g.topQueries.map(r => (
                  <div style="display:flex;justify-content:space-between;gap:10px;font-size:13px;color:#374151;">
                    <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{r.key}</span>
                    <span style="white-space:nowrap;color:#9CA3AF;">{fmt(r.clicks)}c · {fmt(r.impressions)}i · #{r.position}</span>
                  </div>
                ))}
              </div>
            )}
          </div>

          {/* Content gaps: high impressions, off page 1, ~no clicks */}
          <div style="background:linear-gradient(135deg,#EFF6FF,#DBEAFE);border:1px solid #93C5FD;border-radius:12px;padding:16px;">
            <div style="font-size:12px;color:#1D4ED8;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px;">📈 Content gaps</div>
            <div style="font-size:11px;color:#3B82F6;margin-bottom:10px;">High impressions, ranked off page 1, barely any clicks — demand you're not yet capturing.</div>
            {g.contentGaps.length === 0 ? (
              <div style="font-size:13px;color:#9CA3AF;">No clear gaps in this window.</div>
            ) : (
              <div style="display:flex;flex-direction:column;gap:5px;">
                {g.contentGaps.map(r => (
                  <div style="display:flex;justify-content:space-between;gap:10px;font-size:13px;color:#374151;">
                    <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{r.key}</span>
                    <span style="white-space:nowrap;color:#1D4ED8;font-weight:600;">{fmt(r.impressions)}i · #{r.position}</span>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>

        {/* Tyre query panel — the thesis under test */}
        <div style="background:#fff;border:1px solid #E5E7EB;border-radius:12px;padding:16px;margin-top:12px;">
          <div style="font-size:12px;color:#6B7280;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:10px;">🛞 Tyre-related queries</div>
          {g.tyreQueries.length === 0 ? (
            <div style="font-size:13px;color:#9CA3AF;">No tyre/wheel queries in this window yet.</div>
          ) : (
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:5px 20px;">
              {g.tyreQueries.map(r => (
                <div style="display:flex;justify-content:space-between;gap:10px;font-size:13px;color:#374151;">
                  <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{r.key}</span>
                  <span style="white-space:nowrap;color:#9CA3AF;">{fmt(r.clicks)}c · {fmt(r.impressions)}i · #{r.position}</span>
                </div>
              ))}
            </div>
          )}
        </div>

        {/* Clothing demand gap — the merch pitch. Impressions we get but can't serve. */}
        <div style="background:linear-gradient(135deg,#FFF7ED,#FFEDD5);border:1px solid #F5A623;border-radius:12px;padding:16px;margin-top:12px;">
          <div style="font-size:12px;color:#9A3412;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:10px;">👕 Clothing demand gap — no product to serve it</div>
          <div style="display:flex;gap:24px;flex-wrap:wrap;margin-bottom:12px;">
            <div>
              <div style="font-size:26px;font-weight:800;color:#9A3412;line-height:1;">{fmt(g.clothing.impressions)}</div>
              <div style="font-size:11px;color:#B45309;text-transform:uppercase;letter-spacing:.04em;margin-top:3px;">impressions</div>
            </div>
            <div>
              <div style="font-size:26px;font-weight:800;color:#9A3412;line-height:1;">{fmt(g.clothing.clicks)}</div>
              <div style="font-size:11px;color:#B45309;text-transform:uppercase;letter-spacing:.04em;margin-top:3px;">clicks captured</div>
            </div>
            <div>
              <div style="font-size:26px;font-weight:800;color:#9A3412;line-height:1;">{fmt(g.clothing.queryCount)}</div>
              <div style="font-size:11px;color:#B45309;text-transform:uppercase;letter-spacing:.04em;margin-top:3px;">distinct queries</div>
            </div>
          </div>
          {g.clothingQueries.length === 0 ? (
            <div style="font-size:13px;color:#9CA3AF;">No clothing/apparel queries in this window yet.</div>
          ) : (
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:5px 20px;">
              {g.clothingQueries.map(r => (
                <div style="display:flex;justify-content:space-between;gap:10px;font-size:13px;color:#374151;">
                  <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{r.key}</span>
                  <span style="white-space:nowrap;color:#B45309;">{fmt(r.clicks)}c · {fmt(r.impressions)}i · #{r.position}</span>
                </div>
              ))}
            </div>
          )}
          <div style="font-size:12px;color:#9A3412;margin-top:12px;opacity:.85;">We already rank top-5 for these searches — every click lands on content with nothing to buy. That's the range Curve Gear fills.</div>
        </div>
      </>
    )}
  </section>

  {/* ── Partner referrals: outbound clicks we've sent each partner ─────────── */}
  <section style="margin-bottom:28px;">
