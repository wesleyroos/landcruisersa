          <div style="font-size:11px;color:#B91C1C;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px;">⚠ Demand gaps (0 results)</div>
          {searchGaps.length === 0 ? (
            <div style="font-size:13px;color:#9CA3AF;">No zero-result searches — every search found stock.</div>
