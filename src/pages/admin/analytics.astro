                <td style="padding:8px 0;text-align:right;">{fmt(r.website)}</td>
                <td style="padding:8px 0;text-align:right;">{fmt(r.email)}</td>
                <td style="padding:8px 0;text-align:right;">{fmt(r.instagram)}</td>
