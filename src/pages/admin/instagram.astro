---
export const prerender = false;

import AdminLayout from '@/layouts/AdminLayout.astro';
import { getCredentials } from '@/lib/instagram';
import { db } from '@/db/index';
import { listings, clickEvents } from '@/db/schema';
import { desc, eq, and, gte, lte, sql, isNotNull, isNull } from 'drizzle-orm';
import type { Listing } from '@/db/schema';
import type { SQL } from 'drizzle-orm';

const creds = await getCredentials();
const connected = !!creds;

// Filter params
const fModel    = Astro.url.searchParams.get('model')    ?? '';
const fYear     = Astro.url.searchParams.get('year')     ?? '';
const fProvince = Astro.url.searchParams.get('province') ?? '';
const fType     = Astro.url.searchParams.get('type')     ?? '';
const fPosted   = Astro.url.searchParams.get('posted')   === '1';
const hasFilter = !!(fModel || fYear || fProvince || fType || fPosted);

const conds: SQL[] = [eq(listings.status, 'active')];
// Default view shows unposted only; Posted toggle shows posted only
conds.push(fPosted ? isNotNull(listings.ig_posted_at) : isNull(listings.ig_posted_at));
if (fModel)    conds.push(eq(listings.model,        fModel));
if (fProvince) conds.push(eq(listings.province,     fProvince));
if (fType)     conds.push(eq(listings.listing_type, fType));
if (fYear) {
  const [yMin, yMax] = fYear.split('-').map(Number);
  conds.push(gte(listings.year, yMin));
  if (yMax < 9999) conds.push(lte(listings.year, yMax));
}

const active = db.select().from(listings)
  .where(and(...conds))
  .orderBy(desc(listings.created_at)).all();

const totalActive = (db.select({ n: sql<number>`count(*)` }).from(listings)
  .where(and(eq(listings.status, 'active'), isNull(listings.ig_posted_at))).get())?.n ?? 0;
const totalPosted = (db.select({ n: sql<number>`count(*)` }).from(listings)
  .where(and(eq(listings.status, 'active'), isNotNull(listings.ig_posted_at))).get())?.n ?? 0;

// Build toggle URL — adds or removes the posted=1 param while keeping other filters
const postedToggleParams = new URLSearchParams();
if (!fPosted) postedToggleParams.set('posted', '1');
if (fModel)    postedToggleParams.set('model',    fModel);
if (fYear)     postedToggleParams.set('year',     fYear);
if (fProvince) postedToggleParams.set('province', fProvince);
if (fType)     postedToggleParams.set('type',     fType);
const postedToggleUrl = '/admin/instagram' + (postedToggleParams.toString() ? '?' + postedToggleParams.toString() : '');

const urlError   = Astro.url.searchParams.get('error');
const urlSuccess = Astro.url.searchParams.get('connected');

const errorMessages: Record<string, string> = {
  denied:         'You denied the Instagram authorisation.',
  missing_params: 'OAuth callback was missing required parameters.',
  invalid_state:  'OAuth state mismatch — please try again.',
  token_exchange: 'Failed to exchange the authorisation code for a token.',
  not_configured: 'Instagram credentials are not configured on the server.',
};

// ─── IG media stats (posted view only) ───────────────────────────────────────
// Step 1: fetch media list, match to listings by timestamp (±2 min window)
// Step 2: for each match, fetch insights (impressions, reach) — requires
//         instagram_business_manage_insights scope. Degrades gracefully if not yet
//         available (token pre-dates scope addition; just reconnect to get it).
type IgStats = { likes: number; comments: number; reach: number; impressions: number };
const igMediaStats = new Map<number, IgStats>(); // keyed by listing.id

if (fPosted && connected && creds) {
  try {
    const res = await fetch(
      `https://graph.instagram.com/v21.0/${creds!.userId}/media` +
      `?fields=id,timestamp,like_count,comments_count&limit=100` +
      `&access_token=${creds!.accessToken}`
    );
    const json = await res.json();
    if (Array.isArray(json.data)) {
      // Match media items to our listings
      const matched: Array<{ listingId: number; mediaId: string; likes: number; comments: number }> = [];
      for (const item of json.data) {
        const igMs = new Date(item.timestamp).getTime();
        for (const l of active) {
          if (!l.ig_posted_at) continue;
          const ourMs = l.ig_posted_at instanceof Date
            ? l.ig_posted_at.getTime()
            : (l.ig_posted_at as unknown as number) * 1000;
          if (Math.abs(igMs - ourMs) < 2 * 60 * 1000) {
            matched.push({ listingId: l.id, mediaId: item.id, likes: item.like_count ?? 0, comments: item.comments_count ?? 0 });
          }
        }
      }

      // Fetch insights in parallel for each matched post
      await Promise.all(matched.map(async (m) => {
        let reach = 0, impressions = 0;
        try {
          const ir = await fetch(
            `https://graph.instagram.com/v21.0/${m.mediaId}/insights` +
            `?metric=impressions,reach&access_token=${creds!.accessToken}`
          );
          const ij = await ir.json();
          if (Array.isArray(ij.data)) {
            const get = (name: string) => ij.data.find((d: any) => d.name === name)?.values?.[0]?.value ?? 0;
            impressions = get('impressions');
            reach       = get('reach');
          }
        } catch { /* scope not yet available — shows 0 */ }
        igMediaStats.set(m.listingId, { likes: m.likes, comments: m.comments, reach, impressions });
      }));
    }
  } catch { /* IG unavailable — show cards without stats */ }
}

// ─── Outbound clicks per listing ─────────────────────────────────────────────
type ClickCounts = { whatsapp: number; call: number; email: number; portal: number };
const listingClicks = new Map<string, ClickCounts>();

if (fPosted) {
  const rows = db.select({
    slug:   clickEvents.listing_slug,
    source: clickEvents.source,
    count:  sql<number>`cast(count(*) as int)`,
  }).from(clickEvents)
    .groupBy(clickEvents.listing_slug, clickEvents.source)
    .all();

  for (const r of rows) {
    const c = listingClicks.get(r.slug) ?? { whatsapp: 0, call: 0, email: 0, portal: 0 };
    if (r.source === 'whatsapp') c.whatsapp += r.count;
    else if (r.source === 'call') c.call += r.count;
    else if (r.source === 'email') c.email += r.count;
    else c.portal += r.count;
    listingClicks.set(r.slug, c);
  }
}

function firstPhoto(photos: string): string | null {
  try { return JSON.parse(photos)[0] ?? null; } catch { return null; }
}
function photoCount(photos: string): number {
  try { return JSON.parse(photos).length; } catch { return 0; }
}
function formatPrice(n: number) {
  return 'R' + n.toLocaleString('en-ZA');
}
---

<AdminLayout title="Instagram" activePage="instagram">

  <!-- CONNECTION CARD -->
  <div class="section">
    <div class={`conn-card ${connected ? 'conn-card-ok' : 'conn-card-off'}`}>
      <div class="conn-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
        </svg>
      </div>
      <div class="conn-body">
        {connected ? (
          <>
            <p class="conn-title">Connected as <strong>@{creds!.username}</strong></p>
            <p class="conn-sub">Long-lived token · refresh monthly to keep it alive</p>
          </>
        ) : (
          <>
            <p class="conn-title">Not connected</p>
            <p class="conn-sub">Connect your Instagram account to start posting</p>
          </>
        )}
      </div>
      <div class="conn-actions">
        {connected ? (
          <>
            <button id="refresh-token-btn" class="btn btn-outline">Refresh Token</button>
            <button id="disconnect-btn"    class="btn btn-danger">Disconnect</button>
          </>
        ) : (
          <a href="/api/admin/instagram/connect" class="btn btn-ig">Connect Instagram</a>
        )}
      </div>
    </div>

    {urlSuccess && (
      <div class="alert alert-ok">Instagram connected successfully.</div>
    )}
    {urlError && (
      <div class="alert alert-err">{errorMessages[urlError] ?? 'Something went wrong.'}</div>
    )}
  </div>

  <!-- FILTER BAR -->
  {connected && (
    <div class="filter-bar">
      <div class="filter-fields">
        <select class={`af-sel${fModel    ? ' active' : ''}`} data-filter="model">
          <option value="">All Models</option>
          <option value="76-series"       selected={fModel==='76-series'}>76 Series</option>
          <option value="78-series"       selected={fModel==='78-series'}>78 Series</option>
          <option value="79-series"       selected={fModel==='79-series'}>79 Series</option>
          <option value="80-series"       selected={fModel==='80-series'}>80 Series</option>
          <option value="100-series"      selected={fModel==='100-series'}>100 Series</option>
          <option value="200-series"      selected={fModel==='200-series'}>200 Series</option>
          <option value="300-series"      selected={fModel==='300-series'}>300 Series</option>
          <option value="prado-150"       selected={fModel==='prado-150'}>Prado 150</option>
          <option value="prado-250"       selected={fModel==='prado-250'}>Prado 250</option>
          <option value="fj-cruiser"      selected={fModel==='fj-cruiser'}>FJ Cruiser</option>
          <option value="land-cruiser-fj" selected={fModel==='land-cruiser-fj'}>LC FJ</option>
          <option value="other"           selected={fModel==='other'}>Other</option>
        </select>
        <select class={`af-sel${fYear     ? ' active' : ''}`} data-filter="year">
          <option value="">Any Year</option>
          <option value="2023-9999" selected={fYear==='2023-9999'}>2023+</option>
          <option value="2020-2022" selected={fYear==='2020-2022'}>2020–2022</option>
          <option value="2015-2019" selected={fYear==='2015-2019'}>2015–2019</option>
          <option value="2010-2014" selected={fYear==='2010-2014'}>2010–2014</option>
          <option value="2000-2009" selected={fYear==='2000-2009'}>2000s</option>
          <option value="0-1999"    selected={fYear==='0-1999'}>Pre-2000</option>
        </select>
        <select class={`af-sel${fProvince ? ' active' : ''}`} data-filter="province">
          <option value="">All Provinces</option>
          <option value="Gauteng"       selected={fProvince==='Gauteng'}>Gauteng</option>
          <option value="Western Cape"  selected={fProvince==='Western Cape'}>Western Cape</option>
          <option value="KwaZulu-Natal" selected={fProvince==='KwaZulu-Natal'}>KwaZulu-Natal</option>
          <option value="Eastern Cape"  selected={fProvince==='Eastern Cape'}>Eastern Cape</option>
          <option value="Limpopo"       selected={fProvince==='Limpopo'}>Limpopo</option>
          <option value="Mpumalanga"    selected={fProvince==='Mpumalanga'}>Mpumalanga</option>
          <option value="North West"    selected={fProvince==='North West'}>North West</option>
          <option value="Free State"    selected={fProvince==='Free State'}>Free State</option>
          <option value="Northern Cape" selected={fProvince==='Northern Cape'}>Northern Cape</option>
        </select>
        <select class={`af-sel${fType     ? ' active' : ''}`} data-filter="type">
          <option value="">All Types</option>
          <option value="for_sale" selected={fType==='for_sale'}>For Sale</option>
          <option value="show_off" selected={fType==='show_off'}>Show Off</option>
        </select>
      </div>
      <div class="filter-meta">
        <a href={postedToggleUrl} class={`af-posted-toggle${fPosted ? ' active' : ''}`}>
          ✓ Posted ({totalPosted})
        </a>
        {hasFilter
          ? <span class="af-count">{active.length} of {totalActive}</span>
          : <span class="af-count">{totalActive} listing{totalActive !== 1 ? 's' : ''}</span>
        }
        {hasFilter && <a href="/admin/instagram" class="af-clear">✕ Clear</a>}
      </div>
    </div>
  )}

  <!-- LISTINGS -->
  {connected && (
    <div class="section">
      <p class="section-head">{fPosted ? 'Posted to Instagram' : 'Not Yet Posted'}</p>

      {active.length === 0 && (
        <p class="empty-state">No active listings match your filters.</p>
      )}

      <div class="listing-grid">
        {active.map((l: Listing) => {
          const photo = firstPhoto(l.photos);
          const count = photoCount(l.photos);
          const igS = fPosted ? igMediaStats.get(l.id) : undefined;
          const clk = fPosted ? (listingClicks.get(l.slug) ?? { whatsapp: 0, call: 0, email: 0, portal: 0 }) : undefined;
          const hasClicks = clk && (clk.whatsapp + clk.call + clk.email + clk.portal > 0);
          return (
            <div class={`lcard${l.ig_posted_at ? ' lcard-posted' : ''}`} data-id={l.id}>
              <div class="lcard-thumb-wrap">
                {photo
                  ? <img class="lcard-thumb" src={photo} alt={l.title} loading="lazy" />
                  : <div class="lcard-thumb lcard-thumb-empty">🚗</div>
                }
                {count > 1 && <span class="photo-count">{count} photos</span>}
                {l.ig_posted_at && <span class="posted-badge">✓ Posted</span>}
              </div>
              <div class="lcard-body">
                <p class="lcard-title">{l.title}</p>
                <p class="lcard-sub">
                  {l.year} · {l.model.replaceAll('-', ' ').toUpperCase()} · {l.province}
                  {l.listing_type === 'for_sale' && ` · ${formatPrice(l.price)}`}
                </p>
                {l.ig_posted_at && (
                  <p class="lcard-posted-at">Posted {new Intl.DateTimeFormat('en-ZA', { day: 'numeric', month: 'short', year: 'numeric' }).format(l.ig_posted_at)}</p>
                )}
                {(igS || hasClicks) && (
                  <div class="lcard-stats">
                    {igS && (
                      <>
                        <span class="stat-chip stat-ig" title="Likes">
                          <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/></svg>
                          {igS.likes}
                        </span>
                        <span class="stat-chip stat-ig" title="Comments">
                          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                          {igS.comments}
                        </span>
                        {igS.reach > 0 && (
                          <span class="stat-chip stat-reach" title="Reach">
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"/></svg>
                            {igS.reach.toLocaleString('en-ZA')}
                          </span>
                        )}
                        {igS.impressions > 0 && (
                          <span class="stat-chip stat-reach" title="Impressions">
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            {igS.impressions.toLocaleString('en-ZA')}
                          </span>
                        )}
                        {hasClicks && <span class="stat-divider">·</span>}
                      </>
                    )}
                    {clk && clk.whatsapp > 0 && <span class="stat-chip stat-wa">WA {clk.whatsapp}</span>}
                    {clk && clk.call     > 0 && <span class="stat-chip stat-contact">Call {clk.call}</span>}
                    {clk && clk.email    > 0 && <span class="stat-chip stat-contact">Email {clk.email}</span>}
                    {clk && clk.portal   > 0 && <span class="stat-chip stat-portal">Portal {clk.portal}</span>}
                  </div>
                )}
              </div>
              <div class="lcard-action">
                <button class="btn btn-preview" data-action="preview" data-id={l.id}>
                  Preview Caption
                </button>
                <button class={`btn ${l.ig_posted_at ? 'btn-repost' : 'btn-post'}`} data-action="post" data-id={l.id}>
                  {l.ig_posted_at ? 'Repost' : 'Post to Instagram'}
                </button>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  )}

  <!-- PREVIEW MODAL -->
  <div id="preview-modal" class="modal-backdrop" hidden>
    <div class="modal">
      <p class="modal-title">Caption Preview</p>
      <p id="modal-photo-count" class="modal-meta"></p>
      <textarea id="modal-caption" class="modal-caption" rows="14" spellcheck="false"></textarea>
      <div class="modal-actions">
        <button id="modal-cancel"   class="btn btn-outline">Cancel</button>
        <button id="modal-rehashtag" class="btn btn-outline" style="margin-right:auto">↺ New hashtags</button>
        <button id="modal-confirm"  class="btn btn-post">Post Now</button>
      </div>
    </div>
  </div>

  <!-- TOAST -->
  <div id="toast" class="toast" hidden></div>

</AdminLayout>

<style>
  .section { margin-bottom: 2rem; }

  /* ── Connection card ── */
  .conn-card {
    border: 1.5px solid #E5E7EB; border-radius: 0.875rem;
    padding: 1.25rem 1.5rem; display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap;
  }
  .conn-card-ok  { border-color: #111111; }
  .conn-card-off { border-color: #E5E7EB; }

  .conn-icon { color: #111111; flex-shrink: 0; }
  .conn-card-off .conn-icon { color: #9CA3AF; }

  .conn-body { flex: 1; min-width: 0; }
  .conn-title { font-size: 0.9rem; font-weight: 700; color: #111111; }
  .conn-sub   { font-size: 0.72rem; color: #9CA3AF; margin-top: 0.15rem; }

  .conn-actions { display: flex; gap: 0.5rem; flex-shrink: 0; flex-wrap: wrap; }

  /* ── Alerts ── */
  .alert {
    margin-top: 0.75rem; border-radius: 0.5rem; padding: 0.625rem 1rem;
    font-size: 0.8rem; font-weight: 600;
  }
  .alert-ok  { background: #DCFCE7; color: #166534; }
  .alert-err { background: #FEF2F2; color: #991B1B; }

  /* ── Section heading ── */
  .section-head {
    font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em;
    color: #9CA3AF; margin-bottom: 0.75rem; padding-bottom: 0.75rem; border-bottom: 1.5px solid #F3F4F6;
  }
  .empty-state { font-size: 0.875rem; color: #9CA3AF; }

  /* ── Listing grid ── */
  .listing-grid { display: flex; flex-direction: column; gap: 0.625rem; }

  .lcard {
    border: 1.5px solid #E5E7EB; border-radius: 0.75rem;
    display: grid; grid-template-columns: 140px 1fr auto;
    overflow: hidden; transition: border-color 0.15s;
  }
  .lcard:hover { border-color: #F5A623; }

  .lcard-thumb-wrap { position: relative; }
  .lcard-thumb { width: 140px; height: 100%; object-fit: cover; display: block; background: #F3F4F6; min-height: 80px; }
  .lcard-thumb-empty {
    width: 140px; height: 100%; min-height: 80px;
    display: flex; align-items: center; justify-content: center; font-size: 1.5rem; background: #F3F4F6;
  }
  .photo-count {
    position: absolute; bottom: 6px; right: 6px;
    background: rgba(0,0,0,0.65); color: white; font-size: 0.6rem; font-weight: 700;
    padding: 0.15rem 0.45rem; border-radius: 9999px;
  }

  .lcard-body { padding: 0.875rem 1rem; min-width: 0; align-self: center; }
  .lcard-title { font-size: 0.9375rem; font-weight: 700; color: #111111; margin-bottom: 0.25rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .lcard-sub   { font-size: 0.75rem; color: #6B7280; }

  .lcard-action {
    display: flex; flex-direction: column; gap: 0.375rem;
    padding: 0.875rem; border-left: 1.5px solid #F3F4F6;
    justify-content: center; flex-shrink: 0;
  }

  /* ── Buttons ── */
  .btn {
    font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em;
    padding: 0.45rem 0.875rem; border-radius: 0.375rem; cursor: pointer;
    border: 1.5px solid transparent; transition: all 0.15s; white-space: nowrap;
    text-decoration: none; display: inline-block; text-align: center; line-height: 1.5;
  }
  .btn:disabled { opacity: 0.4; cursor: not-allowed; }

  .btn-ig      { background: #111111; color: white; border-color: #111111; }
  .btn-ig:hover { background: #374151; border-color: #374151; }

  .btn-outline  { background: white; color: #6B7280; border-color: #E5E7EB; }
  .btn-outline:hover { color: #111111; border-color: #111111; }

  .btn-danger   { background: white; color: #9CA3AF; border-color: #E5E7EB; }
  .btn-danger:hover { background: #FEF2F2; color: #991B1B; border-color: #FECACA; }

  .btn-preview  { background: white; color: #6B7280; border-color: #E5E7EB; }
  .btn-preview:hover { color: #111111; border-color: #111111; }

  .btn-post     { background: #111111; color: white; border-color: #111111; }
  .btn-post:hover:not(:disabled) { background: #374151; border-color: #374151; }

  .btn-repost   { background: white; color: #6B7280; border-color: #E5E7EB; }
  .btn-repost:hover:not(:disabled) { background: #F9FAFB; border-color: #9CA3AF; color: #374151; }

  .lcard-posted { background: #F9FBF9; }
  .posted-badge {
    position: absolute; top: 6px; right: 6px;
    background: #166534; color: white; font-size: 0.6rem; font-weight: 700;
    padding: 0.15rem 0.45rem; border-radius: 9999px; letter-spacing: 0.04em;
  }
  .lcard-posted-at { font-size: 0.68rem; color: #166534; font-weight: 600; margin-top: 0.2rem; }

  .lcard-stats { display: flex; align-items: center; gap: 0.3rem; flex-wrap: wrap; margin-top: 0.5rem; }
  .stat-chip {
    font-size: 0.62rem; font-weight: 700; padding: 0.12rem 0.45rem; border-radius: 9999px;
    display: inline-flex; align-items: center; gap: 0.2rem; line-height: 1.5;
    background: #F3F4F6; color: #6B7280;
  }
  .stat-ig      { background: #FDF2F8; color: #9D174D; }
  .stat-reach   { background: #F0F4FF; color: #3730A3; }
  .stat-wa      { background: #F0FDF4; color: #166534; }
  .stat-contact { background: #F0F9FF; color: #0369A1; }
  .stat-portal  { background: #EFF6FF; color: #1D4ED8; }
  .stat-divider { font-size: 0.65rem; color: #D1D5DB; }

  /* ── Modal ── */
  .modal-backdrop {
    position: fixed; inset: 0; background: rgba(0,0,0,0.45);
    display: flex; align-items: center; justify-content: center; z-index: 50;
  }
  .modal-backdrop[hidden] { display: none; }
  .modal {
    background: white; border-radius: 0.875rem; border: 1.5px solid #E5E7EB;
    padding: 1.5rem; width: 100%; max-width: 480px; box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    display: flex; flex-direction: column; gap: 0.875rem;
  }
  .modal-title  { font-size: 0.875rem; font-weight: 700; color: #111111; }
  .modal-meta   { font-size: 0.72rem; color: #9CA3AF; margin-top: -0.5rem; }
  .modal-caption {
    font-size: 0.78rem; color: #374151; line-height: 1.6;
    background: #F9FAFB; border: 1.5px solid #E5E7EB; border-radius: 0.5rem;
    padding: 0.875rem 1rem; word-break: break-word;
    width: 100%; box-sizing: border-box; resize: vertical;
    font-family: inherit; outline: none;
  }
  .modal-caption:focus { border-color: #111111; }
  .modal-actions { display: flex; gap: 0.5rem; justify-content: flex-end; }

  /* ── Filter bar ── */
  .filter-bar {
    background: white; border: 1.5px solid #E5E7EB; border-radius: 0.75rem;
    padding: 0.75rem 1rem; margin-bottom: 1.25rem;
    display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
  }
  .filter-fields { display: flex; gap: 0.5rem; flex-wrap: wrap; flex: 1; }
  .filter-meta { display: flex; align-items: center; gap: 0.75rem; flex-shrink: 0; }
  .af-sel {
    font-size: 0.7rem; font-weight: 600; color: #374151;
    border: 1.5px solid #E5E7EB; border-radius: 0.4rem;
    padding: 0.35rem 0.6rem; background: white; cursor: pointer;
    outline: none; transition: border-color 0.15s; box-sizing: border-box;
    appearance: none; -webkit-appearance: none;
  }
  .af-sel:hover { border-color: #9CA3AF; }
  .af-sel.active { border-color: #111111; background: #111111; color: white; }
  .af-count { font-size: 0.72rem; font-weight: 600; color: #9CA3AF; }
  .af-clear {
    font-size: 0.7rem; font-weight: 700; color: #6B7280;
    text-decoration: none; border: 1.5px solid #E5E7EB; border-radius: 0.4rem;
    padding: 0.3rem 0.6rem; transition: all 0.15s;
  }
  .af-clear:hover { border-color: #111111; color: #111111; }
  .af-posted-toggle {
    font-size: 0.7rem; font-weight: 700; color: #6B7280;
    text-decoration: none; border: 1.5px solid #E5E7EB; border-radius: 0.4rem;
    padding: 0.3rem 0.6rem; transition: all 0.15s;
  }
  .af-posted-toggle:hover { border-color: #111111; color: #111111; }
  .af-posted-toggle.active { background: #111111; color: #fff; border-color: #111111; }

  /* ── Toast ── */
  .toast {
    position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 100;
    background: #111111; color: white; font-size: 0.8rem; font-weight: 600;
    padding: 0.75rem 1.25rem; border-radius: 0.625rem;
    box-shadow: 0 4px 16px rgba(0,0,0,0.2); transition: opacity 0.3s;
  }
  .toast[hidden] { display: none; }
  .toast-ok  { background: #166534; }
  .toast-err { background: #991B1B; }

  @media (max-width: 640px) {
    .lcard { grid-template-columns: 80px 1fr; }
    .lcard-thumb, .lcard-thumb-empty { width: 80px; }
    .lcard-action { grid-column: 1 / -1; flex-direction: row; flex-wrap: wrap; border-left: none; border-top: 1.5px solid #F3F4F6; padding: 0.625rem; }
  }
</style>

<script>
  let pendingListingId: number | null = null;

  const modal        = document.getElementById('preview-modal')!;
  const modalCaption = document.getElementById('modal-caption') as HTMLTextAreaElement;
  const modalMeta    = document.getElementById('modal-photo-count')!;
  const modalCancel    = document.getElementById('modal-cancel')!;
  const modalRehashtag = document.getElementById('modal-rehashtag') as HTMLButtonElement;
  const modalConfirm   = document.getElementById('modal-confirm') as HTMLButtonElement;
  const toast        = document.getElementById('toast')!;

  function showToast(msg: string, type: 'ok' | 'err') {
    toast.textContent = msg;
    toast.className = `toast toast-${type}`;
    toast.hidden = false;
    setTimeout(() => { toast.hidden = true; }, 3500);
  }

  const CTA_MARKER = '📲 Link in bio to view full listing';

  // Close modal
  modalCancel.addEventListener('click', () => { modal.hidden = true; pendingListingId = null; });
  modal.addEventListener('click', (e) => { if (e.target === modal) { modal.hidden = true; pendingListingId = null; } });

  // Regenerate hashtags — keep the body the user may have edited, swap only the hashtag block
  modalRehashtag.addEventListener('click', async () => {
    if (!pendingListingId) return;
    modalRehashtag.disabled = true;
    modalRehashtag.textContent = '…';
    let success = false;
    try {
      const res  = await fetch('/api/admin/instagram/post', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ listingId: pendingListingId, previewOnly: true }),
      });
      const data = await res.json();
      if (!res.ok) { showToast(data.error ?? 'Failed to regenerate', 'err'); return; }

      // Extract new hashtags (everything after the CTA line)
      const ctaIdx = data.caption.indexOf(CTA_MARKER);
      const newHashtags = ctaIdx !== -1 ? data.caption.slice(ctaIdx + CTA_MARKER.length).trimStart() : '';

      // Replace only the hashtag portion in the current textarea
      const current = modalCaption.value;
      const bodyEnd = current.indexOf(CTA_MARKER);
      if (bodyEnd !== -1) {
        modalCaption.value = current.slice(0, bodyEnd + CTA_MARKER.length) + (newHashtags ? '\n\n' + newHashtags : '');
      } else {
        modalCaption.value = current.trimEnd() + '\n\n' + newHashtags;
      }
      success = true;
    } finally {
      modalRehashtag.disabled = false;
      modalRehashtag.textContent = success ? '✓ Updated!' : '↺ New hashtags';
      if (success) setTimeout(() => { modalRehashtag.textContent = '↺ New hashtags'; }, 1500);
    }
  });

  // Listing action buttons
  document.addEventListener('click', async (e) => {
    const btn = (e.target as Element).closest<HTMLButtonElement>('[data-action]');
    if (!btn) return;

    const action = btn.dataset.action!;
    const id     = Number(btn.dataset.id!);

    if (action === 'preview') {
      btn.disabled = true;
      btn.textContent = 'Generating…';
      modalCaption.value = 'Generating hashtags with AI…';
      modalCaption.disabled = true;
      modalConfirm.disabled = true;
      modalMeta.textContent = '';
      pendingListingId = id;
      modal.hidden = false;
      try {
        const res  = await fetch('/api/admin/instagram/post', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ listingId: id, previewOnly: true }),
        });
        const data = await res.json();
        if (!res.ok) {
          modal.hidden = true;
          pendingListingId = null;
          showToast(data.error ?? 'Failed to load preview', 'err');
          return;
        }
        modalCaption.value    = data.caption;
        modalCaption.disabled = false;
        modalConfirm.disabled = false;
        modalMeta.textContent = `${data.photoCount} photo${data.photoCount !== 1 ? 's' : ''} will be posted as ${data.photoCount > 1 ? 'a carousel' : 'a single image'}`;
      } finally {
        btn.disabled = false;
        btn.textContent = 'Preview Caption';
      }
    }

    if (action === 'post') {
      if (!confirm('Post this listing to Instagram now?')) return;
      await doPost(id, btn);
    }
  });

  // Confirm from modal — pass whatever caption is currently in the textarea
  modalConfirm.addEventListener('click', async () => {
    if (!pendingListingId) return;
    const id      = pendingListingId;
    const caption = modalCaption.value;
    modal.hidden = true;
    pendingListingId = null;
    const btn = document.querySelector<HTMLButtonElement>(`[data-action="post"][data-id="${id}"]`);
    await doPost(id, btn, caption);
  });

  function markPosted(id: number, btn: HTMLButtonElement | null) {
    const card = document.querySelector<HTMLElement>(`.lcard[data-id="${id}"]`);
    if (card) {
      card.classList.add('lcard-posted');
      const thumbWrap = card.querySelector('.lcard-thumb-wrap');
      if (thumbWrap && !thumbWrap.querySelector('.posted-badge')) {
        const badge = document.createElement('span');
        badge.className = 'posted-badge';
        badge.textContent = '✓ Posted';
        thumbWrap.appendChild(badge);
      }
      const cardBody = card.querySelector('.lcard-body');
      if (cardBody && !cardBody.querySelector('.lcard-posted-at')) {
        const today = new Intl.DateTimeFormat('en-ZA', { day: 'numeric', month: 'short', year: 'numeric' }).format(new Date());
        const p = document.createElement('p');
        p.className = 'lcard-posted-at';
        p.textContent = `Posted ${today}`;
        cardBody.appendChild(p);
      }
    }
    if (btn) { btn.className = 'btn btn-repost'; btn.textContent = 'Repost'; btn.disabled = false; }
  }

  async function pollPosted(id: number, btn: HTMLButtonElement | null, deadline: number) {
    if (Date.now() > deadline) {
      showToast('Post timed out — check Instagram to confirm', 'err');
      if (btn) { btn.disabled = false; btn.textContent = 'Repost'; }
      return;
    }
    const res = await fetch(`/api/admin/instagram/post-status?id=${id}`).catch(() => null);
    if (res?.ok) {
      const data = await res.json();
      if (data.posted) { showToast('Posted to Instagram!', 'ok'); markPosted(id, btn); return; }
    }
    setTimeout(() => pollPosted(id, btn, deadline), 4000);
  }

  async function doPost(id: number, btn: HTMLButtonElement | null, caption?: string) {
    if (btn) { btn.disabled = true; btn.textContent = 'Posting…'; }

    try {
      const res  = await fetch('/api/admin/instagram/post', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ listingId: id, ...(caption ? { caption } : {}) }),
      });
      const data = await res.json();
      if (res.status === 202 || res.ok) {
        // Background job started — poll until ig_posted_at is stamped (2 min timeout)
        pollPosted(id, btn, Date.now() + 120_000);
      } else {
        showToast(data.error ?? 'Post failed', 'err');
        if (btn) { btn.disabled = false; btn.textContent = btn.classList.contains('btn-repost') ? 'Repost' : 'Post to Instagram'; }
      }
    } catch {
      showToast('Network error', 'err');
      if (btn) { btn.disabled = false; btn.textContent = 'Post to Instagram'; }
    }
  }

  // Refresh token
  document.getElementById('refresh-token-btn')?.addEventListener('click', async function () {
    const btn = this as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Refreshing…';
    try {
      const res  = await fetch('/api/admin/instagram/refresh-token', { method: 'POST' });
      const data = await res.json();
      showToast(res.ok ? 'Token refreshed.' : (data.error ?? 'Refresh failed'), res.ok ? 'ok' : 'err');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Refresh Token';
    }
  });

  // Disconnect
  document.getElementById('disconnect-btn')?.addEventListener('click', async function () {
    if (!confirm('Disconnect Instagram? You\'ll need to re-authorise to post again.')) return;
    const btn = this as HTMLButtonElement;
    btn.disabled = true;
    await fetch('/api/admin/instagram/disconnect', { method: 'POST' });
    location.reload();
  });

  // Filter selects — navigate to filtered URL on change
  document.querySelectorAll<HTMLSelectElement>('[data-filter]').forEach(sel => {
    sel.addEventListener('change', () => {
      const params = new URLSearchParams(window.location.search);
      const key = sel.dataset.filter!;
      if (sel.value) params.set(key, sel.value); else params.delete(key);
      params.delete('page');
      window.location.href = '/admin/instagram' + (params.toString() ? '?' + params.toString() : '');
    });
  });
</script>
