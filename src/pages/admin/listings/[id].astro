---
export const prerender = false;

import AdminLayout from '@/layouts/AdminLayout.astro';
import AdminIgPost from '@/components/AdminIgPost.astro';
import { getCredentials } from '@/lib/instagram';
import { db } from '@/db/index';
import { listings } from '@/db/schema';
import { eq } from 'drizzle-orm';

const id = Number(Astro.params.id);
if (isNaN(id)) return Astro.redirect('/admin');

const [listing] = await db.select().from(listings).where(eq(listings.id, id));
if (!listing) return Astro.redirect('/admin');

function firstPhoto(photos: string) {
  try { return JSON.parse(photos)[0] ?? null; } catch { return null; }
}
function allPhotos(photos: string) {
  try { return JSON.parse(photos) as string[]; } catch { return []; }
}

const photos = allPhotos(listing.photos);
const thumb = firstPhoto(listing.photos);

const SOURCE_LABEL: Record<string, string> = {
  autotrader: 'AutoTrader', wbc: 'WeBuyCars', adios: 'Adios',
  wbb: 'We Buy Bakkies', carsza: 'Cars.co.za', own: 'Own listing',
};
const portalLabel = SOURCE_LABEL[listing.source] ?? listing.source;

const igConnected = !!(await getCredentials());

const MODELS = ['70-series','76-series','78-series','79-series','80-series','100-series','200-series','300-series','prado-150','prado-250','fj-cruiser','land-cruiser-fj','other'];
const PROVINCES = ['Gauteng','Western Cape','KwaZulu-Natal','Eastern Cape','Limpopo','Mpumalanga','North West','Free State','Northern Cape'];

// IG caption generation
const modelLabel = listing.model.replace(/-/g, ' ').toUpperCase();
const priceStr = listing.price ? `R${listing.price.toLocaleString('en-ZA')}` : 'POA';
const mileageStr = listing.mileage ? `${listing.mileage.toLocaleString('en-ZA')} km` : 'New';
const transStr = listing.transmission ? (listing.transmission.charAt(0).toUpperCase() + listing.transmission.slice(1)) : '';
const fuelStr = listing.fuel_type ? ` | ${listing.fuel_type}` : '';
const igCaption = `${listing.year} Toyota ${modelLabel} — ${priceStr}

📍 ${listing.province || 'South Africa'}
🛣️ ${mileageStr}
⚙️ ${transStr}${fuelStr}

${listing.description ? listing.description.slice(0, 200).trim() + (listing.description.length > 200 ? '...' : '') + '\n\n' : ''}🔗 Link in bio to view full listing.

#LandCruiser #Toyota #${listing.model.replace(/-/g, '')} #4x4 #Offroad #SouthAfrica #LandCruiserSA #4WD #TruckLife #Overlanding`;

// WhatsApp spec — full vehicle detail, ready to paste into a chat.
// Strip seller-contact boilerplate from the description: "finance" lines,
// standalone prices, phone numbers, URLs, and any leftover emojis.
const EMOJI_RE = /[\u{1F000}-\u{1FAFF}\u{2600}-\u{27BF}\u{2190}-\u{21FF}\u{2B00}-\u{2BFF}\u{FE00}-\u{FE0F}\u{200D}]/gu;
function cleanDescription(raw: string): string {
  return raw.split('\n')
    .map(l => l.replace(EMOJI_RE, '').replace(/\s+$/, ''))
    .filter(l => {
      const t = l.trim();
      if (/finance/i.test(t)) return false;            // "Finance can be arranged"
      if (/^R\s?[\d\s.,]+$/i.test(t)) return false;     // standalone price line
      if (/^\+?\d[\d\s().-]{7,}\d$/.test(t)) return false; // standalone phone number
      if (/https?:\/\//i.test(t)) return false;         // URLs
      return true;
    })
    .join('\n')
    .replace(/\n{3,}/g, '\n\n')
    .trim();
}
const cleanDesc = listing.description ? cleanDescription(listing.description) : '';
const waSpec = [
  `*${listing.title}*`,
  '',
  `Year: ${listing.year}`,
  `Model: ${modelLabel}`,
  listing.mileage ? `Mileage: ${listing.mileage.toLocaleString('en-ZA')} km` : null,
  transStr ? `Transmission: ${transStr}` : null,
  listing.fuel_type ? `Fuel: ${listing.fuel_type}` : null,
  listing.fuel_consumption ? `Consumption: ${listing.fuel_consumption} L/100km` : null,
  listing.power_kw ? `Power: ${listing.power_kw} kW` : null,
  listing.seats ? `Seats: ${listing.seats}` : null,
  listing.colour ? `Colour: ${listing.colour}` : null,
  listing.new_or_used ? `Condition: ${listing.new_or_used}` : null,
  listing.province ? `Province: ${listing.province}` : null,
  cleanDesc ? `\n${cleanDesc}` : null,
].filter(line => line !== null).join('\n');
---

<AdminLayout title={listing.title} activePage="listings">

  <div class="edit-header">
    <a href="/admin" class="back-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      All Listings
    </a>
    <div class="header-badges">
      <span class={`status-badge status-${listing.status}`}>{listing.status}</span>
      <span class={`type-badge type-${listing.listing_type}`}>{listing.listing_type === 'for_sale' ? 'For Sale' : '★ Show Off'}</span>
    </div>
    <div class="header-actions">
      {listing.source_url && (
        <a href={listing.source_url} target="_blank" rel="noopener" class="view-link">
          View on {portalLabel}
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
      )}
      {listing.status === 'active' && listing.slug && (
        <a href={`/listings/${listing.slug}/`} target="_blank" class="view-link">
          View on site
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
      )}
    </div>
  </div>

  <div class="edit-grid">

    <!-- LEFT: Form -->
    <div class="edit-form-col">

      <div id="save-banner" class="save-banner hidden">Changes saved.</div>
      <div id="error-banner" class="error-banner hidden">Something went wrong — try again.</div>

      <form id="edit-form">

        <!-- Source -->
        <div class="card">
          <h2 class="card-heading">Source</h2>
          <div class="field">
            <label>Portal listing</label>
            {listing.source_url
              ? <p class="source-row"><span class="source-portal">{portalLabel}</span><a href={listing.source_url} target="_blank" rel="noopener" class="source-link">{listing.source_url}</a></p>
              : <p class="source-row"><span class="source-portal">{portalLabel}</span><span class="source-none">No external link (own listing)</span></p>
            }
          </div>
        </div>

        <!-- Status & Type -->
        <div class="card">
          <h2 class="card-heading">Status & Type</h2>
          <div class="field-row">
            <div class="field">
              <label>Status</label>
              <select name="status">
                <option value="pending"  selected={listing.status === 'pending'}>Pending</option>
                <option value="active"   selected={listing.status === 'active'}>Active</option>
                <option value="sold"     selected={listing.status === 'sold'}>Sold</option>
              </select>
            </div>
            <div class="field">
              <label>Listing Type</label>
              <select name="listing_type" id="f-listing-type">
                <option value="for_sale"  selected={listing.listing_type === 'for_sale'}>For Sale</option>
                <option value="show_off"  selected={listing.listing_type === 'show_off'}>Show Off</option>
              </select>
            </div>
          </div>
          <div class="field" id="sold-price-field" style={listing.status === 'sold' ? '' : 'display:none'}>
            <label>Sold price (R) <span class="label-hint">actual amount it sold for — feeds valuation &amp; price-trend data</span></label>
            <input type="number" name="sold_price" value={listing.sold_price ?? ''} min="0" placeholder={`Asking was R${listing.price.toLocaleString('en-ZA')}`} />
          </div>
          <div class="field">
            <label>Featured</label>
            <select name="featured" id="f-featured">
              <option value="false" selected={!listing.featured}>No — standard listing</option>
              <option value="true"  selected={!!listing.featured}>★ Yes — show on home page &amp; top of listings</option>
            </select>
          </div>
          <div class="field">
            <label>Dealer offer</label>
            <select name="dealer_offer_optin" id="f-dealer-offer-optin">
              <option value="false" selected={!listing.dealer_offer_optin}>No</option>
              <option value="true"  selected={!!listing.dealer_offer_optin}>🏷️ Yes — seller wants a dealer offer (shop to dealer partners)</option>
            </select>
          </div>
        </div>

        <!-- Vehicle Details -->
        <div class="card">
          <h2 class="card-heading">Vehicle Details</h2>

          <div class="field">
            <label>Title</label>
            <input type="text" name="title" value={listing.title} required />
          </div>

          <div class="field-row">
            <div class="field">
              <label>Model</label>
              <select name="model">
                {MODELS.map(m => <option value={m} selected={listing.model === m}>{m.replaceAll('-', ' ').toUpperCase()}</option>)}
              </select>
            </div>
            <div class="field">
              <label>Year</label>
              <input type="number" name="year" value={listing.year} min="1950" max="2030" required />
            </div>
          </div>

          <div class="field-row">
            <div class="field">
              <label>Transmission</label>
              <select name="transmission">
                <option value="manual"    selected={listing.transmission === 'manual'}>Manual</option>
                <option value="automatic" selected={listing.transmission === 'automatic'}>Automatic</option>
              </select>
            </div>
            <div class="field">
              <label>Condition</label>
              <select name="new_or_used">
                <option value="Used" selected={listing.new_or_used === 'Used'}>Used</option>
                <option value="New"  selected={listing.new_or_used === 'New'}>New</option>
              </select>
            </div>
          </div>

          <div class="field-row">
            <div class="field">
              <label>Fuel Type</label>
              <select name="fuel_type">
                <option value=""        selected={!listing.fuel_type}>— Unknown —</option>
                <option value="Diesel"  selected={listing.fuel_type === 'Diesel'}>Diesel</option>
                <option value="Petrol"  selected={listing.fuel_type === 'Petrol'}>Petrol</option>
                <option value="Hybrid"  selected={listing.fuel_type === 'Hybrid'}>Hybrid</option>
                <option value="Electric" selected={listing.fuel_type === 'Electric'}>Electric</option>
              </select>
            </div>
            <div class="field">
              <label>Colour</label>
              <input type="text" name="colour" value={listing.colour} />
            </div>
          </div>

          <div class="field">
            <label>Province</label>
            <select name="province">
              {PROVINCES.map(p => <option value={p} selected={listing.province === p}>{p}</option>)}
            </select>
          </div>

          <div class="field-row" id="sale-fields" style={listing.listing_type === 'show_off' ? 'display:none' : ''}>
            <div class="field">
              <label>Price (R)</label>
              <input type="number" name="price" value={listing.price} min="0" />
            </div>
            <div class="field">
              <label>Mileage (km)</label>
              <input type="number" name="mileage" value={listing.mileage} min="0" />
            </div>
          </div>
        </div>

        <!-- Description & Mods -->
        <div class="card">
          <h2 class="card-heading">Description</h2>
          <div class="field">
            <label>Description</label>
            <textarea name="description" rows="6">{listing.description}</textarea>
          </div>
          <div class="field" id="mods-field" style={listing.listing_type === 'for_sale' ? 'display:none' : ''}>
            <label>Build Mods <span class="label-hint">(comma or line separated)</span></label>
            <textarea name="mods" rows="4">{listing.mods ?? ''}</textarea>
          </div>
        </div>

        <!-- Seller -->
        <div class="card">
          <h2 class="card-heading">Seller</h2>
          <div class="field">
            <label>Name</label>
            <input type="text" name="seller_name" value={listing.seller_name} />
          </div>
          <div class="field-row">
            <div class="field">
              <label>Email</label>
              <input type="email" name="seller_email" value={listing.seller_email} />
            </div>
            <div class="field">
              <label>Phone</label>
              <input type="tel" name="seller_phone" value={listing.seller_phone} />
            </div>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn-save" id="save-btn">Save Changes</button>
          <a href={`/listings/${listing.slug}/`} target="_blank" class="btn-view-live">View Live →</a>
        </div>

      </form>
    </div>

    <!-- RIGHT: Photos -->
    <div class="edit-photos-col">
      <div class="card">
        <h2 class="card-heading">Photos</h2>
        <p class="no-photos" id="no-photos-msg" style={photos.length > 0 ? 'display:none' : ''}>No photos uploaded.</p>
        <p class="photo-hint" id="photo-hint" style={photos.length > 1 ? '' : 'display:none'}>Drag to reorder. First photo is the cover.</p>
        <div class="photo-grid" id="photo-grid">
          {photos.map((src, i) => (
            <div class="photo-wrap" draggable="true" data-src={src}>
              <span class="photo-num">{i + 1}</span>
              <img src={src} alt={`Photo ${i + 1}`} loading="lazy" />
              <button class="photo-delete" type="button" title="Remove photo">✕</button>
            </div>
          ))}
        </div>
        <p id="order-status" class="order-status hidden"></p>

        <div class="upload-zone" id="upload-zone">
          <input type="file" id="upload-input" accept="image/jpeg,image/png,image/webp" multiple hidden />
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          <span class="upload-label">Drop photos here or <u>click to browse</u></span>
          <span class="upload-hint">JPEG, PNG or WebP · max 10 MB each</span>
        </div>
        <div id="upload-status"></div>
      </div>

      <!-- WhatsApp share -->
      <div class="card ig-card">
        <div class="ig-card-header">
          <span>📱 WhatsApp spec</span>
          <button id="wa-copy-btn" class="ig-copy-btn" type="button">Copy spec</button>
        </div>
        <pre id="wa-spec-text" class="ig-caption-body">{waSpec}</pre>
        {photos.length > 0 && (
          <button id="wa-download-btn" class="wa-dl-btn" type="button" data-id={listing.id} data-count={photos.length}>
            ⬇ Download {photos.length} photo{photos.length > 1 ? 's' : ''}
          </button>
        )}
      </div>

      <!-- IG Caption -->
      <div class="card ig-card">
        <div class="ig-card-header">
          <span>Instagram Caption</span>
          <button id="copy-caption-btn" class="ig-copy-btn" type="button">Copy</button>
        </div>
        <pre id="ig-caption-text" class="ig-caption-body">{igCaption}</pre>
        {igConnected && listing.status === 'active' && (
          <div class="ig-post-row" data-ig-posted-slot={listing.id}>
            {listing.ig_posted_at && (
              <p class="ig-posted-note">✓ Posted to IG {new Intl.DateTimeFormat('en-ZA', { day: 'numeric', month: 'short', year: 'numeric' }).format(listing.ig_posted_at)}</p>
            )}
            <div class="ig-post-actions">
              <button
                type="button"
                class={`btn-ig-post ${listing.ig_posted_at ? 'btn-repost' : 'btn-post'}`}
                data-action="post"
                data-id={listing.id}
              >
                {listing.ig_posted_at ? 'Repost' : 'Post to Instagram'}
              </button>
              {listing.ig_posted_at && (
                <button type="button" id="ig-clear-posted" class="ig-clear-link" data-id={listing.id}>
                  ✕ Mark as not posted
                </button>
              )}
            </div>
          </div>
        )}
      </div>

    </div>

  </div>

  <!-- PHOTO LIGHTBOX -->
  <div id="admin-lb" class="alb" aria-hidden="true">
    <button class="alb-close" id="alb-close" aria-label="Close">✕</button>
    <button class="alb-arrow alb-prev" id="alb-prev" aria-label="Previous">‹</button>
    <div class="alb-img-wrap">
      <img id="alb-img" src="" alt="" />
      <p id="alb-counter" class="alb-counter"></p>
    </div>
    <button class="alb-arrow alb-next" id="alb-next" aria-label="Next">›</button>
  </div>

  <AdminIgPost />

</AdminLayout>

<style>
  .edit-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 1.5rem; flex-wrap: wrap; gap: 0.75rem;
  }
  .back-link {
    display: inline-flex; align-items: center; gap: 0.375rem;
    font-size: 0.8125rem; font-weight: 600; color: #6B7280;
    text-decoration: none; transition: color 0.15s;
  }
  .back-link:hover { color: #111; }
  .header-badges { display: flex; gap: 0.5rem; }
  .header-actions { display: flex; gap: 0.5rem; margin-left: auto; flex-wrap: wrap; }
  .view-link {
    display: inline-flex; align-items: center; gap: 0.3rem;
    font-size: 0.72rem; font-weight: 700; color: #6B7280; text-decoration: none;
    border: 1.5px solid #E5E7EB; border-radius: 0.5rem; padding: 0.35rem 0.75rem;
    transition: all 0.15s;
  }
  .view-link:hover { color: #111111; border-color: #111111; }
  .status-badge, .type-badge {
    font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;
    padding: 0.25rem 0.625rem; border-radius: 9999px;
  }
  .status-pending { background: rgba(245,166,35,0.15); color: #92400E; }
  .status-active  { background: #111111; color: white; }
  .status-sold    { background: #EAE8E3; color: #6B7280; }
  .type-for_sale  { background: rgba(245,166,35,0.12); color: #92400E; }
  .type-show_off  { background: #EAE8E3; color: #6B7280; }

  /* BANNERS */
  .save-banner, .error-banner {
    padding: 0.75rem 1rem; border-radius: 0.5rem; font-size: 0.875rem;
    font-weight: 600; margin-bottom: 1rem; transition: opacity 0.3s;
  }
  .save-banner  { background: rgba(245,166,35,0.15); color: #92400E; border: 1px solid rgba(245,166,35,0.3); }
  .error-banner { background: #FEE2E2; color: #991B1B; border: 1px solid #FECACA; }
  .hidden { display: none; }

  /* LAYOUT */
  .edit-grid { display: grid; grid-template-columns: 1fr 280px; gap: 1.5rem; align-items: start; }
  @media (max-width: 900px) { .edit-grid { grid-template-columns: 1fr; } }

  /* CARD */
  .card {
    background: white; border: 1px solid #DDD9D3; border-radius: 0.875rem;
    padding: 1.5rem; margin-bottom: 1.25rem;
  }
  .card-heading {
    font-size: 0.65rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.14em; color: #6B7280;
    margin-bottom: 1.25rem; padding-bottom: 0.75rem; border-bottom: 1px solid #EAE8E3;
  }

  /* FIELDS */
  .field { margin-bottom: 1rem; }
  .field:last-child { margin-bottom: 0; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
  .field-row .field { margin-bottom: 0; min-width: 0; }
  label {
    display: block; font-size: 0.75rem; font-weight: 600;
    color: #6B7280; margin-bottom: 0.375rem; text-transform: uppercase; letter-spacing: 0.06em;
  }
  .label-hint { font-weight: 400; text-transform: none; letter-spacing: 0; color: #9CA3AF; }
  input, select, textarea {
    box-sizing: border-box; width: 100%; border: 1.5px solid #DDD9D3; border-radius: 0.5rem;
    font-size: 0.9375rem; color: #111; background: white;
    padding: 0.625rem 0.875rem; outline: none; font-family: inherit;
    transition: border-color 0.15s;
  }
  input:focus, select:focus, textarea:focus { border-color: #F5A623; }
  textarea { resize: vertical; }

  /* ACTIONS */
  .form-actions { display: flex; align-items: center; gap: 1rem; padding-bottom: 2rem; }
  .btn-save {
    background: #111; color: white; border: none; border-radius: 0.5rem;
    font-size: 0.875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
    padding: 0.75rem 1.75rem; cursor: pointer; transition: background 0.15s;
  }
  .btn-save:hover { background: #333; }
  .btn-save:disabled { opacity: 0.5; cursor: not-allowed; }
  .btn-view-live {
    font-size: 0.8125rem; font-weight: 600; color: #F5A623;
    text-decoration: none; transition: opacity 0.15s;
  }
  .btn-view-live:hover { opacity: 0.75; }

  /* PHOTOS */
  .photo-hint { font-size: 0.7rem; color: #9CA3AF; margin-bottom: 0.625rem; }
  .photo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .photo-wrap {
    position: relative; border-radius: 0.5rem; overflow: hidden;
    aspect-ratio: 1; background: #EAE8E3; cursor: grab;
    transition: opacity 0.15s, box-shadow 0.15s;
  }
  .photo-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; pointer-events: none; }
  .photo-wrap.dragging { opacity: 0.35; cursor: grabbing; }
  .photo-wrap.drag-over { box-shadow: inset 0 0 0 3px #F5A623; }
  .photo-num {
    position: absolute; top: 0.3rem; left: 0.3rem; z-index: 1;
    background: rgba(0,0,0,0.55); color: white;
    font-size: 0.6rem; font-weight: 700; line-height: 1;
    min-width: 1.25rem; height: 1.25rem; padding: 0 0.3rem;
    border-radius: 9999px; display: flex; align-items: center; justify-content: center;
  }
  .order-status {
    margin-top: 0.625rem; font-size: 0.75rem; font-weight: 600;
    color: #6B7280; transition: color 0.15s;
  }
  .order-status.saved { color: #16A34A; }
  .order-status.error { color: #DC2626; }

  /* Photo lightbox */
  .alb {
    position: fixed; inset: 0; z-index: 1000;
    background: rgba(0,0,0,0.92);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none; transition: opacity 0.15s;
  }
  .alb.open { opacity: 1; pointer-events: all; }
  .alb-img-wrap {
    display: flex; flex-direction: column; align-items: center; gap: 0.625rem;
    max-width: 90vw; max-height: 90vh;
  }
  .alb-img-wrap img {
    max-width: 90vw; max-height: 85vh;
    object-fit: contain; border-radius: 0.5rem; user-select: none;
  }
  .alb-counter { color: rgba(255,255,255,0.5); font-size: 0.75rem; }
  .alb-close, .alb-arrow {
    position: absolute; background: rgba(255,255,255,0.1); border: none;
    color: white; cursor: pointer; border-radius: 9999px;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.15s;
  }
  .alb-close:hover, .alb-arrow:hover { background: rgba(255,255,255,0.25); }
  .alb-close { top: 1.25rem; right: 1.25rem; width: 2.5rem; height: 2.5rem; font-size: 1rem; }
  .alb-arrow { top: 50%; transform: translateY(-50%); width: 3rem; height: 3rem; font-size: 2rem; line-height: 1; padding-bottom: 0.25rem; }
  .alb-prev { left: 1.25rem; }
  .alb-next { right: 1.25rem; }

  .btn-save-order {
    margin-top: 0.625rem; width: 100%; background: #F5A623; color: #111;
    border: none; border-radius: 0.5rem; padding: 0.6rem 1rem;
    font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
    cursor: pointer; transition: background 0.15s;
  }
  .btn-save-order:hover:not(:disabled) { background: #D4881A; }
  .btn-save-order:disabled { opacity: 0.5; cursor: not-allowed; }
  .no-photos { font-size: 0.875rem; color: #9CA3AF; }

  /* DELETE BUTTON */
  .photo-delete {
    position: absolute; top: 0.3rem; right: 0.3rem; z-index: 2;
    background: rgba(0,0,0,0.6); color: white; border: none;
    width: 1.4rem; height: 1.4rem; border-radius: 9999px;
    font-size: 0.6rem; line-height: 1; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity 0.15s;
  }
  .photo-wrap:hover .photo-delete { opacity: 1; }
  .photo-delete:hover { background: rgba(220,38,38,0.85); }

  /* UPLOAD ZONE */
  .upload-zone {
    margin-top: 0.75rem; border: 1.5px dashed #DDD9D3; border-radius: 0.625rem;
    padding: 1.25rem 1rem; display: flex; flex-direction: column;
    align-items: center; gap: 0.4rem; cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    text-align: center;
  }
  .upload-zone:hover, .upload-zone.drag-active { border-color: #F5A623; background: rgba(245,166,35,0.04); }
  .upload-label { font-size: 0.8rem; color: #374151; }
  .upload-label u { color: #F5A623; text-decoration-color: #F5A623; }
  .upload-hint { font-size: 0.7rem; color: #9CA3AF; }
  #upload-status { font-size: 0.75rem; color: #6B7280; margin-top: 0.4rem; min-height: 1.1rem; }

  /* IG CAPTION */
  .ig-card { margin-top: 1rem; }
  .ig-card-header {
    display: flex; align-items: center; gap: 0.75rem; justify-content: space-between;
    padding: 0.75rem 1rem; border-bottom: 1px solid #E5E7EB;
  }
  .ig-card-header span {
    font-size: 0.65rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.12em; color: #F5A623;
  }
  .ig-copy-btn {
    background: rgba(245,166,35,0.12); color: #F5A623;
    border: 1px solid rgba(245,166,35,0.4);
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; padding: 0.3rem 0.75rem; border-radius: 9999px;
    cursor: pointer; transition: background 0.15s;
  }
  .ig-copy-btn:hover, .ig-copy-btn.copied { background: rgba(245,166,35,0.3); }

  .wa-dl-btn {
    display: block; width: calc(100% - 2rem); margin: 0 1rem 1rem;
    background: #25D366; color: #fff; border: none;
    font-size: 0.8rem; font-weight: 700; padding: 0.6rem 1rem;
    border-radius: 0.5rem; cursor: pointer; transition: background 0.15s;
  }
  .wa-dl-btn:hover:not(:disabled) { background: #1da851; }
  .wa-dl-btn:disabled { opacity: 0.6; cursor: not-allowed; }

  .ig-post-row { padding: 0.875rem 1rem; border-top: 1px solid #F0EDE8; }
  .ig-post-actions { display: flex; align-items: center; gap: 0.875rem; margin-top: 0.4rem; }
  .btn-ig-post {
    font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em;
    padding: 0.5rem 1rem; border-radius: 0.375rem; cursor: pointer;
    border: 1.5px solid transparent; transition: all 0.15s; white-space: nowrap; line-height: 1.5;
  }
  .btn-ig-post:disabled { opacity: 0.4; cursor: not-allowed; }
  .btn-ig-post.btn-post   { background: #111111; color: white; border-color: #111111; }
  .btn-ig-post.btn-post:hover:not(:disabled) { background: #374151; border-color: #374151; }
  .btn-ig-post.btn-repost { background: white; color: #6B7280; border-color: #E5E7EB; }
  .btn-ig-post.btn-repost:hover:not(:disabled) { background: #F9FAFB; border-color: #9CA3AF; color: #374151; }
  .ig-clear-link {
    font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
    color: #9CA3AF; background: none; border: none; padding: 0; cursor: pointer;
    font-family: inherit; transition: color 0.15s;
  }
  .ig-clear-link:hover { color: #991B1B; }
  .ig-clear-link:disabled { opacity: 0.4; cursor: not-allowed; }
  .ig-caption-body {
    padding: 0.875rem 1rem; font-size: 0.78rem; line-height: 1.7;
    color: #374151; white-space: pre-wrap; word-break: break-word;
    margin: 0; font-family: inherit;
  }
  .source-row { display: flex; align-items: center; gap: 0.625rem; flex-wrap: wrap; }
  .source-portal { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; background: #F3F4F6; color: #374151; padding: 0.25rem 0.6rem; border-radius: 9999px; flex-shrink: 0; }
  .source-link { font-size: 0.8rem; color: #D4881A; text-decoration: none; word-break: break-all; }
  .source-link:hover { text-decoration: underline; }
  .source-none { font-size: 0.8rem; color: #9CA3AF; }
</style>

<script define:vars={{ listingId: listing.id }}>
  const form = document.getElementById('edit-form');
  const saveBtn = document.getElementById('save-btn');
  const saveBanner = document.getElementById('save-banner');
  const errorBanner = document.getElementById('error-banner');
  const typeSelect = document.getElementById('f-listing-type');
  const saleFields = document.getElementById('sale-fields');
  const modsField = document.getElementById('mods-field');
  const statusSelect = form.querySelector('select[name="status"]');
  const soldPriceField = document.getElementById('sold-price-field');

  // Toggle sale/show-off fields
  typeSelect.addEventListener('change', () => {
    const isShowOff = typeSelect.value === 'show_off';
    saleFields.style.display = isShowOff ? 'none' : '';
    modsField.style.display  = isShowOff ? '' : 'none';
  });

  // Reveal the sold-price field only when status is Sold
  statusSelect.addEventListener('change', () => {
    soldPriceField.style.display = statusSelect.value === 'sold' ? '' : 'none';
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving…';
    saveBanner.classList.add('hidden');
    errorBanner.classList.add('hidden');

    const data = Object.fromEntries(new FormData(form));
    // Coerce numeric fields
    if (data.year)    data.year    = Number(data.year);
    if (data.price)   data.price   = Number(data.price);
    if (data.mileage) data.mileage = Number(data.mileage);
    // Sold price: send a number if filled, else null to clear it
    data.sold_price = data.sold_price ? Number(data.sold_price) : null;
    // Coerce boolean fields
    if ('featured' in data) data.featured = data.featured === 'true';
    if ('dealer_offer_optin' in data) data.dealer_offer_optin = data.dealer_offer_optin === 'true';

    try {
      const res = await fetch(`/api/listings/${listingId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        saveBanner.classList.remove('hidden');
        setTimeout(() => saveBanner.classList.add('hidden'), 3000);
      } else {
        errorBanner.classList.remove('hidden');
      }
    } catch {
      errorBanner.classList.remove('hidden');
    }

    saveBtn.disabled = false;
    saveBtn.textContent = 'Save Changes';
  });

  // ---- Photos section ----
  const grid = document.getElementById('photo-grid');
  const orderStatus = document.getElementById('order-status');
  const noPhotosMsg = document.getElementById('no-photos-msg');
  const photoHint = document.getElementById('photo-hint');
  const uploadZone = document.getElementById('upload-zone');
  const uploadInput = document.getElementById('upload-input');
  const uploadStatus = document.getElementById('upload-status');

  function refreshPhotoMeta() {
    const wraps = grid.querySelectorAll('.photo-wrap');
    wraps.forEach((el, i) => el.querySelector('.photo-num').textContent = String(i + 1));
    noPhotosMsg.style.display = wraps.length === 0 ? '' : 'none';
    photoHint.style.display = wraps.length > 1 ? '' : 'none';
  }

  // Auto-save the photo order, debounced so rapid drags collapse into one request
  let orderSaveTimer = null;
  let orderStatusTimer = null;

  function queueOrderSave() {
    clearTimeout(orderSaveTimer);
    clearTimeout(orderStatusTimer);
    orderStatus.classList.remove('hidden', 'saved', 'error');
    orderStatus.textContent = 'Saving order…';
    orderSaveTimer = setTimeout(async () => {
      const photos = [...grid.querySelectorAll('.photo-wrap')].map(el => el.dataset.src);
      try {
        const res = await fetch(`/api/listings/${listingId}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ photos }),
        });
        if (res.ok) {
          orderStatus.textContent = '✓ Order saved';
          orderStatus.classList.add('saved');
          orderStatusTimer = setTimeout(() => orderStatus.classList.add('hidden'), 2000);
        } else {
          throw new Error();
        }
      } catch {
        orderStatus.textContent = 'Save failed — drag again to retry';
        orderStatus.classList.add('error');
      }
    }, 500);
  }

  function makePhotoWrap(src) {
    const wrap = document.createElement('div');
    wrap.className = 'photo-wrap';
    wrap.draggable = true;
    wrap.dataset.src = src;
    wrap.style.cssText = 'position:relative;border-radius:0.5rem;overflow:hidden;aspect-ratio:1;background:#EAE8E3;cursor:grab;';

    const num = document.createElement('span');
    num.className = 'photo-num';
    num.style.cssText = 'position:absolute;top:0.3rem;left:0.3rem;z-index:1;background:rgba(0,0,0,0.55);color:white;font-size:0.6rem;font-weight:700;min-width:1.25rem;height:1.25rem;padding:0 0.3rem;border-radius:9999px;display:flex;align-items:center;justify-content:center;';

    const img = document.createElement('img');
    img.src = src;
    img.alt = '';
    img.loading = 'lazy';
    img.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;pointer-events:none;';

    const btn = document.createElement('button');
    btn.className = 'photo-delete';
    btn.type = 'button';
    btn.title = 'Remove photo';
    btn.textContent = '✕';
    btn.style.cssText = 'position:absolute;top:0.3rem;right:0.3rem;z-index:2;background:rgba(0,0,0,0.6);color:white;border:none;width:1.4rem;height:1.4rem;border-radius:9999px;font-size:0.6rem;cursor:pointer;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity 0.15s;';

    wrap.appendChild(num);
    wrap.appendChild(img);
    wrap.appendChild(btn);
    return wrap;
  }

  // Drag-and-drop reordering
  let dragSrc = null;

  grid.addEventListener('dragstart', (e) => {
    dragSrc = e.target.closest('.photo-wrap');
    if (!dragSrc) return;
    setTimeout(() => dragSrc.classList.add('dragging'), 0);
    e.dataTransfer.effectAllowed = 'move';
  });

  grid.addEventListener('dragend', () => {
    grid.querySelectorAll('.photo-wrap').forEach(el => el.classList.remove('dragging', 'drag-over'));
  });

  grid.addEventListener('dragover', (e) => {
    e.preventDefault();
    const target = e.target.closest('.photo-wrap');
    grid.querySelectorAll('.photo-wrap').forEach(el => el.classList.remove('drag-over'));
    if (target && target !== dragSrc) target.classList.add('drag-over');
  });

  grid.addEventListener('drop', (e) => {
    e.preventDefault();
    const target = e.target.closest('.photo-wrap');
    if (!target || target === dragSrc) return;
    target.classList.remove('drag-over');
    const all = [...grid.querySelectorAll('.photo-wrap')];
    const si = all.indexOf(dragSrc), ti = all.indexOf(target);
    grid.insertBefore(dragSrc, si < ti ? target.nextSibling : target);
    refreshPhotoMeta();
    queueOrderSave();
  });

  // ---- Lightbox ----
  const alb = document.getElementById('admin-lb');
  const albImg = document.getElementById('alb-img');
  const albCounter = document.getElementById('alb-counter');
  let albIndex = 0;

  function albPhotos() {
    return [...grid.querySelectorAll('.photo-wrap')].map(el => el.dataset.src);
  }
  function albOpen(i) {
    const photos = albPhotos();
    if (!photos.length) return;
    albIndex = ((i % photos.length) + photos.length) % photos.length;
    albImg.src = photos[albIndex];
    albCounter.textContent = `${albIndex + 1} / ${photos.length}`;
    alb.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function albClose() {
    alb.classList.remove('open');
    document.body.style.overflow = '';
  }
  document.getElementById('alb-close').addEventListener('click', albClose);
  document.getElementById('alb-prev').addEventListener('click', () => albOpen(albIndex - 1));
  document.getElementById('alb-next').addEventListener('click', () => albOpen(albIndex + 1));
  alb.addEventListener('click', (e) => { if (e.target === alb) albClose(); });
  document.addEventListener('keydown', (e) => {
    if (!alb.classList.contains('open')) return;
    if (e.key === 'Escape') albClose();
    if (e.key === 'ArrowLeft') albOpen(albIndex - 1);
    if (e.key === 'ArrowRight') albOpen(albIndex + 1);
  });

  // Delete a photo, or open the lightbox when clicking the photo itself
  grid.addEventListener('click', async (e) => {
    const btn = e.target.closest('.photo-delete');
    if (!btn) {
      const wrap = e.target.closest('.photo-wrap');
      if (wrap) {
        const all = [...grid.querySelectorAll('.photo-wrap')];
        albOpen(all.indexOf(wrap));
      }
      return;
    }
    const wrap = btn.closest('.photo-wrap');
    wrap.remove();
    refreshPhotoMeta();
    // Immediately persist the deletion
    const photos = [...grid.querySelectorAll('.photo-wrap')].map(el => el.dataset.src);
    await fetch(`/api/listings/${listingId}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ photos }),
    });
  });

  // Upload
  async function uploadFiles(files) {
    if (!files.length) return;
    uploadStatus.textContent = `Uploading ${files.length} photo${files.length > 1 ? 's' : ''}…`;
    let done = 0;
    for (const file of files) {
      const fd = new FormData();
      fd.append('file', file);
      try {
        const res = await fetch('/api/uploads', { method: 'POST', body: fd });
        if (!res.ok) { uploadStatus.textContent = `Upload failed: ${file.name}`; continue; }
        const { url } = await res.json();
        const wrap = makePhotoWrap(url);
        grid.appendChild(wrap);
        done++;
        refreshPhotoMeta();
        uploadStatus.textContent = `Uploaded ${done} / ${files.length}…`;
      } catch {
        uploadStatus.textContent = `Upload failed: ${file.name}`;
      }
    }
    if (done > 0) {
      const photos = [...grid.querySelectorAll('.photo-wrap')].map(el => el.dataset.src);
      await fetch(`/api/listings/${listingId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ photos }),
      });
      uploadStatus.textContent = `${done} photo${done > 1 ? 's' : ''} saved.`;
    }
    setTimeout(() => uploadStatus.textContent = '', 3000);
  }

  uploadZone.addEventListener('click', () => uploadInput.click());
  uploadInput.addEventListener('change', () => { uploadFiles([...uploadInput.files]); uploadInput.value = ''; });

  uploadZone.addEventListener('dragover', (e) => { e.preventDefault(); uploadZone.classList.add('drag-active'); });
  uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('drag-active'));
  uploadZone.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadZone.classList.remove('drag-active');
    const files = [...e.dataTransfer.files].filter(f => ['image/jpeg','image/png','image/webp'].includes(f.type));
    uploadFiles(files);
  });

  // IG Caption copy
  const copyBtn = document.getElementById('copy-caption-btn');
  if (copyBtn) {
    const captionEl = document.getElementById('ig-caption-text');
    copyBtn.addEventListener('click', () => {
      const text = captionEl?.textContent ?? '';
      navigator.clipboard.writeText(text).then(() => {
        copyBtn.textContent = 'Copied!';
        copyBtn.classList.add('copied');
        setTimeout(() => {
          copyBtn.textContent = 'Copy';
          copyBtn.classList.remove('copied');
        }, 2000);
      });
    });
  }

  // Robust copy — clipboard API where available, textarea+execCommand fallback.
  async function copyToClipboard(text) {
    try {
      if (navigator.clipboard && window.isSecureContext) {
        await navigator.clipboard.writeText(text);
        return true;
      }
    } catch { /* fall through to legacy path */ }
    try {
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.top = '-9999px';
      document.body.appendChild(ta);
      ta.focus();
      ta.select();
      const ok = document.execCommand('copy');
      ta.remove();
      return ok;
    } catch { return false; }
  }

  // WhatsApp spec copy
  const waCopyBtn = document.getElementById('wa-copy-btn');
  if (waCopyBtn) {
    const specEl = document.getElementById('wa-spec-text');
    waCopyBtn.addEventListener('click', async () => {
      const ok = await copyToClipboard(specEl?.textContent ?? '');
      waCopyBtn.textContent = ok ? 'Copied!' : 'Press Ctrl+C';
      waCopyBtn.classList.toggle('copied', ok);
      setTimeout(() => { waCopyBtn.textContent = 'Copy spec'; waCopyBtn.classList.remove('copied'); }, 2000);
    });
  }

  // WhatsApp photo download — hits the same-origin proxy per photo (forces a
  // download via Content-Disposition; small delay dodges the browser's
  // multi-download throttle).
  const waDlBtn = document.getElementById('wa-download-btn');
  if (waDlBtn) {
    waDlBtn.addEventListener('click', async () => {
      const id = waDlBtn.dataset.id;
      const count = Number(waDlBtn.dataset.count || '0');
      const orig = waDlBtn.textContent;
      waDlBtn.disabled = true;
      for (let i = 0; i < count; i++) {
        waDlBtn.textContent = `Downloading ${i + 1}/${count}…`;
        const a = document.createElement('a');
        a.href = `/api/admin/listing-photos/${id}?i=${i}`;
        a.download = '';
        document.body.appendChild(a);
        a.click();
        a.remove();
        await new Promise(r => setTimeout(r, 500));
      }
      waDlBtn.textContent = 'Done ✓';
      setTimeout(() => { waDlBtn.textContent = orig; waDlBtn.disabled = false; }, 2500);
    });
  }

  // ── Undo a mistaken IG post marker ─────────────────────────────────────────
  document.getElementById('ig-clear-posted')?.addEventListener('click', async function () {
    if (!confirm('Mark this listing as NOT posted to Instagram? (Use after deleting the post on IG.)')) return;
    const btn = this;
    btn.disabled = true;
    try {
      const res = await fetch('/api/admin/instagram/clear-posted', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ listingId: Number(btn.dataset.id) }),
      });
      if (res.ok) { window.location.reload(); return; }
      alert('Failed to clear posted status — try again.');
    } catch {
      alert('Network error — try again.');
    }
    btn.disabled = false;
  });
</script>
