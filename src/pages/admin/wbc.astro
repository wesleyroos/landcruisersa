---
export const prerender = false;

import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/db/index';
import { sql } from 'drizzle-orm';

const cookie = Astro.cookies.get('lcsa_admin');
const adminSecret = import.meta.env.ADMIN_SECRET ?? process.env.ADMIN_SECRET ?? '';
if (!cookie || cookie.value !== adminSecret) {
  return Astro.redirect('/admin/login');
}

// ─── WBC value ledger ────────────────────────────────────────────────────────
// Scannable top-to-bottom: three hero numbers (buyers handed over, views on
// stock, vehicles live), one trend strip, one sortable branch table. A ?t=
// timeframe drives everything except "vehicles live" (a now-snapshot) and the
// deltas compare to the equal-length period before. Handoff = click-through
// to the WBC listing or WhatsApp/call/email/reveal on WBC stock (finance_calc
// excluded) — same definition as /admin/dealers. Tracking is bot-filtered and
// admin-excluded, so every number is quotable to WBC (the sponsor receipt
// behind deal-ledger D1).

const T_OPTS = [
  { key: '7d',  label: '7 days',    days: 7 },
  { key: '30d', label: '30 days',   days: 30 },
  { key: '60d', label: '60 days',   days: 60 },
  { key: '90d', label: '90 days',   days: 90 },
  { key: '6m',  label: '6 months',  days: 182 },
  { key: '12m', label: '12 months', days: 365 },
  { key: 'all', label: 'All time',  days: null as number | null },
];
const tKey = Astro.url.searchParams.get('t') ?? '30d';
const t = T_OPTS.find(o => o.key === tKey) ?? T_OPTS[1];
const nowSec = Math.floor(Date.now() / 1000);
const startSec = t.days ? nowSec - t.days * 86_400 : 0;
const priorStartSec = t.days ? nowSec - 2 * t.days * 86_400 : 0;

// ── Stock on site now, per branch (snapshot — not affected by timeframe) ──
const stockRows = db.all<{ seller: string; n: number }>(sql`
  SELECT seller_name seller, count(*) n
  FROM listings WHERE source = 'wbc' AND status = 'active'
  GROUP BY lower(seller_name)
`);

// ── Events back to the start of the PRIOR period (delta needs both halves) ──
const viewRows = db.all<{ ts: number; seller: string }>(sql`
  SELECT v.created_at ts, l.seller_name seller
  FROM view_events v JOIN listings l ON l.slug = v.listing_slug
  WHERE l.source = 'wbc' AND v.created_at >= ${priorStartSec}
`);
const handoffRows = db.all<{ ts: number; seller: string; id: number; title: string; price: number }>(sql`
  SELECT c.created_at ts, l.seller_name seller, l.id id, l.title title, l.price price
  FROM click_events c JOIN listings l ON l.slug = c.listing_slug
  WHERE l.source = 'wbc' AND c.source != 'finance_calc' AND c.created_at >= ${priorStartSec}
`);

// ── Period totals + deltas ──
let views = 0, viewsPrior = 0, handoffs = 0, handoffsPrior = 0;
for (const r of viewRows) r.ts >= startSec ? views++ : viewsPrior++;
for (const r of handoffRows) r.ts >= startSec ? handoffs++ : handoffsPrior++;
const stockNow = stockRows.reduce((s, r) => s + r.n, 0);

// ── Busiest listing this period ──
const byListing = new Map<number, { title: string; price: number; n: number }>();
for (const r of handoffRows) {
  if (r.ts < startSec) continue;
  const e = byListing.get(r.id) ?? { title: r.title, price: r.price, n: 0 };
  e.n++; byListing.set(r.id, e);
}
const busiest = [...byListing.entries()].sort((a, b) => b[1].n - a[1].n)[0] ?? null;

// ── Trend strip: bucket size follows the timeframe ──
const DAY = 86_400_000;
const midnight = new Date(); midnight.setHours(0, 0, 0, 0);
let bucketStarts: number[] = [];   // ms
let bucketMode: 'day' | 'week' | 'month';
if (t.days && t.days <= 30) {
  bucketMode = 'day';
  for (let i = t.days - 1; i >= 0; i--) bucketStarts.push(midnight.getTime() - i * DAY);
} else if (t.days && t.days <= 182) {
  bucketMode = 'week';
  const monday = new Date(midnight); monday.setDate(monday.getDate() - ((monday.getDay() + 6) % 7));
  const weeks = Math.ceil(t.days / 7);
  for (let i = weeks - 1; i >= 0; i--) bucketStarts.push(monday.getTime() - i * 7 * DAY);
} else {
  bucketMode = 'month';
  const firstTs = t.days
    ? Date.now() - t.days * DAY
    : Math.min(...handoffRows.map(r => r.ts * 1000), ...viewRows.map(r => r.ts * 1000), Date.now() - 182 * DAY);
  const cur = new Date(firstTs); cur.setDate(1); cur.setHours(0, 0, 0, 0);
  const end = new Date(); end.setDate(1); end.setHours(0, 0, 0, 0);
  while (cur <= end) { bucketStarts.push(cur.getTime()); cur.setMonth(cur.getMonth() + 1); }
}
const bucketIdx = (tsSec: number) => {
  const ms = tsSec * 1000;
  for (let i = bucketStarts.length - 1; i >= 0; i--) if (ms >= bucketStarts[i]) return i;
  return -1;
};
const strip = new Array(bucketStarts.length).fill(0);
for (const r of handoffRows) {
  if (r.ts < startSec) continue;
  const i = bucketIdx(r.ts);
  if (i >= 0) strip[i]++;
}
const maxStrip = Math.max(1, ...strip);
const fmtDay = new Intl.DateTimeFormat('en-ZA', { day: 'numeric', month: 'short' });
const fmtMonth = new Intl.DateTimeFormat('en-ZA', { month: 'short', year: '2-digit' });
const bucketLabel = (ms: number) =>
  bucketMode === 'day' ? fmtDay.format(ms) : bucketMode === 'week' ? `w/o ${fmtDay.format(ms)}` : fmtMonth.format(ms);

// ── Branch table: stock now + views/handoffs in the period ──
type BranchRow = { name: string; stock: number; views: number; handoffs: number };
const branches = new Map<string, BranchRow>();
const branch = (seller: string): BranchRow => {
  const k = seller.toLowerCase();
  let b = branches.get(k);
  if (!b) { b = { name: seller, stock: 0, views: 0, handoffs: 0 }; branches.set(k, b); }
  return b;
};
for (const r of stockRows) branch(r.seller).stock = r.n;
for (const r of viewRows) if (r.ts >= startSec) branch(r.seller).views++;
for (const r of handoffRows) if (r.ts >= startSec) branch(r.seller).handoffs++;
const branchRows = [...branches.values()]
  .sort((a, b) => b.handoffs - a.handoffs || b.views - a.views || b.stock - a.stock);
// Share of period handoffs — the quotable "X% of everything we send goes to
// this branch". Deliberately NOT a weighted quality score: at ~3-16 handoffs
// per branch, invented weights would rank noise with false authority.
const share = (b: BranchRow) => handoffs ? Math.round(b.handoffs / handoffs * 100) : 0;

const fmtR = (n: number | null) =>
  n == null || n === 0 ? '' : n >= 1_000_000 ? `R${(n / 1_000_000).toFixed(2).replace(/\.?0+$/, '')}m` : `R${Math.round(n / 1000)}k`;
const deltaChip = (cur: number, prior: number) => {
  if (!t.days) return null; // all time — nothing to compare against
  const d = cur - prior;
  return d > 0 ? { cls: 'up', txt: `▲ +${d.toLocaleString()}` } : d < 0 ? { cls: 'down', txt: `▼ ${d.toLocaleString()}` } : { cls: 'flat', txt: '＝' };
};
const vDelta = deltaChip(views, viewsPrior);
const hDelta = deltaChip(handoffs, handoffsPrior);
---

<AdminLayout title="WeBuyCars" activePage="wbc">
  <div class="ledger">
    <div class="head-row">
      <p class="eyebrow">Sent to WeBuyCars, free — {t.days ? `last ${t.label}` : 'all time'}</p>
      <nav class="tf">
        {T_OPTS.map(o => (
          <a href={`/admin/wbc?t=${o.key}`} class={`tf-pill ${o.key === t.key ? 'active' : ''}`}>{o.label}</a>
        ))}
      </nav>
    </div>

    <div class="heroes">
      <div class="hero">
        <span class="hero-n">{handoffs.toLocaleString()}</span>
        <span class="hero-l">buyers handed over</span>
        {hDelta && <span class={`hero-delta ${hDelta.cls}`}>{hDelta.txt} vs prior {t.label}</span>}
      </div>
      <div class="hero">
        <span class="hero-n">{views.toLocaleString()}</span>
        <span class="hero-l">views on their stock</span>
        {vDelta && <span class={`hero-delta ${vDelta.cls}`}>{vDelta.txt} vs prior {t.label}</span>}
      </div>
      <div class="hero">
        <span class="hero-n">{stockNow.toLocaleString()}</span>
        <span class="hero-l">WBC vehicles live on LCSA</span>
        <span class="hero-delta flat">right now · {branches.size ? branchRows.filter(b => b.stock > 0).length : 0} branches</span>
      </div>
    </div>

    {busiest && (
      <p class="context">
        Busiest: <a href={`/admin/listings/${busiest[0]}`}>{busiest[1].title}</a>{fmtR(busiest[1].price) && ` (${fmtR(busiest[1].price)})`} — {busiest[1].n} handoffs.
      </p>
    )}

    <div class="strip">
      <span class="strip-label">Handoffs<br />per {bucketMode}</span>
      <div class="strip-bars">
        {strip.map((n, i) => (
          <span class="wbar" data-tip={`${n} · ${bucketLabel(bucketStarts[i])}`}>
            <span class="wbar-fill" style={`height:${Math.max(3, Math.round(n / maxStrip * 100))}%`}></span>
          </span>
        ))}
      </div>
      <span class="strip-now">{strip[strip.length - 1] ?? 0} this {bucketMode}</span>
    </div>

    <table class="branches">
      <thead>
        <tr>
          <th><button data-key="name" data-dir="asc">Branch</button></th>
          <th class="num"><button data-key="stock">Stock now</button></th>
          <th class="num"><button data-key="views">Views</button></th>
          <th class="num sorted"><button data-key="handoffs">Handoffs</button></th>
          <th class="share-col"><button data-key="share">Share of buyers</button></th>
        </tr>
      </thead>
      <tbody id="branch-rows">
        {branchRows.length === 0 && <tr><td colspan="5" class="empty">No WBC branch activity in this window.</td></tr>}
        {branchRows.map(b => (
          <tr data-name={b.name.toLowerCase()} data-stock={b.stock} data-views={b.views} data-handoffs={b.handoffs} data-share={share(b)}>
            <td class="b-name">{b.name}</td>
            <td class="num">{b.stock || '—'}</td>
            <td class="num">{b.views || '—'}</td>
            <td class="num b-strong">{b.handoffs || '—'}</td>
            <td class="share-col">
              {b.handoffs > 0 && (
                <span class="share-wrap">
                  <span class="share-bar"><span class="share-fill" style={`width:${share(b)}%`}></span></span>
                  <span class="share-n">{share(b)}%</span>
                </span>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>

    <p class="foot-note">
      A handoff = a click-through to the car on webuycars.co.za, or a WhatsApp/call/email/reveal on WBC stock.
      Views and handoffs follow the selected timeframe; stock is what's live right now.
      Bots and admin sessions excluded — every number here is quotable to WBC.
    </p>
  </div>
</AdminLayout>

<script>
  const tbody = document.getElementById('branch-rows')!;
  const rows = [...tbody.querySelectorAll<HTMLElement>('tr[data-name]')];
  const buttons = document.querySelectorAll<HTMLButtonElement>('.branches th button');
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.key!;
      const wasSorted = btn.parentElement!.classList.contains('sorted');
      // First click sorts a column its natural way (text asc, numbers desc);
      // clicking the sorted column again flips it.
      let dir = btn.dataset.dir === 'asc' ? 1 : -1;
      if (wasSorted) dir = btn.parentElement!.classList.contains('flipped') ? dir : -dir;
      buttons.forEach(b => b.parentElement!.classList.remove('sorted', 'flipped'));
      btn.parentElement!.classList.add('sorted');
      if ((btn.dataset.dir === 'asc' ? 1 : -1) !== dir) btn.parentElement!.classList.add('flipped');
      const sorted = [...rows].sort((a, b) => {
        const av = a.dataset[key]!, bv = b.dataset[key]!;
        const cmp = key === 'name' ? av.localeCompare(bv) : Number(av) - Number(bv);
        return cmp * dir;
      });
      sorted.forEach(r => tbody.appendChild(r));
    });
  });
</script>

<style>
  .ledger { max-width: 780px; }

  .head-row { display: flex; align-items: baseline; justify-content: space-between; gap: 14px; flex-wrap: wrap; margin-bottom: 18px; }
  .eyebrow {
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.12em; color: #9a6b00;
  }
  .tf { display: flex; gap: 4px; flex-wrap: wrap; }
  .tf-pill {
    font-size: 11.5px; font-weight: 600; color: #666; text-decoration: none;
    padding: 4px 9px; border: 1px solid #e2e2e2; border-radius: 999px;
  }
  .tf-pill:hover { border-color: #bbb; color: #111; }
  .tf-pill.active { background: #111; border-color: #111; color: white; }

  .heroes { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 22px; margin-bottom: 16px; }
  .hero { display: flex; flex-direction: column; gap: 3px; }
  .hero-n { font-size: 52px; font-weight: 800; line-height: 0.95; letter-spacing: -0.02em; color: #111; }
  .hero-l { font-size: 13px; font-weight: 600; color: #444; margin-top: 4px; }
  .hero-delta { font-size: 12px; font-weight: 700; }
  .hero-delta.up { color: #15803D; }
  .hero-delta.down { color: #B91C1C; }
  .hero-delta.flat { color: #999; }

  .context { font-size: 13.5px; color: #555; line-height: 1.6; margin-bottom: 16px; }
  .context a { color: #111; font-weight: 700; }

  .strip { display: flex; align-items: center; gap: 12px; margin-bottom: 22px; }
  .strip-label { font-size: 11px; color: #888; white-space: nowrap; line-height: 1.35; }
  .strip-bars { flex: 1; display: flex; align-items: flex-end; gap: 3px; height: 44px; }
  .wbar { flex: 1; display: flex; align-items: flex-end; height: 100%; position: relative; }
  .wbar-fill { width: 100%; background: #F5A623; border-radius: 2px 2px 0 0; min-height: 3px; }
  .wbar:hover .wbar-fill { background: #D4881A; }
  .wbar::after {
    content: attr(data-tip);
    position: absolute; bottom: calc(100% + 6px); left: 50%; transform: translateX(-50%);
    background: #111; color: #fff; font-size: 11px; font-weight: 600;
    padding: 3px 8px; border-radius: 5px; white-space: nowrap;
    opacity: 0; pointer-events: none; transition: opacity 0.1s; z-index: 5;
  }
  .wbar:hover::after { opacity: 1; }
  .strip-now { font-size: 12px; font-weight: 700; color: #111; white-space: nowrap; }

  .branches { width: 100%; border-collapse: collapse; border: 1px solid #e5e5e5; border-radius: 8px; overflow: hidden; }
  .branches th { background: #fafafa; border-bottom: 1px solid #e5e5e5; padding: 0; text-align: left; }
  .branches th.num { text-align: right; }
  .branches th button {
    width: 100%; background: none; border: none; cursor: pointer; text-align: inherit;
    font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em;
    color: #999; padding: 8px 12px;
  }
  .branches th button:hover { color: #111; }
  .branches th.sorted button { color: #111; }
  .branches th.sorted button::after { content: ' ↓'; }
  .branches th.sorted.flipped button::after { content: ' ↑'; }
  .branches td { padding: 7px 12px; border-bottom: 1px solid #f4f4f4; font-size: 12.5px; }
  .branches tr:last-child td { border-bottom: none; }
  .branches tbody tr:hover { background: #fffdf7; }
  .b-name { font-weight: 600; color: #222; }
  .share-col { width: 150px; }
  th.share-col button { text-align: left; }
  .share-wrap { display: flex; align-items: center; gap: 8px; }
  .share-bar { flex: 1; height: 10px; background: #f3f3f3; border-radius: 3px; overflow: hidden; }
  .share-fill { display: block; height: 100%; background: #F5A623; border-radius: 3px; min-width: 2px; }
  .share-n { font-size: 11.5px; font-weight: 700; color: #333; font-variant-numeric: tabular-nums; width: 34px; text-align: right; }
  .num { text-align: right; font-variant-numeric: tabular-nums; color: #555; }
  .b-strong { font-weight: 700; color: #111; }
  .empty { color: #888; text-align: center; padding: 16px; }

  .foot-note { color: #aaa; font-size: 11.5px; margin-top: 12px; line-height: 1.55; }
</style>
