---
export const prerender = false;

import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/db/index';
import { sql } from 'drizzle-orm';

const cookie = Astro.cookies.get('lcsa_admin');
const adminSecret = import.meta.env.ADMIN_SECRET ?? process.env.ADMIN_SECRET ?? '';
if (!cookie || cookie.value !== adminSecret) {
  return Astro.redirect('/admin/login');
}

// ─── WBC value ledger ────────────────────────────────────────────────────────
// Readable in three seconds: ONE number (buyers handed to WBC, 30d) with a
// direction arrow, one sentence of context, one thin trend strip, and the
// all-time receipt. Views are context, not the headline — a handoff is value
// delivered, a view is attention. Handoff = click-through to the WBC listing
// or WhatsApp/call/email/reveal on WBC stock (finance_calc excluded) — same
// definition as /admin/dealers, so the two pages never disagree. Tracking is
// bot-filtered and admin-excluded, so every number is quotable to WBC (this
// is the sponsor receipt behind deal-ledger D1).

const WEEKS = 12;
const DAY = 86_400_000;
const monday = new Date(); monday.setHours(0, 0, 0, 0);
monday.setDate(monday.getDate() - ((monday.getDay() + 6) % 7));
const weekStarts: number[] = [];
for (let i = WEEKS - 1; i >= 0; i--) weekStarts.push(monday.getTime() - i * 7 * DAY);
const windowStartSec = Math.floor(weekStarts[0] / 1000);
const d30Sec = Math.floor((Date.now() - 30 * DAY) / 1000);
const d60Sec = Math.floor((Date.now() - 60 * DAY) / 1000);
const weekIdx = (tsSec: number) => Math.floor((tsSec * 1000 - weekStarts[0]) / (7 * DAY));

const stock = db.get<{ n: number; branches: number }>(sql`
  SELECT count(*) n, count(DISTINCT lower(seller_name)) branches
  FROM listings WHERE source = 'wbc' AND status = 'active'
`);

const views = db.get<{ d30: number; total: number }>(sql`
  SELECT
    sum(CASE WHEN v.created_at >= ${d30Sec} THEN 1 ELSE 0 END) d30,
    count(*) total
  FROM view_events v JOIN listings l ON l.slug = v.listing_slug
  WHERE l.source = 'wbc'
`);

// Handoff events, 12 weeks back (strip + 30d/prior-30d split) + all-time count.
const handoffRows = db.all<{ ts: number }>(sql`
  SELECT c.created_at ts
  FROM click_events c JOIN listings l ON l.slug = c.listing_slug
  WHERE l.source = 'wbc' AND c.source != 'finance_calc' AND c.created_at >= ${Math.min(windowStartSec, d60Sec)}
`);
const handoffsAllTime = db.get<{ n: number }>(sql`
  SELECT count(*) n
  FROM click_events c JOIN listings l ON l.slug = c.listing_slug
  WHERE l.source = 'wbc' AND c.source != 'finance_calc'
`);

const weekly = new Array(WEEKS).fill(0);
let h30 = 0, hPrior30 = 0;
for (const r of handoffRows) {
  const i = weekIdx(r.ts);
  if (i >= 0 && i < WEEKS) weekly[i]++;
  if (r.ts >= d30Sec) h30++;
  else if (r.ts >= d60Sec) hPrior30++;
}
const maxWeekly = Math.max(1, ...weekly);
const delta = h30 - hPrior30;

// The one listing doing the most work right now (by handoffs, then views).
const busiest = db.get<{ id: number; title: string; price: number; n: number }>(sql`
  SELECT l.id id, l.title title, l.price price, count(*) n
  FROM click_events c JOIN listings l ON l.slug = c.listing_slug
  WHERE l.source = 'wbc' AND c.source != 'finance_calc' AND c.created_at >= ${d30Sec}
  GROUP BY l.slug ORDER BY n DESC LIMIT 1
`);

const fmtR = (n: number | null) =>
  n == null || n === 0 ? '' : n >= 1_000_000 ? `R${(n / 1_000_000).toFixed(2).replace(/\.?0+$/, '')}m` : `R${Math.round(n / 1000)}k`;
const weekLabel = (ms: number) => new Intl.DateTimeFormat('en-ZA', { day: 'numeric', month: 'short' }).format(new Date(ms));
---

<AdminLayout title="WeBuyCars" activePage="wbc">
  <div class="ledger">
    <p class="eyebrow">Sent to WeBuyCars, free — last 30 days</p>

    <div class="hero">
      <span class="hero-n">{h30}</span>
      <div class="hero-side">
        <span class="hero-l">buyers handed over</span>
        <span class={`hero-delta ${delta > 0 ? 'up' : delta < 0 ? 'down' : 'flat'}`}>
          {delta > 0 ? `▲ +${delta}` : delta < 0 ? `▼ ${delta}` : '＝'} vs prior 30 days
        </span>
      </div>
    </div>

    <p class="context">
      Plus <strong>{(views?.d30 ?? 0).toLocaleString()}</strong> views on their stock —
      <strong>{(stock?.n ?? 0).toLocaleString()}</strong> WBC vehicles live on LCSA
      across <strong>{stock?.branches ?? 0}</strong> branches.
      {busiest && (
        <>Busiest: <a href={`/admin/listings/${busiest.id}`}>{busiest.title}</a>{fmtR(busiest.price) && ` (${fmtR(busiest.price)})`} — {busiest.n} handoffs.</>
      )}
    </p>

    <div class="strip">
      <div class="strip-bars">
        {weekly.map((n, i) => (
          <span class="wbar" data-tip={`${n} · w/o ${weekLabel(weekStarts[i])}`}>
            <span class="wbar-fill" style={`height:${Math.max(3, Math.round(n / maxWeekly * 100))}%`}></span>
          </span>
        ))}
      </div>
      <span class="strip-now">{weekly[WEEKS - 1]} this week</span>
    </div>

    <p class="receipt">
      All-time receipt: <strong>{(handoffsAllTime?.n ?? 0).toLocaleString()}</strong> buyers ·
      <strong>{(views?.total ?? 0).toLocaleString()}</strong> views — delivered free. This is the sponsorship anchor.
    </p>

    <p class="foot-note">
      A handoff = a click-through to the car on webuycars.co.za, or a WhatsApp/call/email/reveal on WBC stock.
      Bots and admin sessions excluded — every number here is quotable to WBC.
    </p>
  </div>
</AdminLayout>

<style>
  .ledger { max-width: 640px; }

  .eyebrow {
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.12em; color: #9a6b00; margin-bottom: 14px;
  }

  .hero { display: flex; align-items: center; gap: 18px; margin-bottom: 18px; }
  .hero-n { font-size: 88px; font-weight: 800; line-height: 0.9; letter-spacing: -0.03em; color: #111; }
  .hero-side { display: flex; flex-direction: column; gap: 4px; }
  .hero-l { font-size: 15px; font-weight: 600; color: #444; }
  .hero-delta { font-size: 13px; font-weight: 700; }
  .hero-delta.up { color: #15803D; }
  .hero-delta.down { color: #B91C1C; }
  .hero-delta.flat { color: #999; }

  .context { font-size: 14px; color: #555; line-height: 1.65; margin-bottom: 18px; }
  .context strong { color: #111; font-weight: 700; }
  .context a { color: #111; font-weight: 700; }

  .strip { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; }
  .strip-bars { flex: 1; display: flex; align-items: flex-end; gap: 4px; height: 44px; }
  .wbar { flex: 1; display: flex; align-items: flex-end; height: 100%; position: relative; }
  .wbar-fill { width: 100%; background: #F5A623; border-radius: 2px 2px 0 0; min-height: 3px; }
  .wbar:hover .wbar-fill { background: #D4881A; }
  .wbar::after {
    content: attr(data-tip);
    position: absolute; bottom: calc(100% + 6px); left: 50%; transform: translateX(-50%);
    background: #111; color: #fff; font-size: 11px; font-weight: 600;
    padding: 3px 8px; border-radius: 5px; white-space: nowrap;
    opacity: 0; pointer-events: none; transition: opacity 0.1s; z-index: 5;
  }
  .wbar:hover::after { opacity: 1; }
  .strip-now { font-size: 12px; font-weight: 700; color: #111; white-space: nowrap; }

  .receipt {
    font-size: 13px; color: #555; line-height: 1.6;
    border-top: 1px solid #eee; padding-top: 14px;
  }
  .receipt strong { color: #111; }

  .foot-note { color: #aaa; font-size: 11.5px; margin-top: 10px; line-height: 1.55; }
</style>
