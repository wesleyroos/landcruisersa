---
export const prerender = false;

import AdminLayout from '@/layouts/AdminLayout.astro';
import AdminIgPost from '@/components/AdminIgPost.astro';
import { getCredentials } from '@/lib/instagram';
import { getIgSuggestions } from '@/lib/post-suggestions';
import { modelFamily, modelLabel } from '@/lib/sources/normalize';
import { db } from '@/db/index';
import { listings, clickEvents, priceEvents } from '@/db/schema';
import { desc, eq, and, or, gte, lte, sql, like, isNotNull, inArray } from 'drizzle-orm';
import type { Listing } from '@/db/schema';
import type { SQL } from 'drizzle-orm';
import { firstPhotoOrNull } from '@/lib/photos';

const PAGE_SIZE = 50;
const page = Math.max(1, Number(Astro.url.searchParams.get('page') ?? '1'));

// Filter params
const fSource   = Astro.url.searchParams.get('source')   ?? '';
const fModel    = Astro.url.searchParams.get('model')    ?? '';  // comma-separated
const fModels   = fModel ? fModel.split(',').filter(Boolean) : [];
const fYear     = Astro.url.searchParams.get('year')     ?? '';
const fPrice    = Astro.url.searchParams.get('price')    ?? '';
const fMileage  = Astro.url.searchParams.get('mileage')  ?? '';
const fProvince = Astro.url.searchParams.get('province') ?? '';
const fType     = Astro.url.searchParams.get('type')     ?? '';
const fPosted   = Astro.url.searchParams.get('posted')   === '1';
const fDrops    = Astro.url.searchParams.get('drops')    === '1';
const fDealer   = Astro.url.searchParams.get('dealer')   === '1';
const fQ        = (Astro.url.searchParams.get('q') ?? '').trim();
const hasFilter = !!(fSource || fModel || fYear || fPrice || fMileage || fProvince || fType || fPosted || fDrops || fDealer || fQ);

function buildFilterUrl(overrides: Record<string, string>) {
  const params = new URLSearchParams();
  const base = { source: fSource, model: fModel, year: fYear, price: fPrice, mileage: fMileage, province: fProvince, type: fType, posted: fPosted ? '1' : '', drops: fDrops ? '1' : '', dealer: fDealer ? '1' : '', q: fQ, ...overrides };
  for (const [k, v] of Object.entries(base)) if (v) params.set(k, v);
  const s = params.toString();
  return `/admin${s ? '?' + s : ''}`;
}

// Fast status counts (unfiltered — for stats row)
const statusCounts = db.select({ status: listings.status, n: sql<number>`count(*)` })
  .from(listings).groupBy(listings.status).all();
const countMap: Record<string, number> = {};
for (const r of statusCounts) countMap[r.status] = r.n;
const pendingCount = countMap['pending'] ?? 0;
const activeCount  = countMap['active']  ?? 0;
const soldCount    = countMap['sold']    ?? 0;
const totalCount   = pendingCount + activeCount + soldCount;

// ─── Price changes (last 30 days) — net movement per listing ─────────────────
// Earliest recorded old_price in the window vs the listing's current price, so
// consecutive cuts show as one honest total.
const dropWindow = new Date(Date.now() - 30 * 24 * 3600 * 1000);
const recentEvents = db.select({
  slug:      priceEvents.slug,
  old_price: priceEvents.old_price,
}).from(priceEvents)
  .where(gte(priceEvents.recorded_at, dropWindow))
  .orderBy(priceEvents.recorded_at)
  .all();

const earliestOld = new Map<string, number>();
for (const e of recentEvents) if (!earliestOld.has(e.slug)) earliestOld.set(e.slug, e.old_price);

const priceChange = new Map<string, number>(); // slug → net change (negative = drop)
if (earliestOld.size > 0) {
  const rows = db.select({ slug: listings.slug, price: listings.price })
    .from(listings)
    .where(inArray(listings.slug, [...earliestOld.keys()]))
    .all();
  for (const r of rows) {
    const old = earliestOld.get(r.slug)!;
    if (r.price > 0 && old > 0 && r.price !== old) priceChange.set(r.slug, r.price - old);
  }
}
const droppedSlugs = [...priceChange.entries()].filter(([, d]) => d < 0).map(([s]) => s);

const droppedActiveCount = droppedSlugs.length
  ? (db.select({ n: sql<number>`count(*)` }).from(listings)
      .where(and(eq(listings.status, 'active'), inArray(listings.slug, droppedSlugs))).get())?.n ?? 0
  : 0;

// Build active WHERE clause with filters
const activeConds: SQL[] = [eq(listings.status, 'active')];
if (fSource)   activeConds.push(eq(listings.source,       fSource));
if (fModels.length) activeConds.push(inArray(listings.model, fModels));
if (fProvince) activeConds.push(eq(listings.province,     fProvince));
if (fType)     activeConds.push(eq(listings.listing_type, fType));
if (fYear) {
  const [yMin, yMax] = fYear.split('-').map(Number);
  activeConds.push(gte(listings.year, yMin));
  if (yMax < 9999) activeConds.push(lte(listings.year, yMax));
}
if (fPrice) {
  const [pMin, pMax] = fPrice.split('-').map(Number);
  activeConds.push(gte(listings.price, pMin));
  if (pMax < 9999999) activeConds.push(lte(listings.price, pMax));
}
if (fMileage) {
  const [mMin, mMax] = fMileage.split('-').map(Number);
  activeConds.push(gte(listings.mileage, mMin));
  if (mMax < 9999999) activeConds.push(lte(listings.mileage, mMax));
}
if (fPosted) activeConds.push(isNotNull(listings.ig_posted_at));
if (fDrops) activeConds.push(droppedSlugs.length ? inArray(listings.slug, droppedSlugs) : sql`0 = 1`);
if (fDealer) activeConds.push(eq(listings.dealer_offer_optin, true));
if (fQ) {
  const pat = `%${fQ}%`;
  activeConds.push(or(
    like(listings.title, pat),
    like(listings.slug, pat),
    like(listings.seller_name, pat),
  )!);
}
const activeWhere = and(...activeConds);

// Filtered count for pagination
const filteredActiveCount = (db.select({ n: sql<number>`count(*)` }).from(listings).where(activeWhere).get())?.n ?? 0;

// Pending: always load all
const pending = db.select().from(listings)
  .where(eq(listings.status, 'pending'))
  .orderBy(desc(listings.created_at)).all();

// Active: paginated + filtered
const totalPages = Math.max(1, Math.ceil(filteredActiveCount / PAGE_SIZE));
const safePage   = Math.min(page, totalPages);
const active = db.select().from(listings)
  .where(activeWhere)
  .orderBy(desc(listings.created_at))
  .limit(PAGE_SIZE).offset((safePage - 1) * PAGE_SIZE).all();

// Sold: most recent first, so they don't vanish after being marked sold and we
// can eyeball asking-vs-sold. Capped — the full history lives in insights.
const sold = db.select().from(listings)
  .where(eq(listings.status, 'sold'))
  .orderBy(desc(listings.off_market_at), desc(listings.created_at))
  .limit(PAGE_SIZE).all();

// ─── Instagram publishing ─────────────────────────────────────────────────────
const creds = await getCredentials();
const igConnected = !!creds;

// IG suggestions — same Hero Engine scoring the morning email uses. Show the
// slot plan + whole ranked shortlist so it can be skimmed and posted from here.
const igSet = igConnected ? getIgSuggestions(12) : { plan: { slot: 'hero' as const, reason: '' }, suggestions: [] };
const igPlan = igSet.plan;
const igSuggestions = igSet.suggestions;
const SLOT_LABEL: Record<string, string> = { hero: '🔥 Hero build', deal: '💰 Deal', drop: '▼ Price drop', cta: '📢 Seller CTA' };
const igPick = igSuggestions[0];
const igMore = igSuggestions.slice(1);
const igMoreNonPrado = igMore.filter(s => modelFamily(s.model) !== 'prado').length;

// Posted count for the filter toggle
const postedCount = (db.select({ n: sql<number>`count(*)` }).from(listings)
  .where(and(eq(listings.status, 'active'), isNotNull(listings.ig_posted_at))).get())?.n ?? 0;

// Dealer-offer opt-in count for the filter toggle
const dealerOptinCount = (db.select({ n: sql<number>`count(*)` }).from(listings)
  .where(and(eq(listings.status, 'active'), eq(listings.dealer_offer_optin, true))).get())?.n ?? 0;

// Private-seller (own submissions, not scraped) count for the filter toggle
const privateCount = (db.select({ n: sql<number>`count(*)` }).from(listings)
  .where(and(eq(listings.status, 'active'), eq(listings.source, 'own'))).get())?.n ?? 0;

// IG media stats — only fetched in the Posted view so normal page loads stay fast.
// Step 1: fetch media list, match to listings by timestamp (±2 min window)
// Step 2: for each match, fetch insights (views, saves, shares)
type IgStats = { likes: number; comments: number; views: number; saves: number; shares: number };
const igMediaStats = new Map<number, IgStats>(); // keyed by listing.id

if (fPosted && creds) {
  try {
    const res = await fetch(
      `https://graph.instagram.com/v21.0/${creds.userId}/media` +
      `?fields=id,timestamp,like_count,comments_count&limit=100` +
      `&access_token=${creds.accessToken}`
    );
    const json = await res.json();
    if (Array.isArray(json.data)) {
      // Match media items to our listings
      const matched: Array<{ listingId: number; mediaId: string; likes: number; comments: number }> = [];
      for (const item of json.data) {
        const igMs = new Date(item.timestamp).getTime();
        for (const l of active) {
          if (!l.ig_posted_at) continue;
          const ourMs = l.ig_posted_at instanceof Date
            ? l.ig_posted_at.getTime()
            : (l.ig_posted_at as unknown as number) * 1000;
          if (Math.abs(igMs - ourMs) < 2 * 60 * 1000) {
            matched.push({ listingId: l.id, mediaId: item.id, likes: item.like_count ?? 0, comments: item.comments_count ?? 0 });
          }
        }
      }

      // Fetch insights in parallel for each matched post.
      // Views (not reach) — matches the headline number shown in the IG app.
      await Promise.all(matched.map(async (m) => {
        let views = 0, saves = 0, shares = 0;
        try {
          const ir = await fetch(
            `https://graph.instagram.com/v21.0/${m.mediaId}/insights` +
            `?metric=views,saved,shares&period=lifetime&access_token=${creds.accessToken}`
          );
          const ij = await ir.json();
          if (Array.isArray(ij.data)) {
            for (const d of ij.data) {
              const val = d.values?.[0]?.value ?? d.value ?? 0;
              if (d.name === 'views')  views  = val;
              if (d.name === 'saved')  saves  = val;
              if (d.name === 'shares') shares = val;
            }
          }
        } catch { /* scope not yet available — shows 0 */ }
        igMediaStats.set(m.listingId, { likes: m.likes, comments: m.comments, views, saves, shares });
      }));
    }
  } catch { /* IG unavailable — show cards without stats */ }
}

// ─── Outbound clicks per listing ──────────────────────────────────────────────
type ClickCounts = { whatsapp: number; call: number; email: number; reveal: number; finance: number; portal: number };
const listingClicks = new Map<string, ClickCounts>();

{
  const rows = db.select({
    slug:   clickEvents.listing_slug,
    source: clickEvents.source,
    count:  sql<number>`cast(count(*) as int)`,
  }).from(clickEvents)
    .groupBy(clickEvents.listing_slug, clickEvents.source)
    .all();

  for (const r of rows) {
    const c = listingClicks.get(r.slug) ?? { whatsapp: 0, call: 0, email: 0, reveal: 0, finance: 0, portal: 0 };
    if (r.source === 'whatsapp') c.whatsapp += r.count;
    else if (r.source === 'call') c.call += r.count;
    else if (r.source === 'email') c.email += r.count;
    else if (r.source === 'reveal_number' || r.source === 'reveal_email') c.reveal += r.count;
    else if (r.source === 'finance_calc') c.finance += r.count;
    else c.portal += r.count;
    listingClicks.set(r.slug, c);
  }
}

const firstPhoto = firstPhotoOrNull;
function formatPrice(n: number) {
  return 'R' + n.toLocaleString('en-ZA');
}
function formatDate(d: Date | null) {
  if (!d) return '—';
  return new Intl.DateTimeFormat('en-ZA', { day: 'numeric', month: 'short', year: 'numeric' }).format(d);
}

const grouped: { label: string; status: string; items: Listing[]; total: number }[] = [
  { label: 'Pending Approval', status: 'pending', items: pending, total: pendingCount },
  { label: 'Active',           status: 'active',  items: active,  total: activeCount  },
  { label: 'Sold',             status: 'sold',    items: sold,    total: soldCount    },
];
---

<AdminLayout title="Listings">

  <!-- STATS -->
  <div class="stats-row">
    <div class="stat stat-pending">
      <span class="stat-val">{pendingCount}</span>
      <span class="stat-lbl">Pending</span>
    </div>
    <div class="stat stat-active">
      <span class="stat-val">{activeCount}</span>
      <span class="stat-lbl">Active</span>
    </div>
    <div class="stat stat-sold">
      <span class="stat-val">{soldCount}</span>
      <span class="stat-lbl">Sold</span>
    </div>
    <div class="stat stat-total">
      <span class="stat-val">{totalCount}</span>
      <span class="stat-lbl">Total</span>
    </div>
  </div>

  <!-- Scraper tools (Run Ingest / backfills) moved to /admin/scrapers -->

  <!-- TODAY'S IG PICK -->
  {igPlan.slot === 'cta' && (
    <div class="pick-card" style="border-color:#F5A623;">
      <div class="pick-info">
        <p class="pick-eyebrow">📢 Today's IG slot: Seller CTA</p>
        <p class="pick-title">Post the seller-acquisition template — "Selling your Cruiser? List it free on landcruisersa.co.za."</p>
        <p class="pick-reasons">{igPlan.reason} · backup hero pick below</p>
      </div>
    </div>
  )}
  {igPick && (
    <div class="pick-card">
      <a href={`/admin/listings/${igPick.id}`} class="pick-thumb-link">
        {igPick.photo
          ? <img class="pick-thumb" src={igPick.photo} alt={igPick.title} loading="lazy" />
          : <div class="pick-thumb pick-thumb-empty">🚗</div>
        }
      </a>
      <div class="pick-info">
        <p class="pick-eyebrow">{SLOT_LABEL[igPick.slot] ?? '📣'} — today's IG pick</p>
        <p class="pick-title">
          <a href={`/admin/listings/${igPick.id}`}>{igPick.title}</a>
          <span class="pick-price">R{igPick.price.toLocaleString('en-ZA')}</span>
          {igPick.dropAmount > 0 && <span class="pick-drop">▼ R{igPick.dropAmount.toLocaleString('en-ZA')}</span>}
        </p>
        <p class="pick-reasons">{igPick.reasons.slice(0, 3).join(' · ')}</p>
      </div>
      <button class="btn btn-post" data-action="post" data-id={igPick.id}>Post to IG</button>
    </div>
  )}

  <!-- IG SUGGESTION SHORTLIST — skim the whole ranked list and post from here -->
  {igMore.length > 0 && (
    <details class="sug-panel">
      <summary class="sug-summary">📣 More IG suggestions <span class="sug-count">{igMore.length}</span>{igMoreNonPrado > 0 && <span class="sug-count sug-count-np">{igMoreNonPrado} non-Prado</span>}</summary>
      <div class="sug-list">
        {igMore.map((s, i) => (
          <div class="sug-row">
            <span class="sug-rank">#{i + 2}</span>
            <a href={`/admin/listings/${s.id}`} class="sug-thumb-link">
              {s.photo
                ? <img class="sug-thumb" src={s.photo} alt={s.title} loading="lazy" />
                : <div class="sug-thumb sug-thumb-empty">🚗</div>
              }
            </a>
            <div class="sug-info">
              <p class="sug-title-row">
                <span class={`sug-model${modelFamily(s.model) === 'prado' ? ' sug-model-prado' : ''}`}>{modelLabel(s.model)}</span>
                <a href={`/admin/listings/${s.id}`} class="sug-title">{s.title}</a>
                <span class="sug-price">R{s.price.toLocaleString('en-ZA')}</span>
                {s.dropAmount > 0 && <span class="pick-drop">▼ R{s.dropAmount.toLocaleString('en-ZA')}</span>}
              </p>
              <p class="sug-reasons">{s.reasons.slice(0, 3).join(' · ')}</p>
            </div>
            <span class="sug-score" title="Suggestion score">{s.score}</span>
            <button class="btn btn-post sug-post" data-action="post" data-id={s.id}>Post</button>
          </div>
        ))}
      </div>
    </details>
  )}

  <!-- FILTER BAR -->
  <div class="filter-bar">
    <div class="filter-fields">
      <input
        type="search"
        id="af-search"
        class={`af-input${fQ ? ' active' : ''}`}
        placeholder="Search title, seller…"
        value={fQ}
        autocomplete="off"
      />
      <select class={`af-sel${fSource   ? ' active' : ''}`} data-filter="source">
        <option value="">All Sources</option>
        <option value="autotrader" selected={fSource==='autotrader'}>AutoTrader</option>
        <option value="wbc"        selected={fSource==='wbc'}>WBC</option>
        <option value="adios"      selected={fSource==='adios'}>Adios</option>
        <option value="wbb"        selected={fSource==='wbb'}>We Buy Bakkies</option>
        <option value="carsza"     selected={fSource==='carsza'}>Cars.co.za</option>
        <option value="own"        selected={fSource==='own'}>Own</option>
      </select>
      <div class="ms-wrap" id="ms-model">
        <button type="button" id="ms-model-btn" class={`af-sel${fModels.length ? ' active' : ''}`} aria-expanded="false">
          <span id="ms-model-label">{fModels.length === 0 ? 'All Models' : fModels.length === 1 ? 'Models (1)' : `Models (${fModels.length})`}</span>
        </button>
        <div id="ms-model-panel" class="ms-panel" hidden>
          {[
            { v: '76-series', l: '76 Series' }, { v: '78-series', l: '78 Series' }, { v: '79-series', l: '79 Series' },
            { v: '80-series', l: '80 Series' }, { v: '100-series', l: '100 Series' }, { v: '200-series', l: '200 Series' },
            { v: '300-series', l: '300 Series' }, { v: 'prado-150', l: 'Prado 150' }, { v: 'prado-250', l: 'Prado 250' },
            { v: 'fj-cruiser', l: 'FJ Cruiser' }, { v: 'land-cruiser-fj', l: 'LC FJ' }, { v: 'other', l: 'Other' },
          ].map(m => (
            <label class="ms-opt"><input type="checkbox" class="ms-model-cb" value={m.v} checked={fModels.includes(m.v)} /> {m.l}</label>
          ))}
          <p class="ms-group">Toyota 4x4 (data only)</p>
          {[
            { v: 'hilux-gd6', l: 'Hilux GD-6' }, { v: 'hilux-d4d', l: 'Hilux D-4D' },
            { v: 'fortuner-gd6', l: 'Fortuner GD-6' }, { v: 'fortuner-d4d', l: 'Fortuner D-4D' },
          ].map(m => (
            <label class="ms-opt"><input type="checkbox" class="ms-model-cb" value={m.v} checked={fModels.includes(m.v)} /> {m.l}</label>
          ))}
        </div>
      </div>
      <select class={`af-sel${fYear     ? ' active' : ''}`} data-filter="year">
        <option value="">Any Year</option>
        <option value="2023-9999" selected={fYear==='2023-9999'}>2023+</option>
        <option value="2020-2022" selected={fYear==='2020-2022'}>2020–2022</option>
        <option value="2015-2019" selected={fYear==='2015-2019'}>2015–2019</option>
        <option value="2010-2014" selected={fYear==='2010-2014'}>2010–2014</option>
        <option value="2000-2009" selected={fYear==='2000-2009'}>2000s</option>
        <option value="0-1999"    selected={fYear==='0-1999'}>Pre-2000</option>
      </select>
      <select class={`af-sel${fPrice    ? ' active' : ''}`} data-filter="price">
        <option value="">Any Price</option>
        <option value="0-300000"       selected={fPrice==='0-300000'}>Under R300k</option>
        <option value="300000-600000"  selected={fPrice==='300000-600000'}>R300k – R600k</option>
        <option value="600000-900000"  selected={fPrice==='600000-900000'}>R600k – R900k</option>
        <option value="900000-9999999" selected={fPrice==='900000-9999999'}>Over R900k</option>
      </select>
      <select class={`af-sel${fMileage  ? ' active' : ''}`} data-filter="mileage">
        <option value="">Any Mileage</option>
        <option value="0-50000"        selected={fMileage==='0-50000'}>Under 50k km</option>
        <option value="0-100000"       selected={fMileage==='0-100000'}>Under 100k km</option>
        <option value="100000-200000"  selected={fMileage==='100000-200000'}>100k – 200k km</option>
        <option value="200000-9999999" selected={fMileage==='200000-9999999'}>Over 200k km</option>
      </select>
      <select class={`af-sel${fProvince ? ' active' : ''}`} data-filter="province">
        <option value="">All Provinces</option>
        <option value="Gauteng"       selected={fProvince==='Gauteng'}>Gauteng</option>
        <option value="Western Cape"  selected={fProvince==='Western Cape'}>Western Cape</option>
        <option value="KwaZulu-Natal" selected={fProvince==='KwaZulu-Natal'}>KwaZulu-Natal</option>
        <option value="Eastern Cape"  selected={fProvince==='Eastern Cape'}>Eastern Cape</option>
        <option value="Limpopo"       selected={fProvince==='Limpopo'}>Limpopo</option>
        <option value="Mpumalanga"    selected={fProvince==='Mpumalanga'}>Mpumalanga</option>
        <option value="North West"    selected={fProvince==='North West'}>North West</option>
        <option value="Free State"    selected={fProvince==='Free State'}>Free State</option>
        <option value="Northern Cape" selected={fProvince==='Northern Cape'}>Northern Cape</option>
      </select>
      <select class={`af-sel${fType     ? ' active' : ''}`} data-filter="type">
        <option value="">All Types</option>
        <option value="for_sale"  selected={fType==='for_sale'}>For Sale</option>
        <option value="show_off"  selected={fType==='show_off'}>Show Off</option>
      </select>
    </div>
    <div class="filter-meta">
      <a href={buildFilterUrl({ source: fSource === 'own' ? '' : 'own', page: '' })} class={`af-posted-toggle${fSource === 'own' ? ' active' : ''}`}>
        👤 Private sellers ({privateCount})
      </a>
      <a href={buildFilterUrl({ drops: fDrops ? '' : '1', page: '' })} class={`af-posted-toggle af-drops-toggle${fDrops ? ' active' : ''}`}>
        ▼ Price Drops ({droppedActiveCount})
      </a>
      {igConnected && (
        <a href={buildFilterUrl({ posted: fPosted ? '' : '1', page: '' })} class={`af-posted-toggle${fPosted ? ' active' : ''}`}>
          ✓ Posted to IG ({postedCount})
        </a>
      )}
      <a href={buildFilterUrl({ dealer: fDealer ? '' : '1', page: '' })} class={`af-posted-toggle${fDealer ? ' active' : ''}`}>
        🏷️ Wants dealer offer ({dealerOptinCount})
      </a>
      {hasFilter && <span class="af-count">{filteredActiveCount} listing{filteredActiveCount !== 1 ? 's' : ''}</span>}
      {hasFilter && <a href="/admin" class="af-clear">✕ Clear</a>}
    </div>
  </div>

  <!-- GROUPS -->
  {grouped.map(({ label, status, items, total }) => (
    <div class={`group group-${status}`}>
      <p class="group-head">
        <span class={`status-dot dot-${status}`}></span>
        {label}
        <span class="group-count" data-base={items.length}>{total}</span>
      </p>

      {items.length === 0 && <p class="empty-state">None</p>}

      <div class="card-list">
        {items.map((l: Listing) => {
          const photo = firstPhoto(l.photos);
          const igS = fPosted ? igMediaStats.get(l.id) : undefined;
          const clk = listingClicks.get(l.slug) ?? { whatsapp: 0, call: 0, email: 0, reveal: 0, finance: 0, portal: 0 };
          const hasClicks = clk.whatsapp + clk.call + clk.email + clk.reveal + clk.finance + clk.portal > 0;
          return (
            <div
              class={`lcard lcard-${l.status}`}
              id={`card-${l.id}`}
              data-source={l.source ?? 'own'}
              data-model={l.model}
              data-year={l.year}
              data-price={l.price}
              data-province={l.province ?? ''}
              data-type={l.listing_type}
            >
              <a href={`/admin/listings/${l.id}`} class="lcard-thumb-link">
                {photo
                  ? <img class="lcard-thumb" src={photo} alt={l.title} loading="lazy" />
                  : <div class="lcard-thumb lcard-thumb-empty">🚗</div>
                }
              </a>
              <div class="lcard-body" data-ig-posted-slot={l.id}>
                <div class="lcard-meta">
                  <span class={`badge badge-${l.listing_type === 'for_sale' ? 'sale' : 'show'}`}>
                    {l.listing_type === 'for_sale' ? 'For Sale' : '★ Show Off'}
                  </span>
                  {l.listing_type === 'for_sale' && (
                    <span class="lcard-price">{formatPrice(l.price)}</span>
                  )}
                  {l.status === 'sold' && (
                    l.sold_price
                      ? <span class="chg-chip chg-sold">✓ Sold R{l.sold_price.toLocaleString('en-ZA')}{l.price > 0 && l.sold_price !== l.price ? ` (${l.sold_price < l.price ? '▼' : '▲'} R${Math.abs(l.price - l.sold_price).toLocaleString('en-ZA')})` : ''}</span>
                      : <span class="chg-chip chg-sold-missing">Sold — add price</span>
                  )}
                  {priceChange.has(l.slug) && (priceChange.get(l.slug)! < 0
                    ? <span class="chg-chip chg-drop">▼ R{Math.abs(priceChange.get(l.slug)!).toLocaleString('en-ZA')}</span>
                    : <span class="chg-chip chg-raise">▲ R{priceChange.get(l.slug)!.toLocaleString('en-ZA')}</span>
                  )}
                  {l.dealer_offer_optin && (
                    <span class="badge badge-dealer">🏷️ Dealer offer</span>
                  )}
                </div>
                <a href={`/admin/listings/${l.id}`} class="lcard-title">{l.title}</a>
                <p class="lcard-sub">{l.year} · {l.model.replaceAll('-', ' ').toUpperCase()} · {l.province}{l.mileage > 0 ? ` · ${l.mileage.toLocaleString('en-ZA')} km` : ''}</p>
                <p class="lcard-seller">
                  {l.seller_name} · <a href={`mailto:${l.seller_email}`}>{l.seller_email}</a> · <a href={`tel:${l.seller_phone}`}>{l.seller_phone}</a>
                </p>
                <p class="lcard-date">{formatDate(l.created_at)}</p>
                {l.ig_posted_at && (
                  <p class="lcard-posted-at">✓ Posted to IG {formatDate(l.ig_posted_at)}</p>
                )}
                {(igS || hasClicks) && (
                  <div class="lcard-stats">
                    {igS && (
                      <>
                        <span class="stat-chip stat-ig">Likes {igS.likes}</span>
                        <span class="stat-chip stat-ig">Comments {igS.comments}</span>
                        {igS.saves > 0 && (
                          <span class="stat-chip stat-saves">Saves {igS.saves.toLocaleString('en-ZA')}</span>
                        )}
                        {igS.shares > 0 && (
                          <span class="stat-chip stat-shares">Shares {igS.shares.toLocaleString('en-ZA')}</span>
                        )}
                        {igS.views > 0 && (
                          <span class="stat-chip stat-views">Views {igS.views.toLocaleString('en-ZA')}</span>
                        )}
                        {hasClicks && <span class="stat-divider">·</span>}
                      </>
                    )}
                    {clk.whatsapp > 0 && <span class="stat-chip stat-wa">WA {clk.whatsapp}</span>}
                    {clk.call     > 0 && <span class="stat-chip stat-contact">Call {clk.call}</span>}
                    {clk.email    > 0 && <span class="stat-chip stat-contact">Email {clk.email}</span>}
                    {clk.reveal   > 0 && <span class="stat-chip stat-reveal">Revealed {clk.reveal}</span>}
                    {clk.finance  > 0 && <span class="stat-chip stat-finance">Finance {clk.finance}</span>}
                    {clk.portal   > 0 && <span class="stat-chip stat-portal">Portal {clk.portal}</span>}
                  </div>
                )}
                <div class="action-links">
                  <a href={`/admin/listings/${l.id}`} class="action-link">Edit</a>
                  {l.slug && <a href={`/listings/${l.slug}/`} target="_blank" class="action-link">View ↗</a>}
                  {l.status === 'active'  && <button class="action-link" data-action="sold" data-id={l.id}>Mark Sold</button>}
                  {l.status === 'pending' && <button class="action-link action-link-danger" data-action="delete" data-id={l.id}>Delete</button>}
                  {l.status === 'sold'    && <button class="action-link" data-action="reactivate" data-id={l.id}>Reactivate</button>}
                </div>
              </div>
              {(l.status === 'pending' || (l.status === 'active' && igConnected)) && (
                <div class="lcard-cta">
                  {l.status === 'pending'
                    ? <button class="btn btn-approve" data-action="approve" data-id={l.id}>✓ Approve</button>
                    : <button class={`btn ${l.ig_posted_at ? 'btn-repost' : 'btn-post'}`} data-action="post" data-id={l.id}>
                        {l.ig_posted_at ? 'Repost' : 'Post to IG'}
                      </button>
                  }
                </div>
              )}
            </div>
          );
        })}
      </div>
    </div>
  ))}

  <!-- PAGINATION -->
  {totalPages > 1 && (
    <div class="pagination">
      {safePage > 1
        ? <a href={buildFilterUrl({ page: String(safePage - 1) })} class="btn btn-page">← Prev</a>
        : <span class="btn btn-page btn-page-disabled">← Prev</span>
      }
      <span class="page-info">
        Page {safePage} of {totalPages}
        <span class="page-sub"> ({filteredActiveCount} listing{filteredActiveCount !== 1 ? 's' : ''})</span>
      </span>
      {safePage < totalPages
        ? <a href={buildFilterUrl({ page: String(safePage + 1) })} class="btn btn-page">Next →</a>
        : <span class="btn btn-page btn-page-disabled">Next →</span>
      }
    </div>
  )}

  <AdminIgPost />

</AdminLayout>

