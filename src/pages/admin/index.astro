    font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em;
    padding: 0.45rem 0.75rem; border-radius: 0.375rem; cursor: pointer;
    border: 1.5px solid transparent; transition: all 0.15s; white-space: nowrap;
    text-decoration: none; display: inline-block; text-align: center; line-height: 1.5;
  }
  .btn:disabled { opacity: 0.35; cursor: not-allowed; }

  .btn-edit    { background: white; color: #6B7280; border-color: #E5E7EB; }
  .btn-edit:hover { color: #111111; border-color: #111111; }

  .btn-approve { background: #F5A623; color: #111111; border-color: #F5A623; }
  .btn-approve:hover { background: #D4881A; border-color: #D4881A; }

  .btn-post    { background: #111111; color: white; border-color: #111111; }
  .btn-post:hover:not(:disabled) { background: #374151; border-color: #374151; }

  .btn-repost  { background: white; color: #6B7280; border-color: #E5E7EB; }
  .btn-repost:hover:not(:disabled) { background: #F9FAFB; border-color: #9CA3AF; color: #374151; }

  /* PAGINATION */
  .pagination {
    display: flex; align-items: center; justify-content: center; gap: 1rem;
    padding: 1.5rem 0 0.5rem; border-top: 1.5px solid #F3F4F6; margin-top: 1rem;
  }
  .btn-page {
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
    padding: 0.5rem 1rem; border-radius: 0.5rem; border: 1.5px solid #E5E7EB;
    background: white; color: #374151; text-decoration: none; transition: all 0.15s;
  }
  .btn-page:hover:not(.btn-page-disabled) { border-color: #111111; color: #111111; }
  .btn-page-disabled { opacity: 0.35; cursor: default; }
  .page-info { font-size: 0.75rem; font-weight: 600; color: #6B7280; }
  .page-sub  { font-weight: 400; color: #9CA3AF; }

  @media (max-width: 640px) {
    .lcard { grid-template-columns: 80px 1fr; }
    .lcard-thumb, .lcard-thumb-empty { width: 80px; }
    .lcard-cta { grid-column: 1 / -1; border-top: 1.5px solid #F3F4F6; padding: 0.625rem 0.875rem; }
    .lcard-cta .btn { width: 100%; }
  }
</style>

<script>
  // ── Admin filters — server-side, navigate on change ──────────────────────
  document.querySelectorAll<HTMLSelectElement>('.af-sel[data-filter]').forEach(sel => {
    sel.addEventListener('change', () => {
      const params = new URLSearchParams(window.location.search);
      params.delete('page');
      if (sel.value) params.set(sel.dataset.filter!, sel.value);
      else params.delete(sel.dataset.filter!);
      window.location.href = '/admin' + (params.toString() ? '?' + params.toString() : '');
    });
  });

  // ── Multi-select model — navigate when the panel closes if changed ───────
  const msBtn = document.getElementById('ms-model-btn');
  const msPanel = document.getElementById('ms-model-panel');
  if (msBtn && msPanel) {
    const boxes = () => Array.from(msPanel.querySelectorAll<HTMLInputElement>('.ms-model-cb'));
    const selected = () => boxes().filter(b => b.checked).map(b => b.value).sort().join(',');
    let openedWith = selected();
    const close = () => {
      msPanel.hidden = true;
      msBtn.setAttribute('aria-expanded', 'false');
      const now = selected();
      if (now !== openedWith) {
        const params = new URLSearchParams(window.location.search);
        params.delete('page');
        if (now) params.set('model', now); else params.delete('model');
        window.location.href = '/admin' + (params.toString() ? '?' + params.toString() : '');
      }
    };
    msBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      if (msPanel.hidden) { openedWith = selected(); msPanel.hidden = false; msBtn.setAttribute('aria-expanded', 'true'); }
      else close();
    });
    msPanel.addEventListener('click', (e) => e.stopPropagation());
    document.addEventListener('click', () => { if (!msPanel.hidden) close(); });
  }

  // ── Search — navigate on Enter, or on clearing the field ────────────────
  const searchInput = document.getElementById('af-search') as HTMLInputElement | null;
  function applySearch() {
    const params = new URLSearchParams(window.location.search);
    params.delete('page');
    const q = searchInput!.value.trim();
    if (q) params.set('q', q); else params.delete('q');
    window.location.href = '/admin' + (params.toString() ? '?' + params.toString() : '');
  }
  searchInput?.addEventListener('keydown', (e) => { if (e.key === 'Enter') applySearch(); });
  searchInput?.addEventListener('search', () => { if (!searchInput.value) applySearch(); }); // ✕ clear button

  // Run-time helpers + scraper tool handlers moved to /admin/scrapers

  function updateStat(selector: string, delta: number) {
    const el = document.querySelector(selector);
    if (el) el.textContent = String(Math.max(0, Number(el.textContent) + delta));
  }

  function removeCard(id: string) {
    const card = document.getElementById(`card-${id}`);
    if (!card) return;
    card.style.transition = 'opacity 0.25s, transform 0.25s';
    card.style.opacity = '0';
    card.style.transform = 'translateX(8px)';
    setTimeout(() => card.remove(), 260);
  }

  document.addEventListener('click', async (e) => {
    const btn = (e.target as Element).closest<HTMLButtonElement>('[data-action]');
    if (!btn) return;

    const action = btn.dataset.action!;
    const id = btn.dataset.id!;

    // ── IG publishing is handled by the shared AdminIgPost component ──
    if (action === 'post') return;

    if (action === 'delete') {
      if (!confirm('Delete this listing permanently?')) return;
    }

    const originalText = btn.textContent;
    btn.disabled = true;
    btn.textContent = '…';

    try {
      let res: Response;
      if (action === 'delete') {
        res = await fetch(`/api/listings/${id}`, { method: 'DELETE' });
      } else {
        const statusMap: Record<string, string> = { approve: 'active', sold: 'sold', reactivate: 'active' };
        res = await fetch(`/api/listings/${id}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: statusMap[action] }),
        });
      }

      if (res.ok) {
        if (action === 'approve') {
          updateStat('.stat-pending .stat-val', -1);
          updateStat('.stat-active .stat-val',  +1);
        } else if (action === 'sold') {
          updateStat('.stat-active .stat-val', -1);
          updateStat('.stat-sold .stat-val',   +1);
        } else if (action === 'reactivate') {
          updateStat('.stat-sold .stat-val',   -1);
          updateStat('.stat-active .stat-val', +1);
        } else if (action === 'delete') {
          updateStat('.stat-pending .stat-val', -1);
          updateStat('.stat-total .stat-val',   -1);
        }
        removeCard(id);
      } else {
        btn.disabled = false;
        btn.textContent = originalText;
        alert('Something went wrong — try again.');
      }
    } catch {
      btn.disabled = false;
      btn.textContent = originalText;
      alert('Network error — try again.');
    }
  });

</script>
